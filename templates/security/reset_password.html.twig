{% extends 'base.html.twig' %}

{% block title %}Réinitialiser votre mot de passe - ADN Family Office{% endblock %}

{% block page_styles %}
<style>
    :root {
        --adn-primary: #1C29A1;
        --adn-primary-light: #2D3FDB;
        --adn-secondary: #3B82F6;
        --gradient-primary: linear-gradient(135deg, #0F1751 0%, #1C29A1 30%, #2D3FDB 70%, #3B82F6 100%);
        --font-primary: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    /* ===== Auth header minimal (comme la page login) ===== */
    .auth-header-reset {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(15, 23, 81, 0.3);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .auth-header-reset img {
        height: 36px;
        width: auto;
    }
    .auth-header-reset .back-link {
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.15);
        transition: all 0.3s ease;
    }
    .auth-header-reset .back-link:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border-color: rgba(255, 255, 255, 0.3);
    }

    /* ===== Page entière ===== */
    body {
        font-family: var(--font-primary) !important;
        background: var(--gradient-primary) !important;
        min-height: 100vh;
        margin: 0;
        overflow-x: hidden;
    }

    main {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 6rem 1rem 2rem;
    }

    /* ===== Fond animé ===== */
    .reset-bg-orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.15;
        pointer-events: none;
        z-index: 0;
    }
    .reset-bg-orb--1 {
        width: 500px; height: 500px;
        background: #3B82F6;
        top: -10%; left: -5%;
        animation: orbFloat1 20s ease-in-out infinite;
    }
    .reset-bg-orb--2 {
        width: 400px; height: 400px;
        background: #6366F1;
        bottom: -10%; right: -5%;
        animation: orbFloat2 25s ease-in-out infinite;
    }
    .reset-bg-orb--3 {
        width: 300px; height: 300px;
        background: #8B5CF6;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        animation: orbFloat3 18s ease-in-out infinite;
    }
    @keyframes orbFloat1 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(60px, 80px); }
    }
    @keyframes orbFloat2 {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(-50px, -60px); }
    }
    @keyframes orbFloat3 {
        0%, 100% { transform: translate(-50%, -50%) scale(1); }
        50% { transform: translate(-40%, -60%) scale(1.15); }
    }

    /* ===== Carte principale ===== */
    .reset-card {
        position: relative;
        z-index: 10;
        background: rgba(255, 255, 255, 0.97);
        backdrop-filter: blur(20px);
        border-radius: 1.5rem;
        box-shadow:
            0 25px 60px rgba(0, 0, 0, 0.15),
            0 0 0 1px rgba(255, 255, 255, 0.2);
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 440px;
        animation: cardSlideIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        box-sizing: border-box;
    }
    @keyframes cardSlideIn {
        from { opacity: 0; transform: translateY(30px) scale(0.97); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ===== Icône cadenas ===== */
    .reset-icon {
        width: 64px;
        height: 64px;
        margin: 0 auto 1.25rem;
        background: linear-gradient(135deg, var(--adn-primary), var(--adn-secondary));
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(28, 41, 161, 0.3);
    }
    .reset-icon svg {
        width: 30px;
        height: 30px;
        color: white;
    }

    /* ===== Titres ===== */
    .reset-title {
        font-family: var(--font-primary);
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        text-align: center;
        margin: 0 0 0.375rem;
        line-height: 1.3;
    }
    .reset-subtitle {
        font-size: 0.875rem;
        color: #64748b;
        text-align: center;
        margin: 0 0 1.75rem;
        line-height: 1.5;
    }

    /* ===== Champs formulaire ===== */
    .reset-form-group {
        margin-bottom: 1.25rem;
    }
    .reset-form-label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.375rem;
    }
    .reset-input-wrap {
        position: relative;
    }
    .reset-form-input {
        width: 100%;
        padding: 0.75rem 3rem 0.75rem 1rem;
        border: 2px solid #e5e7eb;
        border-radius: 0.75rem;
        font-size: 0.9375rem;
        font-family: var(--font-primary);
        color: #1e293b;
        background: #fff;
        outline: none;
        transition: all 0.25s ease;
        box-sizing: border-box;
    }
    .reset-form-input::placeholder {
        color: #94a3b8;
    }
    .reset-form-input:focus {
        border-color: var(--adn-secondary);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.12);
    }
    .reset-toggle-pw {
        position: absolute;
        right: 0.5rem;
        top: 50%;
        transform: translateY(-50%);
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        padding: 0;
        color: #64748b;
    }
    .reset-toggle-pw:hover {
        background: #e2e8f0;
        color: #334155;
    }
    .reset-toggle-pw svg {
        width: 18px;
        height: 18px;
    }

    /* ===== Barre de force ===== */
    .reset-strength {
        margin-top: 0.5rem;
        display: none;
    }
    .reset-strength.active { display: block; }
    .reset-strength-bar {
        height: 4px;
        background: #e5e7eb;
        border-radius: 2px;
        overflow: hidden;
        margin-bottom: 0.375rem;
    }
    .reset-strength-fill {
        height: 100%;
        width: 0%;
        border-radius: 2px;
        transition: width 0.35s ease, background-color 0.35s ease;
    }
    .reset-strength-text {
        font-size: 0.75rem;
        font-weight: 600;
    }

    /* ===== Exigences ===== */
    .reset-requirements {
        margin-top: 1rem;
        padding: 0.875rem 1rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
    }
    .reset-requirements-title {
        font-size: 0.75rem;
        font-weight: 700;
        color: #475569;
        margin: 0 0 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .reset-req {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
        color: #94a3b8;
        margin-bottom: 0.25rem;
        transition: color 0.25s ease;
    }
    .reset-req:last-child { margin-bottom: 0; }
    .reset-req.met { color: #10b981; }
    .reset-req-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .reset-req-icon svg { width: 16px; height: 16px; }

    /* ===== Erreur ===== */
    .reset-error {
        color: #ef4444;
        font-size: 0.8125rem;
        margin-top: 0.375rem;
        display: none;
    }

    /* ===== Bouton submit ===== */
    .reset-submit {
        width: 100%;
        padding: 0.875rem;
        margin-top: 1.5rem;
        border: none;
        border-radius: 0.75rem;
        background: linear-gradient(135deg, var(--adn-primary), var(--adn-secondary));
        color: white;
        font-family: var(--font-primary);
        font-size: 0.9375rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 14px rgba(28, 41, 161, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    .reset-submit:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(28, 41, 161, 0.4);
    }
    .reset-submit:active:not(:disabled) {
        transform: translateY(0);
    }
    .reset-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }
    .reset-submit svg {
        width: 18px;
        height: 18px;
    }

    /* ===== Lien retour ===== */
    .reset-back-link {
        display: block;
        text-align: center;
        margin-top: 1.25rem;
        color: var(--adn-secondary);
        text-decoration: none;
        font-size: 0.8125rem;
        font-weight: 600;
        transition: color 0.2s;
    }
    .reset-back-link:hover { color: var(--adn-primary); }

    /* ===== Responsive ===== */
    @media (max-width: 480px) {
        .reset-card {
            padding: 2rem 1.25rem;
            border-radius: 1rem;
            margin: 0 0.5rem;
        }
        .reset-icon {
            width: 52px; height: 52px;
            border-radius: 0.75rem;
        }
        .reset-icon svg { width: 24px; height: 24px; }
        .reset-title { font-size: 1.25rem; }
        .auth-header-reset {
            padding: 0.75rem 1rem;
        }
        .auth-header-reset img { height: 28px; }
        main { padding-top: 5rem; }
    }
</style>
{% endblock %}

{% block header %}
    <header class="auth-header-reset">
        <a href="{{ path('app_home') }}">
            <img src="{{ asset('build/theme/images/ADN_Logo_enlarged_x5.png') }}" alt="ADN Family Office">
        </a>
        <a href="{{ path('app_login') }}" class="back-link">← Retour à la connexion</a>
    </header>
{% endblock %}

{% block footer %}{% endblock %}

{% block body_color %}{% endblock %}

{% block body %}
<!-- Orbes décoratives -->
<div class="reset-bg-orb reset-bg-orb--1"></div>
<div class="reset-bg-orb reset-bg-orb--2"></div>
<div class="reset-bg-orb reset-bg-orb--3"></div>

<div class="reset-card">
    <!-- Icône -->
    <div class="reset-icon">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
    </div>

    <!-- Titre -->
    <h1 class="reset-title">Nouveau mot de passe</h1>
    <p class="reset-subtitle">Choisissez un mot de passe sécurisé pour votre compte ADN Family Office</p>

    <!-- Formulaire -->
    <form id="resetPasswordForm" method="POST" onsubmit="return handleResetPassword(event)">
        <input type="hidden" name="token" value="{{ token }}">

        <!-- Nouveau mot de passe -->
        <div class="reset-form-group">
            <label for="password" class="reset-form-label">Nouveau mot de passe</label>
            <div class="reset-input-wrap">
                <input type="password" id="password" name="password" class="reset-form-input"
                       placeholder="Entrez votre nouveau mot de passe"
                       required autocomplete="new-password" oninput="checkPasswordStrength()">
                <button type="button" class="reset-toggle-pw" onclick="togglePassword('password')" tabindex="-1" title="Afficher/masquer">
                    <svg id="passwordIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </button>
            </div>
            <p id="passwordError" class="reset-error"></p>

            <!-- Barre de force -->
            <div id="passwordStrength" class="reset-strength">
                <div class="reset-strength-bar">
                    <div id="strengthFill" class="reset-strength-fill"></div>
                </div>
                <p id="strengthText" class="reset-strength-text"></p>
            </div>
        </div>

        <!-- Confirmation -->
        <div class="reset-form-group">
            <label for="confirm_password" class="reset-form-label">Confirmer le mot de passe</label>
            <div class="reset-input-wrap">
                <input type="password" id="confirm_password" name="confirm_password" class="reset-form-input"
                       placeholder="Confirmez votre mot de passe"
                       required autocomplete="new-password" oninput="checkPasswordMatch()">
                <button type="button" class="reset-toggle-pw" onclick="togglePassword('confirm_password')" tabindex="-1" title="Afficher/masquer">
                    <svg id="confirmPasswordIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </button>
            </div>
            <p id="confirmPasswordError" class="reset-error"></p>
        </div>

        <!-- Exigences -->
        <div class="reset-requirements">
            <p class="reset-requirements-title">Exigences du mot de passe</p>
            <div id="req-length" class="reset-req">
                <span class="reset-req-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                    </svg>
                </span>
                <span>Au moins 8 caractères</span>
            </div>
            <div id="req-lowercase" class="reset-req">
                <span class="reset-req-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                    </svg>
                </span>
                <span>Une lettre minuscule</span>
            </div>
            <div id="req-uppercase" class="reset-req">
                <span class="reset-req-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                    </svg>
                </span>
                <span>Une lettre majuscule</span>
            </div>
            <div id="req-number" class="reset-req">
                <span class="reset-req-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                    </svg>
                </span>
                <span>Un chiffre</span>
            </div>
        </div>

        <!-- Bouton -->
        <button type="submit" id="submitBtn" class="reset-submit" disabled>
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
            Réinitialiser mon mot de passe
        </button>
    </form>

    <!-- Retour -->
    <a href="{{ path('app_login') }}" class="reset-back-link">← Retour à la connexion</a>
</div>

<script>
    /* ===== Toggle password visibility ===== */
    function togglePassword(fieldId) {
        const field = document.getElementById(fieldId);
        const iconSvg = document.getElementById(fieldId + 'Icon');
        if (field.type === 'password') {
            field.type = 'text';
            iconSvg.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
        } else {
            field.type = 'password';
            iconSvg.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
        }
    }

    /* ===== Check password strength ===== */
    function checkPasswordStrength() {
        const password = document.getElementById('password').value;
        const strengthDiv = document.getElementById('passwordStrength');
        const strengthFill = document.getElementById('strengthFill');
        const strengthText = document.getElementById('strengthText');

        if (password.length === 0) {
            strengthDiv.classList.remove('active');
            updateSubmitButton();
            return;
        }

        strengthDiv.classList.add('active');

        let strength = 0;
        if (password.length >= 8) strength += 25;
        if (password.length >= 12) strength += 15;
        if (/[a-z]/.test(password)) strength += 20;
        if (/[A-Z]/.test(password)) strength += 20;
        if (/[0-9]/.test(password)) strength += 20;
        if (/[^A-Za-z0-9]/.test(password)) strength += 20;

        let color, text;
        if (strength < 40) { color = '#ef4444'; text = 'Faible'; }
        else if (strength < 70) { color = '#f59e0b'; text = 'Moyen'; }
        else if (strength < 90) { color = '#10b981'; text = 'Bon'; }
        else { color = '#059669'; text = 'Excellent'; }

        strengthFill.style.width = Math.min(strength, 100) + '%';
        strengthFill.style.backgroundColor = color;
        strengthText.textContent = text;
        strengthText.style.color = color;

        updateRequirements(password);
        updateSubmitButton();
    }

    /* ===== Update requirements ===== */
    function updateRequirements(password) {
        const reqs = {
            'req-length': password.length >= 8,
            'req-lowercase': /[a-z]/.test(password),
            'req-uppercase': /[A-Z]/.test(password),
            'req-number': /[0-9]/.test(password)
        };

        const checkSvg = '<polyline points="20 6 9 17 4 12"></polyline>';
        const circleSvg = '<circle cx="12" cy="12" r="10"></circle>';

        for (const [id, met] of Object.entries(reqs)) {
            const el = document.getElementById(id);
            const iconSvg = el.querySelector('.reset-req-icon svg');
            if (met) {
                el.classList.add('met');
                iconSvg.innerHTML = checkSvg;
            } else {
                el.classList.remove('met');
                iconSvg.innerHTML = circleSvg;
            }
        }
    }

    /* ===== Check passwords match ===== */
    function checkPasswordMatch() {
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;
        const errorDiv = document.getElementById('confirmPasswordError');

        if (confirmPassword.length === 0) {
            errorDiv.style.display = 'none';
            updateSubmitButton();
            return;
        }

        if (password !== confirmPassword) {
            errorDiv.textContent = 'Les mots de passe ne correspondent pas';
            errorDiv.style.display = 'block';
        } else {
            errorDiv.style.display = 'none';
        }
        updateSubmitButton();
    }

    /* ===== Update submit button ===== */
    function updateSubmitButton() {
        const password = document.getElementById('password').value;
        const confirmPassword = document.getElementById('confirm_password').value;
        const submitBtn = document.getElementById('submitBtn');

        const isValid =
            password.length >= 8 &&
            /[a-z]/.test(password) &&
            /[A-Z]/.test(password) &&
            /[0-9]/.test(password) &&
            password === confirmPassword;

        submitBtn.disabled = !isValid;
    }

    /* ===== Handle form submission ===== */
    async function handleResetPassword(event) {
        event.preventDefault();

        const form = document.getElementById('resetPasswordForm');
        const submitBtn = document.getElementById('submitBtn');
        const passwordError = document.getElementById('passwordError');

        passwordError.style.display = 'none';
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<svg class="animate-spin" style="width:18px;height:18px;animation:spin 1s linear infinite" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M7.76 7.76L4.93 4.93"></path></svg> Réinitialisation en cours...';

        try {
            const formData = new FormData(form);
            const response = await fetch(form.action || window.location.href, {
                method: 'POST',
                body: new URLSearchParams(formData)
            });

            const data = await response.json();

            if (response.ok && data.success) {
                submitBtn.innerHTML = '<svg style="width:18px;height:18px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Mot de passe réinitialisé !';
                submitBtn.style.background = 'linear-gradient(135deg, #10b981, #059669)';
                setTimeout(() => { window.location.href = data.redirect; }, 1500);
            } else {
                passwordError.textContent = data.message || 'Une erreur est survenue. Veuillez réessayer.';
                passwordError.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg> Réinitialiser mon mot de passe';
            }
        } catch (error) {
            console.error('Erreur:', error);
            passwordError.textContent = 'Une erreur est survenue. Veuillez réessayer.';
            passwordError.style.display = 'block';
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg> Réinitialiser mon mot de passe';
        }

        return false;
    }

    /* ===== Auto-focus ===== */
    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('password').focus();
    });
</script>
{% endblock %}
