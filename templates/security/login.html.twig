                        </div>

                        <button type="submit" class="submit-btn mt-4 min-h-[44px] min-w-[220px]" id="submitBtn" disabled>
                            <span id="submitBtnText">🚀 Se connecter</span>
                        </button>
                    </form>

                    {# Formulaire pour la transition MoneyPitch (vers la page de transition ADN) #}
                    <form id="moneypitchForm" method="post" action="{{ path('app_moneypitch_login') }}" style="display: none;">
                        <input type="hidden" name="email" id="mp_login" value="">
                        <input type="hidden" name="password" id="mp_password" value="">
