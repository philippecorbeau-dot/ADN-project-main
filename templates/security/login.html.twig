                    <!-- Effet de fond décoratif -->
                    <div class="card-decoration"></div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="auth-page pb-12 md:pb-16">
            <div class="auth-container">
                <!-- Section informations -->
                <div class="auth-info">
                    <h1>Bienvenue chez ADN Family Office</h1>
                    <p>Connectez-vous à votre espace personnel pour accéder à vos investissements, suivre vos performances et gérer votre patrimoine.</p>
                    
                    <div class="auth-features">
                        <div class="auth-feature">
                            <div class="auth-feature-icon">📊</div>
                            <div class="auth-feature-text">Tableau de bord personnalisé</div>
                        </div>
                        <div class="auth-feature">
                            <div class="auth-feature-icon">💼</div>
                            <div class="auth-feature-text">Gestion de portefeuille</div>
                        </div>
                        <div class="auth-feature">
                            <div class="auth-feature-icon">🔒</div>
                            <div class="auth-feature-text">Sécurité maximale</div>
                        </div>
                        <div class="auth-feature">
                            <div class="auth-feature-icon">📱</div>
                            <div class="auth-feature-text">Accès mobile optimisé</div>
                        </div>
                    </div>
                </div>

                <!-- Formulaire de connexion -->
                <div class="auth-form-container mb-6">
                    <div class="auth-form-header">
                        <h2 class="auth-form-title">Se connecter</h2>
                        <p class="auth-form-subtitle">Accédez à votre espace personnel</p>
                    </div>

                    {% if error is defined and error %}
                        {# Erreur gérée par les flashs globaux (Notyf) — on n'affiche plus l'alerte inline ici #}
                    {% endif %}

                    {# Formulaire de connexion #}
                    <form action="{{ path('app_login') }}" method="post" class="auth-form" id="loginForm">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                        
                        <div class="form-group">
                            <label for="email" class="form-label">Adresse email</label>
                            <div class="relative">
                                <input type="email" 
                                       id="email" 
                                       name="email" 
                                       class="form-input w-full" 
                                       placeholder="pierre@adnfamilyoffice.fr"
