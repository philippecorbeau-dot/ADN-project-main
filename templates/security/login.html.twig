    {% endif %}
{% endblock %}

{% block page_scripts %}
    <script>
        // 🚀 Système de connexion révolutionnaire avec détection MoneyPitch
        class RevolutionaryLogin {
            constructor() {
                this.validationRules = {
                    email: (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value),
                    password: (value) => value.length >= 1
                };
                
                // Type de compte détecté (null, 'adn', 'moneypitch')
                this.accountType = null;
                this.checkTimeout = null;
                
                this.init();
            }

            init() {
                this.createParticles();
                this.setupEventListeners();
                this.setupValidation();
                this.setupAccountTypeDetection();
                this.animateEntrance();
                this.focusFirstInput();
            }
            
            // Détection automatique du type de compte
            setupAccountTypeDetection() {
                const emailInput = document.getElementById('email');
                
                emailInput.addEventListener('input', () => {
                    // Debounce - attendre 500ms après la dernière frappe
                    clearTimeout(this.checkTimeout);
                    
                    const email = emailInput.value.trim();
                    if (this.validationRules.email(email)) {
                        this.checkTimeout = setTimeout(() => {
                            this.checkAccountType(email);
                        }, 500);
                    } else {
                        this.resetAccountType();
                    }
                });
                
                // Vérifier aussi au blur
                emailInput.addEventListener('blur', () => {
                    const email = emailInput.value.trim();
                    if (this.validationRules.email(email) && !this.accountType) {
                        this.checkAccountType(email);
                    }
                });
            }
            
            // Vérifier le type de compte via API
            async checkAccountType(email) {
                try {
                    const formData = new FormData();
                    formData.append('email', email);
                    
                    const response = await fetch('{{ path("api_check_user_type") }}', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const data = await response.json();
                    
                    if (data.exists) {
                        this.accountType = data.type;
                        this.updateUIForAccountType(data.type);
                    } else {
                        this.resetAccountType();
                    }
                } catch (error) {
                    console.error('Erreur lors de la vérification du compte:', error);
                    this.resetAccountType();
                }
            }
            
            // Mettre à jour l'interface selon le type de compte
            updateUIForAccountType(type) {
                const indicator = document.getElementById('account-type-indicator');
                const badge = document.getElementById('account-type-badge');
                const passwordLabel = document.getElementById('password-label');
                const passwordHint = document.getElementById('password-hint');
                const submitBtnText = document.getElementById('submitBtnText');
                const rememberSection = document.getElementById('remember-me-section');
                
                indicator.classList.remove('hidden');
                
                if (type === 'moneypitch') {
                    // Utilisateur MoneyPitch
                    badge.innerHTML = '🔗 Compte MoneyPitch';
                    badge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-purple-100 text-purple-700 border border-purple-200';
                    
                    passwordLabel.innerHTML = 'Mot de passe <span class="text-purple-600 font-semibold">MoneyPitch</span>';
                    passwordHint.textContent = 'Utilisez votre mot de passe MoneyPitch (différent du mot de passe ADN)';
                    passwordHint.classList.remove('hidden');
                    
                    submitBtnText.innerHTML = '🔗 Accéder à MoneyPitch';
                    
                    // Cacher "Se souvenir de moi" pour MoneyPitch
                    if (rememberSection) {
                        rememberSection.style.display = 'none';
                    }
                } else {
                    // Utilisateur ADN
                    badge.innerHTML = '🏠 Compte ADN';
                    badge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 border border-blue-200';
                    
                    passwordLabel.textContent = 'Mot de passe';
                    passwordHint.classList.add('hidden');
                    
                    submitBtnText.innerHTML = '🚀 Se connecter';
                    
                    if (rememberSection) {
                        rememberSection.style.display = 'flex';
                    }
                }
            }
            
            // Réinitialiser le type de compte
            resetAccountType() {
                this.accountType = null;
                
                const indicator = document.getElementById('account-type-indicator');
                const passwordLabel = document.getElementById('password-label');
                const passwordHint = document.getElementById('password-hint');
                const submitBtnText = document.getElementById('submitBtnText');
                const rememberSection = document.getElementById('remember-me-section');
                
                indicator.classList.add('hidden');
                passwordLabel.textContent = 'Mot de passe';
                passwordHint.classList.add('hidden');
                submitBtnText.innerHTML = '🚀 Se connecter';
                
                if (rememberSection) {
                    rememberSection.style.display = 'flex';
                }
            }

            // Création des particules animées
            createParticles() {
                const particlesContainer = document.createElement('div');
                particlesContainer.className = 'particles';
                document.body.appendChild(particlesContainer);

                for (let i = 0; i < 12; i++) {
                    const particle = document.createElement('div');
                    particle.className = 'particle';
                    particle.style.left = Math.random() * 100 + '%';
                    particle.style.top = Math.random() * 100 + '%';
                    particle.style.animationDelay = Math.random() * 6 + 's';
                    particle.style.animationDuration = (4 + Math.random() * 4) + 's';
                    particlesContainer.appendChild(particle);
                }
            }

            // Configuration des événements
            setupEventListeners() {
                const form = document.getElementById('loginForm');
                const forgotPasswordLink = document.getElementById('forgotPasswordLink');
                const togglePassword = document.getElementById('togglePassword');

                // Soumission du formulaire
                form.addEventListener('submit', (e) => {
                    this.handleSubmit(e);
                });

                // Lien mot de passe oublié
                forgotPasswordLink.addEventListener('click', (e) => {
                    e.preventDefault();
                    this.showForgotPasswordModal();
                });

                // Toggle password visibility
                if (togglePassword) {
                    togglePassword.addEventListener('click', () => this.togglePasswordVisibility());
                }

                // Validation en temps réel pour activer/désactiver le bouton
                const inputs = document.querySelectorAll('.form-input');
                inputs.forEach(input => {
                    input.addEventListener('input', () => this.updateSubmitButton());
                });

                // Initial state
                this.updateSubmitButton();
            }

            // Toggle password visibility
            togglePasswordVisibility() {
                const passwordInput = document.getElementById('password');
                const eyeIcon = document.getElementById('eyeIcon');
                const toggleBtn = document.getElementById('togglePassword');
                
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    eyeIcon.textContent = '🙈';
                    toggleBtn.style.background = 'rgba(59, 130, 246, 0.1)';
                    toggleBtn.style.borderColor = 'rgba(59, 130, 246, 0.3)';
                } else {
                    passwordInput.type = 'password';
                    eyeIcon.textContent = '👁️';
                    toggleBtn.style.background = 'rgba(241, 245, 249, 0.8)';
                    toggleBtn.style.borderColor = 'rgba(226, 232, 240, 0.8)';
                }
            }

            // Update submit button state
            updateSubmitButton() {
                const emailInput = document.getElementById('email');
                const passwordInput = document.getElementById('password');
                const submitBtn = document.getElementById('submitBtn');
                
                const emailValid = emailInput.value.trim() !== '' && this.validationRules.email(emailInput.value);
                const passwordValid = passwordInput.value.trim() !== '';
                
                submitBtn.disabled = !(emailValid && passwordValid);
            }

            // Système de validation avancé
            setupValidation() {
                const inputs = document.querySelectorAll('.form-input');
                
                inputs.forEach(input => {
                    const formGroup = input.closest('.form-group');
                    const icon = formGroup.querySelector('.form-icon');
                    const indicator = formGroup.querySelector('.validation-indicator');

                    // Validation en temps réel
                    input.addEventListener('input', () => {
                        this.validateField(input);
                    });

                    // Effets de focus
                    input.addEventListener('focus', () => {
                        formGroup.classList.add('focused');
                        formGroup.style.transform = 'scale(1.02)';
                    });

                    input.addEventListener('blur', () => {
                        formGroup.classList.remove('focused');
                        formGroup.style.transform = 'scale(1)';
                    });
                });
            }

            // Validation d'un champ spécifique
            validateField(input) {
                const fieldName = input.id;
                const value = input.value;
                const formGroup = input.closest('.form-group');
                const errorElement = document.getElementById(fieldName + '-error');
                
                let isValid = false;
                let errorMessage = '';
                
                if (value.length === 0) {
                    // Champ vide - pas d'erreur affichée mais pas valide
                    input.classList.remove('border-red-500');
                    input.removeAttribute('aria-invalid');
                    input.removeAttribute('aria-describedby');
                    if (errorElement) errorElement.classList.add('hidden');
                } else if (this.validationRules[fieldName] && this.validationRules[fieldName](value)) {
                    // Champ valide
                    isValid = true;
                    input.classList.remove('border-red-500');
                    input.removeAttribute('aria-invalid');
                    input.removeAttribute('aria-describedby');
                    if (errorElement) errorElement.classList.add('hidden');
                } else {
                    // Champ invalide
                    input.classList.add('border-red-500');
                    input.setAttribute('aria-invalid', 'true');
                    input.setAttribute('aria-describedby', fieldName + '-error');
                    
                    if (fieldName === 'email') {
                        errorMessage = 'Veuillez saisir une adresse email valide.';
                    } else if (fieldName === 'password') {
                        errorMessage = 'Le mot de passe est requis.';
                    }
                    
                    if (errorElement && errorMessage) {
                        errorElement.textContent = errorMessage;
                        errorElement.classList.remove('hidden');
                    }
                }
                
                return isValid;
            }

            // Animation d'entrée
            animateEntrance() {
                const authContainer = document.querySelector('.auth-container');
                const features = document.querySelectorAll('.auth-feature');

                if (authContainer) {
                    authContainer.style.opacity = '0';
                    authContainer.style.transform = 'translateY(50px)';
                    
                    setTimeout(() => {
                        authContainer.style.transition = 'all 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
                        authContainer.style.opacity = '1';
                        authContainer.style.transform = 'translateY(0)';
                    }, 200);
                }

                features.forEach((feature, index) => {
                    feature.style.opacity = '0';
                    feature.style.transform = 'translateX(-50px)';
                    
                    setTimeout(() => {
                        feature.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
                        feature.style.opacity = '1';
                        feature.style.transform = 'translateX(0)';
                    }, 400 + (index * 150));
                });
            }

            // Focus sur le premier champ
            focusFirstInput() {
                setTimeout(() => {
                    const emailInput = document.getElementById('email');
                    if (emailInput && !emailInput.value) {
                        emailInput.focus();
                    }
                }, 1000);
            }

            // Modal mot de passe oublié - Moderne et fonctionnelle
            showForgotPasswordModal() {
                const modal = document.createElement('div');
                modal.id = 'forgotPasswordModal';
                modal.innerHTML = `
                    <div style="
                        position: fixed;
                        top: 0;
                        left: 0;
                        right: 0;
                        bottom: 0;
                        background: rgba(0, 0, 0, 0.6);
                        backdrop-filter: blur(10px);
                        z-index: 9999;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        animation: fadeIn 0.3s ease;
                        padding: 1rem;
                    " onclick="if(event.target === this) this.remove()">
                        <div style="
                            background: white;
                            border-radius: 1.5rem;
                            padding: 2.5rem 2rem;
                            max-width: 480px;
                            width: 100%;
                            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
                            position: relative;
                            animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                        " onclick="event.stopPropagation()">
                            <!-- Header -->
                            <div style="text-align: center; margin-bottom: 2rem;">
                                <div style="
                                    width: 64px;
                                    height: 64px;
                                    background: linear-gradient(135deg, #3B82F6, #1C29A1);
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    margin: 0 auto 1rem;
                                    font-size: 2rem;
                                ">🔐</div>
                                <h3 style="
                                    font-family: var(--font-primary);
                                    font-size: 1.5rem;
                                    color: #1e293b;
                                    margin: 0 0 0.5rem 0;
                                    font-weight: 700;
                                ">Mot de passe oublié ?</h3>
                                <p style="
                                    color: #64748b;
                                    font-size: 0.95rem;
                                    line-height: 1.5;
                                    margin: 0;
                                ">Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>
                            </div>

                            <!-- Formulaire -->
                            <form id="forgotPasswordForm" onsubmit="return handleForgotPassword(event)">
                                <div style="margin-bottom: 1.5rem;">
                                    <label style="
                                        display: block;
                                        font-size: 0.875rem;
                                        font-weight: 600;
                                        color: #374151;
                                        margin-bottom: 0.5rem;
                                    ">Adresse email</label>
                                    <div style="position: relative;">
                                        <span style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); font-size: 1.25rem;">📧</span>
                                        <input 
                                            type="email" 
                                            id="resetEmail" 
                                            name="email"
                                            placeholder="pierre@adnfamilyoffice.fr"
                                            required
                                            style="
                                                width: 100%;
                                                padding: 0.75rem 1rem 0.75rem 2.75rem;
                                                border: 2px solid #e5e7eb;
                                                border-radius: 0.75rem;
                                                font-size: 1rem;
                                                transition: all 0.2s;
                                                outline: none;
                                                box-sizing: border-box;
                                            "
                                            onfocus="this.style.borderColor='#3B82F6'; this.style.boxShadow='0 0 0 3px rgba(59, 130, 246, 0.1)'"
                                            onblur="this.style.borderColor='#e5e7eb'; this.style.boxShadow='none'"
                                        >
                                    </div>
                                    <p id="resetEmailError" style="
                                        color: #ef4444;
                                        font-size: 0.875rem;
                                        margin: 0.5rem 0 0 0;
                                        display: none;
                                    "></p>
                                </div>

                                <!-- Message de succès -->
                                <div id="resetSuccessMessage" style="
                                    display: none;
                                    background: #ecfdf5;
                                    border: 2px solid #10b981;
                                    border-radius: 0.75rem;
                                    padding: 1rem;
                                    margin-bottom: 1.5rem;
                                ">
                                    <p style="
                                        color: #065f46;
                                        font-size: 0.875rem;
                                        margin: 0;
                                        line-height: 1.5;
                                        font-weight: 500;
                                    ">✅ Si cette adresse email existe dans notre système, vous recevrez un lien de réinitialisation dans quelques instants.</p>
                                </div>

                                <!-- Boutons -->
                                <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
                                    <button type="button" onclick="document.getElementById('forgotPasswordModal').remove()" style="
                                        flex: 1;
                                        background: #f1f5f9;
                                        color: #64748b;
                                        padding: 0.875rem 1.5rem;
                                        border: none;
                                        border-radius: 0.75rem;
                                        font-weight: 600;
                                        font-size: 1rem;
                                        cursor: pointer;
                                        transition: all 0.2s;
                                    " onmouseover="this.style.background='#e2e8f0'" onmouseout="this.style.background='#f1f5f9'">
                                        Annuler
                                    </button>
                                    <button type="submit" id="resetSubmitBtn" style="
                                        flex: 1;
                                        background: linear-gradient(135deg, #3B82F6, #1C29A1);
                                        color: white;
                                        padding: 0.875rem 1.5rem;
                                        border: none;
                                        border-radius: 0.75rem;
                                        font-weight: 600;
                                        font-size: 1rem;
                                        cursor: pointer;
                                        transition: all 0.2s;
                                        box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3);
                                    " onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 8px -1px rgba(59, 130, 246, 0.4)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 6px -1px rgba(59, 130, 246, 0.3)'">
                                        Envoyer le lien
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                `;

                // Ajouter les styles d'animation
                if (!document.getElementById('resetModalStyles')) {
                    const style = document.createElement('style');
                    style.id = 'resetModalStyles';
                    style.textContent = `
                        @keyframes fadeIn {
                            from { opacity: 0; }
                            to { opacity: 1; }
                        }
                        @keyframes slideUp {
                            from { transform: translateY(30px) scale(0.95); opacity: 0; }
                            to { transform: translateY(0) scale(1); opacity: 1; }
                        }
                    `;
                    document.head.appendChild(style);
                }

                document.body.appendChild(modal);
            }

            // Gestion de la soumission
            handleSubmit(e) {
                const submitBtn = document.getElementById('submitBtn');
                const submitBtnText = document.getElementById('submitBtnText');
                const email = document.getElementById('email').value;
                const password = document.getElementById('password').value;
                
                // Valider tous les champs
                const emailValid = this.validationRules.email(email);
                const passwordValid = this.validationRules.password(password);
                
                if (!emailValid || !passwordValid) {
                    e.preventDefault();
                    
                    // Animation de secousse pour indiquer l'erreur
                    const formContainer = document.querySelector('.auth-form-container');
                    formContainer.style.animation = 'shake 0.5s ease-in-out';
                    
                    setTimeout(() => {
                        formContainer.style.animation = '';
                    }, 500);
                    
                    return;
                }
                
                // Animation de chargement
                submitBtn.disabled = true;
                
                // Si c'est un compte MoneyPitch, soumettre vers MoneyPitch
                if (this.accountType === 'moneypitch') {
                    e.preventDefault();
                    
                    submitBtnText.innerHTML = '⏳ Redirection vers MoneyPitch...';
                    
                    // Remplir et soumettre le formulaire MoneyPitch
                    document.getElementById('mp_login').value = email;
                    document.getElementById('mp_password').value = password;
                    
                    // Soumettre le formulaire MoneyPitch
                    setTimeout(() => {
                        document.getElementById('moneypitchForm').submit();
                    }, 300);
                    
                    return;
                }
                
                // Sinon, connexion ADN normale
                submitBtnText.innerHTML = '⏳ Connexion en cours...';
                // Le formulaire sera soumis normalement par Symfony
            }
        }

        // Styles CSS pour l'animation de secousse
        const shakeStyle = document.createElement('style');
        shakeStyle.textContent = `
            @keyframes shake {
                0%, 100% { transform: translateX(0); }
                25% { transform: translateX(-10px); }
                75% { transform: translateX(10px); }
            }
        `;
        document.head.appendChild(shakeStyle);

        // Fonction globale pour gérer la réinitialisation du mot de passe
        async function handleForgotPassword(event) {
            event.preventDefault();
            
            const form = document.getElementById('forgotPasswordForm');
            const emailInput = document.getElementById('resetEmail');
            const submitBtn = document.getElementById('resetSubmitBtn');
            const errorDiv = document.getElementById('resetEmailError');
            const successDiv = document.getElementById('resetSuccessMessage');
            
            // Reset messages
            errorDiv.style.display = 'none';
            successDiv.style.display = 'none';
            
            // Validation email
            const email = emailInput.value.trim();
            if (!email || !email.includes('@')) {
                errorDiv.textContent = 'Veuillez entrer une adresse email valide.';
                errorDiv.style.display = 'block';
                return false;
            }
            
            // Désactiver le bouton et montrer le chargement
            submitBtn.disabled = true;
            submitBtn.innerHTML = '⏳ Envoi en cours...';
            
            try {
                const response = await fetch('{{ path('app_forgot_password') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: new URLSearchParams({
                        email: email
                    })
                });
                
                const data = await response.json();
                
                if (response.ok && data.success) {
                    // Afficher le message de succès
                    successDiv.style.display = 'block';
                    emailInput.style.display = 'none';

                    // Masquer le label associé au champ email
                    // Structure HTML : <label>...</label><div><span></span><input id="resetEmail" ...></div>
                    const wrapperDiv = emailInput.parentElement;
                    const labelElement = wrapperDiv ? wrapperDiv.previousElementSibling : null;
                    if (labelElement && labelElement.style) {
                        labelElement.style.display = 'none';
                    }

                    submitBtn.style.display = 'none';
                    
                    // Fermer automatiquement après 5 secondes
                    setTimeout(() => {
                        document.getElementById('forgotPasswordModal').remove();
                    }, 5000);
                } else {
                    errorDiv.textContent = data.message || 'Une erreur est survenue. Veuillez réessayer.';
                    errorDiv.style.display = 'block';
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = 'Envoyer le lien';
                }
            } catch (error) {
                console.error('Erreur:', error);
                errorDiv.textContent = 'Une erreur est survenue. Veuillez réessayer.';
                errorDiv.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Envoyer le lien';
            }
            
            return false;
        }

        // Initialisation au chargement de la page
        document.addEventListener('DOMContentLoaded', () => {
            new RevolutionaryLogin();
        });
    </script>
{% endblock %}