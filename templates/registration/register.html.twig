{% block page_scripts %}
    <script>
        // 🚀 Système d'inscription multi-étapes révolutionnaire
        class RevolutionaryRegistration {
            constructor() {
                this.currentStep = 1;
                this.totalSteps = 4;
                this.formData = {};
                this.trackingDebounceTimer = null;
                this.trackingUrl = '{{ path('api_registration_tracking') }}';
                this.validationRules = {
                    email: (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value),
                    // Clé correspondant exactement au name du champ email généré par Symfony
                    'registration_form[email]': (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value),
                    // Validation du mot de passe : min 12 caractères
                    'registration_form[plainPassword]': (value) => value.length >= 12,
                    type: (value) => value !== null && value !== undefined
                };
                
                this.init();
            }

            init() {
                this.createParticles();
                this.setupEventListeners();
                this.setupValidation();
                this.animateEntrance();
                this.focusFirstInput();
            }

            // Création des particules animées
            createParticles() {
                const particlesContainer = document.createElement('div');
                particlesContainer.className = 'particles';
                document.body.appendChild(particlesContainer);

                for (let i = 0; i < 15; i++) {
                    const particle = document.createElement('div');
                    particle.className = 'particle';
                    particle.style.left = Math.random() * 100 + '%';
                    particle.style.top = Math.random() * 100 + '%';
                    particle.style.animationDelay = Math.random() * 6 + 's';
                    particle.style.animationDuration = (4 + Math.random() * 4) + 's';
                    particlesContainer.appendChild(particle);
                }
            }

            // Configuration des événements
            setupEventListeners() {
                const nextBtn = document.getElementById('nextBtn');
                const prevBtn = document.getElementById('prevBtn');
                const form = document.getElementById('registrationForm');

                nextBtn.addEventListener('click', () => this.nextStep());
                prevBtn.addEventListener('click', () => this.prevStep());
                
                // Gestion des types d'utilisateur
                document.querySelectorAll('.user-type-option').forEach(option => {
                    option.addEventListener('click', () => {
                        const radio = option.querySelector('input[type="radio"]');
                        radio.checked = true;
                        this.updateUserTypeSelection();
                        this.validateCurrentStep();
                        // Tracking en temps réel
                        this.trackRegistrationData();
                    });
                });

                // Soumission du formulaire: on ne laisse soumettre qu'à l'étape 4 et si valide
                form.addEventListener('submit', (e) => {
                    if (this.currentStep !== this.totalSteps || !this.validateCurrentStep()) {
                        e.preventDefault();
                        this.showValidationErrors();
                        return;
                    }
                    this.handleSubmit(e);
                });
            }

            // Système de validation avancé
            setupValidation() {
                const inputs = document.querySelectorAll('.form-input');
                
                inputs.forEach(input => {
                    const formGroup = input.closest('.form-group');
                    const icon = formGroup.querySelector('.form-icon');
                    const indicator = formGroup.querySelector('.validation-indicator');

                    // Validation en temps réel
                    input.addEventListener('input', () => {
                        this.validateField(input);
                        this.updateSummary();
                        // Tracking en temps réel
                        this.trackRegistrationData();
                    });

                    // Effets de focus
                    input.addEventListener('focus', () => {
                        formGroup.classList.add('focused');
                        formGroup.style.transform = 'scale(1.02)';
                    });

                    input.addEventListener('blur', () => {
                        formGroup.classList.remove('focused');
                        formGroup.style.transform = 'scale(1)';
                    });

                    // Validation du mot de passe avec indicateur de force
                    if (input.type === 'password') {
                        input.addEventListener('input', () => this.updatePasswordStrength(input.value));
                    }
                });
            }

            // Validation d'un champ spécifique
            validateField(input) {
                const fieldName = input.name;
                const value = input.value.trim();
                const formGroup = input.closest('.form-group');
                const indicator = formGroup.querySelector('.validation-indicator');
                const errorContainer = formGroup.querySelector('.form-error-container');
                
                // Pas de validation pour nom et prénom
                if (fieldName.includes('firstName') || fieldName.includes('lastName')) {
                    // Masquer l'indicateur et garder un style neutre
                    formGroup.classList.remove('valid', 'error', 'loading');
                    indicator.style.opacity = '0';
                    input.style.borderColor = 'rgba(28, 41, 161, 0.15)';
                    this.clearCustomErrors(errorContainer);
                    return;
                }

                // Gestion spéciale pour le mot de passe
                if (fieldName.includes('plainPassword')) {
                    // On utilise validationRules pour vérifier la longueur
                    if (this.validationRules[fieldName] && !this.validationRules[fieldName](value)) {
                        // Si invalide (trop court)
                        formGroup.classList.remove('valid', 'loading');
                        formGroup.classList.add('error');
                        // indicator.style.opacity = '0'; // On garde masqué ou on affiche une croix ? L'utilisateur a demandé d'être explicite.
                        // On peut afficher l'erreur dans le conteneur
                        this.clearCustomErrors(errorContainer);
                        if (value.length > 0) {
                             this.showCustomError(fieldName, errorContainer, value);
                        }
                        // La couleur de bordure sera gérée par updatePasswordStrength mais on peut forcer l'erreur ici si on veut bloquer visuellement
                        input.style.borderColor = 'var(--adn-error)';
                    } else {
                        // Si valide (>= 12 chars)
                        formGroup.classList.remove('error');
                        // On laisse updatePasswordStrength gérer le style "valid" ou neutre
                        this.clearCustomErrors(errorContainer);
                    }
                    return;
                }
                
                // Nettoyage des messages d'erreur précédents
                this.clearCustomErrors(errorContainer);
                
                // Simulation d'un délai de validation (effet loading)
                formGroup.classList.add('loading');
                indicator.textContent = '⏳';
                indicator.style.opacity = '1';
                
                setTimeout(() => {
                    formGroup.classList.remove('loading');

                    if (this.validationRules[fieldName]) {
                        if (this.validationRules[fieldName](value)) {
                            formGroup.classList.remove('error');
                            formGroup.classList.add('valid');
                            indicator.textContent = '✓';
                            indicator.style.background = 'var(--adn-success)';
                            indicator.style.color = 'white';
                            indicator.style.opacity = '1';
                            input.style.borderColor = 'var(--adn-success)';
                        } else if (value.length > 0) {
                            formGroup.classList.remove('valid');
                            formGroup.classList.add('error');
                            indicator.textContent = '✗';
                            indicator.style.background = 'var(--adn-error)';
                            indicator.style.color = 'white';
                            indicator.style.opacity = '1';
                            input.style.borderColor = 'var(--adn-error)';

                            // Ajout de messages d'erreur personnalisés
                            this.showCustomError(fieldName, errorContainer, value);
                        } else {
                            // Champ vide: neutre
                            formGroup.classList.remove('valid', 'error');
                            indicator.textContent = '';
                            indicator.style.opacity = '0';
                            input.style.borderColor = 'rgba(28, 41, 161, 0.15)';
                        }
                    } else {
                        // Aucun règle de validation: état neutre
                        formGroup.classList.remove('valid', 'error');
                        indicator.textContent = '';
                        indicator.style.opacity = '0';
                        input.style.borderColor = 'rgba(28, 41, 161, 0.15)';
                    }
                }, 300);
            }

            // Affichage d'erreurs personnalisées
            showCustomError(fieldName, errorContainer, value) {
                let errorMessage = '';
                
                switch(fieldName) {
                    case 'registration_form[email]':
                        if (!value.includes('@')) {
                            errorMessage = 'Veuillez inclure un symbole @ dans votre adresse email.';
                        } else if (!value.includes('.')) {
                            errorMessage = 'Veuillez saisir une adresse email valide avec un domaine.';
                        } else {
                            errorMessage = 'Cette adresse email ne semble pas valide.';
                        }
                        break;
                    case 'registration_form[plainPassword]':
                        if (value.length < 12) {
                            errorMessage = `Le mot de passe doit contenir au moins 12 caractères (actuellement ${value.length}).`;
                        }
                        break;
                    default:
                        // Pas de message d'erreur pour les autres champs
                        return;
                }
                
                if (errorMessage && !errorContainer.querySelector('.custom-error')) {
                    const customError = document.createElement('div');
                    customError.className = 'form-error custom-error';
                    customError.innerHTML = errorMessage;
                    errorContainer.appendChild(customError);
                }
            }

            // Nettoyage des erreurs personnalisées
            clearCustomErrors(errorContainer) {
                const customErrors = errorContainer.querySelectorAll('.custom-error');
                customErrors.forEach(error => error.remove());
            }

            // 🎯 Système de tracking en temps réel
            trackRegistrationData() {
                // Debounce pour éviter trop de requêtes
                clearTimeout(this.trackingDebounceTimer);
                this.trackingDebounceTimer = setTimeout(() => {
                    this.sendTrackingData();
                }, 1000); // Attendre 1 seconde après la dernière modification
            }

            sendTrackingData() {
                try {
                    // Récupérer les données du formulaire
                    const form = document.getElementById('registrationForm');
                    if (!form) return;

                    const formData = new FormData(form);
                    const trackingData = {
                        firstName: formData.get('registration_form[firstName]') || null,
                        lastName: formData.get('registration_form[lastName]') || null,
                        email: formData.get('registration_form[email]') || null,
                        profileType: null
                    };

                    // Récupérer le type de profil sélectionné
                    const typeInputs = form.querySelectorAll('input[name="registration_form[type]"]:checked');
                    if (typeInputs.length > 0) {
                        const selectedType = typeInputs[0].value;
                        // Mapper les valeurs pour correspondre aux constantes User
                        const privateType = '{{ constant('App\\Entity\\User\\User::USER_TYPE_PRIVATE') }}';
                        const proType = '{{ constant('App\\Entity\\User\\User::USER_TYPE_PRO') }}';
                        
                        if (selectedType === privateType) {
                            trackingData.profileType = 'Particulier';
                        } else if (selectedType === proType) {
                            trackingData.profileType = 'Personne morale';
                        }
                    }

                    // Envoyer uniquement si on a au moins un champ rempli
                    if (trackingData.firstName || trackingData.lastName || trackingData.email || trackingData.profileType) {
                        fetch(this.trackingUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            },
                            body: JSON.stringify(trackingData)
                        }).catch(error => {
                            // Ignorer silencieusement les erreurs de tracking pour ne pas perturber l'utilisateur
                            console.debug('Tracking error:', error);
                        });
                    }
                } catch (error) {
                    // Ignorer silencieusement les erreurs
                    console.debug('Tracking error:', error);
                }
            }

            // Indicateur de force du mot de passe
            updatePasswordStrength(password) {
                const strengthFill = document.getElementById('strengthFill');
                const strengthText = document.getElementById('strengthText');
                const passwordInput = document.querySelector('input[name*="plainPassword"]');
                
                if (!strengthFill || !strengthText || !passwordInput) return;

                let strength = 0;
                let strengthClass = '';
                let strengthLabel = '';
                let borderColor = 'rgba(28, 41, 161, 0.15)'; // Couleur par défaut

                // Critères de validation améliorés
                if (password.length >= 8) strength++;
                if (password.length >= 12) strength++; // Bonus pour longueur recommandée
                if (/[A-Z]/.test(password)) strength++;
                if (/[0-9]/.test(password)) strength++;
                if (/[^A-Za-z0-9]/.test(password)) strength++;

                switch (strength) {
                    case 0:
                        strengthClass = 'empty';
                        strengthLabel = 'Saisissez votre mot de passe';
                        borderColor = 'rgba(28, 41, 161, 0.15)';
                        break;
                    case 1:
                    case 2:
                        strengthClass = 'weak';
                        strengthLabel = '🔴 Faible - Ajoutez des majuscules, chiffres et caractères spéciaux';
                        borderColor = '#ef4444'; // Rouge
                        break;
                    case 3:
                        strengthClass = 'fair';
                        strengthLabel = '🟡 Moyen - Ajoutez encore quelques éléments pour plus de sécurité';
                        borderColor = '#f59e0b'; // Orange
                        break;
                    case 4:
                        strengthClass = 'good';
                        strengthLabel = '🟢 Bon - Mot de passe sécurisé';
                        borderColor = '#10b981'; // Vert
                        break;
                    case 5:
                        strengthClass = 'strong';
                        strengthLabel = '✅ Excellent - Mot de passe très sécurisé';
                        borderColor = '#059669'; // Vert foncé
                        break;
                }

                // Application des styles
                strengthFill.className = `strength-fill ${strengthClass}`;
                strengthText.className = `strength-text ${strengthClass}`;
                strengthText.textContent = strengthLabel;
                
                // Couleur de bordure cohérente avec la jauge
                passwordInput.style.borderColor = borderColor;

                // Animation de la barre de progression
                const percentage = password.length === 0 ? 0 : Math.max(20, (strength / 5) * 100);
                strengthFill.style.width = `${percentage}%`;
            }

            // Navigation entre les étapes
            nextStep() {
                if (!this.validateCurrentStep()) {
                    this.showValidationErrors();
                    return;
                }

                if (this.currentStep < this.totalSteps) {
                    this.animateStepTransition(this.currentStep, this.currentStep + 1);
                    this.currentStep++;
                    this.updateProgress();
                    this.updateNavigation();
                    
                    if (this.currentStep === this.totalSteps) {
                        this.updateSummary();
                    }
                }
            }

            prevStep() {
                if (this.currentStep > 1) {
                    this.animateStepTransition(this.currentStep, this.currentStep - 1, true);
                    this.currentStep--;
                    this.updateProgress();
                    this.updateNavigation();
                }
            }

            // Animation entre les étapes - Version robuste (Display)
            animateStepTransition(fromStep, toStep, reverse = false) {
                const fromElement = document.querySelector(`[data-step="${fromStep}"].form-step`);
                const toElement = document.querySelector(`[data-step="${toStep}"].form-step`);

                if (!fromElement || !toElement) return;

                // 1. Masquer l'étape actuelle
                fromElement.style.opacity = '0';
                fromElement.classList.remove('active');
                
                // Petit délai pour laisser la transition se faire si on veut, 
                // mais pour le display none immédiat c'est mieux pour le repaint
                fromElement.style.display = 'none';

                // 2. Afficher la nouvelle étape
                toElement.style.display = 'block';
                toElement.style.opacity = '0';
                
                // Force reflow
                void toElement.offsetWidth;

                toElement.classList.add('active');
                toElement.style.opacity = '1';
                
                // Scroll to top of form container if needed (sur mobile)
                if (window.innerWidth < 768) {
                    const container = document.querySelector('.auth-form-container');
                    if (container) {
                        const headerOffset = 80;
                        const elementPosition = container.getBoundingClientRect().top;
                        const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
                        
                        window.scrollTo({
                            top: offsetPosition,
                            behavior: "smooth"
                        });
                    }
                }

                // Focus sur le premier champ
                const firstInput = toElement.querySelector('.form-input');
                if (firstInput) {
                    setTimeout(() => firstInput.focus(), 300);
                }
            }

            // Mise à jour de la barre de progression
            updateProgress() {
                const progressFill = document.getElementById('progressFill');
                const percentage = (this.currentStep / this.totalSteps) * 100;
                progressFill.style.width = percentage + '%';

                // Mise à jour des cercles d'étapes
                document.querySelectorAll('.step-circle').forEach((circle, index) => {
                    const step = index + 1;
                    const label = circle.parentElement.querySelector('.step-label');
                    
                    circle.classList.remove('active', 'completed');
                    label.classList.remove('active');
                    
                    if (step < this.currentStep) {
                        circle.classList.add('completed');
                    } else if (step === this.currentStep) {
                        circle.classList.add('active');
                        label.classList.add('active');
                    }
                });
            }

            // Mise à jour de la navigation
            updateNavigation() {
                const prevBtn = document.getElementById('prevBtn');
                const nextBtn = document.getElementById('nextBtn');
                const submitBtn = document.getElementById('submitBtn');
                const prevBtnStep4 = document.getElementById('prevBtnStep4');
                const submitBtnStep4 = document.getElementById('submitBtnStep4');

                prevBtn.disabled = this.currentStep === 1;
                
                if (this.currentStep === this.totalSteps) {
                    // Étape 4 : masquer la navigation générale, utiliser la navigation intégrée
                    nextBtn.style.display = 'none';
                    submitBtn.style.display = 'none';
                    prevBtn.style.display = 'none';
                    
                    // Gérer les boutons spécifiques de l'étape 4
                    if (prevBtnStep4 && !prevBtnStep4.hasAttribute('data-listener-added')) {
                        prevBtnStep4.addEventListener('click', () => this.prevStep());
                        prevBtnStep4.setAttribute('data-listener-added', 'true');
                    }
                    if (submitBtnStep4) {
                        // Le bouton est déjà un submit, pas besoin d'event listener
                    }
                } else {
                    nextBtn.style.display = 'flex';
                    submitBtn.style.display = 'none';
                    prevBtn.style.display = 'flex';
                }
            }

            // Validation de l'étape courante
            validateCurrentStep() {
                const currentStepElement = document.querySelector(`[data-step="${this.currentStep}"].form-step.active`);
                const inputs = currentStepElement.querySelectorAll('.form-input');
                const radios = currentStepElement.querySelectorAll('input[type="radio"]');
                
                let isValid = true;

                // Validation des champs texte
                inputs.forEach(input => {
                    const fieldName = input.name;
                    if (this.validationRules[fieldName] && !this.validationRules[fieldName](input.value)) {
                        isValid = false;
                        this.validateField(input);
                    }
                });

                // Validation des radios (type d'utilisateur)
                if (radios.length > 0) {
                    const isRadioSelected = Array.from(radios).some(radio => radio.checked);
                    if (!isRadioSelected) {
                        isValid = false;
                    }
                }

                return isValid;
            }

            // Mise à jour du récapitulatif
            updateSummary() {
                const firstName = document.querySelector('[name="registration_form[firstName]"]')?.value || '';
                const lastName = document.querySelector('[name="registration_form[lastName]"]')?.value || '';
                const email = document.querySelector('[name="registration_form[email]"]')?.value || '';
                const typeRadios = document.querySelectorAll('[name="registration_form[type]"]');
                
                let selectedType = '';
                typeRadios.forEach(radio => {
                    if (radio.checked) {
                        selectedType = radio.parentElement.querySelector('.user-type-title')?.textContent || '';
                    }
                });

                const nameNode = document.getElementById('summaryName');
                const emailNode = document.getElementById('summaryEmail');
                const typeNode = document.getElementById('summaryType');
                if (nameNode) nameNode.textContent = `${firstName} ${lastName}`.trim() || '-';
                if (emailNode) emailNode.textContent = email || '-';
                if (typeNode) typeNode.textContent = selectedType || '-';
            }

            // Mise à jour de la sélection du type d'utilisateur
            updateUserTypeSelection() {
                document.querySelectorAll('.user-type-card').forEach(card => {
                    card.classList.remove('selected');
                });
                
                document.querySelectorAll('[name="registration_form[type]"]').forEach(radio => {
                    if (radio.checked) {
                        radio.parentElement.querySelector('.user-type-card').classList.add('selected');
                    }
                });
            }

            // Animation d'entrée
            animateEntrance() {
                const authContainer = document.querySelector('.auth-container');
                const benefits = document.querySelectorAll('.auth-benefit');

                if (authContainer) {
                    authContainer.style.opacity = '0';
                    authContainer.style.transform = 'translateY(50px)';
                    
                    setTimeout(() => {
                        authContainer.style.transition = 'all 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
                        authContainer.style.opacity = '1';
                        authContainer.style.transform = 'translateY(0)';
                    }, 200);
                }

                benefits.forEach((benefit, index) => {
                    benefit.style.opacity = '0';
                    benefit.style.transform = 'translateX(-50px)';
                    
                    setTimeout(() => {
                        benefit.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
                        benefit.style.opacity = '1';
                        benefit.style.transform = 'translateX(0)';
                    }, 400 + (index * 150));
                });
            }

            // Focus sur le premier champ
            focusFirstInput() {
                setTimeout(() => {
                    const firstInput = document.querySelector('.form-step.active .form-input');
                    if (firstInput) {
                        firstInput.focus();
                    }
                }, 1000);
            }

            // Affichage des erreurs de validation
            showValidationErrors() {
                // Animation de secousse pour indiquer l'erreur
                const currentStepElement = document.querySelector(`[data-step="${this.currentStep}"].form-step.active`);
                currentStepElement.style.animation = 'shake 0.5s ease-in-out';
                
                setTimeout(() => {
                    currentStepElement.style.animation = '';
                }, 500);
            }

            // Gestion de la soumission
            handleSubmit(e) {
                const submitBtn = document.getElementById('submitBtn');
                const submitBtnStep4 = document.getElementById('submitBtnStep4');
                
                // Déterminer quel bouton utiliser
                const activeSubmitBtn = this.currentStep === this.totalSteps ? submitBtnStep4 : submitBtn;
                
                if (activeSubmitBtn) {
                    // Animation de chargement
                    activeSubmitBtn.innerHTML = '⏳ Création en cours...';
                    activeSubmitBtn.disabled = true;
                }
                
                // Ici, le formulaire sera soumis normalement par Symfony
                // Pas besoin de preventDefault() car on veut que la soumission continue
            }
        }

        // Styles CSS pour l'animation de secousse
        const shakeStyle = document.createElement('style');
        shakeStyle.textContent = `
            @keyframes shake {
                0%, 100% { transform: translateX(0); }
                25% { transform: translateX(-10px); }
                75% { transform: translateX(10px); }
            }
        `;
        document.head.appendChild(shakeStyle);

        // Initialisation au chargement de la page
        document.addEventListener('DOMContentLoaded', () => {
            new RevolutionaryRegistration();
        });
    </script>
{% endblock %}
