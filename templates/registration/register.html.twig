{% endblock %}

{% block header %}
    <!-- Header simple pour les pages d'authentification -->
    <header class="auth-header">
        <div class="auth-header-container">
            <a href="{{ path('app_home') }}" class="auth-logo">
                <img src="{{ asset('build/theme/images/ADN_Logo_enlarged_x5.png') }}" alt="ADN Family Office">
            </a>
            <a href="{{ path('app_home') }}" class="auth-back-btn">
                Retour à l'accueil
            </a>
        </div>
    </header>
{% endblock %}

{% block body %}
    {% for flash_error in app.flashes('verify_email_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

    <div class="auth-page">
        <div class="auth-container">
            <!-- Section informations -->
            <div class="auth-info">
                <h1>Rejoignez ADN Family Office</h1>
                <p>Créez votre compte pour accéder à nos services de gestion patrimoniale et d'investissement de premier plan.</p>
                
                <div class="auth-benefits">
                    <div class="auth-benefit">
                        <div class="auth-benefit-icon">🚀</div>
                        <div class="auth-benefit-text">Opportunités d'investissement exclusives</div>
                    </div>
                    <div class="auth-benefit">
                        <div class="auth-benefit-icon">👥</div>
                        <div class="auth-benefit-text">Conseil patrimonial personnalisé</div>
                    </div>
                    <div class="auth-benefit">
                        <div class="auth-benefit-icon">📊</div>
                        <div class="auth-benefit-text">Suivi en temps réel de vos investissements</div>
                    </div>
                    <div class="auth-benefit">
                        <div class="auth-benefit-icon">🔐</div>
                        <div class="auth-benefit-text">Sécurité et confidentialité maximales</div>
                    </div>
                </div>
            </div>

            <!-- Formulaire d'inscription multi-étapes révolutionnaire -->
            <div class="auth-form-container">
                <!-- Indicateur de progression -->
                <div class="progress-container">
                    <div class="progress-bar">
