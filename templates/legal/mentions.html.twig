        font-size: 1.5rem;
        font-weight: 700;
        color: #1C29A1;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .legal-section h2::before {
        content: '';
        width: 4px;
        height: 1.5rem;
        background: linear-gradient(135deg, #3B82F6, #1C29A1);
        border-radius: 2px;
    }
    
    .legal-section h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: #374151;
        margin: 1.5rem 0 0.75rem 0;
    }
    
    .legal-section p {
        color: #4b5563;
        line-height: 1.75;
        margin-bottom: 1rem;
    }
    
    .info-box {
        background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
        border-left: 4px solid #3B82F6;
        border-radius: 0.75rem;
        padding: 1.5rem;
        margin: 1.5rem 0;
    }
    
    .info-box p {
        margin: 0.5rem 0;
        color: #1e40af;
    }
    
    .info-box strong {
        color: #1e3a8a;
    }
    
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #3B82F6;
        text-decoration: none;
        font-weight: 600;
        padding: 0.75rem 1.5rem;
        border: 2px solid #3B82F6;
        border-radius: 0.75rem;
        transition: all 0.2s;
        margin-top: 2rem;
    }
    
    .back-link:hover {
        background: #3B82F6;
        color: white;
        transform: translateY(-2px);
    }
    
    @media (max-width: 768px) {
        .legal-page {
            padding: 2rem 1rem;
        }
        
        .legal-container {
            padding: 2rem 1.5rem;
            border-radius: 1.5rem;
        }
        
        .legal-header h1 {
            font-size: 2rem;
        }
        
        .legal-section h2 {
