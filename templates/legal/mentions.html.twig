{% block meta_robots %}noindex, follow{% endblock %}

{% block body %}
<style>
    .legal-page {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        min-height: 100vh;
        padding: 4rem 0;
    }
    
    .legal-container {
        max-width: 900px;
        margin: 0 auto;
        background: white;
        border-radius: 2rem;
        padding: 3rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
    }
    
    .legal-header {
        text-align: center;
        margin-bottom: 3rem;
        padding-bottom: 2rem;
        border-bottom: 2px solid #e5e7eb;
    }
    
    .legal-header h1 {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 2.5rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 0.75rem;
    }
    
    .legal-header .subtitle {
        color: #64748b;
        font-size: 1.125rem;
    }
    
    .legal-section {
        margin-bottom: 2.5rem;
    }
    
    .legal-section h2 {
