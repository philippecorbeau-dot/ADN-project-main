<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bourse - ADN Family Office</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        .gradient-bg {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Header Super Admin -->
    {% if is_granted('ROLE_SUPER_ADMIN') %}
        <div class="gradient-bg text-white shadow-lg">
            <div class="container mx-auto px-4 py-3">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-4">
                        <h1 class="text-xl font-bold">ADN Family Office - Administration</h1>
                        <span class="bg-purple-500 px-3 py-1 rounded-full text-xs font-medium">
                            Super Admin
                        </span>
                    </div>
                    <div class="flex items-center space-x-4">
                        <a href="{{ path('admin_bourse') }}" 
                           class="bg-white bg-opacity-20 hover:bg-opacity-30 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 flex items-center space-x-2">
                            <i class="fas fa-chart-line"></i>
                            <span>Bourse</span>
                        </a>
                        <a href="{{ path('app_home') }}" 
                           class="bg-white bg-opacity-20 hover:bg-opacity-30 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 flex items-center space-x-2">
                            <i class="fas fa-home"></i>
                            <span>Site</span>
                        </a>
                        <a href="{{ path('admin') }}" 
                           class="bg-white bg-opacity-20 hover:bg-opacity-30 px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 flex items-center space-x-2">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Dashboard</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Main Content -->
    <div class="container mx-auto px-4 py-6">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">📈 Marché Boursier</h1>
            <p class="text-gray-600">Données en temps réel des principales actions</p>
        </div>

        <!-- Navigation des marchés -->
        <div class="mb-6">
            <div class="flex flex-wrap gap-2">
                <a href="{{ path('admin_bourse', {market: 'us'}) }}" 
                   class="px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 
                          {% if market == 'us' %}bg-blue-600 text-white{% else %}bg-gray-200 text-gray-700 hover:bg-gray-300{% endif %}">
                    🇺🇸 États-Unis
                </a>
                <a href="{{ path('admin_bourse', {market: 'cac40'}) }}" 
                   class="px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 
                          {% if market == 'cac40' %}bg-blue-600 text-white{% else %}bg-gray-200 text-gray-700 hover:bg-gray-300{% endif %}">
                    🇫🇷 CAC 40
                </a>
                <a href="{{ path('admin_bourse', {market: 'china'}) }}" 
                   class="px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 
                          {% if market == 'china' %}bg-blue-600 text-white{% else %}bg-gray-200 text-gray-700 hover:bg-gray-300{% endif %}">
                    🇨🇳 Chine
                </a>
                <a href="{{ path('admin_bourse', {market: 'germany'}) }}" 
                   class="px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 
                          {% if market == 'germany' %}bg-blue-600 text-white{% else %}bg-gray-200 text-gray-700 hover:bg-gray-300{% endif %}">
                    🇩🇪 Allemagne
                </a>
                <a href="{{ path('admin_bourse', {market: 'indices'}) }}" 
                   class="px-4 py-2 rounded-lg text-sm font-medium transition-colors duration-200 
                          {% if market == 'indices' %}bg-blue-600 text-white{% else %}bg-gray-200 text-gray-700 hover:bg-gray-300{% endif %}">
                    📊 Indices
                </a>
            </div>
        </div>

        {% if error %}
            <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-circle text-red-400"></i>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-sm font-medium text-red-800">Erreur</h3>
                        <div class="mt-2 text-sm text-red-700">{{ error }}</div>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if stocks is empty and not error %}
            <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-triangle text-yellow-400"></i>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-sm font-medium text-yellow-800">Aucune donnée</h3>
                        <div class="mt-2 text-sm text-yellow-700">Aucune donnée boursière disponible pour le moment.</div>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {% for stock in stocks %}
                <div class="bg-white rounded-xl shadow-lg border border-gray-200 hover:shadow-xl transition-shadow duration-300">
                    <div class="p-6">
                        <!-- Header -->
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <h3 class="text-lg font-semibold text-gray-900">{{ stock.symbol }}</h3>
                                <p class="text-sm text-gray-500 truncate">{{ stock.name }}</p>
                            </div>
                            <div class="flex items-center">
                                {% if stock.isPositive %}
                                    <i class="fas fa-arrow-up text-green-500"></i>
                                {% else %}
                                    <i class="fas fa-arrow-down text-red-500"></i>
                                {% endif %}
                            </div>
                        </div>

                        <!-- Prix principal -->
                        <div class="mb-4">
                            <div class="text-2xl font-bold text-gray-900">
                                ${{ stock.price|number_format(2, '.', ',') }}
                            </div>
                            <div class="flex items-center space-x-2">
                                <span class="text-sm font-medium {% if stock.isPositive %}text-green-600{% else %}text-red-600{% endif %}">
                                    {% if stock.isPositive %}+{% endif %}{{ stock.change|number_format(2, '.', ',') }}
                                </span>
                                <span class="text-sm font-medium {% if stock.isPositive %}text-green-600{% else %}text-red-600{% endif %}">
                                    ({% if stock.isPositive %}+{% endif %}{{ stock.changePercent|number_format(2, '.', ',') }}%)
                                </span>
                            </div>
                        </div>

                        <!-- Détails -->
                        <div class="space-y-2 text-sm text-gray-600">
                            <div class="flex justify-between">
                                <span>Volume:</span>
                                <span class="font-medium">{{ stock.volume|number_format(0, '.', ',') }}</span>
                            </div>
                            <div class="flex justify-between">
                                <span>Ouverture:</span>
                                <span class="font-medium">${{ stock.open|number_format(2, '.', ',') }}</span>
                            </div>
                            <div class="flex justify-between">
                                <span>Plus haut:</span>
                                <span class="font-medium text-green-600">${{ stock.high|number_format(2, '.', ',') }}</span>
                            </div>
                            <div class="flex justify-between">
                                <span>Plus bas:</span>
                                <span class="font-medium text-red-600">${{ stock.low|number_format(2, '.', ',') }}</span>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <!-- Informations supplémentaires -->
        <div class="mt-8 bg-blue-50 rounded-lg p-6">
            <div class="flex items-center mb-4">
                <i class="fas fa-info-circle text-blue-500 mr-3"></i>
                <h3 class="text-lg font-semibold text-blue-900">Informations</h3>
            </div>
            <div class="text-sm text-blue-800">
                <p class="mb-2">• Les données sont mises à jour en temps réel via l'API Twelve Data</p>
                <p class="mb-2">• Affichage des 5 principales actions technologiques</p>
                <p>• Les variations sont calculées par rapport à la clôture précédente</p>
            </div>
        </div>
    </div>

    <!-- Auto-refresh script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Mise à jour AJAX toutes les 30 secondes
            setInterval(function() {
                fetch(window.location.href)
                    .then(response => response.text())
                    .then(html => {
                        // Extraire seulement les cartes des actions
                        const parser = new DOMParser();
                        const doc = parser.parseFromString(html, 'text/html');
                        const newCards = doc.querySelector('.grid');
                        const currentCards = document.querySelector('.grid');
                        
                        if (newCards && currentCards) {
                            currentCards.innerHTML = newCards.innerHTML;
                        }
                    })
                    .catch(error => {
                        /* log removed */
                    });
            }, 30000);
        });
    </script>
</body>
</html> 