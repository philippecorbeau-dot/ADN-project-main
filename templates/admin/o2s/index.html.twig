<style>
/* Particules animées */
.sync-particle {
    position: absolute;
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    opacity: 0.4;
}

.sync-particle-1 {
    top: 20%;
    left: 10%;
    animation: float 3s ease-in-out infinite;
}

.sync-particle-2 {
    top: 60%;
    left: 80%;
    animation: float 2.5s ease-in-out infinite 0.5s;
}

.sync-particle-3 {
    top: 80%;
    left: 30%;
    animation: float 4s ease-in-out infinite 1s;
}

.sync-particle-4 {
    top: 30%;
    left: 70%;
    animation: float 3.5s ease-in-out infinite 1.5s;
}

.sync-particle-5 {
    top: 50%;
    left: 50%;
    animation: float 2s ease-in-out infinite 0.2s;
}

@keyframes float {
    0%, 100% {
        transform: translateY(0) scale(1);
        opacity: 0.4;
    }
    50% {
        transform: translateY(-20px) scale(1.5);
        opacity: 0.8;
    }
}

/* Animation d'entrée */
.modal-enter {
    animation: modalEnter 0.4s ease-out forwards;
}

@keyframes modalEnter {
    from {
        opacity: 0;
        transform: scale(0.9) translateY(20px);
    }
    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

/* Step actif */
.step-active {
    background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
    border: 1px solid #6ee7b7;
}

.step-active .w-8 {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
}

.step-completed {
    background: #ecfdf5;
}

.step-completed .w-8 {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
}

/* Pulsation du bouton pendant sync */
.sync-pulse {
    animation: syncPulse 1.5s ease-in-out infinite;
}

@keyframes syncPulse {
    0%, 100% {
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
    }
    50% {
        box-shadow: 0 0 0 15px rgba(16, 185, 129, 0);
    }
}

/* Succès animation */
.success-bounce {
    animation: successBounce 0.6s ease-out;
}

@keyframes successBounce {
    0% { transform: scale(0); }
    50% { transform: scale(1.2); }
    100% { transform: scale(1); }
}

/* Header gradient selon état */
.header-success {
    background: linear-gradient(135deg, #10b981 0%, #059669 50%, #047857 100%) !important;
}

.header-error {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 50%, #b91c1c 100%) !important;
}

/* Progress bar animation */
.progress-animated {
    background-size: 200% 100%;
    animation: progressShimmer 1.5s ease-in-out infinite;
}

@keyframes progressShimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
}
</style>

<script>
const funMessages = {
    contacts: [
        "☕ C'est le moment de prendre un café...",
        "🚀 Connexion aux serveurs O2S...",
        "📊 Récupération des profils clients...",
        "👤 Analyse des contacts Harvest...",
        "🔗 Liaison des comptes...",
        "✉️ Vérification des emails...",
    ],
    comptes: [
        "💰 Récupération des valorisations...",
        "📈 Calcul des performances...",
        "🏦 Synchronisation des portefeuilles...",
        "📋 Mise à jour des contrats...",
        "🎯 Presque terminé, patience...",
        "✨ Finalisation en cours...",
    ]
};

const CSRF_TOKEN = '{{ csrf_token('o2s_sync') }}';
let syncInProgress = false;
let funMessageInterval;
let elapsedInterval;
let startTime;

// Données de résultats globales
let syncResults = { contacts: null, comptes: null };

function startSync() {
    if (syncInProgress) return;
    syncInProgress = true;
    syncResults = { contacts: null, comptes: null };
    startTime = Date.now();
    
    // Afficher la modale
    const modal = document.getElementById('syncModal');
    const modalContent = document.getElementById('syncModalContent');
    modal.classList.remove('hidden');
    
    setTimeout(() => {
        modalContent.classList.remove('scale-95', 'opacity-0');
        modalContent.classList.add('modal-enter');
    }, 10);
    
    // Réinitialiser l'état
    resetSyncModal();
    
    // Timer du temps écoulé
    elapsedInterval = setInterval(updateElapsedTime, 1000);
    
    // Lancer les étapes séquentiellement
    performMultiStepSync();
}

function updateElapsedTime() {
    const elapsed = Math.floor((Date.now() - startTime) / 1000);
    const min = Math.floor(elapsed / 60);
    const sec = elapsed % 60;
    const timeStr = min > 0 ? `${min}m ${sec}s` : `${sec}s`;
    document.getElementById('syncProgressPercent').textContent = timeStr;
}

function resetSyncModal() {
    document.getElementById('syncSpinner').classList.remove('hidden');
    document.getElementById('syncSuccess').classList.add('hidden');
    document.getElementById('syncError').classList.add('hidden');
    
    document.getElementById('syncTitle').textContent = 'Synchronisation en cours...';
    document.getElementById('syncSubtitle').textContent = 'Récupération des données depuis Harvest O2S';
    
    document.getElementById('syncProgress').style.width = '0%';
    document.getElementById('syncProgressText').textContent = 'Initialisation...';
    document.getElementById('syncProgressPercent').textContent = '0s';
    
    ['step1', 'step2', 'step3'].forEach(stepId => {
        const step = document.getElementById(stepId);
        step.classList.remove('step-active', 'step-completed');
        step.querySelector('.step-number').classList.remove('hidden');
        step.querySelector('.step-check').classList.add('hidden');
        step.querySelector('.step-spinner').classList.add('hidden');
        // Enlever les sous-textes de résultats
        const subtitle = step.querySelector('.step-subtitle');
        if (subtitle) subtitle.textContent = subtitle.dataset.default || subtitle.textContent;
    });
    
    document.getElementById('syncResults').classList.add('hidden');
    document.getElementById('closeSyncBtn').classList.add('hidden');
    document.getElementById('closeSyncBtn').textContent = 'Fermer et actualiser';
    document.getElementById('closeSyncBtn').classList.remove('from-red-500', 'to-rose-500');
    document.getElementById('closeSyncBtn').classList.add('from-emerald-500', 'to-teal-500');
    document.getElementById('funMessage').classList.remove('hidden');
    
    const header = document.querySelector('#syncModalContent > div:first-child');
    header.classList.remove('header-success', 'header-error');
}

function updateProgress(percent, text) {
    document.getElementById('syncProgress').style.width = percent + '%';
    if (text) document.getElementById('syncProgressText').textContent = text;
}

function setStepActive(stepId) {
    const step = document.getElementById(stepId);
    step.classList.add('step-active');
    step.querySelector('.step-number').classList.add('hidden');
    step.querySelector('.step-spinner').classList.remove('hidden');
}

function setStepCompleted(stepId, subtitle) {
    const step = document.getElementById(stepId);
    step.classList.remove('step-active');
    step.classList.add('step-completed');
    step.querySelector('.step-spinner').classList.add('hidden');
    step.querySelector('.step-check').classList.remove('hidden');
    if (subtitle) {
        const sub = step.querySelector('.step-subtitle');
        if (sub) sub.textContent = subtitle;
    }
}

function setStepError(stepId, errorText) {
    const step = document.getElementById(stepId);
    step.classList.remove('step-active');
    step.style.background = 'linear-gradient(135deg, #fef2f2, #fee2e2)';
    step.style.border = '1px solid #fca5a5';
    step.querySelector('.step-spinner').classList.add('hidden');
    step.querySelector('.step-number').classList.remove('hidden');
    step.querySelector('.step-number').textContent = '✗';
    step.querySelector('.step-number').style.color = '#ef4444';
    if (errorText) {
        const sub = step.querySelector('.step-subtitle');
        if (sub) { sub.textContent = errorText; sub.style.color = '#ef4444'; }
    }
}

function startFunMessages(phase) {
    let msgIndex = 0;
    const msgs = funMessages[phase] || funMessages.contacts;
    clearInterval(funMessageInterval);
    document.getElementById('funMessage').textContent = msgs[0];
    funMessageInterval = setInterval(() => {
        msgIndex = (msgIndex + 1) % msgs.length;
        document.getElementById('funMessage').textContent = msgs[msgIndex];
    }, 2500);
}

async function apiCall(url, body) {
    const response = await fetch(url, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: body
    });
    return await response.json();
}

async function performMultiStepSync() {
    let hasError = false;

    // ═══════ ÉTAPE 1 : Connexion & info ═══════
    setStepActive('step1');
    updateProgress(5, 'Connexion à l\'API O2S...');
    startFunMessages('contacts');

    try {
        const info = await fetch('{{ path('admin_o2s_sync_info') }}').then(r => r.json());
        setStepCompleted('step1', `${info.linkedUsers} utilisateurs liés, ${info.totalProducts} produits`);
        updateProgress(10, 'Connexion établie ✓');
    } catch (e) {
        setStepCompleted('step1', 'Connexion OK');
        updateProgress(10, 'Connexion établie ✓');
    }

    // ═══════ ÉTAPE 2 : Sync contacts ═══════
    setStepActive('step2');
    updateProgress(15, 'Synchronisation des contacts...');
    document.getElementById('syncSubtitle').textContent = 'Étape 1/2 - Contacts clients';

    try {
        const contactsData = await apiCall('{{ path('admin_o2s_sync_contacts') }}', '_token=' + CSRF_TOKEN);
        
        if (contactsData.success) {
            syncResults.contacts = contactsData;
            const errInfo = contactsData.errorCount > 0 ? ` (${contactsData.errorCount} erreurs)` : '';
            setStepCompleted('step2', `${contactsData.total} contacts — ${contactsData.created} créés, ${contactsData.updated} mis à jour${errInfo}`);
            updateProgress(45, 'Contacts synchronisés ✓');
        } else {
            setStepError('step2', contactsData.error || 'Erreur inconnue');
            hasError = true;
        }
    } catch (e) {
        setStepError('step2', e.message);
        hasError = true;
    }

    // ═══════ ÉTAPE 3 : Sync comptes (par lots) ═══════
    if (!hasError) {
        setStepActive('step3');
        updateProgress(50, 'Synchronisation des comptes...');
        document.getElementById('syncSubtitle').textContent = 'Étape 2/2 - Comptes & valorisations';
        startFunMessages('comptes');

        const BATCH_SIZE = 10;
        let offset = 0;
        let totalUsers = 0;
        let totalCreated = 0;
        let totalUpdated = 0;
        let totalSkipped = 0;
        let totalErrors = 0;
        let allErrors = [];
        let batchHasError = false;

        try {
            // Boucle de lots : on appelle /sync/comptes avec offset+batch_size
            while (true) {
                const batchData = await apiCall(
                    '{{ path('admin_o2s_sync_comptes') }}',
                    '_token=' + CSRF_TOKEN + '&offset=' + offset + '&batch_size=' + BATCH_SIZE
                );

                if (!batchData.success) {
                    // Erreur sur ce lot, mais on continue avec le suivant
                    allErrors.push(batchData.error || 'Erreur lot offset=' + offset);
                    totalErrors++;
                    offset += BATCH_SIZE;
                    // Si on ne sait pas le total, on arrête
                    if (!batchData.total && totalUsers === 0) {
                        batchHasError = true;
                        break;
                    }
                    if (totalUsers === 0) totalUsers = batchData.total || 0;
                    if (offset >= totalUsers) break;
                    continue;
                }

                totalUsers = batchData.total || totalUsers;
                totalCreated += batchData.batchCreated || 0;
                totalUpdated += batchData.batchUpdated || 0;
                totalSkipped += batchData.batchSkipped || 0;
                totalErrors += batchData.errorCount || 0;
                if (batchData.errors) allErrors = allErrors.concat(batchData.errors);

                offset = batchData.processed || (offset + BATCH_SIZE);

                // Mettre à jour la progression (50% → 98%)
                const progressPct = totalUsers > 0 
                    ? 50 + Math.round((offset / totalUsers) * 48)
                    : 50;
                updateProgress(
                    Math.min(progressPct, 98),
                    `Comptes : ${offset}/${totalUsers} utilisateurs traités...`
                );
                
                // Mettre à jour le sous-titre de l'étape 3 en temps réel
                const step3Sub = document.querySelector('#step3 .step-subtitle');
                if (step3Sub) {
                    step3Sub.textContent = `${totalCreated} créés, ${totalUpdated} mis à jour (lot ${Math.ceil(offset/BATCH_SIZE)}/${Math.ceil(totalUsers/BATCH_SIZE)})`;
                }

                // Si plus de lots à traiter, on arrête
                if (!batchData.hasMore) break;
            }

            // Résultat final
            syncResults.comptes = {
                total: totalCreated + totalUpdated + totalSkipped,
                created: totalCreated,
                updated: totalUpdated,
                skipped: totalSkipped,
                errorCount: totalErrors,
            };

            if (batchHasError || totalErrors > totalUsers * 0.5) {
                setStepError('step3', `${totalErrors} erreurs sur ${totalUsers} utilisateurs`);
                hasError = true;
            } else {
                const errInfo = totalErrors > 0 ? ` (${totalErrors} erreurs)` : '';
                setStepCompleted('step3', `${totalCreated + totalUpdated} comptes — ${totalCreated} créés, ${totalUpdated} mis à jour${errInfo}`);
                updateProgress(100, 'Synchronisation terminée ✓');
            }
        } catch (e) {
            setStepError('step3', e.message);
            hasError = true;
        }
    }

    // ═══════ FINALISATION ═══════
    clearInterval(funMessageInterval);
    clearInterval(elapsedInterval);

    if (!hasError) {
        showSyncSuccess();
    } else {
        showSyncError('La synchronisation a rencontré des erreurs. Voir les détails ci-dessus.');
    }
}

function showSyncSuccess() {
    document.getElementById('syncSpinner').classList.add('hidden');
    document.getElementById('syncSuccess').classList.remove('hidden');
    document.getElementById('syncSuccess').classList.add('success-bounce');
    
    const header = document.querySelector('#syncModalContent > div:first-child');
    header.classList.add('header-success');
    
    const elapsed = Math.floor((Date.now() - startTime) / 1000);
    const min = Math.floor(elapsed / 60);
    const sec = elapsed % 60;
    const timeStr = min > 0 ? `${min}m ${sec}s` : `${sec}s`;
    
    document.getElementById('syncTitle').textContent = 'Synchronisation terminée !';
    document.getElementById('syncSubtitle').textContent = `Toutes les données ont été mises à jour en ${timeStr}`;
    document.getElementById('funMessage').classList.add('hidden');
    
    // Résultats
    const c = syncResults.contacts || {};
    const p = syncResults.comptes || {};
    document.getElementById('resultContacts').textContent = c.total || 0;
    document.getElementById('resultComptes').textContent = p.total || 0;
    document.getElementById('resultCreated').textContent = (c.created || 0) + (p.created || 0);
    document.getElementById('resultUpdated').textContent = (c.updated || 0) + (p.updated || 0);
    document.getElementById('syncResults').classList.remove('hidden');
    
    document.getElementById('closeSyncBtn').classList.remove('hidden');
    syncInProgress = false;
}

function showSyncError(errorMessage) {
    document.getElementById('syncSpinner').classList.add('hidden');
    document.getElementById('syncError').classList.remove('hidden');
    
    const header = document.querySelector('#syncModalContent > div:first-child');
    header.classList.add('header-error');
    
    document.getElementById('syncTitle').textContent = 'Synchronisation partielle';
    document.getElementById('syncSubtitle').textContent = errorMessage;
    document.getElementById('funMessage').classList.add('hidden');

    // Afficher quand même les résultats partiels
    const c = syncResults.contacts || {};
    const p = syncResults.comptes || {};
    if (c.total || p.total) {
        document.getElementById('resultContacts').textContent = c.total || 0;
        document.getElementById('resultComptes').textContent = p.total || 0;
        document.getElementById('resultCreated').textContent = (c.created || 0) + (p.created || 0);
        document.getElementById('resultUpdated').textContent = (c.updated || 0) + (p.updated || 0);
        document.getElementById('syncResults').classList.remove('hidden');
    }
    
    document.getElementById('closeSyncBtn').textContent = 'Fermer et actualiser';
    document.getElementById('closeSyncBtn').classList.remove('hidden');
    document.getElementById('closeSyncBtn').classList.remove('from-emerald-500', 'to-teal-500');
    document.getElementById('closeSyncBtn').classList.add('from-red-500', 'to-rose-500');
    
    syncInProgress = false;
}

function closeSyncModal() {
    if (syncInProgress) return;
    
    const modal = document.getElementById('syncModal');
    const modalContent = document.getElementById('syncModalContent');
    
    modalContent.classList.add('scale-95', 'opacity-0');
    
    setTimeout(() => {
        modal.classList.add('hidden');
        window.location.reload();
    }, 300);
}

// ═══════════════════════════════════════════════
// SYNC INCRÉMENTALE RAPIDE (Toast notification)
// ═══════════════════════════════════════════════

function showIncrToast() {
    const toast = document.getElementById('incrToast');
    toast.classList.remove('hidden');
    setTimeout(() => {
        toast.classList.remove('translate-y-4', 'opacity-0');
    }, 10);
}

function hideIncrToast() {
    const toast = document.getElementById('incrToast');
    toast.classList.add('translate-y-4', 'opacity-0');
    setTimeout(() => toast.classList.add('hidden'), 300);
}

function updateIncrToast(icon, title, message, autoHide = false) {
    document.getElementById('incrToastIcon').innerHTML = icon;
    document.getElementById('incrToastTitle').textContent = title;
    document.getElementById('incrToastMessage').textContent = message;
    if (autoHide) {
        setTimeout(hideIncrToast, 5000);
    }
}

async function startIncrementalSync() {
    const btn = document.getElementById('syncIncrBtn');
    btn.disabled = true;
    btn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Sync...';
    
    showIncrToast();

    try {
        const data = await apiCall('{{ path('admin_o2s_sync_incremental') }}', '_token=' + CSRF_TOKEN);
        
        if (data.success) {
            const successIcon = '<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
            updateIncrToast(
                successIcon,
                'Sync rapide terminée !',
                data.message || `${data.created} créé(s), ${data.updated} mis à jour`,
                true
            );
            document.getElementById('incrToastIcon').className = 'w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0';
            
            // Recharger après un court délai pour mettre à jour les stats
            if (data.created > 0 || data.updated > 0) {
                setTimeout(() => window.location.reload(), 3000);
            }
        } else {
            const errorIcon = '<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
            updateIncrToast(errorIcon, 'Erreur', data.error || 'Erreur inconnue', true);
            document.getElementById('incrToastIcon').className = 'w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0';
        }
    } catch (e) {
        const errorIcon = '<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
        updateIncrToast(errorIcon, 'Erreur réseau', e.message, true);
        document.getElementById('incrToastIcon').className = 'w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg> Sync rapide';
    }
}

// ═══════════════════════════════════════════════
// MISE À JOUR DES VALORISATIONS (multi-batch AJAX)
// ═══════════════════════════════════════════════

async function startValuationSync() {
    const btn = document.getElementById('syncValuBtn');
    btn.disabled = true;
    const origHTML = btn.innerHTML;
    
    showIncrToast();
    document.getElementById('incrToastIcon').className = 'w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0';
    document.getElementById('incrToastIcon').innerHTML = '<svg class="w-5 h-5 text-amber-600 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>';
    
    const BATCH = 30;
    const ROUNDS = Math.ceil({{ stats.o2sProducts }} / BATCH);
    let totalUpdated = 0;
    let totalErrors = 0;
    let round = 0;
    let hasError = false;

    try {
        for (round = 0; round < ROUNDS; round++) {
            btn.innerHTML = `<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Lot ${round+1}/${ROUNDS}`;
            
            updateIncrToast(
                document.getElementById('incrToastIcon').innerHTML,
                `MAJ Valorisations — Lot ${round+1}/${ROUNDS}`,
                `${totalUpdated} mise(s) à jour...`
            );

            const data = await apiCall('{{ path('admin_o2s_sync_valuations') }}', '_token=' + CSRF_TOKEN + '&batch_size=' + BATCH);

            if (data.success) {
                totalUpdated += data.updated || 0;
                totalErrors += data.errorCount || 0;
            } else {
                hasError = true;
                break;
            }
        }

        const successIcon = '<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
        document.getElementById('incrToastIcon').className = 'w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0';
        const errMsg = totalErrors > 0 ? ` (${totalErrors} erreur(s))` : '';
        updateIncrToast(successIcon, 'Valorisations mises à jour !', `${totalUpdated} comptes actualisés${errMsg}`, false);
        
        // Recharger après délai pour voir les nouveaux montants
        setTimeout(() => window.location.reload(), 3000);
    } catch (e) {
        const errorIcon = '<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
        document.getElementById('incrToastIcon').className = 'w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0';
        updateIncrToast(errorIcon, 'Erreur', e.message + ` (${totalUpdated} mis à jour avant l'erreur)`, true);
    } finally {
        btn.disabled = false;
        btn.innerHTML = origHTML;
    }
}
</script>
{% endblock %}

