{% extends 'admin_modern/base.html.twig' %}

{% block title %}Dashboard O2S - Harvest{% endblock %}
{% block page_title %}🌾 Intégration O2S - Harvest{% endblock %}

{% block content %}
<div class="fade-in">
    <!-- Header avec actions -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6 sm:mb-8">
        <div>
            <p class="text-gray-600 mt-1">Gestion des comptes clients synchronisés depuis Harvest O2S</p>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            <!-- Sync incrémentale (rapide) -->
            <button type="button" 
                    id="syncIncrBtn"
                    onclick="startIncrementalSync()"
                    class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-semibold hover-lift shadow-lg hover:shadow-xl transition-all duration-300"
                    title="Rapide (~10s) : détecte et synchronise uniquement les nouveaux contacts">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Sync rapide
            </button>
            <!-- MAJ Valorisations -->
            <button type="button" 
                    id="syncValuBtn"
                    onclick="startValuationSync()"
                    class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 text-white font-semibold hover-lift shadow-lg hover:shadow-xl transition-all duration-300"
                    title="Met à jour les valorisations de tous les comptes (~2-5min)">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8V7m0 1v8m0 0v1"></path>
                </svg>
                MAJ Valorisations
            </button>
            <!-- Sync complète -->
            <button type="button" 
                    id="syncButton"
                    onclick="startSync()"
                    class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-green-600 to-emerald-600 text-white font-semibold hover-lift shadow-lg hover:shadow-xl transition-all duration-300"
                    title="Complète (~15min) : resynchronise tous les contacts et comptes">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Sync complète
            </button>
        </div>
    </div>

    <!-- Modal de synchronisation -->
    <div id="syncModal" class="fixed inset-0 z-50 hidden">
        <!-- Backdrop avec flou -->
        <div class="absolute inset-0 bg-gray-900/70 backdrop-blur-sm" onclick="closeSyncModal()"></div>
        
        <!-- Contenu de la modale -->
        <div class="absolute inset-0 flex items-center justify-center p-4">
            <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden transform transition-all duration-500 scale-95 opacity-0" id="syncModalContent">
                <!-- Header avec gradient animé -->
                <div class="relative h-32 bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500 overflow-hidden">
                    <div class="absolute inset-0 bg-gradient-to-r from-emerald-400 via-teal-400 to-cyan-400 animate-pulse opacity-50"></div>
                    
                    <!-- Particules animées -->
                    <div class="absolute inset-0 overflow-hidden">
                        <div class="sync-particle sync-particle-1"></div>
                        <div class="sync-particle sync-particle-2"></div>
                        <div class="sync-particle sync-particle-3"></div>
                        <div class="sync-particle sync-particle-4"></div>
                        <div class="sync-particle sync-particle-5"></div>
                    </div>
                    
                    <!-- Icône centrale -->
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div id="syncIcon" class="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center backdrop-blur-sm">
                            <svg id="syncSpinner" class="w-10 h-10 text-white animate-spin" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <svg id="syncSuccess" class="w-10 h-10 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                            </svg>
                            <svg id="syncError" class="w-10 h-10 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </div>
                    </div>
                </div>
                
                <!-- Corps de la modale -->
                <div class="p-8">
                    <h3 id="syncTitle" class="text-2xl font-bold text-center text-gray-900 mb-2">
                        Synchronisation en cours...
                    </h3>
                    <p id="syncSubtitle" class="text-center text-gray-500 mb-6">
                        Récupération des données depuis Harvest O2S
                    </p>
                    
                    <!-- Barre de progression -->
                    <div class="mb-6">
                        <div class="h-3 bg-gray-200 rounded-full overflow-hidden">
                            <div id="syncProgress" class="h-full bg-gradient-to-r from-emerald-500 to-teal-500 rounded-full transition-all duration-500 ease-out" style="width: 0%"></div>
                        </div>
                        <div class="flex justify-between mt-2 text-xs text-gray-500">
                            <span id="syncProgressText">Initialisation...</span>
                            <span id="syncProgressPercent">0%</span>
                        </div>
                    </div>
                    
                    <!-- Étapes de progression -->
                    <div class="space-y-3 mb-6" id="syncSteps">
                        <div class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 transition-all duration-300" id="step1">
                            <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0">
                                <span class="step-number text-gray-600 font-bold text-sm">1</span>
                                <svg class="step-check w-4 h-4 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                </svg>
                                <svg class="step-spinner w-4 h-4 text-white hidden animate-spin" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-gray-700">Connexion API O2S</p>
                                <p class="step-subtitle text-xs text-gray-500 truncate" data-default="Authentification sécurisée">Authentification sécurisée</p>
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 transition-all duration-300" id="step2">
                            <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0">
                                <span class="step-number text-gray-600 font-bold text-sm">2</span>
                                <svg class="step-check w-4 h-4 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                </svg>
                                <svg class="step-spinner w-4 h-4 text-white hidden animate-spin" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-gray-700">Synchronisation des contacts</p>
                                <p class="step-subtitle text-xs text-gray-500 truncate" data-default="Mise à jour des profils clients">Mise à jour des profils clients</p>
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 transition-all duration-300" id="step3">
                            <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0">
                                <span class="step-number text-gray-600 font-bold text-sm">3</span>
                                <svg class="step-check w-4 h-4 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                </svg>
                                <svg class="step-spinner w-4 h-4 text-white hidden animate-spin" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-gray-700">Synchronisation des comptes</p>
                                <p class="step-subtitle text-xs text-gray-500 truncate" data-default="Valorisations et patrimoine">Valorisations et patrimoine</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Message fun pendant l'attente -->
                    <div id="funMessage" class="text-center text-sm text-gray-400 italic mb-6">
                        ☕ C'est le moment de prendre un café...
                    </div>
                    
                    <!-- Résultats (caché par défaut) -->
                    <div id="syncResults" class="hidden">
                        <div class="bg-gradient-to-br from-emerald-50 to-teal-50 rounded-2xl p-5 border border-emerald-200">
                            <h4 class="font-bold text-emerald-800 mb-3 flex items-center gap-2">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                                Résultats de la synchronisation
                            </h4>
                            <div class="grid grid-cols-2 gap-3 text-sm">
                                <div class="bg-white rounded-xl p-3 text-center">
                                    <p class="text-2xl font-bold text-blue-600" id="resultContacts">0</p>
                                    <p class="text-gray-500 text-xs">Contacts</p>
                                </div>
                                <div class="bg-white rounded-xl p-3 text-center">
                                    <p class="text-2xl font-bold text-emerald-600" id="resultComptes">0</p>
                                    <p class="text-gray-500 text-xs">Comptes</p>
                                </div>
                                <div class="bg-white rounded-xl p-3 text-center">
                                    <p class="text-2xl font-bold text-green-600" id="resultCreated">0</p>
                                    <p class="text-gray-500 text-xs">Créés</p>
                                </div>
                                <div class="bg-white rounded-xl p-3 text-center">
                                    <p class="text-2xl font-bold text-amber-600" id="resultUpdated">0</p>
                                    <p class="text-gray-500 text-xs">Mis à jour</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Bouton fermer -->
                    <button id="closeSyncBtn" onclick="closeSyncModal()" class="hidden w-full mt-6 px-6 py-3 bg-gradient-to-r from-emerald-500 to-teal-500 text-white font-semibold rounded-xl hover:shadow-lg transition-all duration-300">
                        Fermer et actualiser
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Flash messages -->
    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 bg-green-100 border border-green-300 text-green-800 rounded-xl flex items-center gap-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            {{ message }}
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="mb-4 p-4 bg-red-100 border border-red-300 text-red-800 rounded-xl flex items-center gap-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            {{ message }}
        </div>
    {% endfor %}

    <!-- Encours géré — carte principale (comme O2S) -->
    <div class="bg-gradient-to-r from-blue-900 to-indigo-900 rounded-3xl p-6 sm:p-8 mb-6 text-white shadow-2xl relative overflow-hidden">
        <div class="absolute top-0 right-0 -mt-8 -mr-8 w-40 h-40 bg-white/5 rounded-full blur-2xl"></div>
        <div class="absolute bottom-0 left-0 -mb-6 -ml-6 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
        <div class="relative">
            <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
                <div>
                    <p class="text-sm font-bold text-blue-300 uppercase tracking-wider mb-1">💼 Encours géré</p>
                    <p class="text-4xl sm:text-5xl font-extrabold tracking-tight">{{ categories.gere.valuation|number_format(0, ',', ' ') }} €</p>
                    <p class="text-blue-300 mt-2 text-sm">{{ categories.gere.count }} comptes sous gestion directe CGP (Assurance Vie, PER, PEA, SCPI…)</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-4">
                    <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-5 py-3 text-center">
                        <p class="text-xl font-bold">{{ categories.epargne.valuation|number_format(0, ',', ' ') }} €</p>
                        <p class="text-xs text-blue-200">🏢 Épargne salariale</p>
                        <p class="text-xs text-blue-300/60">{{ categories.epargne.count }} comptes</p>
                    </div>
                    <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-5 py-3 text-center">
                        <p class="text-xl font-bold">{{ categories.agrege.valuation|number_format(0, ',', ' ') }} €</p>
                        <p class="text-xs text-blue-200">🏦 Comptes agrégés</p>
                        <p class="text-xs text-blue-300/60">{{ categories.agrege.count }} comptes</p>
                    </div>
                </div>
            </div>
            <div class="mt-5 pt-4 border-t border-white/10 flex flex-col sm:flex-row sm:items-center justify-between gap-2 text-xs text-blue-300/80">
                <span>Total tous comptes : <strong class="text-white">{{ stats.totalValuation|number_format(0, ',', ' ') }} €</strong> ({{ stats.o2sProducts }} comptes)</span>
                <span>{{ stats.linkedUsers }} clients liés à O2S sur {{ stats.totalUsers }} utilisateurs</span>
            </div>
        </div>
    </div>

    <!-- Détail par catégorie de comptes -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6 mb-8">
        <h3 class="text-lg font-bold text-gray-900 mb-2 flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            Répartition des comptes par catégorie
        </h3>
        <p class="text-sm text-gray-500 mb-6">
            Les {{ stats.o2sProducts }} comptes synchronisés depuis O2S sont répartis en 3 catégories selon le type de produit financier.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
            {% for key, cat in categories %}
            <div class="rounded-2xl border-2 p-5 transition-all duration-200 hover:shadow-md
                {% if key == 'gere' %}border-blue-200 bg-gradient-to-br from-blue-50 to-indigo-50
                {% elseif key == 'epargne' %}border-cyan-200 bg-gradient-to-br from-cyan-50 to-sky-50
                {% else %}border-gray-200 bg-gradient-to-br from-gray-50 to-slate-50{% endif %}">
                
                <div class="flex items-center gap-3 mb-3">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center
                        {% if key == 'gere' %}bg-gradient-to-br from-blue-500 to-indigo-600
                        {% elseif key == 'epargne' %}bg-gradient-to-br from-cyan-500 to-sky-600
                        {% else %}bg-gradient-to-br from-gray-500 to-slate-600{% endif %}">
                        {% if key == 'gere' %}
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                        {% elseif key == 'epargne' %}
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                        </svg>
                        {% else %}
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                        </svg>
                        {% endif %}
                    </div>
                    <div>
                        <h4 class="font-bold text-gray-900">{{ cat.label }}</h4>
                        <p class="text-xs text-gray-500">{{ cat.description }}</p>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3 mb-4">
                    <div class="text-center bg-white/70 rounded-xl p-3">
                        <p class="text-2xl font-bold {% if key == 'gere' %}text-blue-700{% elseif key == 'epargne' %}text-cyan-700{% else %}text-gray-700{% endif %}">{{ cat.count }}</p>
                        <p class="text-xs text-gray-500">comptes</p>
                    </div>
                    <div class="text-center bg-white/70 rounded-xl p-3">
                        <p class="text-lg font-bold {% if key == 'gere' %}text-blue-700{% elseif key == 'epargne' %}text-cyan-700{% else %}text-gray-700{% endif %}">{{ cat.valuation|number_format(0, ',', ' ') }} €</p>
                        <p class="text-xs text-gray-500">encours</p>
                    </div>
                </div>

                {% if cat.types|length > 0 %}
                <div class="space-y-1">
                    {% for t in cat.types %}
                    <div class="flex items-center justify-between text-xs px-2 py-1.5 rounded-lg bg-white/50">
                        <span class="text-gray-700 font-medium">{{ t.type|replace({'_': ' '}) }}</span>
                        <span class="flex items-center gap-2">
                            <span class="text-gray-500">{{ t.count }} compte{{ t.count > 1 ? 's' : '' }}</span>
                            {% if t.valuation > 0 %}
                            <span class="font-semibold {% if key == 'gere' %}text-blue-600{% elseif key == 'epargne' %}text-cyan-600{% else %}text-gray-600{% endif %}">{{ t.valuation|number_format(0, ',', ' ') }} €</span>
                            {% else %}
                            <span class="text-gray-400">—</span>
                            {% endif %}
                        </span>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
            {% endfor %}
        </div>

        <!-- Barre de répartition visuelle -->
        {% set total_comptes = categories.gere.count + categories.epargne.count + categories.agrege.count %}
        {% if total_comptes > 0 %}
        <div class="mb-4">
            <p class="text-sm font-medium text-gray-700 mb-2">Répartition des {{ total_comptes }} comptes :</p>
            <div class="h-6 flex rounded-full overflow-hidden">
                {% if categories.gere.count > 0 %}
                <div class="bg-gradient-to-r from-blue-500 to-indigo-500 flex items-center justify-center text-white text-xs font-bold" style="width: {{ (categories.gere.count / total_comptes * 100)|round(1) }}%">
                    {% if (categories.gere.count / total_comptes * 100) > 10 %}{{ categories.gere.count }}{% endif %}
                </div>
                {% endif %}
                {% if categories.epargne.count > 0 %}
                <div class="bg-gradient-to-r from-cyan-500 to-sky-500 flex items-center justify-center text-white text-xs font-bold" style="width: {{ (categories.epargne.count / total_comptes * 100)|round(1) }}%">
                    {% if (categories.epargne.count / total_comptes * 100) > 10 %}{{ categories.epargne.count }}{% endif %}
                </div>
                {% endif %}
                {% if categories.agrege.count > 0 %}
                <div class="bg-gradient-to-r from-gray-400 to-slate-500 flex items-center justify-center text-white text-xs font-bold" style="width: {{ (categories.agrege.count / total_comptes * 100)|round(1) }}%">
                    {% if (categories.agrege.count / total_comptes * 100) > 10 %}{{ categories.agrege.count }}{% endif %}
                </div>
                {% endif %}
            </div>
            <div class="flex items-center gap-6 mt-2 text-xs text-gray-500">
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-gradient-to-r from-blue-500 to-indigo-500"></span> Gestion directe ({{ ((categories.gere.count / total_comptes) * 100)|round(1) }}%)</span>
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-gradient-to-r from-cyan-500 to-sky-500"></span> Épargne salariale ({{ ((categories.epargne.count / total_comptes) * 100)|round(1) }}%)</span>
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-gradient-to-r from-gray-400 to-slate-500"></span> Agrégés ({{ ((categories.agrege.count / total_comptes) * 100)|round(1) }}%)</span>
            </div>
        </div>
        {% endif %}

        <!-- Légende explicative -->
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mt-4">
            <h4 class="font-semibold text-amber-800 text-sm mb-2 flex items-center gap-2">
