{% extends 'admin/base.html.twig' %}

{% block title %}Client {{ user.fullName }} - O2S{% endblock %}

{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="{{ path('admin_o2s_clients') }}" class="btn btn-outline-secondary mb-2">
                <i class="fas fa-arrow-left me-1"></i> Retour
            </a>
            <h1 class="h3 mb-0">
                {{ user.fullName ?: 'Client #' ~ user.id }}
                {% if user.o2sContactId %}
                    <span class="badge bg-success">O2S</span>
                {% endif %}
            </h1>
        </div>
        <div>
            {% if user.o2sContactId %}
                <button type="button" class="btn btn-success" id="syncBtn">
                    <i class="fas fa-sync-alt me-1"></i> Synchroniser
                </button>
            {% endif %}
        </div>
    </div>

    <div class="row">
        {# Informations utilisateur #}
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-user me-2"></i>Informations client</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <th class="text-muted">Email</th>
                            <td>{{ user.email }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Téléphone</th>
                            <td>{{ user.phone ?: '-' }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Adresse</th>
                            <td>
                                {{ user.address ?: '-' }}<br>
                                {{ user.postalCode }} {{ user.city }}
                            </td>
                        </tr>
                        <tr>
                            <th class="text-muted">Inscription</th>
                            <td>{{ user.createdAt|date('d/m/Y') }}</td>
                        </tr>
                    </table>
                </div>
            </div>

            {# Liaison O2S #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-link me-2"></i>Liaison O2S</h5>
                </div>
                <div class="card-body">
                    {% if user.o2sContactId %}
                        <div class="alert alert-success mb-3">
                            <i class="fas fa-check-circle me-1"></i>
                            Utilisateur lié à O2S
                        </div>
                        <table class="table table-borderless mb-0">
                            <tr>
                                <th class="text-muted">Contact ID</th>
                                <td><code>{{ user.o2sContactId }}</code></td>
                            </tr>
                            <tr>
                                <th class="text-muted">Dernière sync</th>
                                <td>{{ user.o2sSyncedAt|date('d/m/Y H:i') }}</td>
                            </tr>
                        </table>
                        
                        {% if o2sContact %}
                        <hr>
                        <h6>Données O2S</h6>
                        <table class="table table-borderless table-sm mb-0">
                            <tr>
                                <th class="text-muted">Nom O2S</th>
                                <td>{{ o2sContact.fullName }}</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Email O2S</th>
                                <td>{{ o2sContact.email ?: '-' }}</td>
                            </tr>
                            <tr>
                                <th class="text-muted">Téléphone O2S</th>
                                <td>{{ o2sContact.telephone ?: '-' }}</td>
                            </tr>
                        </table>
                        {% endif %}
                    {% else %}
                        <div class="alert alert-warning mb-3">
                            <i class="fas fa-exclamation-triangle me-1"></i>
                            Utilisateur non lié à O2S
                        </div>
                        <button type="button" class="btn btn-primary w-100"
                                data-bs-toggle="modal" data-bs-target="#linkModal">
                            <i class="fas fa-link me-1"></i> Lier à un contact O2S
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Liste des produits #}
        <div class="col-md-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-briefcase me-2"></i>Produits ({{ products|length }})</h5>
                </div>
                <div class="card-body p-0">
                    {% if products|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Produit</th>
                                    <th>Type</th>
                                    <th>Distributeur</th>
                                    <th class="text-end">Valorisation</th>
                                    <th>Date valeur</th>
                                    <th>Source</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for product in products %}
                                <tr>
                                    <td>
                                        <a href="{{ path('admin_products_edit', {id: product.id}) }}">
                                            {{ product.displayAlias ?: product.internalName }}
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">{{ product.productType }}</span>
                                    </td>
                                    <td>{{ product.distributor }}</td>
                                    <td class="text-end">
                                        {% if product.o2sValuation %}
                                            <strong>{{ product.o2sValuation|number_format(2, ',', ' ') }} €</strong>
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if product.o2sValuationDate %}
                                            {{ product.o2sValuationDate|date('d/m/Y') }}
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if product.o2sCompteId %}
                                            <span class="badge bg-success">O2S</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Manuel</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <th colspan="3">Total</th>
                                    <th class="text-end">
                                        {% set total = 0 %}
                                        {% for p in products %}
                                            {% set total = total + (p.o2sValuation|default(0)) %}
                                        {% endfor %}
                                        <strong>{{ total|number_format(2, ',', ' ') }} €</strong>
                                    </th>
                                    <th colspan="2"></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    {% else %}
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-folder-open fa-3x mb-3"></i>
                        <p>Aucun produit pour ce client</p>
                        {% if user.o2sContactId %}
                        <button type="button" class="btn btn-primary" id="syncBtn2">
                            <i class="fas fa-sync-alt me-1"></i> Synchroniser depuis O2S
                        </button>
                        {% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

{# Modal de liaison O2S #}
<div class="modal fade" id="linkModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Lier à un contact O2S</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Rechercher un contact O2S</label>
                    <input type="text" class="form-control" id="o2sContactSearch" 
                           placeholder="Nom ou email...">
                </div>
                <div id="o2sContactResults" class="list-group" style="max-height: 300px; overflow-y: auto;">
                </div>
                <div class="mb-3 mt-3">
                    <label class="form-label">Ou saisir l'ID du contact O2S</label>
                    <input type="text" class="form-control" id="o2sContactIdInput" 
                           placeholder="ex: 6fef4227-aedb-11ee-a200-246e960d0462">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" id="confirmLinkBtn">Lier</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Recherche de contacts O2S
    let searchTimeout;
    const searchInput = document.getElementById('o2sContactSearch');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            const query = this.value;
            if (query.length < 2) {
                document.getElementById('o2sContactResults').innerHTML = '';
                return;
            }
            searchTimeout = setTimeout(() => {
                fetch('{{ path('admin_o2s_contacts_search') }}?q=' + encodeURIComponent(query))
                    .then(r => r.json())
                    .then(data => {
                        const container = document.getElementById('o2sContactResults');
                        if (data.contacts && data.contacts.length > 0) {
                            container.innerHTML = data.contacts.map(c => `
                                <button type="button" class="list-group-item list-group-item-action o2s-contact-item"
                                        data-contact-id="${c.id}">
                                    <strong>${c.name || 'N/A'}</strong>
                                    <br><small class="text-muted">${c.email || 'Pas d\'email'}</small>
                                </button>
                            `).join('');
                            
                            container.querySelectorAll('.o2s-contact-item').forEach(item => {
                                item.addEventListener('click', function() {
                                    document.getElementById('o2sContactIdInput').value = this.dataset.contactId;
                                    container.querySelectorAll('.o2s-contact-item').forEach(i => i.classList.remove('active'));
                                    this.classList.add('active');
                                });
                            });
                        } else {
                            container.innerHTML = '<div class="list-group-item text-muted">Aucun contact trouvé</div>';
                        }
                    });
            }, 300);
        });
    }

    // Confirmation de liaison
    const linkBtn = document.getElementById('confirmLinkBtn');
    if (linkBtn) {
        linkBtn.addEventListener('click', function() {
            const contactId = document.getElementById('o2sContactIdInput').value;
            
            if (!contactId) {
                alert('Veuillez sélectionner ou saisir un ID de contact O2S');
                return;
            }
            
            const formData = new FormData();
            formData.append('o2sContactId', contactId);
            
            fetch('{{ path('admin_o2s_client_link', {id: user.id}) }}', {
                method: 'POST',
                body: formData
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    alert('Utilisateur lié avec succès!');
                    location.reload();
                } else {
                    alert('Erreur: ' + (data.error || 'Erreur inconnue'));
                }
            });
        });
    }

    // Sync
    const syncBtns = document.querySelectorAll('#syncBtn, #syncBtn2');
    syncBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const icon = this.querySelector('i');
            icon.classList.add('fa-spin');
            
            fetch('{{ path('admin_o2s_client_sync', {id: user.id}) }}', { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    icon.classList.remove('fa-spin');
                    if (data.success) {
                        alert(data.message);
                        location.reload();
                    } else {
                        alert('Erreur: ' + (data.error || 'Erreur inconnue'));
                    }
                });
        });
    });
});
</script>
{% endblock %}

