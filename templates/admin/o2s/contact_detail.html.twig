{% extends 'admin_modern/base.html.twig' %}

{% block title %}{{ contact.fullName }} - O2S{% endblock %}
{% block page_title %}👤 {{ contact.fullName }}{% endblock %}

{% block content %}
<div class="fade-in">
    <!-- Header -->
    <div class="mb-6">
        <a href="{{ path('admin_o2s_contacts') }}" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Retour aux contacts
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Colonne gauche : Infos contact -->
        <div class="space-y-6">
            <!-- Carte contact O2S -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="bg-gradient-to-r from-blue-600 to-indigo-700 p-6 text-white">
                    <div class="flex items-center gap-4">
                        <div class="w-16 h-16 rounded-full bg-white/20 backdrop-blur flex items-center justify-center text-2xl font-bold">
                            {{ contact.fullName|slice(0,2)|upper }}
                        </div>
                        <div>
                            <h2 class="text-xl font-bold">{{ contact.fullName }}</h2>
                            <p class="text-blue-200 text-sm">Contact Harvest O2S</p>
                        </div>
                    </div>
                </div>
                <div class="p-6 space-y-4">
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Email</p>
                        <p class="text-gray-900">{{ contact.email ?? '—' }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Téléphone</p>
                        <p class="text-gray-900">{{ contact.telephone ?? '—' }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Mobile</p>
                        <p class="text-gray-900">{{ contact.telephoneMobile ?? '—' }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Date de naissance</p>
                        <p class="text-gray-900">{{ contact.dateNaissance ? contact.dateNaissance|date('d/m/Y') : '—' }}</p>
                    </div>
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">ID O2S</p>
                        <p class="text-gray-500 font-mono text-xs break-all">{{ contact.id }}</p>
                    </div>
                </div>
            </div>

            <!-- Liaison utilisateur local -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                        </svg>
                        Liaison locale
                    </h3>
                </div>
                <div class="p-6">
                    {% if linkedUser %}
                        <div class="flex items-center gap-3 p-4 bg-green-50 rounded-xl border border-green-200 mb-4">
                            <div class="w-10 h-10 rounded-full bg-green-600 flex items-center justify-center text-white font-semibold">
                                {{ linkedUser.email|slice(0,1)|upper }}
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-gray-900 truncate">{{ linkedUser.email }}</p>
                                <p class="text-sm text-gray-500">{{ linkedUser.firstName }} {{ linkedUser.lastName }}</p>
                            </div>
                            <span class="px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">Lié</span>
                        </div>
                        <a href="{{ path('user_dashboard') }}?_switch_user={{ linkedUser.email }}" 
                           target="_blank"
                           class="block w-full text-center px-4 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">
                            <svg class="w-4 h-4 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                            </svg>
                            Voir son dashboard
                        </a>
                    {% else %}
                        <div class="text-center py-4">
                            <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-3">
                                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
                                </svg>
                            </div>
                            <p class="text-gray-500 mb-4">Aucun utilisateur lié à ce contact</p>
                            <button type="button" 
                                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition-colors"
                                    onclick="document.getElementById('linkModal').classList.remove('hidden')">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"></path>
                                </svg>
                                Lier à un utilisateur
                            </button>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Colonne droite : Comptes -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Résumé -->
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
                    <p class="text-sm text-gray-500 mb-1">Nombre de comptes</p>
                    <p class="text-2xl font-bold text-gray-900">{{ summary.compte_count }}</p>
                </div>
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
                    <p class="text-sm text-gray-500 mb-1">Valorisation totale</p>
                    <p class="text-2xl font-bold text-green-600">{{ summary.total_valuation|number_format(0, ',', ' ') }} €</p>
                </div>
                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 col-span-2 sm:col-span-1">
                    <p class="text-sm text-gray-500 mb-1">Types de produits</p>
                    <p class="text-2xl font-bold text-gray-900">{{ summary.by_type|keys|length }}</p>
                </div>
            </div>

            <!-- Liste des comptes -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
                    <h3 class="font-semibold text-gray-900">Comptes O2S</h3>
                    <p class="text-sm text-gray-500">{{ comptesWithDetails|length }} compte(s) associé(s)</p>
                </div>

                {% if comptesWithDetails is not empty %}
                    <div class="divide-y divide-gray-100">
                        {% for item in comptesWithDetails %}
                            {% set compte = item.compte %}
                            {% set details = item.details %}
                            {% set localProduct = item.localProduct %}
                            
                            <div class="p-6 hover:bg-gray-50/50 transition-colors">
                                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-4">
                                    <div class="flex items-start gap-3">
                                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-violet-600 flex items-center justify-center text-white font-semibold">
                                            {{ compte.productType|slice(0,2)|upper }}
                                        </div>
                                        <div>
                                            <h4 class="font-semibold text-gray-900">{{ compte.displayName }}</h4>
                                            <div class="flex items-center gap-2 mt-1">
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
                                                    {{ compte.productType }}
                                                </span>
                                                {% if compte.isActif %}
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                                        Actif
                                                    </span>
                                                {% else %}
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                                        {{ compte.statut ?? 'Inactif' }}
                                                    </span>
                                                {% endif %}
                                                {% if localProduct %}
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">
                                                        Synchro local
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        {% if details and details.hasValuation %}
                                            <p class="text-2xl font-bold text-gray-900">{{ details.totalValue|number_format(0, ',', ' ') }} €</p>
                                            {% if details.valuationDate %}
                                                <p class="text-xs text-gray-500">au {{ details.valuationDate|date('d/m/Y') }}</p>
                                            {% endif %}
                                        {% elseif compte.montant %}
                                            <p class="text-2xl font-bold text-gray-900">{{ compte.montant|number_format(0, ',', ' ') }} €</p>
                                        {% else %}
                                            <p class="text-gray-400">Valorisation non disponible</p>
                                        {% endif %}
                                    </div>
                                </div>

                                <!-- Détails du compte -->
                                {% if details and details.situation|length > 0 %}
                                    <div class="mt-4 pt-4 border-t border-gray-100">
                                        <p class="text-sm font-medium text-gray-700 mb-3">
                                            {{ details.situation|length }} support(s) d'investissement
                                        </p>
                                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                            {% for asset in details.situation|slice(0, 4) %}
                                                <div class="flex items-center justify-between p-2 bg-gray-50 rounded-lg text-sm">
                                                    <span class="text-gray-600 truncate" style="max-width: 60%;">
                                                        {{ asset.assetName ?? ('Asset #' ~ asset.assetId|slice(0,6)) }}
                                                    </span>
                                                    <span class="font-medium text-gray-900">
                                                        {{ asset.value|number_format(0, ',', ' ') }} €
                                                    </span>
                                                </div>
                                            {% endfor %}
                                            {% if details.situation|length > 4 %}
                                                <div class="p-2 text-center text-sm text-gray-500">
                                                    + {{ details.situation|length - 4 }} autre(s)
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}

                                <!-- Actions -->
                                <div class="mt-4 pt-4 border-t border-gray-100 flex justify-end gap-2">
                                    <a href="{{ path('admin_o2s_compte_detail', {compteId: compte.id}) }}" 
                                       class="inline-flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium text-blue-600 hover:bg-blue-50 transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                        </svg>
                                        Voir détails complet
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="p-12 text-center">
                        <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                        </svg>
                        <p class="text-gray-500">Aucun compte trouvé pour ce contact</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<!-- Modal de liaison -->
<div id="linkModal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen px-4">
        <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('linkModal').classList.add('hidden')"></div>
        <div class="relative bg-white rounded-2xl shadow-xl max-w-md w-full p-6">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Lier à un utilisateur local</h3>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Rechercher un utilisateur</label>
                <input type="text" id="userSearchInput" 
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       placeholder="Email ou nom...">
            </div>
            <div id="userSearchResults" class="max-h-60 overflow-y-auto mb-4 space-y-2">
                <!-- Résultats de recherche -->
            </div>
            <div class="flex justify-end gap-2">
                <button type="button" 
                        onclick="document.getElementById('linkModal').classList.add('hidden')"
                        class="px-4 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50">
                    Annuler
                </button>
                <button type="button" id="confirmLinkBtn"
                        class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed"
                        disabled>
                    Lier
                </button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('userSearchInput');
    const resultsContainer = document.getElementById('userSearchResults');
    const confirmBtn = document.getElementById('confirmLinkBtn');
    let selectedUserId = null;
    let searchTimeout;

    if (searchInput) {
        searchInput.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            const query = this.value;
            
            if (query.length < 2) {
                resultsContainer.innerHTML = '';
                return;
            }

            searchTimeout = setTimeout(() => {
                fetch('{{ path('admin_o2s_api_users_search') }}?q=' + encodeURIComponent(query))
                    .then(r => r.json())
                    .then(users => {
                        if (users.length > 0) {
                            resultsContainer.innerHTML = users.map(u => `
                                <button type="button" 
                                        class="w-full p-3 text-left rounded-lg border border-gray-200 hover:border-blue-500 hover:bg-blue-50 transition-colors user-item"
                                        data-user-id="${u.id}">
                                    <div class="font-medium text-gray-900">${u.email}</div>
                                    <div class="text-sm text-gray-500">${u.name || 'Nom non renseigné'}</div>
                                </button>
                            `).join('');

                            document.querySelectorAll('.user-item').forEach(item => {
                                item.addEventListener('click', function() {
                                    document.querySelectorAll('.user-item').forEach(i => {
                                        i.classList.remove('border-blue-500', 'bg-blue-50');
                                    });
                                    this.classList.add('border-blue-500', 'bg-blue-50');
                                    selectedUserId = this.dataset.userId;
                                    confirmBtn.disabled = false;
                                });
                            });
                        } else {
                            resultsContainer.innerHTML = '<p class="text-center text-gray-500 py-4">Aucun utilisateur trouvé</p>';
                        }
                    });
            }, 300);
        });
    }

    if (confirmBtn) {
        confirmBtn.addEventListener('click', function() {
            if (!selectedUserId) return;

            const formData = new FormData();
            formData.append('contactId', '{{ contact.id }}');
            formData.append('userId', selectedUserId);

            fetch('{{ path('admin_o2s_link_user') }}', {
                method: 'POST',
                body: formData
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    location.reload();
                } else {
                    alert('Erreur: ' + (data.error || 'Erreur inconnue'));
                }
            });
        });
    }
});
</script>
{% endblock %}

