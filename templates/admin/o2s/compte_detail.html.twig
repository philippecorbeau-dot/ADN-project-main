{% extends 'admin_modern/base.html.twig' %}

{% block title %}{{ compte.displayName }} - O2S{% endblock %}
{% block page_title %}💼 {{ compte.displayName }}{% endblock %}

{% block content %}
<div class="fade-in">
    <!-- Header -->
    <div class="mb-6">
        <a href="{{ path('admin_o2s_contacts') }}" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Retour
        </a>
    </div>

    <!-- En-tête du compte -->
    <div class="bg-gradient-to-r from-purple-600 to-violet-700 rounded-2xl shadow-lg p-6 sm:p-8 text-white mb-6">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 rounded-xl bg-white/20 backdrop-blur flex items-center justify-center">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                </div>
                <div>
                    <h1 class="text-2xl font-bold">{{ compte.displayName }}</h1>
                    <div class="flex items-center gap-2 mt-1">
                        <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-white/20">{{ compte.productType }}</span>
                        {% if compte.isActif %}
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-500/80">Actif</span>
                        {% else %}
                            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gray-500/80">{{ compte.statut ?? 'Inactif' }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>
            <div class="text-right">
                {% if details.hasValuation %}
                    <p class="text-purple-200 text-sm">Valorisation totale</p>
                    <p class="text-3xl sm:text-4xl font-bold">{{ details.totalValue|number_format(0, ',', ' ') }} €</p>
                    {% if details.valuationDate %}
                        <p class="text-purple-200 text-xs mt-1">au {{ details.valuationDate|date('d/m/Y') }}</p>
                    {% endif %}
                {% else %}
                    <p class="text-purple-200">Valorisation non disponible</p>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <!-- Liquidité -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                </div>
            </div>
            <p class="text-sm text-gray-500">Liquidité</p>
            <p class="text-xl font-bold text-gray-900">
                {{ details.liquidity is not null ? (details.liquidity|number_format(0, ',', ' ') ~ ' €') : '—' }}
            </p>
        </div>

        <!-- Nombre de supports -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                </div>
            </div>
            <p class="text-sm text-gray-500">Supports</p>
            <p class="text-xl font-bold text-gray-900">{{ assetsEnriched|length }}</p>
        </div>

        <!-- Statut local -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl {{ localProduct ? 'bg-green-100' : 'bg-gray-100' }} flex items-center justify-center">
                    <svg class="w-5 h-5 {{ localProduct ? 'text-green-600' : 'text-gray-400' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
            </div>
            <p class="text-sm text-gray-500">Synchro locale</p>
            <p class="text-xl font-bold {{ localProduct ? 'text-green-600' : 'text-gray-400' }}">
                {{ localProduct ? 'Oui' : 'Non' }}
            </p>
        </div>

        <!-- ID O2S -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center">
                    <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
                    </svg>
                </div>
            </div>
            <p class="text-sm text-gray-500">ID Compte</p>
            <p class="text-xs font-mono text-gray-600 truncate" title="{{ compte.id }}">{{ compte.id|slice(0,16) }}...</p>
        </div>
    </div>

    <!-- Supports d'investissement -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
            <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                Supports d'investissement
            </h3>
            <p class="text-sm text-gray-500">{{ assetsEnriched|length }} ligne(s) dans ce compte</p>
        </div>

        {% if assetsEnriched is not empty %}
            <!-- Vue Desktop -->
            <div class="hidden lg:block overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Support</th>
                            <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">ISIN</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Quantité</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">VL</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Date VL</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Valorisation</th>
                            <th class="px-6 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">%</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-100">
                        {% for item in assetsEnriched %}
                            {% set line = item.line %}
                            {% set info = item.info %}
                            {% set pct = details.totalValue > 0 ? ((line.value / details.totalValue) * 100) : 0 %}
                            <tr class="hover:bg-blue-50/50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center text-indigo-700 font-semibold text-xs">
                                            {{ (info.label ?? line.assetName ?? 'UC')|slice(0,2)|upper }}
                                        </div>
                                        <div class="min-w-0">
                                            <div class="font-medium text-gray-900 truncate" style="max-width: 200px;">
                                                {{ info.label ?? line.assetName ?? ('Support #' ~ line.assetId|slice(0,6)) }}
                                            </div>
                                            {% if info %}
                                                <div class="text-xs text-gray-500">
                                                    {{ info.assetType ?? '' }} {% if info.managementCompany %}• {{ info.managementCompany }}{% endif %}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="font-mono text-sm text-gray-600">{{ info.isin ?? line.isin ?? '—' }}</span>
                                </td>
                                <td class="px-6 py-4 text-right font-medium text-gray-900">
                                    {{ line.quantity|number_format(4, ',', ' ') }}
                                </td>
                                <td class="px-6 py-4 text-right text-gray-600">
                                    {{ line.netAssetValue|number_format(2, ',', ' ') }} €
                                </td>
                                <td class="px-6 py-4 text-right text-gray-500 text-sm">
                                    {{ line.netAssetValueDate ? line.netAssetValueDate|date('d/m/Y') : '—' }}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <span class="font-bold text-gray-900">{{ line.value|number_format(0, ',', ' ') }} €</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <div class="w-16 h-2 bg-gray-200 rounded-full overflow-hidden">
                                            <div class="h-full bg-gradient-to-r from-purple-500 to-violet-500 rounded-full" 
                                                 style="width: {{ pct|number_format(1, '.', '') }}%"></div>
                                        </div>
                                        <span class="text-sm text-gray-600 w-12 text-right">{{ pct|number_format(1, ',', '') }}%</span>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot class="bg-gray-50">
                        <tr>
                            <td colspan="5" class="px-6 py-4 font-semibold text-gray-900">Total</td>
                            <td class="px-6 py-4 text-right font-bold text-gray-900 text-lg">
                                {{ details.totalValue|number_format(0, ',', ' ') }} €
                            </td>
                            <td class="px-6 py-4 text-right font-semibold text-gray-600">100%</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <!-- Vue Mobile/Tablet -->
            <div class="lg:hidden divide-y divide-gray-100">
                {% for item in assetsEnriched %}
                    {% set line = item.line %}
                    {% set info = item.info %}
                    {% set pct = details.totalValue > 0 ? ((line.value / details.totalValue) * 100) : 0 %}
                    <div class="p-4">
                        <div class="flex items-start gap-3 mb-3">
                            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center text-indigo-700 font-semibold flex-shrink-0">
                                {{ (info.label ?? line.assetName ?? 'UC')|slice(0,2)|upper }}
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="font-semibold text-gray-900 truncate">
                                    {{ info.label ?? line.assetName ?? ('Support #' ~ line.assetId|slice(0,6)) }}
                                </div>
                                <div class="text-xs text-gray-500 font-mono">{{ info.isin ?? line.isin ?? '—' }}</div>
                            </div>
                            <div class="text-right flex-shrink-0">
                                <div class="font-bold text-gray-900">{{ line.value|number_format(0, ',', ' ') }} €</div>
                                <div class="text-xs text-gray-500">{{ pct|number_format(1, ',', '') }}%</div>
                            </div>
                        </div>
                        <div class="grid grid-cols-3 gap-2 text-sm">
                            <div class="bg-gray-50 rounded-lg p-2">
                                <div class="text-xs text-gray-500">Qté</div>
                                <div class="font-medium text-gray-900">{{ line.quantity|number_format(2, ',', ' ') }}</div>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-2">
                                <div class="text-xs text-gray-500">VL</div>
                                <div class="font-medium text-gray-900">{{ line.netAssetValue|number_format(2, ',', ' ') }} €</div>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-2">
                                <div class="text-xs text-gray-500">Date</div>
                                <div class="font-medium text-gray-900">{{ line.netAssetValueDate ? line.netAssetValueDate|date('d/m') : '—' }}</div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
                <!-- Total mobile -->
                <div class="p-4 bg-gray-50">
                    <div class="flex items-center justify-between">
                        <span class="font-semibold text-gray-900">Total valorisation</span>
                        <span class="text-xl font-bold text-gray-900">{{ details.totalValue|number_format(0, ',', ' ') }} €</span>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="p-12 text-center">
                <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                <p class="text-gray-500">Aucun support d'investissement trouvé</p>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

