{% extends 'admin_modern/base.html.twig' %}

{% block title %}Contacts O2S - Harvest{% endblock %}
{% block page_title %}👥 Contacts O2S{% endblock %}

{% block content %}
<div class="fade-in">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <div>
            <a href="{{ path('admin_o2s_index') }}" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 mb-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Retour au dashboard O2S
            </a>
            <p class="text-gray-600">{{ totalCount }} contact(s) synchronisés localement — données en base, 0 appel API</p>
        </div>
    </div>

    <!-- Flash messages -->
    {% for message in app.flashes('error') %}
        <div class="mb-4 p-4 bg-red-100 border border-red-300 text-red-800 rounded-xl">
            {{ message }}
        </div>
    {% endfor %}

    <!-- Filtres et recherche -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-4 mb-6">
        <form method="GET" action="{{ path('admin_o2s_contacts') }}" class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <div class="relative">
                    <input type="text" 
                           name="search" 
                           value="{{ search }}" 
                           placeholder="Rechercher par nom, email, ID O2S..."
                           class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                    <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
            </div>
            
            <div class="w-full md:w-48">
                <select name="status" class="w-full py-2.5 px-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                    <option value="" {{ statusFilter == '' ? 'selected' : '' }}>Tous les contacts</option>
                    <option value="linked" {{ statusFilter == 'linked' ? 'selected' : '' }}>Liés O2S</option>
                    <option value="unlinked" {{ statusFilter == 'unlinked' ? 'selected' : '' }}>Non liés O2S</option>
                </select>
            </div>
            
            <div class="flex gap-2">
                <button type="submit" class="px-4 py-2.5 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition-colors flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                    Filtrer
                </button>
                {% if search or statusFilter %}
                    <a href="{{ path('admin_o2s_contacts') }}" class="px-4 py-2.5 rounded-xl bg-gray-200 text-gray-700 font-semibold hover:bg-gray-300 transition-colors flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        Effacer
                    </a>
                {% endif %}
            </div>
        </form>
    </div>

    <!-- Liste des contacts -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
            <div class="flex items-center justify-between">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900">Contacts</h3>
                    <p class="text-sm text-gray-600">
                        {{ totalCount }} résultat(s)
                        {% if search %} — Recherche: "{{ search }}"{% endif %}
                        {% if statusFilter %} — Filtre: {{ statusFilter == 'linked' ? 'Liés O2S' : 'Non liés' }}{% endif %}
                    </p>
                </div>
                <!-- Pagination header -->
                <div class="flex items-center gap-2">
                    {% if page > 1 %}
                        <a href="{{ path('admin_o2s_contacts', {page: page - 1, search: search, status: statusFilter}) }}" 
                           class="px-3 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                            </svg>
                        </a>
                    {% endif %}
                    <span class="px-3 py-2 text-sm text-gray-600 bg-white rounded-lg border border-gray-300">
                        Page {{ page }} / {{ totalPages > 0 ? totalPages : 1 }}
                    </span>
                    {% if page < totalPages %}
                        <a href="{{ path('admin_o2s_contacts', {page: page + 1, search: search, status: statusFilter}) }}" 
                           class="px-3 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if users is not empty %}
            <!-- Vue Desktop -->
            <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Contact</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Email</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Téléphone</th>
                            <th class="px-6 py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Comptes</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Statut O2S</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-100">
                        {% for user in users %}
                            {% set accountCount = userAccountCounts[user.id] ?? 0 %}
                            <tr class="hover:bg-blue-50/50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-gradient-to-br {{ user.o2sContactId ? 'from-blue-500 to-indigo-600' : 'from-gray-400 to-gray-500' }} flex items-center justify-center text-white font-semibold text-sm">
                                            {{ (user.firstName ~ ' ' ~ user.lastName)|slice(0,2)|upper }}
                                        </div>
                                        <div>
                                            <div class="font-semibold text-gray-900">{{ user.firstName }} {{ user.lastName }}</div>
                                            {% if user.o2sContactId %}
                                                <div class="text-xs text-gray-500 font-mono">{{ user.o2sContactId|slice(0,12) }}...</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-gray-600">
                                    {{ user.email ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-gray-600">
                                    {{ user.phone ?? '—' }}
                                </td>
                                <td class="px-6 py-4 text-center">
                                    {% if accountCount > 0 %}
                                        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-100 text-blue-800 font-semibold text-sm">
                                            {{ accountCount }}
                                        </span>
                                    {% else %}
                                        <span class="text-gray-400">—</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4">
                                    {% if user.o2sContactId %}
                                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-800 border border-green-200">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                            </svg>
                                            Lié O2S
                                        </span>
                                        {% if user.o2sSyncedAt %}
                                            <div class="text-xs text-gray-400 mt-1">Sync: {{ user.o2sSyncedAt|date('d/m/Y H:i') }}</div>
                                        {% endif %}
                                    {% else %}
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-600">
                                            Non lié
                                        </span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        {% if user.o2sContactId %}
                                            <a href="{{ path('admin_o2s_contact_detail', {contactId: user.o2sContactId}) }}" 
                                               class="inline-flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium text-blue-600 hover:text-white hover:bg-gradient-to-r hover:from-blue-600 hover:to-indigo-600 transition-all duration-200">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                                </svg>
                                                Détails O2S
                                            </a>
                                        {% endif %}
                                        <a href="{{ path('admin_modern_user_view', {id: user.id}) }}" 
                                           class="inline-flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-all duration-200">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                            </svg>
                                            Profil
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <!-- Vue Mobile -->
            <div class="md:hidden divide-y divide-gray-100">
                {% for user in users %}
                    {% set accountCount = userAccountCounts[user.id] ?? 0 %}
                    <div class="p-4 hover:bg-blue-50/50 transition-colors">
                        <div class="flex items-center gap-3 mb-2">
                            <div class="w-12 h-12 rounded-full bg-gradient-to-br {{ user.o2sContactId ? 'from-blue-500 to-indigo-600' : 'from-gray-400 to-gray-500' }} flex items-center justify-center text-white font-semibold">
                                {{ (user.firstName ~ ' ' ~ user.lastName)|slice(0,2)|upper }}
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="font-semibold text-gray-900 truncate">{{ user.firstName }} {{ user.lastName }}</div>
                                <div class="text-sm text-gray-500 truncate">{{ user.email ?? 'Pas d\'email' }}</div>
                            </div>
                            {% if user.o2sContactId %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Lié</span>
                            {% endif %}
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-xs text-gray-500">{{ accountCount }} compte(s)</span>
                            <div class="flex gap-2">
                                {% if user.o2sContactId %}
                                    <a href="{{ path('admin_o2s_contact_detail', {contactId: user.o2sContactId}) }}" class="text-xs text-blue-600 font-medium">Détails O2S</a>
                                {% endif %}
                                <a href="{{ path('admin_modern_user_view', {id: user.id}) }}" class="text-xs text-gray-600 font-medium">Profil</a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- Pagination bottom -->
            {% if totalPages > 1 %}
                <div class="px-6 py-4 bg-gray-50 border-t border-gray-200">
                    <div class="flex items-center justify-between">
                        <div class="text-sm text-gray-600">
                            Affichage {{ ((page - 1) * limit) + 1 }} - {{ min(page * limit, totalCount) }} sur {{ totalCount }}
                        </div>
                        <div class="flex items-center gap-1">
                            {% for p in range(max(1, page - 3), min(totalPages, page + 3)) %}
                                <a href="{{ path('admin_o2s_contacts', {page: p, search: search, status: statusFilter}) }}"
                                   class="px-3 py-1.5 rounded-lg text-sm font-medium {{ p == page ? 'bg-blue-600 text-white' : 'bg-white border border-gray-300 text-gray-700 hover:bg-gray-50' }} transition-colors">
                                    {{ p }}
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            {% endif %}
        {% else %}
            <div class="p-12 text-center">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                {% if search or statusFilter %}
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Aucun résultat</h3>
                    <p class="text-gray-500 mb-4">Aucun contact ne correspond à vos critères</p>
                    <a href="{{ path('admin_o2s_contacts') }}" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-200 text-gray-700 font-medium hover:bg-gray-300 transition-colors">
                        Effacer les filtres
                    </a>
                {% else %}
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Aucun contact</h3>
                    <p class="text-gray-500">Lancez une synchronisation pour importer les contacts O2S</p>
                {% endif %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
