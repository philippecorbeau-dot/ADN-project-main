{% extends 'admin_modern/base.html.twig' %}

{% block title %}Produits O2S - Harvest{% endblock %}
{% block page_title %}📦 Produits O2S (Types de contrats){% endblock %}

{% block content %}
<div class="fade-in">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <div>
            <p class="text-gray-600 mt-1">Types de contrats disponibles dans O2S (Assurance Vie, PEA, PER, etc.)</p>
        </div>
        <a href="{{ path('admin_o2s_index') }}" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Retour
        </a>
    </div>

    <!-- Stats par type -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-purple-600">{{ products|length }}</div>
            <div class="text-sm text-gray-500">Produits total</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-blue-600">{{ byType|length }}</div>
            <div class="text-sm text-gray-500">Types différents</div>
        </div>
    </div>

    <!-- Groupes par type -->
    {% for type, typeProducts in byType %}
    <div class="mb-6">
        <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-purple-500"></span>
            {{ typeProducts[0].typeLabel }} 
            <span class="text-sm font-normal text-gray-500">({{ typeProducts|length }})</span>
        </h3>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nom du produit</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Institution</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for product in typeProducts %}
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <code class="text-xs bg-gray-100 px-2 py-1 rounded">{{ product.productId }}</code>
                            </td>
                            <td class="px-6 py-4">
                                <span class="font-medium text-gray-900">{{ product.label ?? 'N/A' }}</span>
                            </td>
                            <td class="px-6 py-4">
                                {% set instLabel = institutionsMap[product.institutionId] ?? product.institutionId %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    {{ instLabel }}
                                </span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {% else %}
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-12 text-center text-gray-500">
        Aucun produit O2S trouvé
    </div>
    {% endfor %}
</div>
{% endblock %}

