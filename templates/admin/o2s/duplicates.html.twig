{% extends 'admin_modern/base.html.twig' %}

{% block title %}Doublons O2S{% endblock %}
{% block page_title %}🔍 Gestion des doublons O2S{% endblock %}

{% block content %}
<div class="fade-in">
    <!-- Retour + Actions -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <div>
            <a href="{{ path('admin_o2s_index') }}" class="text-blue-600 hover:text-blue-800 text-sm flex items-center gap-1 mb-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                Retour au dashboard O2S
            </a>
            <p class="text-gray-600 mt-1">
                Détecte les utilisateurs créés manuellement qui ont un doublon O2S (email placeholder).
                La fusion transfère le lien O2S et les produits vers le compte avec le vrai email.
            </p>
        </div>
        {% if duplicates|length > 0 %}
        <button type="button"
                id="mergeAllBtn"
                onclick="mergeAll()"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-red-600 to-rose-600 text-white font-semibold hover-lift shadow-lg hover:shadow-xl transition-all duration-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
            Fusionner tout ({{ duplicates|length }})
        </button>
        {% endif %}
    </div>

    <!-- Résumé -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-amber-600" id="duplicateCount">{{ duplicates|length }}</p>
                    <p class="text-sm text-gray-500">Doublons détectés</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-violet-600 flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-purple-600" id="productCount">{{ totalProducts }}</p>
                    <p class="text-sm text-gray-500">Produits à transférer</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-green-600" id="mergedCount">0</p>
                    <p class="text-sm text-gray-500">Fusionnés</p>
                </div>
            </div>
        </div>
    </div>

    {% if duplicates|length == 0 %}
    <!-- Aucun doublon -->
    <div class="bg-white rounded-2xl shadow-sm border border-green-200 p-8 text-center">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Base de données propre !</h3>
        <p class="text-gray-500">Aucun doublon O2S détecté. Tous les utilisateurs sont correctement liés.</p>
    </div>
    {% else %}
    <!-- Liste des doublons -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-200">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Compte manuel</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Email réel</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase">→</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Compte O2S (placeholder)</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase">Produits</th>
                        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for dup in duplicates %}
                    <tr class="hover:bg-gray-50 transition-colors" id="row-{{ dup.manual_id }}-{{ dup.o2s_id }}">
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2">
                                <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 text-xs font-bold">
                                    {{ dup.manual_fn|first|upper }}{{ dup.manual_ln|first|upper }}
                                </div>
                                <div>
                                    <p class="font-medium text-gray-900">{{ dup.manual_fn }} {{ dup.manual_ln }}</p>
                                    <p class="text-xs text-gray-400">#{{ dup.manual_id }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-3">
                            <span class="text-blue-600 font-mono text-xs">{{ dup.manual_email }}</span>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                            </svg>
                        </td>
                        <td class="px-4 py-3">
                            <div>
                                <p class="font-medium text-gray-700">{{ dup.o2s_fn }} {{ dup.o2s_ln }}</p>
                                <p class="text-xs text-gray-400 font-mono truncate max-w-[200px]" title="{{ dup.o2s_email }}">{{ dup.o2s_email }}</p>
                                <p class="text-xs text-amber-600 mt-0.5">O2S: {{ dup.o2s_contact_id[:12] }}...</p>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-center">
                            {% if dup.product_count > 0 %}
                            <span class="inline-flex items-center px-2 py-1 rounded-full bg-purple-100 text-purple-700 text-xs font-semibold">
                                {{ dup.product_count }}
                            </span>
                            {% else %}
                            <span class="text-gray-400">0</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3 text-center">
                            <button 
                                onclick="mergeSingle({{ dup.manual_id }}, {{ dup.o2s_id }}, this)"
                                class="merge-btn inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-green-100 text-green-700 hover:bg-green-200 text-xs font-semibold transition-all">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"></path>
                                </svg>
                                Fusionner
                            </button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>

<!-- Toast notification -->
<div id="mergeToast" class="fixed bottom-4 right-4 z-50 hidden transform transition-all duration-300 translate-y-4 opacity-0">
    <div class="bg-white rounded-2xl shadow-2xl border border-gray-200 p-5 max-w-sm">
        <div class="flex items-start gap-3">
            <div id="toastIcon" class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <p id="toastTitle" class="font-bold text-gray-900 text-sm">Fusion réussie</p>
                <p id="toastMessage" class="text-xs text-gray-500 mt-0.5"></p>
            </div>
            <button onclick="hideToast()" class="text-gray-400 hover:text-gray-600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
    </div>
</div>

<script>
const CSRF_TOKEN = '{{ csrf_token('o2s_merge') }}';
let mergedCount = 0;

function showToast(title, message, isError = false) {
    const toast = document.getElementById('mergeToast');
    document.getElementById('toastTitle').textContent = title;
    document.getElementById('toastMessage').textContent = message;
    const icon = document.getElementById('toastIcon');
    icon.className = isError
        ? 'w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0'
        : 'w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0';
    icon.innerHTML = isError
        ? '<svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>'
        : '<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
    
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.remove('translate-y-4', 'opacity-0'), 10);
    setTimeout(hideToast, 4000);
}

function hideToast() {
    const toast = document.getElementById('mergeToast');
    toast.classList.add('translate-y-4', 'opacity-0');
    setTimeout(() => toast.classList.add('hidden'), 300);
}

async function mergeSingle(manualId, o2sId, btn) {
    btn.disabled = true;
    btn.innerHTML = '<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Fusion...';

    try {
        const response = await fetch('{{ path('admin_o2s_merge_duplicate') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body: `_token=${CSRF_TOKEN}&manual_id=${manualId}&o2s_id=${o2sId}`
        });
        const data = await response.json();

        if (data.success) {
            const row = document.getElementById(`row-${manualId}-${o2sId}`);
            row.style.transition = 'all 0.4s';
            row.style.opacity = '0';
            row.style.transform = 'translateX(50px)';
            setTimeout(() => row.remove(), 400);

            mergedCount++;
            document.getElementById('mergedCount').textContent = mergedCount;
            const dupCount = document.getElementById('duplicateCount');
            dupCount.textContent = parseInt(dupCount.textContent) - 1;

            showToast('Fusion réussie !', data.message);
        } else {
            showToast('Erreur', data.error || 'Erreur inconnue', true);
            btn.disabled = false;
            btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"></path></svg> Fusionner';
        }
    } catch (e) {
        showToast('Erreur réseau', e.message, true);
        btn.disabled = false;
        btn.innerHTML = 'Fusionner';
    }
}

async function mergeAll() {
    const btn = document.getElementById('mergeAllBtn');
    if (!confirm('Fusionner TOUS les doublons ? Cette action est irréversible.')) return;

    btn.disabled = true;
    btn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Fusion en cours...';

    try {
        const response = await fetch('{{ path('admin_o2s_merge_all_duplicates') }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
            body: `_token=${CSRF_TOKEN}`
        });
        const data = await response.json();

        if (data.success) {
            showToast('Fusion terminée !', data.message);
            setTimeout(() => window.location.reload(), 2000);
        } else {
            showToast('Fusion partielle', `${data.merged} fusionné(s), ${data.errors.length} erreur(s)`, data.errors.length > 0);
            setTimeout(() => window.location.reload(), 3000);
        }
    } catch (e) {
        showToast('Erreur réseau', e.message, true);
        btn.disabled = false;
        btn.innerHTML = 'Fusionner tout';
    }
}
</script>
{% endblock %}

