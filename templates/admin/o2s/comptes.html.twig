{% extends 'admin_modern/base.html.twig' %}

{% block title %}Comptes O2S - Valorisations{% endblock %}
{% block page_title %}📊 Comptes O2S - Valorisations{% endblock %}

{% block content %}
<div class="fade-in">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
        <div>
            <a href="{{ path('admin_o2s_index') }}" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 mb-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Retour
            </a>
            <p class="text-gray-600 mt-1">Tous les comptes clients avec leurs valorisations O2S</p>
        </div>
    </div>

    <!-- Stats avec légendes -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-blue-600">{{ totalCount }}</div>
            <div class="text-sm text-gray-500">Comptes O2S synchronisés</div>
            <div class="text-xs text-gray-400 mt-1">Tous types confondus (gérés + épargne + agrégés)</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-emerald-600">{{ totalValuation|number_format(0, ',', ' ') }} €</div>
            <div class="text-sm text-gray-500">Encours total</div>
            <div class="text-xs text-gray-400 mt-1">Somme des valorisations O2S de tous les comptes</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-purple-600">{{ availableTypes|length }}</div>
            <div class="text-sm text-gray-500">Types de produits</div>
            <div class="text-xs text-gray-400 mt-1">Catégories de produits financiers distincts</div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-gray-600">{{ totalPages }}</div>
            <div class="text-sm text-gray-500">Pages</div>
            <div class="text-xs text-gray-400 mt-1">{{ totalCount }} comptes au total</div>
        </div>
    </div>

    <!-- Légende des types -->
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-6">
        <div class="flex flex-wrap items-center gap-4 text-xs">
            <span class="font-semibold text-gray-700">Légende des catégories :</span>
            <span class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
                💼 <strong>Gestion directe</strong> = Assurance vie, PER, PEA, SCPI, Compte-titres…
            </span>
            <span class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-cyan-500"></span>
                🏢 <strong>Épargne salariale</strong> = PEE, PERCO
            </span>
            <span class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-gray-400"></span>
                🏦 <strong>Agrégés</strong> = Comptes courants, Livrets, PEL…
            </span>
        </div>
    </div>

    <!-- Filtres et recherche -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-4 mb-6">
        <form method="GET" action="{{ path('admin_o2s_comptes') }}" class="flex flex-col md:flex-row gap-4">
            <!-- Recherche -->
            <div class="flex-1">
                <div class="relative">
                    <input type="text" 
                           name="search" 
                           value="{{ search }}" 
                           placeholder="Rechercher par nom, client, email..."
                           class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                    <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
            </div>
            
            <!-- Filtre par type -->
            <div class="w-full md:w-48">
                <select name="type" class="w-full py-2.5 px-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                    <option value="">Tous les types</option>
                    {% for type in availableTypes %}
                        <option value="{{ type }}" {{ typeFilter == type ? 'selected' : '' }}>{{ type }}</option>
                    {% endfor %}
                </select>
            </div>
            
            <!-- Boutons -->
            <div class="flex gap-2">
                <button type="submit" class="px-4 py-2.5 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition-colors flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                    Filtrer
                </button>
                {% if search or typeFilter %}
                    <a href="{{ path('admin_o2s_comptes') }}" class="px-4 py-2.5 rounded-xl bg-gray-200 text-gray-700 font-semibold hover:bg-gray-300 transition-colors flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        Effacer
                    </a>
                {% endif %}
            </div>
        </form>
    </div>

    <!-- Liste des comptes -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Client</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Produit</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Valorisation</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date Valeur</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sync</th>
                        <th class="relative px-6 py-3">
                            <span class="sr-only">Actions</span>
                        </th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for product in products %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap">
                            {% if product.user %}
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-semibold text-sm">
                                        {{ product.user.firstName|slice(0,1)|upper }}{{ product.user.lastName|slice(0,1)|upper }}
                                    </div>
                                    <div>
                                        <a href="{{ path('admin_modern_user_view', {id: product.user.id}) }}" class="text-indigo-600 hover:text-indigo-900 font-medium">
                                            {{ product.user.firstName }} {{ product.user.lastName }}
                                        </a>
                                        <div class="text-xs text-gray-500">{{ product.user.email }}</div>
                                    </div>
                                </div>
                            {% else %}
                                <span class="text-gray-400">—</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4">
                            <div class="font-medium text-gray-900">{{ product.displayAlias }}</div>
                            <code class="text-xs text-gray-400">{{ product.o2sCompteId|slice(0,12) }}...</code>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            {% set gereTypes = ['ASSURANCE_VIE', 'PER', 'PEA', 'PEA_PME', 'SCPI', 'COMPTE_TITRES', 'CAPITALISATION', 'DEFISCALISATION', 'MADELIN', 'RETRAITE_ENTREPRISE', 'AUTRE'] %}
                            {% set epargneTypes = ['EPARGNE_SALARIALE', 'PERCO'] %}
                            {% set agregeTypes = ['COMPTE_COURANT', 'LIVRET', 'EPARGNE_LOGEMENT', 'COMPTE_A_TERME'] %}
                            {% if product.productType in gereTypes %}
                                {% set catColor = 'blue' %}
                                {% set catLabel = '💼' %}
                            {% elseif product.productType in epargneTypes %}
                                {% set catColor = 'cyan' %}
                                {% set catLabel = '🏢' %}
                            {% elseif product.productType in agregeTypes %}
                                {% set catColor = 'gray' %}
                                {% set catLabel = '🏦' %}
                            {% else %}
                                {% set catColor = 'blue' %}
                                {% set catLabel = '💼' %}
                            {% endif %}
                            <div class="flex items-center gap-1.5">
                                <span class="text-xs" title="{% if catColor == 'blue' %}Gestion directe{% elseif catColor == 'cyan' %}Épargne salariale{% else %}Agrégé{% endif %}">{{ catLabel }}</span>
                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-{{ catColor }}-100 text-{{ catColor }}-800">
                                    {{ product.productType|replace({'_': ' '})|title }}
                                </span>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right">
                            {% if product.o2sValuation %}
                                <span class="font-bold text-gray-900">{{ product.o2sValuation|number_format(2, ',', ' ') }} €</span>
                            {% else %}
                                <span class="text-gray-400">—</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            {{ product.o2sValuationDate ? product.o2sValuationDate|date('d/m/Y') : '—' }}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            {{ product.o2sSyncedAt ? product.o2sSyncedAt|date('d/m H:i') : '—' }}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <a href="{{ path('admin_o2s_compte_detail', {compteId: product.o2sCompteId}) }}" 
                               class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-900">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                </svg>
                                Détails
                            </a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="px-6 py-12 text-center text-gray-500">
                            {% if search or typeFilter %}
                                <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                                <p class="font-medium">Aucun résultat pour votre recherche</p>
                                <p class="text-sm mt-1">Essayez avec d'autres termes ou effacez les filtres</p>
                            {% else %}
                                Aucun compte O2S synchronisé localement.
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        {% if totalPages > 1 %}
            <div class="px-6 py-4 bg-gray-50 border-t border-gray-200">
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                    <p class="text-sm text-gray-600">
                        Page {{ page }} sur {{ totalPages }} ({{ totalCount }} résultats)
                    </p>
                    <nav class="flex items-center gap-1">
                        {# Première page #}
                        {% if page > 2 %}
                            <a href="{{ path('admin_o2s_comptes', {page: 1, search: search, type: typeFilter}) }}" 
                               class="px-3 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors text-sm">
                                1
                            </a>
                            {% if page > 3 %}
                                <span class="px-2 text-gray-400">...</span>
                            {% endif %}
                        {% endif %}
                        
                        {# Bouton Précédent #}
                        {% if page > 1 %}
                            <a href="{{ path('admin_o2s_comptes', {page: page - 1, search: search, type: typeFilter}) }}" 
                               class="px-3 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                </svg>
                            </a>
                        {% endif %}
                        
                        {# Page courante #}
                        <span class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium">
                            {{ page }}
                        </span>
                        
                        {# Bouton Suivant #}
                        {% if page < totalPages %}
                            <a href="{{ path('admin_o2s_comptes', {page: page + 1, search: search, type: typeFilter}) }}" 
                               class="px-3 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                </svg>
                            </a>
                        {% endif %}
                        
                        {# Dernière page #}
                        {% if page < totalPages - 1 %}
                            {% if page < totalPages - 2 %}
                                <span class="px-2 text-gray-400">...</span>
                            {% endif %}
                            <a href="{{ path('admin_o2s_comptes', {page: totalPages, search: search, type: typeFilter}) }}" 
                               class="px-3 py-2 rounded-lg bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 transition-colors text-sm">
                                {{ totalPages }}
                            </a>
                        {% endif %}
                    </nav>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
