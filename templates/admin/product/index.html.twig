{% extends 'admin_modern/base.html.twig' %}

{% block title %}Produits{% endblock %}
{% block page_title %}📦 Produits{% endblock %}

{% block content %}
<div class="fade-in">
  <!-- Header avec statistiques -->
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6 sm:mb-8">
    <div></div>
    
    <!-- Stats rapides -->
    <div class="flex items-center gap-3 sm:gap-4 w-full sm:w-auto">
      <div class="text-center px-4 py-2 bg-indigo-50 rounded-xl border border-indigo-100">
        <p class="text-xl sm:text-2xl font-bold text-indigo-600">{{ total }}</p>
        <p class="text-xs text-gray-600">Total</p>
      </div>
      <a href="{{ path('admin_products_new') }}" 
         class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-4 sm:px-6 py-2.5 sm:py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold hover-lift shadow-lg hover:shadow-xl transition-all duration-300 text-sm sm:text-base">
        <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        <span class="hidden sm:inline">Nouveau produit</span>
        <span class="sm:hidden">Nouveau</span>
      </a>
    </div>
  </div>

  <!-- Tableau moderne (Desktop/Tablet) -->
  <div class="hidden md:block admin-card overflow-hidden">
    <div class="px-4 sm:px-6 py-4 bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
      <h3 class="text-base sm:text-lg font-semibold text-gray-900">Liste des produits</h3>
      <p class="text-xs sm:text-sm text-gray-600 mt-1">{{ total }} produit{{ total > 1 ? 's' : '' }} — Page {{ page }}/{{ totalPages }}</p>
    </div>
    
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                Client
              </div>
            </th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
                Distributeur
              </div>
            </th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                </svg>
                Type
              </div>
            </th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path>
                </svg>
                Alias
              </div>
            </th>
            <th class="px-6 py-4 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-100">
        {% for p in products %}
          <tr class="hover:bg-gradient-to-r hover:from-blue-50 hover:to-indigo-50 transition-all duration-200 group">
            <td class="px-6 py-4">
              <div class="flex items-center">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-semibold text-sm mr-3">
                  {{ p.user ? p.user.email|slice(0,1)|upper : '?' }}
                </div>
                <div class="text-sm font-medium text-gray-900">
                  {{ p.user ? p.user.email : '—' }}
                </div>
              </div>
            </td>
            <td class="px-6 py-4">
              <div class="text-sm font-semibold text-gray-900">{{ p.distributor }}</div>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gradient-to-r from-green-100 to-emerald-100 text-green-800 border border-green-200">
                {{ p.productType }}
              </span>
            </td>
            <td class="px-6 py-4">
              <div class="text-sm text-gray-600">
                {% if p.displayAlias %}
                  <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-800">
                    {{ p.displayAlias }}
                  </span>
                {% else %}
                  <span class="text-gray-400">—</span>
                {% endif %}
              </div>
            </td>
            <td class="px-6 py-4 text-right">
              <a href="{{ path('admin_products_edit', {id: p.id}) }}" 
                 class="inline-flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium text-indigo-600 hover:text-white hover:bg-gradient-to-r hover:from-indigo-600 hover:to-purple-600 transition-all duration-200 hover:shadow-lg group-hover:scale-105">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Éditer
              </a>
            </td>
          </tr>
        {% else %}
          <tr>
            <td colspan="5" class="px-6 py-12 text-center">
              <div class="flex flex-col items-center justify-center">
                <svg class="w-16 h-16 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                </svg>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Aucun produit</h3>
                <p class="text-gray-500 mb-4">Commencez par créer votre premier produit financier</p>
                <a href="{{ path('admin_products_new') }}" 
                   class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold hover-lift">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                  </svg>
                  Créer un produit
                </a>
              </div>
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  {% if totalPages > 1 %}
  <div class="flex items-center justify-between mt-4 px-4 py-3 bg-white rounded-xl border border-gray-200">
    <div class="text-sm text-gray-600">
      Page {{ page }} sur {{ totalPages }} ({{ total }} produits)
    </div>
    <div class="flex items-center gap-2">
      {% if page > 1 %}
        <a href="{{ path('admin_products_index', {page: page - 1}) }}" 
           class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
          ← Précédent
        </a>
      {% endif %}
      
      {% for p in range(max(1, page - 2), min(totalPages, page + 2)) %}
        {% if p == page %}
          <span class="px-3 py-1.5 text-sm font-bold text-white bg-indigo-600 rounded-lg">{{ p }}</span>
        {% else %}
          <a href="{{ path('admin_products_index', {page: p}) }}" 
             class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
            {{ p }}
          </a>
        {% endif %}
      {% endfor %}
      
      {% if page < totalPages %}
        <a href="{{ path('admin_products_index', {page: page + 1}) }}" 
           class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
          Suivant →
        </a>
      {% endif %}
    </div>
  </div>
  {% endif %}

  <!-- Vue en cartes (Mobile) -->
  <div class="md:hidden space-y-4">
    <div class="flex items-center justify-between mb-4">
      <div>
        <h3 class="text-lg font-semibold text-gray-900">Liste des produits</h3>
        <p class="text-sm text-gray-600 mt-1">{{ total }} produit{{ total > 1 ? 's' : '' }} — Page {{ page }}/{{ totalPages }}</p>
      </div>
    </div>

    {% if products is not empty %}
      {% for p in products %}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-all duration-200">
          <a href="{{ path('admin_products_edit', {id: p.id}) }}" class="block">
            <div class="p-4 sm:p-5">
              <!-- Header de la carte -->
              <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-3 flex-1 min-w-0">
                  <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-semibold text-sm sm:text-base flex-shrink-0">
                    {{ p.user ? p.user.email|slice(0,1)|upper : '?' }}
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="text-sm sm:text-base font-semibold text-gray-900 truncate">
                      {{ p.user ? p.user.email : '—' }}
                    </div>
                    <div class="text-xs sm:text-sm text-gray-500 mt-0.5">
                      {{ p.distributor }}
                    </div>
                  </div>
                </div>
                <div class="flex-shrink-0 ml-2">
                  <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </div>
              </div>

              <!-- Informations du produit -->
              <div class="grid grid-cols-2 gap-3 pt-4 border-t border-gray-100">
                <div>
                  <div class="text-xs text-gray-500 mb-1">Type</div>
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-gradient-to-r from-green-100 to-emerald-100 text-green-800 border border-green-200">
                    {{ p.productType }}
                  </span>
                </div>
                <div>
                  <div class="text-xs text-gray-500 mb-1">Alias</div>
                  <div class="text-sm font-medium text-gray-900">
                    {% if p.displayAlias %}
                      <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-800">
                        {{ p.displayAlias }}
                      </span>
                    {% else %}
                      <span class="text-gray-400">—</span>
                    {% endif %}
                  </div>
                </div>
              </div>

              <!-- Bouton d'action -->
              <div class="mt-4 pt-4 border-t border-gray-100">
                <div class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                  Éditer le produit
                </div>
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    {% else %}
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 sm:p-12 text-center">
        <div class="flex flex-col items-center justify-center">
          <div class="w-16 h-16 sm:w-20 sm:h-20 bg-gray-100 rounded-2xl flex items-center justify-center mb-4">
            <svg class="w-8 h-8 sm:w-10 sm:h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-2">Aucun produit</h3>
          <p class="text-sm sm:text-base text-gray-500 mb-6">Commencez par créer votre premier produit financier</p>
          <a href="{{ path('admin_products_new') }}" 
             class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold hover-lift shadow-lg hover:shadow-xl transition-all duration-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Créer un produit
          </a>
        </div>
      </div>
    {% endif %}

    {% if totalPages > 1 %}
    <div class="flex items-center justify-between mt-4 px-4 py-3 bg-white rounded-xl border border-gray-200">
      <div class="text-sm text-gray-600">
        {{ page }}/{{ totalPages }}
      </div>
      <div class="flex items-center gap-2">
        {% if page > 1 %}
          <a href="{{ path('admin_products_index', {page: page - 1}) }}" 
             class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">←</a>
        {% endif %}
        {% if page < totalPages %}
          <a href="{{ path('admin_products_index', {page: page + 1}) }}" 
             class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200">→</a>
        {% endif %}
      </div>
    </div>
    {% endif %}
  </div>
</div>

<style>
/* Améliorations responsive pour le tableau desktop/tablet */
@media (max-width: 1024px) {
  .admin-card table th,
  .admin-card table td {
    padding: 0.75rem 0.5rem !important;
    font-size: 0.875rem;
  }
  
  .admin-card table th:last-child,
  .admin-card table td:last-child {
    padding-right: 1rem !important;
  }
}

/* Masquer certaines colonnes sur tablette */
@media (max-width: 768px) and (min-width: 640px) {
  .admin-card table th:nth-child(4),
  .admin-card table td:nth-child(4) {
    display: none;
  }
}

/* Améliorations pour les cartes mobiles */
@media (max-width: 640px) {
  .admin-card {
    margin: 0 -1rem;
    border-radius: 0;
  }
  
  /* Espacement réduit sur mobile */
  .space-y-4 > * + * {
    margin-top: 0.75rem;
  }
}
</style>
{% endblock %}



