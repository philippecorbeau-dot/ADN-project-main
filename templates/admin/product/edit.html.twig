{% extends 'admin_modern/base.html.twig' %}

{% block title %}Éditer produit{% endblock %}
{% block page_title %}✏️ Éditer produit{% endblock %}

{% block content %}
<div class="fade-in">
  <!-- Header minimal -->
  <div class="flex items-center justify-between mb-4">
    <nav class="flex items-center space-x-2 text-sm text-gray-500">
      <a href="{{ path('admin_products_index') }}" class="hover:text-indigo-600 transition-colors">
        <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Retour aux produits
      </a>
    </nav>
  </div>

  <div class="space-y-8">
    <!-- Formulaire principal -->
    <div class="admin-card p-6 md:p-8 shadow-lg border border-gray-200 rounded-2xl bg-white">
      <div class="mb-6 pb-4 border-b border-gray-200">
        <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-3">
          <div class="w-10 h-10 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          Informations du produit
        </h2>
      </div>

        {{ form_start(form, {attr: {class: 'space-y-8'}}) }}
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Colonne gauche -->
            <div class="space-y-6">
              <div class="form-group">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                  <label class="text-sm font-semibold text-gray-700">Client associé</label>
                </div>
                <div class="space-y-2">
                  <div class="relative" id="userCombobox">
                    <button type="button" id="userSelectToggle" class="w-full px-4 py-3 border border-gray-200 rounded-lg bg-white flex items-center justify-between focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                      <span id="userSelectLabel" class="truncate text-gray-700">Sélectionner un client…</span>
                      <svg class="w-4 h-4 text-gray-400 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div id="userSelectDropdown" class="absolute left-0 right-0 mt-1 bg-white border border-gray-200 rounded-lg shadow-lg z-30 hidden">
                      <div class="p-2 border-b border-gray-100">
                        <input id="userSelectSearch" type="text" class="w-full px-3 py-2 border border-gray-200 rounded-md focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" placeholder="Rechercher par nom ou e‑mail…" />
                      </div>
                      <ul id="userSelectOptions" class="max-h-64 overflow-auto py-1"></ul>
                      <div id="userSelectEmpty" class="py-6 text-sm text-gray-500 text-center hidden">
                        <svg class="mx-auto h-8 w-8 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        Aucun client trouvé
                      </div>
                    </div>
                  </div>
                  {{ form_widget(form.user, {id: 'userSelect', attr: {class: 'hidden'}}) }}
                </div>
              </div>

              <div class="form-group">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                  </svg>
                  <label class="text-sm font-semibold text-gray-700">Type de produit</label>
                </div>
                {{ form_widget(form.productType, {id: 'productTypeSelect', attr: {class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all bg-white'}}) }}
                <div id="productTypeOtherWrap" class="mt-3 hidden">
                  <div class="bg-blue-50 border border-blue-200 rounded-lg p-3">
                    <label class="block text-sm font-medium text-blue-900 mb-2">Nouveau type de produit</label>
                    {{ form_widget(form.productTypeOther, {attr: {placeholder: 'Saisir un nouveau type…', class:'w-full px-3 py-2 border border-blue-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white'}}) }}
                    <p class="text-xs text-blue-700 mt-1">Ce nouveau type sera ajouté à la liste</p>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                  </svg>
                  <label class="text-sm font-semibold text-gray-700">Distributeur</label>
                </div>
                {{ form_widget(form.distributor, {id: 'distributorSelect', attr: {class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all bg-white'}}) }}
                <div id="distributorOtherWrap" class="mt-3 hidden">
                  <div class="bg-green-50 border border-green-200 rounded-lg p-3">
                    <label class="block text-sm font-medium text-green-900 mb-2">Nouveau distributeur</label>
                    {{ form_widget(form.distributorOther, {attr: {placeholder: 'Ajouter un nouveau distributeur…', class:'w-full px-3 py-2 border border-green-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 bg-white'}}) }}
                    <p class="text-xs text-green-700 mt-1">Ce nouveau distributeur sera ajouté à la liste</p>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"></path>
                  </svg>
                  <label class="text-sm font-semibold text-gray-700">Alias d'affichage <span class="text-gray-400 font-normal">(optionnel)</span></label>
                </div>
                {{ form_widget(form.displayAlias, {attr: {class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all', placeholder: 'Ex: 990'}}) }}
              </div>
            </div>

            <!-- Colonne droite -->
            <div class="space-y-6">
              <div class="form-group">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                  </svg>
                  <label class="text-sm font-semibold text-gray-700">Fonds Euro <span class="text-gray-400 font-normal">(si Assurance-vie / PER)</span></label>
                </div>
                {{ form_widget(form.euroFund, {attr: {class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all'}}) }}
              </div>

              <div class="form-group">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <label class="text-sm font-semibold text-gray-700">Fiscalité datée</label>
                </div>
                {{ form_widget(form.fiscalDate, {attr: {class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all'}}) }}
              </div>

              <div class="form-group">
                <div class="flex items-center gap-2 mb-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
                  </svg>
                  <label class="text-sm font-semibold text-gray-700">Montant initial</label>
                </div>
                {{ form_widget(form.initialAmount, {attr: {class: 'w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all', placeholder: '100000.00'}}) }}
              </div>

              <!-- Versements additionnels -->
              <div class="form-group">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    <label class="text-sm font-semibold text-gray-700">Versements additionnels</label>
                  </div>
                  <div class="flex items-center gap-2">
                    <button type="button" id="contribAddBtn" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded-md bg-indigo-50 text-indigo-700 hover:bg-indigo-100">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                      Ajouter
                    </button>
                    <button type="button" id="contribRemoveBtn" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs rounded-md bg-rose-50 text-rose-700 hover:bg-rose-100">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" /></svg>
                      Retirer
                    </button>
                  </div>
                </div>
                <div id="contrib-collection"
                     class="space-y-3"
                     data-prototype="{{ form_widget(form.contributions.vars.prototype)|e('html_attr') }}"
                     data-widget-counter="{{ form.contributions.children|length }}">
                  {% for c in form.contributions %}
                    <div class="p-3 border border-gray-200 rounded-lg bg-white contrib-item">{{ form_widget(c) }}</div>
                  {% endfor %}
                </div>
                <p class="text-xs text-gray-500 mt-2">Ajoutez des versements complémentaires. Ils s'ajouteront automatiquement au montant initial.</p>
              </div>

              <!-- Total investi -->
              <div class="bg-gray-50 border border-gray-200 rounded-lg p-3">
                <div class="flex items-center justify-between">
                  <span class="text-sm font-medium text-gray-700">Total investi (calculé)</span>
                  <span id="totalInvestedDisplay" class="text-sm font-semibold text-gray-900">
                    {{ product.getTotalInvested()|number_format(2, ',', ' ') }} €
                  </span>
                </div>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-4 pt-8 mt-8 border-t border-gray-200">
            <a href="{{ path('admin_products_index') }}" 
               class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-gray-700 hover:text-gray-900 hover:bg-gray-100 transition-all border border-gray-300 font-medium">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
              Annuler
            </a>
            <button type="submit" class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold hover:from-indigo-700 hover:to-purple-700 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Enregistrer les modifications
            </button>
          </div>
        {{ form_end(form) }}
      </div>

      {# ─── SUPPORTS O2S (depuis Harvest) ─── #}
      {% if isO2S is defined and isO2S %}
      <div class="admin-card p-6 md:p-8 shadow-lg border border-orange-200 rounded-2xl bg-white mb-8" id="o2s-supports-section">
        <div class="mb-6 pb-4 border-b border-orange-200">
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <h3 class="text-2xl font-bold text-gray-900 flex items-center gap-3">
              <div class="w-10 h-10 bg-gradient-to-br from-orange-500 to-amber-600 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/>
                </svg>
              </div>
              Supports O2S / Harvest
            </h3>
            <div class="flex items-center gap-3">
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-orange-50 text-orange-700 rounded-lg text-xs font-medium border border-orange-200">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Compte O2S : {{ product.o2sCompteId }}
              </span>
              {% if o2sSupports|length > 0 %}
              <button type="button" id="importO2sBtn"
                      class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-orange-500 to-amber-500 text-white hover:from-orange-600 hover:to-amber-600 transition-all font-medium shadow-sm hover:shadow-md">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                Importer dans notre base
              </button>
              {% endif %}
            </div>
          </div>
        </div>

        {% if o2sError is defined and o2sError %}
          <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
              </svg>
              <span class="font-semibold">Erreur API O2S</span>
            </div>
            <p>{{ o2sError }}</p>
          </div>
        {% elseif o2sSupports|length > 0 %}
          <div class="mb-4 flex items-center gap-3 px-4 py-3 bg-gradient-to-r from-orange-50 to-amber-50 rounded-xl border border-orange-100">
            <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <div>
              <span class="text-sm font-semibold text-gray-900">{{ o2sSupports|length }}</span>
              <span class="text-sm text-gray-600 ml-1">support{{ o2sSupports|length > 1 ? 's' : '' }} trouvé{{ o2sSupports|length > 1 ? 's' : '' }} sur Harvest</span>
            </div>
          </div>

          <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gradient-to-r from-orange-50 to-amber-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">ISIN</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Libellé</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Type</th>
                  <th class="px-4 py-3 text-right text-xs font-bold text-gray-700 uppercase tracking-wider">Nb parts</th>
                  <th class="px-4 py-3 text-right text-xs font-bold text-gray-700 uppercase tracking-wider">Cours (€)</th>
                  <th class="px-4 py-3 text-right text-xs font-bold text-gray-700 uppercase tracking-wider">Prix moyen</th>
                  <th class="px-4 py-3 text-right text-xs font-bold text-gray-700 uppercase tracking-wider">Évaluation (€)</th>
                  <th class="px-4 py-3 text-right text-xs font-bold text-gray-700 uppercase tracking-wider">%</th>
                  <th class="px-4 py-3 text-right text-xs font-bold text-gray-700 uppercase tracking-wider">+/- value (€)</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-100">
                {% set totalO2sValue = 0 %}
                {% for s in o2sSupports %}
                  {% set totalO2sValue = totalO2sValue + (s.value ?? 0) %}
                  <tr class="hover:bg-orange-50/50 transition-all">
                    <td class="px-4 py-3 text-xs font-mono text-gray-500">{{ s.isin ?? '--' }}</td>
                    <td class="px-4 py-3">
                      <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-100 to-amber-100 flex items-center justify-center text-xs font-bold text-orange-700">
                          {{ s.name|slice(0, 2)|upper }}
                        </div>
                        <div>
                          <p class="text-sm font-semibold text-gray-900">{{ s.name }}</p>
                          {% if s.netAssetValueDate %}
                          <p class="text-xs text-gray-500">VL au {{ s.netAssetValueDate }}</p>
                          {% endif %}
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-3">
                      {% if s.assetType %}
                      <span class="inline-flex px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs">{{ s.assetType }}</span>
                      {% else %}
                      <span class="text-gray-300">--</span>
                      {% endif %}
                    </td>
                    <td class="px-4 py-3 text-right text-sm font-medium text-gray-900 tabular-nums">
                      {{ s.quantity is not null ? s.quantity|number_format(2, ',', ' ') : '--' }}
                    </td>
                    <td class="px-4 py-3 text-right text-sm font-medium text-gray-900 tabular-nums">
                      {{ s.netAssetValue is not null ? s.netAssetValue|number_format(4, ',', ' ') : '--' }}
                    </td>
                    <td class="px-4 py-3 text-right text-sm text-gray-700 tabular-nums">
                      {% if s.averageBuyPrice is not null %}
                        {{ s.averageBuyPrice|number_format(2, ',', ' ') }}
                        {% if s.averageBuyPriceDate %}
                        <br><span class="text-xs text-gray-400">{{ s.averageBuyPriceDate }}</span>
                        {% endif %}
                      {% else %}
                        <span class="text-gray-300">--</span>
                      {% endif %}
                    </td>
                    <td class="px-4 py-3 text-right text-sm font-bold text-gray-900 tabular-nums">
                      {{ s.value is not null ? s.value|number_format(2, ',', ' ') ~ ' €' : '--' }}
                    </td>
                    <td class="px-4 py-3 text-right text-sm text-gray-700 tabular-nums">
                      {{ s.percentage is not null ? s.percentage|number_format(2, ',', ' ') ~ '%' : '--' }}
                    </td>
                    <td class="px-4 py-3 text-right text-sm tabular-nums">
                      {% if s.gainLoss is not null %}
                        <span class="{{ s.gainLoss >= 0 ? 'text-emerald-600' : 'text-red-600' }} font-semibold">
                          {{ s.gainLoss >= 0 ? '+' : '' }}{{ s.gainLoss|number_format(2, ',', ' ') }}
                        </span>
                        {% if s.gainLossPercent is not null %}
                        <br><span class="text-xs {{ s.gainLossPercent >= 0 ? 'text-emerald-500' : 'text-red-500' }}">
                          ({{ s.gainLossPercent >= 0 ? '+' : '' }}{{ s.gainLossPercent|number_format(2, ',', ' ') }}%)
                        </span>
                        {% endif %}
                      {% else %}
                        <span class="text-gray-300">--</span>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
              <tfoot>
                <tr class="bg-gradient-to-r from-orange-50 to-amber-50 border-t-2 border-orange-200">
                  <td class="px-4 py-3 text-sm font-bold text-gray-900" colspan="6">Total des supports O2S</td>
                  <td class="px-4 py-3 text-right font-bold text-gray-900 text-sm tabular-nums">{{ totalO2sValue|number_format(2, ',', ' ') }} €</td>
                  <td class="px-4 py-3 text-right font-bold text-gray-900 text-sm">100,00%</td>
                  <td class="px-4 py-3"></td>
                </tr>
              </tfoot>
            </table>
          </div>

          <div id="importO2sResult" class="mt-4 hidden"></div>
        {% else %}
          <div class="p-8 text-center">
            <div class="w-14 h-14 bg-orange-50 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
              </svg>
            </div>
            <p class="text-gray-700 font-semibold mb-1">Aucun support trouvé dans O2S</p>
            <p class="text-gray-500 text-sm">L'API O2S n'a retourné aucune ligne de support pour ce compte.</p>
          </div>
        {% endif %}
      </div>
      {% endif %}

      <!-- Supports liés (base locale) -->
      <div class="admin-card p-6 md:p-8 shadow-lg border border-gray-200 rounded-2xl bg-white">
        <div class="mb-6 pb-4 border-b border-gray-200">
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <h3 class="text-2xl font-bold text-gray-900 flex items-center gap-3">
              <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              </div>
              Supports liés (base locale)
            </h3>
            <a href="{{ path('admin_support_search_index', {product: product.id}) }}" 
               class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-indigo-50 to-purple-50 text-indigo-700 hover:from-indigo-100 hover:to-purple-100 transition-all font-medium shadow-sm hover:shadow-md">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              Rechercher un support
            </a>
          </div>
        </div>

        {% if holdings is not empty %}
          <div class="mb-6 flex items-center gap-3 px-4 py-3 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl border border-blue-100">
            <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
              </svg>
            </div>
            <div>
              <span class="holding-count text-sm font-semibold text-gray-900">{{ holdings|length }}</span>
              <span class="holding-count-text text-sm text-gray-600 ml-1">support{{ holdings|length > 1 ? 's' : '' }} associé{{ holdings|length > 1 ? 's' : '' }}</span>
            </div>
          </div>
        {% endif %}

        <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gradient-to-r from-gray-50 to-gray-100">
              <tr>
                <th class="px-4 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Nom</th>
                <th class="px-4 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Symbole</th>
                <th class="px-4 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Exchange</th>
                <th class="px-4 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Cours</th>
                <th class="px-4 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Date cours</th>
                <th class="px-4 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Nb parts</th>
                <th class="px-4 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">Montant</th>
                <th class="px-4 py-4 text-right text-xs font-bold text-gray-700 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-100" id="holdingsTableBody">
            {% for h in holdings %}
              <tr class="holding-row hover:bg-gradient-to-r hover:from-blue-50/50 hover:to-indigo-50/50 transition-all duration-200 group" data-holding-id="{{ h.id }}">
                <td class="px-4 py-4">
                  <div class="text-sm font-semibold text-gray-900">{{ h.instrument.name }}</div>
                </td>
                <td class="px-4 py-4">
                  <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-bold bg-gradient-to-r from-blue-100 to-indigo-100 text-blue-800 border border-blue-200">
                    {{ h.instrument.symbol }}
                  </span>
                </td>
                <td class="px-4 py-4">
                  <div class="text-sm font-medium text-gray-700">{{ h.instrument.exchange }}</div>
                </td>
                <td class="px-4 py-4">
                  <input type="number" 
                         step="0.000001" 
                         value="{{ h.lastPrice ?? '' }}" 
                         data-field="lastPrice"
                         class="holding-input w-full min-w-[100px] px-3 py-2 text-sm border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all bg-white hover:border-gray-300"
                         placeholder="0.00">
                </td>
                <td class="px-4 py-4">
                  <input type="date" 
                         value="{{ h.lastPriceDate ? h.lastPriceDate|date('Y-m-d') : '' }}" 
                         data-field="lastPriceDate"
                         class="holding-input w-full min-w-[140px] px-3 py-2 text-sm border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all bg-white hover:border-gray-300">
                </td>
                <td class="px-4 py-4">
                  <input type="number" 
                         step="0.000001" 
                         value="{{ h.units ?? '' }}" 
                         data-field="units"
                         class="holding-input w-full min-w-[100px] px-3 py-2 text-sm border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all bg-white hover:border-gray-300"
                         placeholder="0.00">
                </td>
                <td class="px-4 py-4">
                  <span class="holding-amount text-sm font-bold text-gray-900 bg-gray-50 px-3 py-2 rounded-lg inline-block min-w-[100px]">
                    {% if h.amount %}
                      {{ h.amount|number_format(2, ',', ' ') }} €
                    {% elseif h.lastPrice and h.units %}
                      {% set amount = h.lastPrice * h.units %}
                      {{ amount|number_format(2, ',', ' ') }} €
                    {% else %}
                      —
                    {% endif %}
                  </span>
                </td>
                <td class="px-4 py-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <button type="button" 
                            class="holding-save-btn inline-flex items-center justify-center w-8 h-8 rounded-lg text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 border-0 opacity-0 group-hover:opacity-100 transition-all duration-200 shadow-sm hover:shadow-md"
                            data-holding-id="{{ h.id }}"
                            title="Enregistrer les modifications">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                    </button>
                    <button type="button" 
                            class="holding-delete-btn inline-flex items-center justify-center w-8 h-8 rounded-lg text-sm font-medium text-white bg-red-500 hover:bg-red-600 border-0 transition-all shadow-sm hover:shadow-md"
                            data-holding-id="{{ h.id }}"
                            data-product-id="{{ product.id }}"
                            data-instrument-name="{{ h.instrument.name }}"
                            title="Supprimer">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                  </div>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="8" class="px-8 py-12 text-center">
                  <div class="flex flex-col items-center justify-center">
                    <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-4">
                      <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                      </svg>
                    </div>
                    <p class="text-gray-700 font-semibold text-base mb-1">Aucun support lié</p>
                    <p class="text-gray-500 text-sm">Les supports seront affichés ici une fois associés</p>
                    <a href="{{ path('admin_support_search_index', {product: product.id}) }}" 
                       class="mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 transition-all text-sm font-medium">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                      </svg>
                      Ajouter un support
                    </a>
                  </div>
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function(){
  var typeSelect = document.getElementById('productTypeSelect') || document.querySelector('[name="'+ ({{ form.productType.vars.full_name|json_encode|raw }}) +'"]');
  var typeWrap = document.getElementById('productTypeOtherWrap');
  var distSelect = document.getElementById('distributorSelect') || document.querySelector('[name="'+ ({{ form.distributor.vars.full_name|json_encode|raw }}) +'"]');
  var distWrap = document.getElementById('distributorOtherWrap');
  var userSelect = document.getElementById('userSelect') || document.querySelector('[name="'+ ({{ form.user.vars.full_name|json_encode|raw }}) +'"]');
  var userToggle = document.getElementById('userSelectToggle');
  var userDropdown = document.getElementById('userSelectDropdown');
  var userLabel = document.getElementById('userSelectLabel');
  var userSearch = document.getElementById('userSelectSearch');
  var userOptions = document.getElementById('userSelectOptions');
  var userEmpty = document.getElementById('userSelectEmpty');

  function toggleOther(select, wrap){
    if (!select || !wrap) return;
    var val = (select.value || '').toString().toUpperCase();
    wrap.classList.toggle('hidden', val !== 'OTHER');
  }
  toggleOther(typeSelect, typeWrap);
  toggleOther(distSelect, distWrap);
  if (typeSelect) typeSelect.addEventListener('change', function(){ toggleOther(typeSelect, typeWrap); });
  if (distSelect) distSelect.addEventListener('change', function(){ toggleOther(distSelect, distWrap); });

  function openDropdown() { if (userDropdown) { userDropdown.classList.remove('hidden'); if (userSearch) userSearch.focus(); } }
  function closeDropdown() { if (userDropdown) { userDropdown.classList.add('hidden'); } }
  function ensureOption(select, value, label){
    if (!select) return null;
    var found = Array.prototype.slice.call(select.options || []).find(function(o){ return o.value == value; });
    if (!found) { found = document.createElement('option'); found.value = value; found.text = label || value; select.appendChild(found); }
    return found;
  }
  function formatUserLabel(raw){
    if (!raw) return '';
    var m = raw.match(/^(.*?)\s*[<\(\[]\s*([^>\)\]]+@[^>\)\]]+)\s*[>\)\]]\s*$/);
    if (m) { var name=(m[1]||'').trim(); var email=(m[2]||'').trim(); return (name?name+' — ':'')+email; }
    return raw;
  }
  function setUserSelection(id, label){
    if (!userSelect) return;
    ensureOption(userSelect, id, label);
    userSelect.value = id;
    var idx = Array.prototype.slice.call(userSelect.options).findIndex(function(o){ return o.value == id; });
    if (idx >= 0) userSelect.selectedIndex = idx;
    userSelect.dispatchEvent(new Event('change', {bubbles:true}));
    if (userLabel && label) userLabel.textContent = formatUserLabel(label);
    closeDropdown();
  }
  function renderUserOptions(list){
    if (!userOptions || !userEmpty) return;
    userOptions.innerHTML='';
    if (!list || list.length===0){ userEmpty.classList.remove('hidden'); return; }
    userEmpty.classList.add('hidden');
    list.forEach(function(item){
      var li = document.createElement('li');
      li.className = 'px-3 py-2 hover:bg-gray-50 cursor-pointer flex items-center justify-between transition-colors';
      li.dataset.id = item.id; li.dataset.label = item.label;
      li.innerHTML = '<span class="truncate">' + (function(t){var d=document.createElement('div'); d.textContent=t; return d.innerHTML;})(formatUserLabel(item.label)) + '</span>' + '<span class="ml-3 text-xs text-gray-500">#' + item.id + '</span>';
      li.addEventListener('mousedown', function(e){ e.preventDefault(); });
      li.addEventListener('click', function(e){ e.preventDefault(); e.stopPropagation(); setUserSelection(item.id, item.label); });
      li.setAttribute('tabindex','0');
      li.addEventListener('keydown', function(e){ if (e.key==='Enter'){ e.preventDefault(); setUserSelection(item.id, item.label); } });
      userOptions.appendChild(li);
    });
  }
  function runUserAjax(){
    if (!userSearch) return;
    var q = userSearch.value.trim();
    fetch('{{ path('admin_users_search') }}?q=' + encodeURIComponent(q), {credentials:'same-origin', headers:{'Accept':'application/json'}})
      .then(function(r){ if(!r.ok) throw new Error('Network'); return r.json(); })
      .then(function(list){ renderUserOptions(list); })
      .catch(function(){ renderUserOptions([]); });
  }
  if (userToggle) { userToggle.addEventListener('click', function(e){ e.preventDefault(); e.stopPropagation(); if (!userDropdown || userDropdown.classList.contains('hidden')) openDropdown(); else closeDropdown(); }); }
  if (userSearch) {
    var pendingTimer=null;
    userSearch.addEventListener('input', function(){ clearTimeout(pendingTimer); pendingTimer = setTimeout(runUserAjax, 300); });
    userSearch.addEventListener('keydown', function(e){ if (e.key==='Escape'){ closeDropdown(); return; } if (e.key==='ArrowDown'){ e.preventDefault(); var first=userOptions && userOptions.querySelector('li'); if (first) first.focus(); } if (e.key==='Enter'){ var firstLi=userOptions && userOptions.querySelector('li'); if (firstLi) firstLi.click(); }});
  }
  document.addEventListener('click', function(e){ var root=document.getElementById('userCombobox'); if (!root) return; if (!root.contains(e.target)) closeDropdown(); });
  if (userSelect && userLabel) { var current=userSelect.options && userSelect.options[userSelect.selectedIndex]; if (current && current.text && current.value) { userLabel.textContent = current.text; } userSelect.addEventListener('change', function(){ var opt=userSelect.options && userSelect.options[userSelect.selectedIndex]; if (opt && opt.text) userLabel.textContent = opt.text; }); }

  // Gestion collection des versements + total investi dynamique
  (function(){
    var container = document.getElementById('contrib-collection');
    var addBtn = document.getElementById('contribAddBtn');
    var removeBtn = document.getElementById('contribRemoveBtn');
    var totalEl = document.getElementById('totalInvestedDisplay');
    var initialInput = document.querySelector('[name="{{ form.initialAmount.vars.full_name }}"]');
    var euroInput = document.querySelector('[name="{{ form.euroFund.vars.full_name }}"]');

    function parseMoney(v){
      try{
        if (typeof v !== 'string') v = String(v || '');
        v = v.replace(/\s/g,'').replace(',', '.');
        return parseFloat(v) || 0;
      }catch(e){ return 0; }
    }

    function formatEUR(n){
      try{ return n.toLocaleString('fr-FR', { style:'currency', currency:'EUR' }); }catch(e){ return (Math.round(n*100)/100).toString() + ' €'; }
    }

    function recalc(){
      var total = parseMoney(initialInput ? initialInput.value : 0);
      total += parseMoney(euroInput ? euroInput.value : 0);
      if (container){
        var amounts = container.querySelectorAll('input[name$="[amount]"]');
        amounts.forEach(function(inp){ total += parseMoney(inp.value); });
      }
      if (totalEl){ totalEl.textContent = formatEUR(total); }
    }

    function bindRow(row){
      if (!row) return;
      var inputs = row.querySelectorAll('input');
      inputs.forEach(function(inp){ inp.addEventListener('input', recalc); });
    }

    if (container){
      Array.prototype.forEach.call(container.querySelectorAll('.contrib-item'), bindRow);
    }
    if (initialInput){ initialInput.addEventListener('input', recalc); }
    if (euroInput){ euroInput.addEventListener('input', recalc); }
    recalc();

    function addItem(){
      if (!container) return;
      var counter = parseInt(container.getAttribute('data-widget-counter') || '0', 10);
      var proto = container.getAttribute('data-prototype') || '';
      var html = proto.replace(/__name__/g, String(counter));
      var wrapper = document.createElement('div');
      wrapper.className = 'p-3 border border-gray-200 rounded-lg bg-white contrib-item';
      wrapper.innerHTML = html;
      container.appendChild(wrapper);
      container.setAttribute('data-widget-counter', String(counter + 1));
      bindRow(wrapper);
      recalc();
    }
    function removeItem(){
      if (!container) return;
      var nodes = container.querySelectorAll('.contrib-item');
      if (nodes.length > 0){
        container.removeChild(nodes[nodes.length - 1]);
        var counter = Math.max(0, parseInt(container.getAttribute('data-widget-counter') || '1', 10) - 1);
        container.setAttribute('data-widget-counter', String(counter));
        recalc();
      }
    }
    if (addBtn) addBtn.addEventListener('click', addItem);
    if (removeBtn) removeBtn.addEventListener('click', removeItem);
  })();

  // Gestion des modifications des holdings
  (function(){
    var tableBody = document.getElementById('holdingsTableBody');
    if (!tableBody) return;

    var saveButtons = tableBody.querySelectorAll('.holding-save-btn');
    var inputs = tableBody.querySelectorAll('.holding-input');
    var changedRows = new Set();

    function updateAmount(row) {
      var priceInput = row.querySelector('input[data-field="lastPrice"]');
      var unitsInput = row.querySelector('input[data-field="units"]');
      var amountCell = row.querySelector('.holding-amount');
      
      if (!priceInput || !unitsInput || !amountCell) return;
      
      var price = parseFloat(priceInput.value) || 0;
      var units = parseFloat(unitsInput.value) || 0;
      var amount = price * units;
      
      if (amount > 0) {
        amountCell.textContent = amount.toLocaleString('fr-FR', { 
          minimumFractionDigits: 2, 
          maximumFractionDigits: 2 
        }) + ' €';
      } else {
        amountCell.textContent = '—';
      }
    }

    function showSaveButton(row) {
      var saveBtn = row.querySelector('.holding-save-btn');
      if (saveBtn) {
        saveBtn.classList.remove('opacity-0');
        row.classList.add('changed');
        changedRows.add(row);
      }
    }

    function hideSaveButton(row) {
      var saveBtn = row.querySelector('.holding-save-btn');
      if (saveBtn) {
        saveBtn.classList.add('opacity-0');
        row.classList.remove('changed');
        changedRows.delete(row);
      }
    }

    inputs.forEach(function(input) {
      var row = input.closest('.holding-row');
      if (!row) return;

      input.addEventListener('input', function() {
        updateAmount(row);
        showSaveButton(row);
      });

      input.addEventListener('change', function() {
        updateAmount(row);
      });
    });

    saveButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var holdingId = btn.getAttribute('data-holding-id');
        var row = btn.closest('.holding-row');
        if (!row || !holdingId) return;

        var data = {
          lastPrice: null,
          lastPriceDate: null,
          units: null
        };

        var priceInput = row.querySelector('input[data-field="lastPrice"]');
        var dateInput = row.querySelector('input[data-field="lastPriceDate"]');
        var unitsInput = row.querySelector('input[data-field="units"]');

        if (priceInput && priceInput.value) {
          data.lastPrice = priceInput.value;
        }
        if (dateInput && dateInput.value) {
          data.lastPriceDate = dateInput.value;
        }
        if (unitsInput && unitsInput.value) {
          data.units = unitsInput.value;
        }

        btn.disabled = true;
        btn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>';

        var updateUrl = '{{ path('admin_products_update_holding', {holdingId: '__ID__'}) }}'.replace('__ID__', holdingId);
        fetch(updateUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify(data)
        })
        .then(function(response) {
          if (!response.ok) throw new Error('Erreur réseau');
          return response.json();
        })
        .then(function(result) {
          if (result.success) {
            hideSaveButton(row);
            btn.innerHTML = '<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
            setTimeout(function() {
              btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
              btn.disabled = false;
            }, 2000);
          } else {
            throw new Error(result.error || 'Erreur lors de la sauvegarde');
          }
        })
        .catch(function(error) {
          console.error('Erreur:', error);
          alert('Erreur lors de la sauvegarde: ' + error.message);
          btn.disabled = false;
          btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
        });
      });
    });

    // Afficher le bouton de sauvegarde au survol de la ligne
    tableBody.querySelectorAll('.holding-row').forEach(function(row) {
      row.addEventListener('mouseenter', function() {
        if (changedRows.has(row)) {
          var saveBtn = row.querySelector('.holding-save-btn');
          if (saveBtn) saveBtn.classList.remove('opacity-0');
        }
      });
    });

    // ─── Import O2S supports ───
    (function(){
      var importBtn = document.getElementById('importO2sBtn');
      var resultDiv = document.getElementById('importO2sResult');
      if (!importBtn) return;

      importBtn.addEventListener('click', function(){
        if (!confirm('Importer les supports depuis O2S/Harvest ? Les supports existants seront mis à jour.')) return;
        
        importBtn.disabled = true;
        importBtn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke-width="4" stroke-dasharray="31.42 31.42" stroke-dashoffset="0"/></svg> Import en cours…';

        var formData = new FormData();
        formData.append('_token', '{{ csrf_token('import_o2s') }}');

        fetch('{{ path('admin_products_import_o2s', {id: product.id}) }}', {
          method: 'POST',
          credentials: 'same-origin',
          body: formData
        })
        .then(function(r){ return r.json(); })
        .then(function(data){
          if (data.success) {
            if (resultDiv) {
              resultDiv.classList.remove('hidden');
              resultDiv.innerHTML = '<div class="p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 text-sm flex items-center gap-2">' +
                '<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>' +
                '<span><strong>Import réussi !</strong> ' + data.message + ' La page va se recharger…</span></div>';
            }
            setTimeout(function(){ window.location.reload(); }, 1500);
          } else {
            throw new Error(data.error || 'Erreur inconnue');
          }
        })
        .catch(function(err){
          if (resultDiv) {
            resultDiv.classList.remove('hidden');
            resultDiv.innerHTML = '<div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">' +
              '<strong>Erreur :</strong> ' + err.message + '</div>';
          }
          importBtn.disabled = false;
          importBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg> Importer dans notre base';
        });
      });
    })();

    // Gestion de la suppression des holdings
    var deleteButtons = tableBody.querySelectorAll('.holding-delete-btn');
    deleteButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var holdingId = btn.getAttribute('data-holding-id');
        var productId = btn.getAttribute('data-product-id');
        var instrumentName = btn.getAttribute('data-instrument-name') || 'ce support';
        
        if (!confirm('Êtes-vous sûr de vouloir supprimer "' + instrumentName + '" ?')) {
          return;
        }

        btn.disabled = true;
        btn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>';

        var deleteUrl = '{{ path('admin_products_remove_holding', {productId: '__PRODUCT_ID__', holdingId: '__HOLDING_ID__'}) }}'
          .replace('__PRODUCT_ID__', productId)
          .replace('__HOLDING_ID__', holdingId);

        fetch(deleteUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: '_token=' + encodeURIComponent('{{ csrf_token('remove_holding') }}') + '&ajax=1'
        })
        .then(function(response) {
          if (!response.ok) throw new Error('Erreur réseau');
          return response.json();
        })
        .then(function(result) {
          if (result.success) {
            // Afficher le toast de succès
            if (window.toast && window.toast.success) {
              window.toast.success('Support supprimé avec succès');
            } else if (window.showToast) {
              window.showToast('Support supprimé avec succès', 'success');
            }

            // Supprimer la ligne du tableau
            var row = btn.closest('.holding-row');
            if (row) {
              row.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
              row.style.opacity = '0';
              row.style.transform = 'translateX(-20px)';
              
              setTimeout(function() {
                row.remove();
                
                // Mettre à jour le compteur
                var countElement = document.querySelector('.holding-count');
                var countContainer = countElement ? countElement.closest('.mb-6') : null;
                if (countElement) {
                  var currentCount = parseInt(countElement.textContent) || 0;
                  var newCount = Math.max(0, currentCount - 1);
                  countElement.textContent = newCount;
                  
                  // Mettre à jour le texte
                  var countText = document.querySelector('.holding-count-text');
                  if (countText) {
                    if (newCount === 0) {
                      countText.textContent = 'Aucun support associé';
                      // Masquer le conteneur du compteur si plus de supports
                      if (countContainer) {
                        countContainer.style.transition = 'opacity 0.3s ease';
                        countContainer.style.opacity = '0';
                        setTimeout(function() {
                          countContainer.style.display = 'none';
                        }, 300);
                      }
                    } else {
                      countText.textContent = 'support' + (newCount > 1 ? 's' : '') + ' associé' + (newCount > 1 ? 's' : '');
                    }
                  }
                }

                // Si plus de supports, afficher le message vide
                var remainingRows = tableBody.querySelectorAll('.holding-row');
                if (remainingRows.length === 0) {
                  var emptyRow = document.createElement('tr');
                  emptyRow.innerHTML = '<td colspan="8" class="px-8 py-12 text-center"><div class="flex flex-col items-center justify-center"><div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-4"><svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg></div><p class="text-gray-700 font-semibold text-base mb-1">Aucun support lié</p><p class="text-gray-500 text-sm">Les supports seront affichés ici une fois associés</p><a href="{{ path('admin_support_search_index', {product: product.id}) }}" class="mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 transition-all text-sm font-medium"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>Ajouter un support</a></div></td>';
                  tableBody.appendChild(emptyRow);
                }
              }, 300);
            }
          } else {
            throw new Error(result.error || 'Erreur lors de la suppression');
          }
        })
        .catch(function(error) {
          console.error('Erreur:', error);
          if (window.toast && window.toast.error) {
            window.toast.error('Erreur lors de la suppression: ' + error.message);
          } else if (window.showToast) {
            window.showToast('Erreur lors de la suppression: ' + error.message, 'error');
          } else {
            alert('Erreur lors de la suppression: ' + error.message);
          }
          btn.disabled = false;
          btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
        });
      });
    });
  })();
});
</script>

<style>
/* Styles responsive pour le tableau des supports */
@media (max-width: 1024px) {
  .holding-input {
    min-width: 80px !important;
    font-size: 0.875rem;
  }
}

@media (max-width: 768px) {
  .admin-card {
    padding: 1.5rem !important;
  }
  
  /* Rendre le tableau scrollable horizontalement sur mobile */
  .overflow-x-auto {
    -webkit-overflow-scrolling: touch;
  }
  
  /* Réduire l'espacement des cellules sur mobile */
  .holding-row td {
    padding: 0.75rem 0.5rem !important;
  }
  
  .holding-row th {
    padding: 0.75rem 0.5rem !important;
    font-size: 0.7rem;
  }
  
  /* Ajuster la taille des inputs sur mobile */
  .holding-input {
    min-width: 70px !important;
    padding: 0.5rem 0.5rem !important;
    font-size: 0.8rem;
  }
  
  /* Masquer certaines colonnes sur très petits écrans */
  @media (max-width: 640px) {
    .holding-row th:nth-child(3),
    .holding-row td:nth-child(3) {
      display: none;
    }
  }
}

/* Amélioration de l'apparence des inputs */
.holding-input:focus {
  transform: scale(1.02);
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}

.holding-input:hover:not(:focus) {
  border-color: #cbd5e1;
}

/* Animation pour le bouton de sauvegarde */
.holding-save-btn {
  transition: all 0.2s ease;
}

.holding-save-btn:hover {
  transform: scale(1.1);
}

.holding-save-btn:active {
  transform: scale(0.95);
}

/* Style pour les lignes modifiées */
.holding-row.changed {
  background: linear-gradient(to right, #eff6ff 0%, #dbeafe 100%);
}

.holding-row.changed .holding-input {
  border-color: #3b82f6;
  background: #ffffff;
}
</style>
{% endblock %}


