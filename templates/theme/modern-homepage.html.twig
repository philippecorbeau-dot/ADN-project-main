<!-- Script pour le carousel mobile -->
<script>
    let homepageCurrentSlide = 0;
    const homepageTotalSlides = 4;

    function homepageGoToSlide(slideIndex) {
        homepageCurrentSlide = slideIndex;
        homepageUpdateCarousel();
    }

    function homepagePrevSlide() {
        homepageCurrentSlide = (homepageCurrentSlide - 1 + homepageTotalSlides) % homepageTotalSlides;
        homepageUpdateCarousel();
    }

    function homepageNextSlide() {
        homepageCurrentSlide = (homepageCurrentSlide + 1) % homepageTotalSlides;
        homepageUpdateCarousel();
    }

    function homepageUpdateCarousel() {
        const slides = document.getElementById('homepageCarouselSlides');
        if (slides) {
            const offset = -homepageCurrentSlide * 100;
            slides.style.transform = `translateX(${offset}%)`;
            
            // Update indicators
            document.querySelectorAll('.indicator-mobile').forEach((indicator, index) => {
                if (index === homepageCurrentSlide) {
                    indicator.classList.add('active');
                } else {
                    indicator.classList.remove('active');
                }
            });
        }
    }

    // Touch swipe support
    let homepageTouchStartX = 0;
    let homepageTouchEndX = 0;

    document.addEventListener('DOMContentLoaded', function() {
        const carouselElement = document.querySelector('.carousel-mobile-wrapper');
        if (carouselElement) {
            carouselElement.addEventListener('touchstart', function(e) {
                homepageTouchStartX = e.changedTouches[0].screenX;
            }, { passive: true });

            carouselElement.addEventListener('touchend', function(e) {
                homepageTouchEndX = e.changedTouches[0].screenX;
                handleHomepageSwipe();
            }, { passive: true });
        }
    });

    function handleHomepageSwipe() {
        const swipeThreshold = 50;
        const diff = homepageTouchStartX - homepageTouchEndX;

        if (Math.abs(diff) > swipeThreshold) {
            if (diff > 0) {
                // Swipe left - next slide
                homepageNextSlide();
            } else {
                // Swipe right - previous slide
                homepagePrevSlide();
            }
        }
    }
</script>

{# Scripts du simulateur d'investissement - Temporairement masqués (à réactiver plus tard avec la section simulateur)
<!-- Chart.js pour le simulateur -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<!-- Script du simulateur d'investissement - Comparaison Avec/Sans conseil ADN -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Configuration des rendements
    const TAUX_SANS_CONSEIL = 0.05;  // 5% - Fonds euros classique
    const TAUX_AVEC_CONSEIL = 0.10;  // 10% - Avec conseil ADN

    // Éléments DOM - Sliders
    const initialSlider = document.getElementById('initial-amount');
    const monthlySlider = document.getElementById('monthly-amount');
    const durationSlider = document.getElementById('investment-duration');
    
    if (!initialSlider || !monthlySlider || !durationSlider) return;

    // Affichages des valeurs
    const initialDisplay = document.getElementById('initial-display');
    const monthlyDisplay = document.getElementById('monthly-display');
    const durationDisplay = document.getElementById('duration-display');
    
    // Barres de progression
    const initialFill = document.getElementById('initial-fill');
    const monthlyFill = document.getElementById('monthly-fill');
    const durationFill = document.getElementById('duration-fill');

    // Résultats
    const totalInvestedEl = document.getElementById('total-invested');
    const resultWithoutEl = document.getElementById('result-without');
    const gainWithoutEl = document.getElementById('gain-without');
    const resultWithEl = document.getElementById('result-with');
    const gainWithEl = document.getElementById('gain-with');
    const differenceValueEl = document.getElementById('difference-value');
    const differenceMultiplierEl = document.getElementById('difference-multiplier');

    // Configuration du graphique
    let investmentChart = null;
    const chartCanvas = document.getElementById('investment-chart');
    
    if (chartCanvas) {
        const ctx = chartCanvas.getContext('2d');
        
        // Gradient pour la courbe avec conseil ADN
        const gradientWith = ctx.createLinearGradient(0, 0, 0, 280);
        gradientWith.addColorStop(0, 'rgba(20, 184, 166, 0.35)');
        gradientWith.addColorStop(1, 'rgba(20, 184, 166, 0)');
        
        // Gradient pour la courbe sans conseil
        const gradientWithout = ctx.createLinearGradient(0, 0, 0, 280);
        gradientWithout.addColorStop(0, 'rgba(148, 163, 184, 0.2)');
        gradientWithout.addColorStop(1, 'rgba(148, 163, 184, 0)');

        investmentChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: [],
                datasets: [
                    {
                        label: 'Sans conseil (5%)',
                        data: [],
                        borderColor: '#94a3b8',
                        backgroundColor: gradientWithout,
                        borderWidth: 2,
                        borderDash: [6, 4],
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        pointHoverBackgroundColor: '#94a3b8',
                        pointHoverBorderColor: '#fff',
                        pointHoverBorderWidth: 2,
                    },
                    {
                        label: 'Avec conseil ADN (10%)',
                        data: [],
                        borderColor: '#14b8a6',
                        backgroundColor: gradientWith,
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        pointHoverBackgroundColor: '#14b8a6',
                        pointHoverBorderColor: '#fff',
                        pointHoverBorderWidth: 2,
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.95)',
                        titleColor: '#f1f5f9',
                        bodyColor: '#94a3b8',
                        borderColor: 'rgba(148, 163, 184, 0.2)',
                        borderWidth: 1,
                        padding: 14,
                        cornerRadius: 10,
                        titleFont: {
                            family: 'Outfit, sans-serif',
                            size: 14,
                            weight: 600
                        },
                        bodyFont: {
                            family: 'Outfit, sans-serif',
                            size: 13
                        },
                        callbacks: {
                            title: function(items) {
                                return 'Année ' + items[0].label;
                            },
                            label: function(context) {
                                const value = context.parsed.y;
                                return context.dataset.label + ': ' + formatCurrency(value);
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: {
                            color: 'rgba(148, 163, 184, 0.08)',
                            drawBorder: false
                        },
                        ticks: {
                            color: '#64748b',
                            font: {
                                family: 'Outfit, sans-serif',
                                size: 11
                            },
                            maxTicksLimit: 10,
                            callback: function(value, index) {
                                const label = this.getLabelForValue(value);
                                if (index === 0) return 'Début';
                                if (label % 5 === 0 || index === this.chart.data.labels.length - 1) {
                                    return label + ' ans';
                                }
                                return '';
                            }
                        }
                    },
                    y: {
                        grid: {
                            color: 'rgba(148, 163, 184, 0.08)',
                            drawBorder: false
                        },
                        ticks: {
                            color: '#64748b',
                            font: {
                                family: 'Outfit, sans-serif',
                                size: 11
                            },
                            callback: function(value) {
                                if (value >= 1000000) {
                                    return (value / 1000000).toFixed(1) + ' M€';
                                }
                                if (value >= 1000) {
                                    return (value / 1000).toFixed(0) + ' k€';
                                }
                                return value + ' €';
                            }
                        }
                    }
                }
            }
        });
    }

    // Formatage des devises
    function formatCurrency(value) {
        return new Intl.NumberFormat('fr-FR', {
            style: 'currency',
            currency: 'EUR',
            minimumFractionDigits: 0,
            maximumFractionDigits: 0
        }).format(Math.round(value));
    }

    // Calcul du capital avec versements mensuels et intérêts composés
    function calculateFutureValue(initial, monthly, years, annualRate) {
        const monthlyRate = annualRate / 12;
        const months = years * 12;
        
        // Valeur future du capital initial
        const futureInitial = initial * Math.pow(1 + monthlyRate, months);
        
        // Valeur future des versements mensuels (formule des annuités)
        let futureMonthly = 0;
        if (monthlyRate > 0 && monthly > 0) {
            futureMonthly = monthly * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);
        } else if (monthly > 0) {
            futureMonthly = monthly * months;
        }
        
        return futureInitial + futureMonthly;
    }

    // Calcul de la projection année par année
    function calculateYearlyProjection(initial, monthly, years, annualRate) {
        const data = [];
        for (let year = 0; year <= years; year++) {
            const value = calculateFutureValue(initial, monthly, year, annualRate);
            data.push(Math.round(value));
        }
        return data;
    }

    // Calcul complet
    function calculateProjection() {
        const initial = parseInt(initialSlider.value);
        const monthly = parseInt(monthlySlider.value);
        const years = parseInt(durationSlider.value);

        // Total versé
        const totalInvested = initial + (monthly * 12 * years);

        // Calcul sans conseil (5%)
        const finalWithout = calculateFutureValue(initial, monthly, years, TAUX_SANS_CONSEIL);
        const gainWithout = finalWithout - totalInvested;
        const dataWithout = calculateYearlyProjection(initial, monthly, years, TAUX_SANS_CONSEIL);

        // Calcul avec conseil ADN (10%)
        const finalWith = calculateFutureValue(initial, monthly, years, TAUX_AVEC_CONSEIL);
        const gainWith = finalWith - totalInvested;
        const dataWith = calculateYearlyProjection(initial, monthly, years, TAUX_AVEC_CONSEIL);

        // Différence
        const difference = finalWith - finalWithout;
        const multiplier = finalWithout > 0 ? (finalWith / finalWithout) : 0;

        // Labels pour le graphique
        const labels = [];
        for (let i = 0; i <= years; i++) {
            labels.push(i);
        }

        return {
            initial,
            monthly,
            years,
            totalInvested,
            finalWithout: Math.round(finalWithout),
            gainWithout: Math.round(gainWithout),
            finalWith: Math.round(finalWith),
            gainWith: Math.round(gainWith),
            difference: Math.round(difference),
            multiplier: multiplier.toFixed(1),
            labels,
            dataWithout,
            dataWith
        };
    }

    // Mise à jour de l'interface
    function updateUI() {
        const result = calculateProjection();

        // Mise à jour des affichages de sliders
        initialDisplay.textContent = formatCurrency(result.initial);
        monthlyDisplay.textContent = formatCurrency(result.monthly);
        durationDisplay.textContent = result.years + ' an' + (result.years > 1 ? 's' : '');

        // Mise à jour des barres de progression
        const initialPercent = ((result.initial - 500) / (100000 - 500)) * 100;
        const monthlyPercent = (result.monthly / 2000) * 100;
        const durationPercent = ((result.years - 5) / (50 - 5)) * 100;

        initialFill.style.width = Math.min(100, Math.max(0, initialPercent)) + '%';
        monthlyFill.style.width = Math.min(100, Math.max(0, monthlyPercent)) + '%';
        durationFill.style.width = Math.min(100, Math.max(0, durationPercent)) + '%';

        // Mise à jour des résultats
        totalInvestedEl.textContent = formatCurrency(result.totalInvested);
        
        resultWithoutEl.textContent = formatCurrency(result.finalWithout);
        gainWithoutEl.textContent = '+' + formatCurrency(result.gainWithout) + ' de gains';
        
        resultWithEl.textContent = formatCurrency(result.finalWith);
        gainWithEl.textContent = '+' + formatCurrency(result.gainWith) + ' de gains';
        
        differenceValueEl.textContent = '+' + formatCurrency(result.difference);
        differenceMultiplierEl.textContent = 'Capital multiplié par ' + result.multiplier + '×';

        // Mise à jour du graphique
        if (investmentChart) {
            investmentChart.data.labels = result.labels;
            investmentChart.data.datasets[0].data = result.dataWithout;
            investmentChart.data.datasets[1].data = result.dataWith;
            investmentChart.update('none');
        }
    }

    // Event listeners pour les sliders
    initialSlider.addEventListener('input', updateUI);
    monthlySlider.addEventListener('input', updateUI);
    durationSlider.addEventListener('input', updateUI);

    // Initialisation
    updateUI();
});
</script>
#}

