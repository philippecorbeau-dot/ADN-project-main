    <style>
    /* Header moderne */
    .clean-modern-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 9998;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
    }
    
    .header-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 80px;
    }
    
    .logo-section {
        display: flex;
        align-items: center;
    }
    
    .logo-link {
        display: flex;
        align-items: center;
        text-decoration: none;
        transition: transform 0.3s ease;
    }
    
    .logo-link:hover {
        transform: scale(1.05);
    }
    
    .logo-img {
        height: 40px;
        margin-right: 10px;
    }
    
    .logo-text {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.3rem;
        font-weight: 800;
        color: #1C29A1;
        display: flex;
        flex-direction: column;
        line-height: 1.1;
    }
    
    .logo-subtitle {
        font-size: 0.7rem;
        font-weight: 500;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .desktop-nav {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }
    
    .nav-item {
        position: relative;
    }
    
    .nav-link {
        color: #1C29A1;
        text-decoration: none;
        font-weight: 500;
        font-family: 'Inter', sans-serif;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        transition: all 0.3s ease;
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .nav-link:hover {
        background: rgba(28, 41, 161, 0.1);
        color: #1C29A1;
    }
    
    .dropdown-arrow {
        transition: transform 0.3s ease;
        opacity: 0.7;
    }
    
    .dropdown-container:hover .dropdown-arrow {
        transform: rotate(180deg);
        opacity: 1;
    }
    
    /* Menu déroulant moderne */
    .dropdown-menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 50%;
        transform: translateX(-50%);
        background: rgba(255, 255, 255, 0.98);
        border-radius: 1rem;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.05);
        opacity: 0;
        visibility: hidden;
        transform: translateX(-50%) translateY(-10px);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 1000;
        min-width: 650px;
        backdrop-filter: blur(20px);
    }
    
    .dropdown-container:hover .dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
    }
    
    .dropdown-content {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        padding: 2rem;
    }
    
    .dropdown-section h4 {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-weight: 700;
        color: #1C29A1;
        margin-bottom: 1rem;
        font-size: 0.9rem;
        border-bottom: 2px solid rgba(28, 41, 161, 0.1);
        padding-bottom: 0.5rem;
    }
    
    .dropdown-section a {
        display: block;
        padding: 0.5rem 0;
        color: #64748b;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.3s ease;
        border-radius: 0.25rem;
        padding-left: 0.5rem;
        margin-left: -0.5rem;
    }
    
    .dropdown-section a:hover {
        color: #1C29A1;
        background: rgba(28, 41, 161, 0.05);
        padding-left: 1rem;
    }
    
    .header-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
    }
    
    .btn-primary,
    .btn-secondary {
