    .mobile-toggle {
        display: none;
        flex-direction: column;
        gap: 4px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 9999;
        position: relative;
    }
    
    .hamburger-line {
        width: 24px;
        height: 3px;
        background: #1C29A1;
        transition: all 0.3s ease;
        border-radius: 2px;
    }
    
    .mobile-toggle.active .hamburger-line:nth-child(1) {
        transform: rotate(45deg) translate(6px, 6px);
    }
    
    .mobile-toggle.active .hamburger-line:nth-child(2) {
        opacity: 0;
    }
    
    .mobile-toggle.active .hamburger-line:nth-child(3) {
        transform: rotate(-45deg) translate(6px, -6px);
    }
    
    .mobile-menu {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        z-index: 9999;
        pointer-events: none;
    }
    
    .mobile-menu.active {
        opacity: 1;
        visibility: visible;
        pointer-events: all;
    }
    
    .mobile-content {
        position: absolute;
        top: 0;
        right: 0;
        width: 320px;
        height: 100vh;
        background: white;
        transform: translateX(100%);
        transition: transform 0.3s ease;
        padding: 2rem;
        overflow-y: auto;
        overflow-x: hidden;
        box-shadow: -5px 0 15px rgba(0, 0, 0, 0.1);
        z-index: 10000;
        -webkit-overflow-scrolling: touch;
    }
    
    .mobile-menu.active .mobile-content {
        transform: translateX(0);
