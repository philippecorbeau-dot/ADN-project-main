{% extends 'base.html.twig' %}

{# =============== SEO OPTIMISÉ POUR LA HOMEPAGE =============== #}
{# Title 50-60 chars, mot-cl\u00e9 principal en t\u00eate #}
{% block title %}ADN Family Office Paris | Gestion de patrimoine accessible{% endblock %}

{# Meta description 150-155 chars max #}
{% block meta_description %}Family office indépendant à Paris : gestion de patrimoine, transmission, private equity, immobilier. Accessible à toutes les familles. Consultation gratuite.{% endblock %}

{% block og_title %}ADN Family Office | Le family office accessible à toutes les familles{% endblock %}
{% block og_description %}{{ annees_expertise() }} ans d'expertise, {{ clients_accompagnes() }} familles accompagnées, {{ actifs_geres() }}M€ d'actifs gérés. Gestion de patrimoine, transmission, private equity à Paris.{% endblock %}
{% block og_type %}website{% endblock %}

{# JSON-LD spécifique à la Homepage #}
{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "ADN Family Office",
    "alternateName": "ADN FO",
    "url": "{{ url('app_home') }}",
    "description": "Premier family office ouvert à toutes les familles - Gestion de patrimoine, investissement et transmission",
    "publisher": {
        "@type": "Organization",
        "name": "ADN Family Office"
    },
    "potentialAction": {
        "@type": "SearchAction",
        "target": {
            "@type": "EntryPoint",
            "urlTemplate": "{{ url('app_home') }}?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
    }
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "FinancialService",
    "name": "ADN Family Office",
    "description": "Family office spécialisé en gestion de patrimoine, investissement immobilier, private equity et transmission successorale pour les familles françaises.",
    "url": "{{ url('app_home') }}",
    "logo": "{{ absolute_url(asset('build/theme/images/ADN_Logo_enlarged_x5.png')) }}",
    "image": "{{ absolute_url(asset('build/theme/images/og-image-adn.jpg')) }}",
    "telephone": "+33-7-55-60-89-47",
    "email": "contact@adnfamilyoffice.fr",
    "address": {
        "@type": "PostalAddress",
        "streetAddress": "140 bis rue de Rennes",
        "addressLocality": "Paris",
        "postalCode": "75006",
        "addressCountry": "FR"
    },
    "geo": {
        "@type": "GeoCoordinates",
        "latitude": "48.8456",
        "longitude": "2.3276"
    },
    "openingHoursSpecification": [
        {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "09:00",
            "closes": "18:00"
        }
    ],
    "priceRange": "€€€",
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "170",
        "bestRating": "5"
    },
    "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Services de gestion patrimoniale",
        "itemListElement": [
            {
                "@type": "OfferCatalog",
                "name": "Gestion de patrimoine",
                "itemListElement": [
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Optimisation fiscale"}},
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Stratégies d'investissement"}},
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Conseil patrimonial"}}
                ]
            },
            {
                "@type": "OfferCatalog",
                "name": "Gestion immobilière",
                "itemListElement": [
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "SCPI & OPCI"}},
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Défiscalisation immobilière"}}
                ]
            },
            {
                "@type": "OfferCatalog",
                "name": "Private Equity",
                "itemListElement": [
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Capital investissement"}},
                    {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Investissement startup"}}
                ]
            }
        ]
    },
    "sameAs": [
        "https://www.linkedin.com/company/adn-family-office"
    ]
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Accueil",
            "item": "{{ url('app_home') }}"
        }
    ]
}
</script>
{% endblock %}

