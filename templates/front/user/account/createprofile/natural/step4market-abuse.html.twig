{% extends 'front/layouts/funnel.layout.html.twig' %}

{% block title %}Connaissance des marchés financiers - Abus de marché{% endblock %}

{% block content %}
<div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header avec progression -->
        <div class="mb-8">
            <div class="flex items-center justify-between mb-6">
                <h1 class="text-3xl font-bold text-gray-900">Votre compréhension des risques</h1>
                <div class="text-sm text-gray-500">
                    Étape {{ step }}/{{ totalSteps }}
                </div>
            </div>
            
            <!-- Barre de progression -->
            <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-gradient-to-r from-blue-600 to-indigo-600 h-2 rounded-full transition-all duration-300" 
                     style="width: {{ (step / totalSteps) * 100 }}%"></div>
            </div>
        </div>

        <!-- Introduction -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-8">
            <div class="flex items-start space-x-3">
                <i class="fa-solid fa-shield-alt text-blue-600 mt-1"></i>
                <div class="flex-1">
                    <h3 class="font-semibold text-blue-800 mb-2">Informations sur l'abus de marché</h3>
                    <p class="text-sm text-blue-700">
                        Ces questions nous permettent d'évaluer votre exposition potentielle aux risques d'abus de marché et de déterminer les mesures de protection appropriées.
                    </p>
                </div>
            </div>
        </div>

        <!-- Formulaire -->
        <form method="post" class="space-y-6">
            {{ form_start(form) }}
            
            <!-- Question 1 -->
            <div class="bg-white border border-gray-200 rounded-lg p-6">
                <div class="mb-4">
                    <h3 class="text-lg font-semibold text-gray-800 mb-2">
                        {{ form_label(form.hasOtherSecuritiesAccounts) }}
                    </h3>
                </div>
                <div class="space-y-3">
                    {{ form_widget(form.hasOtherSecuritiesAccounts) }}
                </div>
            </div>

            <!-- Question 2 -->
            <div class="bg-white border border-gray-200 rounded-lg p-6">
                <div class="mb-4">
                    <h3 class="text-lg font-semibold text-gray-800 mb-2">
                        {{ form_label(form.hasFinancialProfession) }}
                    </h3>
                </div>
                <div class="space-y-3">
                    {{ form_widget(form.hasFinancialProfession) }}
                </div>
                
                <!-- Sous-question conditionnelle pour la profession -->
                <div id="profession-details" class="mt-4 hidden">
                    <div class="mb-4">
                        <h4 class="text-md font-medium text-gray-700 mb-2">
                            {{ form_label(form.professionDetails) }}
                        </h4>
                        <p class="text-sm text-gray-600 mb-2">
                            Précisez votre profession dans le domaine financier...
                        </p>
                    </div>
                    {{ form_widget(form.professionDetails) }}
                </div>
            </div>

            <!-- Question 3 -->
            <div class="bg-white border border-gray-200 rounded-lg p-6">
                <div class="mb-4">
                    <h3 class="text-lg font-semibold text-gray-800 mb-2">
                        {{ form_label(form.isListedCompanyDirector) }}
                    </h3>
                </div>
                <div class="space-y-3">
                    {{ form_widget(form.isListedCompanyDirector) }}
                </div>
                
                <!-- Sous-question conditionnelle pour la société cotée -->
                <div id="company-details" class="mt-4 hidden">
                    <div class="mb-4">
                        <h4 class="text-md font-medium text-gray-700 mb-2">
                            {{ form_label(form.listedCompanyDetails) }}
                        </h4>
                        <p class="text-sm text-gray-600 mb-2">
                            Précisez la société cotée...
                        </p>
                    </div>
                    {{ form_widget(form.listedCompanyDetails) }}
                </div>
            </div>

            <!-- Boutons de navigation -->
            <div class="flex justify-between items-center pt-6 border-t border-gray-200">
                <a href="{{ path('user_create_profile', {'step': 4, 'substep': 'beginner2'}) }}" 
                   class="inline-flex items-center px-6 py-3 border border-gray-300 rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                    <i class="fa-solid fa-arrow-left mr-2"></i>
                    Précédent
                </a>
                
                <button type="submit" 
                        class="inline-flex items-center px-8 py-3 bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-lg hover:from-blue-700 hover:to-indigo-700 transition-all transform hover:scale-105">
                    Suivant
                    <i class="fa-solid fa-arrow-right ml-2"></i>
                </button>
            </div>

            {{ form_end(form) }}
        </form>
    </div>
</div>

<!-- JavaScript pour l'affichage conditionnel -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Gestion de l'affichage conditionnel pour la profession
    const professionRadios = document.querySelectorAll('input[name="knowledge_market_abuse[hasFinancialProfession]"]');
    const professionDetails = document.getElementById('profession-details');
    
    function toggleProfessionDetails() {
        const selectedValue = document.querySelector('input[name="knowledge_market_abuse[hasFinancialProfession]"]:checked');
        if (selectedValue && selectedValue.value === '1') {
            professionDetails.classList.remove('hidden');
        } else {
            professionDetails.classList.add('hidden');
        }
    }
    
    professionRadios.forEach(radio => {
        radio.addEventListener('change', toggleProfessionDetails);
    });
    
    // Gestion de l'affichage conditionnel pour la société cotée
    const companyRadios = document.querySelectorAll('input[name="knowledge_market_abuse[isListedCompanyDirector]"]');
    const companyDetails = document.getElementById('company-details');
    
    function toggleCompanyDetails() {
        const selectedValue = document.querySelector('input[name="knowledge_market_abuse[isListedCompanyDirector]"]:checked');
        if (selectedValue && selectedValue.value === '1') {
            companyDetails.classList.remove('hidden');
        } else {
            companyDetails.classList.add('hidden');
        }
    }
    
    companyRadios.forEach(radio => {
        radio.addEventListener('change', toggleCompanyDetails);
    });
    
    // Initialiser l'état
    toggleProfessionDetails();
    toggleCompanyDetails();
});
</script>
{% endblock %} 