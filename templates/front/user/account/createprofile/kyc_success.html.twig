{% extends 'base.html.twig' %}

{% block title %}Documents envoyés avec succès !{% endblock %}

{% block body %}
<div class="flex flex-col items-center justify-center min-h-screen bg-gray-50">
    <div class="bg-white rounded-lg shadow-lg p-10 mt-10 text-center relative">
        <canvas id="confetti-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
        <h1 class="text-3xl font-bold text-green-600 mb-4">🎉 Félicitations !</h1>
        <p class="text-lg text-gray-700 mb-6">
            Vos documents ont bien été envoyés.<br>
            Notre équipe va les vérifier sous peu.<br>
            Merci pour votre confiance !
        </p>
        <a href="{{ path('user_dashboard') }}" class="inline-block px-6 py-3 bg-blue-800 text-white rounded-lg font-semibold shadow hover:bg-blue-900 transition">
            Accéder à mon espace
        </a>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<script>
    // Animation confettis au chargement
    window.onload = function() {
        confetti({
            particleCount: 150,
            spread: 70,
            origin: { y: 0.6 }
        });
    };
</script>
{% endblock %} 