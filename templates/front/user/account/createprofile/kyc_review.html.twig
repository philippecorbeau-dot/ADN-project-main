</div>

<script>
document.addEventListener('DOMContentLoaded', function(){
  const modal = document.getElementById('recap-modal');
  const openRecap = document.getElementById('open-recap');
  const closeRecap = document.getElementById('recap-close');
  const closeRecapFooter = document.getElementById('recap-close-footer');
  if (openRecap && modal) {
    openRecap.addEventListener('click', () => { modal.classList.remove('hidden'); document.body.style.overflow = 'hidden'; });
  }
  if (closeRecap && modal) {
    closeRecap.addEventListener('click', () => { modal.classList.add('hidden'); document.body.style.overflow = ''; });
  }
  if (closeRecapFooter && modal) {
    closeRecapFooter.addEventListener('click', () => { modal.classList.add('hidden'); document.body.style.overflow = ''; });
  }
  if (modal) {
    modal.addEventListener('click', (e) => { if (e.target === modal) { modal.classList.add('hidden'); document.body.style.overflow = ''; } });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { modal.classList.add('hidden'); document.body.style.overflow = ''; } });
  }
});
</script>
<!-- MODALE RÉCAPITULATIF -->
<div id="recap-modal" class="fixed inset-0 z-50 hidden transition-opacity duration-300">
  <!-- Overlay avec animation -->
  <div class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/50 to-black/60 backdrop-blur-sm"></div>
  
  <!-- Conteneur de la modale -->
  <div class="relative flex items-center justify-center min-h-screen p-4 sm:p-6">
