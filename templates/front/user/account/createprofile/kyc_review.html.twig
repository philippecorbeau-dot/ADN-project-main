                  <p class="text-sm font-medium text-indigo-100 uppercase tracking-wider">Votre profil</p>
                  <p class="text-2xl sm:text-3xl font-bold mt-2">{{ investorProfile ?? '—' }}</p>
                </div>
                <div class="flex items-center justify-center w-20 h-20 sm:w-24 sm:h-24 bg-white/20 backdrop-blur-sm rounded-2xl shadow-lg mt-4 sm:mt-0">
                  <span class="text-3xl sm:text-4xl font-bold">{{ investorScore ?? 0 }}</span>
                </div>
              </div>
            </div>
          </details>

          <!-- Accordéon Étape 2 -->
          <details class="group bg-white rounded-2xl border-2 border-gray-200 shadow-sm hover:shadow-lg transition-all duration-300">
            <summary class="cursor-pointer list-none px-5 sm:px-6 py-4 sm:py-5 font-bold text-base sm:text-lg text-gray-900 flex items-center justify-between hover:bg-gradient-to-r hover:from-emerald-50 hover:to-teal-50 transition-all duration-200 rounded-2xl">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center shadow-md">
                  <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                  </svg>
                </div>
                <span class="text-sm sm:text-base lg:text-lg">Étape 2 — Objectifs et horizon</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs sm:text-sm text-gray-500 font-normal hidden sm:inline">Cliquer pour déplier</span>
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-400 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            </summary>
            <div class="px-5 sm:px-6 pb-5 sm:pb-6 pt-2">
              <dl class="space-y-3 sm:space-y-4">
                <div class="border-l-4 border-emerald-500 bg-gradient-to-r from-emerald-50 to-emerald-100/50 rounded-r-xl p-4 shadow-sm">
                  <dt class="text-xs font-bold text-emerald-700 uppercase tracking-wider mb-2">Objectifs d'investissement</dt>
                  <dd class="text-sm font-semibold text-gray-900">{{ (objectiveLabels ?? [])|join(', ') }}</dd>
                </div>
                <div class="border-l-4 border-teal-500 bg-gradient-to-r from-teal-50 to-teal-100/50 rounded-r-xl p-4 shadow-sm">
                  <dt class="text-xs font-bold text-teal-700 uppercase tracking-wider mb-2">Horizon d'investissement</dt>
                  <dd class="text-sm font-semibold text-gray-900">{{ (investmentTermLabels ?? [])|join(', ') }}</dd>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
                  <div class="bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-xl p-4 border border-emerald-200 shadow-sm">
                    <dt class="text-xs font-medium text-emerald-700 uppercase tracking-wider mb-1">Épargne disponible</dt>
                    <dd class="text-xl font-bold text-emerald-700">{{ info.liquidity ?? 0 }} €</dd>
                  </div>
                  <div class="bg-gradient-to-br from-teal-50 to-teal-100 rounded-xl p-4 border border-teal-200 shadow-sm">
                    <dt class="text-xs font-medium text-teal-700 uppercase tracking-wider mb-1">Origine des fonds</dt>
                    <dd class="text-sm font-semibold text-gray-900">{{ (sourceOfFundsLabels ?? [])|join(', ') }}</dd>
                  </div>
                </div>
              </dl>
            </div>
          </details>

          <!-- Accordéon Étape 3 -->
          <details class="group bg-white rounded-2xl border-2 border-gray-200 shadow-sm hover:shadow-lg transition-all duration-300">
            <summary class="cursor-pointer list-none px-5 sm:px-6 py-4 sm:py-5 font-bold text-base sm:text-lg text-gray-900 flex items-center justify-between hover:bg-gradient-to-r hover:from-amber-50 hover:to-orange-50 transition-all duration-200 rounded-2xl">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center shadow-md">
                  <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <span class="text-sm sm:text-base lg:text-lg">Étape 3 — Situation financière</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs sm:text-sm text-gray-500 font-normal hidden sm:inline">Cliquer pour déplier</span>
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-400 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            </summary>
            <div class="px-5 sm:px-6 pb-5 sm:pb-6 pt-2">
              <!-- Revenus -->
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4 sm:mb-6">
                <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-xl p-4 border border-amber-200 shadow-sm">
                  <dt class="text-xs font-medium text-amber-700 mb-1">Salaire mensuel</dt>
                  <dd class="text-lg sm:text-xl font-bold text-amber-900">{{ info.salary ?? 0 }} €</dd>
                </div>
                <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-xl p-4 border border-amber-200 shadow-sm">
                  <dt class="text-xs font-medium text-amber-700 mb-1">Capitalisation</dt>
                  <dd class="text-lg sm:text-xl font-bold text-amber-900">{{ info.capitalisation ?? 0 }} €</dd>
                </div>
                <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-xl p-4 border border-amber-200 shadow-sm">
                  <dt class="text-xs font-medium text-amber-700 mb-1">Revenus locatifs</dt>
                  <dd class="text-lg sm:text-xl font-bold text-amber-900">{{ info.realestateIncome ?? 0 }} €</dd>
                </div>
              </div>
              <!-- Immobilier -->
              <div class="bg-gradient-to-br from-orange-50 to-red-100 rounded-xl p-5 border-2 border-orange-300 mb-4 sm:mb-6 shadow-md">
                <div class="flex justify-between items-center mb-4">
                  <span class="text-sm font-bold text-orange-800 uppercase tracking-wide">Total immobilier</span>
                  <span class="text-xl sm:text-2xl font-bold text-orange-900">{{ info.realestate ?? 0 }} €</span>
                </div>
                <div class="space-y-3 pl-4 border-l-4 border-orange-400">
                  <div class="flex justify-between text-sm"><span class="text-gray-700 font-medium">• Résidence principale</span><span class="font-bold text-gray-900">{{ info.realestatePrimaryResidence ?? 0 }} €</span></div>
                  <div class="flex justify-between text-sm"><span class="text-gray-700 font-medium">• Investissement</span><span class="font-bold text-gray-900">{{ info.realestateInvestment ?? 0 }} €</span></div>
                  <div class="flex justify-between text-sm"><span class="text-gray-700 font-medium">• SCPI</span><span class="font-bold text-gray-900">{{ info.scpi ?? 0 }} €</span></div>
                </div>
              </div>
              <!-- Épargne -->
              <div class="bg-gradient-to-br from-green-50 to-emerald-100 rounded-xl p-5 border-2 border-green-300 shadow-md">
                <div class="flex justify-between items-center mb-4">
                  <span class="text-sm font-bold text-green-800 uppercase tracking-wide">Total épargne</span>
                  <span class="text-xl sm:text-2xl font-bold text-green-900">{{ info.depositSavings ?? 0 }} €</span>
                </div>
                <div class="space-y-3 pl-4 border-l-4 border-green-400">
                  <div class="flex justify-between text-sm"><span class="text-gray-700 font-medium">• Compte courant</span><span class="font-bold text-gray-900">{{ info.depositSavingsChecking ?? 0 }} €</span></div>
                  <div class="flex justify-between text-sm"><span class="text-gray-700 font-medium">• Livret A</span><span class="font-bold text-gray-900">{{ info.depositSavingsLivretA ?? 0 }} €</span></div>
                  <div class="flex justify-between text-sm"><span class="text-gray-700 font-medium">• LDD</span><span class="font-bold text-gray-900">{{ info.depositSavingsLdd ?? 0 }} €</span></div>
                  <div class="flex justify-between text-sm"><span class="text-gray-700 font-medium">• CSL</span><span class="font-bold text-gray-900">{{ info.depositSavingsCsl ?? 0 }} €</span></div>
                  <div class="flex justify-between text-sm"><span class="text-gray-700 font-medium">• Autre livret</span><span class="font-bold text-gray-900">{{ info.depositSavingsOther ?? 0 }} €</span></div>
                </div>
              </div>
            </div>
          </details>

          <!-- Accordéon Étape 4 - Amélioré -->
          <details class="group bg-white rounded-2xl border-2 border-gray-200 shadow-sm hover:shadow-lg transition-all duration-300">
            <summary class="cursor-pointer list-none px-5 sm:px-6 py-4 sm:py-5 font-bold text-base sm:text-lg text-gray-900 flex items-center justify-between hover:bg-gradient-to-r hover:from-violet-50 hover:to-fuchsia-50 transition-all duration-200 rounded-2xl">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg bg-gradient-to-br from-violet-500 to-fuchsia-600 flex items-center justify-center shadow-md">
                  <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                  </svg>
                </div>
                <span class="text-sm sm:text-base lg:text-lg">Étape 4 — Expérience & MIF</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-xs sm:text-sm text-gray-500 font-normal hidden sm:inline">Cliquer pour déplier</span>
                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-gray-400 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </div>
            </summary>
            <div class="px-5 sm:px-6 pb-5 sm:pb-6 pt-2">
              <!-- Mini synthèse -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-4 mb-5 sm:mb-6">
                <div class="bg-gradient-to-br from-violet-50 to-violet-100 rounded-xl p-4 border-2 border-violet-200 shadow-sm">
                  <dt class="text-xs font-bold text-violet-700 uppercase tracking-wider mb-2">Connaissance MIF</dt>
                  <dd class="text-base sm:text-lg font-bold text-gray-900">{{ info.mif ? 'Oui' : 'Non' }}</dd>
                </div>
                <div class="bg-gradient-to-br from-fuchsia-50 to-fuchsia-100 rounded-xl p-4 border-2 border-fuchsia-200 shadow-sm">
                  <dt class="text-xs font-bold text-fuchsia-700 uppercase tracking-wider mb-2">Employé secteur financier</dt>
                  <dd class="text-base sm:text-lg font-bold text-gray-900">{{ info.financeWorker ? 'Oui' : 'Non' }}</dd>
                </div>
              </div>

              <!-- Connaissance produits financiers -->
              <div class="mb-5 sm:mb-6">
                <div class="flex items-center gap-2 mb-3 sm:mb-4">
                  <div class="w-1 h-6 bg-gradient-to-b from-violet-500 to-fuchsia-500 rounded-full"></div>
                  <h4 class="text-sm sm:text-base font-bold text-gray-800">Questionnaire — Produits financiers</h4>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-3">
                  {% for i in 1..8 %}
                    <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200">
                      <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ financialLabels[i-1] }}</div>
                      <div class="text-sm font-bold text-gray-900">{{ financialProducts ? (answerMap[attribute(financialProducts, 'getQuestion' ~ i)] ?? '—') : '—' }}</div>
                    </div>
                  {% endfor %}
                </div>
              </div>

              <!-- Connaissance produits complexes -->
              <div class="mb-5 sm:mb-6">
                <div class="flex items-center gap-2 mb-3 sm:mb-4">
                  <div class="w-1 h-6 bg-gradient-to-b from-violet-500 to-fuchsia-500 rounded-full"></div>
                  <h4 class="text-sm sm:text-base font-bold text-gray-800">Questionnaire — Produits complexes</h4>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-3">
                  {% for i in 1..10 %}
                    <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200">
                      <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ complexLabels[i-1] }}</div>
                      <div class="text-sm font-bold text-gray-900">{{ complexProducts ? (answerMap[attribute(complexProducts, 'getQuestion' ~ i)] ?? '—') : '—' }}</div>
                    </div>
                  {% endfor %}
                </div>
              </div>

              <!-- Expérience marchés -->
              <div class="mb-5 sm:mb-6">
                <div class="flex items-center gap-2 mb-3 sm:mb-4">
                  <div class="w-1 h-6 bg-gradient-to-b from-violet-500 to-fuchsia-500 rounded-full"></div>
                  <h4 class="text-sm sm:text-base font-bold text-gray-800">Expérience des marchés</h4>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-3">
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 flex justify-between items-center hover:shadow-md transition-all duration-200">
                    <span class="text-sm font-medium text-gray-700">Actions</span>
                    <span class="text-sm font-bold text-gray-900">{{ marketExperience and marketExperience.hasStocksExperience ? 'Oui' : 'Non' }}</span>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 flex justify-between items-center hover:shadow-md transition-all duration-200">
                    <span class="text-sm font-medium text-gray-700">Obligations</span>
                    <span class="text-sm font-bold text-gray-900">{{ marketExperience and marketExperience.hasBondsExperience ? 'Oui' : 'Non' }}</span>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 flex justify-between items-center hover:shadow-md transition-all duration-200">
                    <span class="text-sm font-medium text-gray-700">OPCVM</span>
                    <span class="text-sm font-bold text-gray-900">{{ marketExperience and marketExperience.hasUcitsExperience ? 'Oui' : 'Non' }}</span>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 flex justify-between items-center hover:shadow-md transition-all duration-200">
                    <span class="text-sm font-medium text-gray-700">Immobilier</span>
                    <span class="text-sm font-bold text-gray-900">{{ marketExperience and marketExperience.hasRealEstateExperience ? 'Oui' : 'Non' }}</span>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 flex justify-between items-center hover:shadow-md transition-all duration-200 sm:col-span-2">
                    <span class="text-sm font-medium text-gray-700">Instruments complexes</span>
                    <span class="text-sm font-bold text-gray-900">{{ marketExperience and marketExperience.hasComplexInstrumentsExperience ? 'Oui' : 'Non' }}</span>
                  </div>
                </div>
              </div>

              <!-- Expérience investissement -->
              <div class="mb-5 sm:mb-6">
                <div class="flex items-center gap-2 mb-3 sm:mb-4">
                  <div class="w-1 h-6 bg-gradient-to-b from-violet-500 to-fuchsia-500 rounded-full"></div>
                  <h4 class="text-sm sm:text-base font-bold text-gray-800">Expérience d'investissement</h4>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-3">
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200">
                    <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ investmentExperienceLabels['hasLostSignificantAmounts'] }}</div>
                    <div class="text-sm font-bold text-gray-900">{{ investmentExperience and investmentExperience.hasLostSignificantAmounts ? 'Oui' : 'Non' }}</div>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200">
                    <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ investmentExperienceLabels['managesOwnPortfolio'] }}</div>
                    <div class="text-sm font-bold text-gray-900">{{ investmentExperience and investmentExperience.managesOwnPortfolio ? 'Oui' : 'Non' }}</div>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200">
                    <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ investmentExperienceLabels['portfolioSecuritiesLines'] }}</div>
                    <div class="text-sm font-bold text-gray-900">{{ investmentExperience and investmentExperience.portfolioSecuritiesLines ?: '—' }}</div>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200">
                    <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ investmentExperienceLabels['concentratesOnSingleSecurity'] }}</div>
                    <div class="text-sm font-bold text-gray-900">{{ investmentExperience and investmentExperience.concentratesOnSingleSecurity ? 'Oui' : 'Non' }}</div>
                  </div>
                </div>
              </div>

              <!-- Abus de marché -->
              <div>
                <div class="flex items-center gap-2 mb-3 sm:mb-4">
                  <div class="w-1 h-6 bg-gradient-to-b from-violet-500 to-fuchsia-500 rounded-full"></div>
                  <h4 class="text-sm sm:text-base font-bold text-gray-800">Abus de marché</h4>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-3">
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200">
                    <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ marketAbuseLabels['hasOtherSecuritiesAccounts'] }}</div>
                    <div class="text-sm font-bold text-gray-900">{{ ik and ik.marketAbuse and ik.marketAbuse.hasOtherSecuritiesAccounts ? 'Oui' : 'Non' }}</div>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200">
                    <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ marketAbuseLabels['hasFinancialProfession'] }}</div>
                    <div class="text-sm font-bold text-gray-900">{{ ik and ik.marketAbuse and ik.marketAbuse.hasFinancialProfession ? 'Oui' : 'Non' }}</div>
                  </div>
                  <div class="bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-3 sm:p-4 border border-gray-200 hover:shadow-md transition-all duration-200 sm:col-span-2">
                    <div class="text-xs text-gray-600 mb-1.5 font-medium">{{ marketAbuseLabels['isListedCompanyDirector'] }}</div>
                    <div class="text-sm font-bold text-gray-900">{{ ik and ik.marketAbuse and ik.marketAbuse.isListedCompanyDirector ? 'Oui' : 'Non' }}</div>
                  </div>
                </div>
              </div>
            </div>
          </details>

        </div>
      </div>

      <!-- Footer avec gradient -->
      <div class="flex-shrink-0 bg-gradient-to-r from-gray-50 to-gray-100 px-6 sm:px-8 py-4 sm:py-5 border-t-2 border-gray-200">
        <div class="flex items-center justify-between">
          <p class="text-xs sm:text-sm text-gray-600">
            <svg class="w-4 h-4 inline mr-1.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Utilisez la touche <kbd class="px-2 py-1 bg-white border border-gray-300 rounded text-xs font-mono shadow-sm">Échap</kbd> pour fermer
          </p>
          <button id="recap-close-footer" class="px-4 sm:px-6 py-2 sm:py-2.5 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-105">
            Fermer
          </button>
        </div>
      </div>

    </div>
  </div>
</div>
{% endblock %}


