{% extends 'front/layouts/funnel.layout.html.twig' %}

{% block body %}
<div class="container pb-10 mt-24 md:mt-0 px-4 sm:px-6">
  <div class="max-w-7xl mx-auto">
    <!-- En-tête avec badge de statut -->
    <div class="text-center mb-8 md:mb-12">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full mb-4 shadow-lg">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-gray-900 to-gray-700 bg-clip-text text-transparent mb-2">Récapitulatif de vos informations</h1>
      <p class="text-gray-600 text-lg">Vérifiez vos informations puis téléchargez votre récapitulatif.</p>
    </div>

    <div class="space-y-6 lg:space-y-8">
      
      <!-- Bouton pour ouvrir la modale récap -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
        <div class="px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold shadow-md">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <div>
              <h2 class="text-lg sm:text-xl font-bold text-gray-900">Récapitulatif détaillé</h2>
              <p class="text-sm text-gray-600 mt-0.5">Profil, profil investisseur, étape 2 & 3, expérience & MIF</p>
            </div>
          </div>
          <button id="open-recap" class="w-full sm:w-auto px-6 py-3 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-105">
            <span class="flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
              Ouvrir
            </span>
          </button>
        </div>
      </div>

        <!-- Ancien contenu (masqué, désormais dans la modale) -->
        <div id="inline-recap" class="hidden">
        
        <!-- Card Profil -->
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden">
          <div class="bg-gradient-to-r from-blue-50 to-indigo-50 px-6 py-4 border-b border-blue-100">
            <div class="flex items-center">
              <div class="flex-shrink-0 w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <h2 class="ml-3 text-xl font-bold text-gray-900">Profil</h2>
            </div>
          </div>
          <div class="p-6">
            <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Nom complet</dt>
                <dd class="text-base font-semibold text-gray-900">{{ user.fullName }}</dd>
              </div>
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Email</dt>
                <dd class="text-base font-semibold text-gray-900 break-all">{{ user.email }}</dd>
              </div>
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Type de compte</dt>
                <dd class="mt-1">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium {% if user.isPro %}bg-purple-100 text-purple-800{% else %}bg-blue-100 text-blue-800{% endif %}">
                    {{ user.isPro ? 'Professionnel' : 'Particulier' }}
                  </span>
                </dd>
              </div>
            </dl>
          </div>
        </div>

        <!-- Card Profil Investisseur -->
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden">
          <div class="bg-gradient-to-r from-indigo-50 to-purple-50 px-6 py-4 border-b border-indigo-100">
            <div class="flex items-center">
              <div class="flex-shrink-0 w-10 h-10 bg-indigo-500 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                </svg>
              </div>
              <h2 class="ml-3 text-xl font-bold text-gray-900">Profil investisseur</h2>
            </div>
          </div>
          <div class="p-6">
            <div class="flex items-center justify-between bg-gradient-to-r from-indigo-500 to-purple-600 rounded-xl p-6 text-white">
              <div>
                <p class="text-sm font-medium text-indigo-100">Votre profil</p>
                <p class="text-2xl font-bold mt-1">{{ investorProfile ?? '—' }}</p>
              </div>
              <div class="flex items-center justify-center w-16 h-16 bg-white bg-opacity-20 rounded-full">
                <span class="text-2xl font-bold">{{ investorScore ?? 0 }}</span>
              </div>
            </div>
          </div>
        </div>

        {% if info %}
        <!-- Card Objectifs et Horizon -->
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden">
          <div class="bg-gradient-to-r from-emerald-50 to-teal-50 px-6 py-4 border-b border-emerald-100">
            <div class="flex items-center">
              <div class="flex-shrink-0 w-10 h-10 bg-emerald-500 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </div>
              <h2 class="ml-3 text-xl font-bold text-gray-900">Objectifs et horizon</h2>
            </div>
          </div>
          <div class="p-6">
            <dl class="space-y-4">
              <div class="border-l-4 border-emerald-400 bg-emerald-50 rounded-r-lg p-4">
                <dt class="text-xs font-medium text-emerald-700 uppercase tracking-wider mb-2">Objectifs d'investissement</dt>
                <dd class="text-sm text-gray-900 font-medium">{{ (objectiveLabels ?? [])|join(', ') }}</dd>
              </div>
              <div class="border-l-4 border-teal-400 bg-teal-50 rounded-r-lg p-4">
                <dt class="text-xs font-medium text-teal-700 uppercase tracking-wider mb-2">Horizon d'investissement</dt>
                <dd class="text-sm text-gray-900 font-medium">{{ (investmentTermLabels ?? [])|join(', ') }}</dd>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                  <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Épargne disponible</dt>
                  <dd class="text-lg font-bold text-emerald-600">{{ info.liquidity ?? 0 }} €</dd>
                </div>
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                  <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Origine des fonds</dt>
                  <dd class="text-sm text-gray-900 font-medium">{{ (sourceOfFundsLabels ?? [])|join(', ') }}</dd>
                </div>
              </div>
            </dl>
          </div>
        </div>

        <!-- Card Situation Financière -->
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden">
          <div class="bg-gradient-to-r from-amber-50 to-orange-50 px-6 py-4 border-b border-amber-100">
            <div class="flex items-center">
              <div class="flex-shrink-0 w-10 h-10 bg-amber-500 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <h2 class="ml-3 text-xl font-bold text-gray-900">Situation financière</h2>
            </div>
          </div>
          <div class="p-6">
            <div class="space-y-6">
              <!-- Revenus -->
              <div>
                <h3 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
                  </svg>
                  Revenus
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                  <div class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-lg p-4 border border-amber-100">
                    <dt class="text-xs font-medium text-amber-700 mb-1">Salaire mensuel</dt>
                    <dd class="text-lg font-bold text-gray-900">{{ info.salary ?? 0 }} €</dd>
                  </div>
                  <div class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-lg p-4 border border-amber-100">
                    <dt class="text-xs font-medium text-amber-700 mb-1">Capitalisation</dt>
                    <dd class="text-lg font-bold text-gray-900">{{ info.capitalisation ?? 0 }} €</dd>
                  </div>
                  <div class="bg-gradient-to-br from-amber-50 to-orange-50 rounded-lg p-4 border border-amber-100">
                    <dt class="text-xs font-medium text-amber-700 mb-1">Revenus locatifs</dt>
                    <dd class="text-lg font-bold text-gray-900">{{ info.realestateIncome ?? 0 }} €</dd>
                  </div>
                </div>
              </div>

              <!-- Immobilier -->
              <div>
                <h3 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                  </svg>
                  Patrimoine immobilier
                </h3>
                <div class="bg-gradient-to-br from-orange-50 to-red-50 rounded-xl p-4 border border-orange-200">
                  <div class="flex justify-between items-center mb-3">
                    <span class="text-sm font-medium text-orange-800">Total immobilier</span>
                    <span class="text-xl font-bold text-orange-900">{{ info.realestate ?? 0 }} €</span>
                  </div>
                  <div class="space-y-2 pl-4 border-l-2 border-orange-300">
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-600">• Résidence principale</span>
                      <span class="font-semibold text-gray-900">{{ info.realestatePrimaryResidence ?? 0 }} €</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-600">• Investissement</span>
                      <span class="font-semibold text-gray-900">{{ info.realestateInvestment ?? 0 }} €</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-600">• SCPI</span>
                      <span class="font-semibold text-gray-900">{{ info.scpi ?? 0 }} €</span>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Épargne -->
              <div>
                <h3 class="text-sm font-semibold text-gray-700 mb-3 flex items-center">
                  <svg class="w-5 h-5 mr-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 8h6m-5 0a3 3 0 110 6H9l3 3m-3-6h6m6 1a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  Comptes et épargne
                </h3>
                <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl p-4 border border-green-200">
                  <div class="flex justify-between items-center mb-3">
                    <span class="text-sm font-medium text-green-800">Total épargne</span>
                    <span class="text-xl font-bold text-green-900">{{ info.depositSavings ?? 0 }} €</span>
                  </div>
                  <div class="space-y-2 pl-4 border-l-2 border-green-300">
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-600">• Compte courant</span>
                      <span class="font-semibold text-gray-900">{{ info.depositSavingsChecking ?? 0 }} €</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-600">• Livret A</span>
                      <span class="font-semibold text-gray-900">{{ info.depositSavingsLivretA ?? 0 }} €</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-600">• LDD</span>
                      <span class="font-semibold text-gray-900">{{ info.depositSavingsLdd ?? 0 }} €</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-600">• CSL</span>
                      <span class="font-semibold text-gray-900">{{ info.depositSavingsCsl ?? 0 }} €</span>
                    </div>
                    <div class="flex justify-between text-sm">
                      <span class="text-gray-600">• Autre livret</span>
                      <span class="font-semibold text-gray-900">{{ info.depositSavingsOther ?? 0 }} €</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        {% endif %}

        {% if info %}
        <!-- Card Expérience & MIF (Étape 4) -->
        <div class="bg-white rounded-2xl shadow-lg hover:shadow-xl transition-shadow duration-300 overflow-hidden">
          <div class="bg-gradient-to-r from-violet-50 to-fuchsia-50 px-6 py-4 border-b border-violet-100">
            <div class="flex items-center">
              <div class="flex-shrink-0 w-10 h-10 bg-violet-500 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/>
                </svg>
              </div>
              <h2 class="ml-3 text-xl font-bold text-gray-900">Expérience & MIF (Étape 4)</h2>
            </div>
          </div>
          <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Connaissance MIF</dt>
                <dd class="text-sm font-semibold text-gray-900">{{ info.mif ? 'Oui' : 'Non' }}</dd>
              </div>
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Employé du secteur financier</dt>
                <dd class="text-sm font-semibold text-gray-900">{{ info.financeWorker ? 'Oui' : 'Non' }}</dd>
              </div>
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Personne politiquement exposée</dt>
                <dd class="text-sm font-semibold text-gray-900">{{ info.political is same as(null) ? '—' : (info.political ? 'Oui' : 'Non') }}</dd>
              </div>
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <dt class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Titres financiers détenus</dt>
                <dd class="text-sm font-semibold text-gray-900">{{ info.securities ? 'Oui' : 'Non' }}</dd>
              </div>
            </div>

            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-white rounded-xl p-4 border border-gray-100">
                <h3 class="text-sm font-semibold text-gray-700 mb-2">Types de titres</h3>
                <p class="text-sm text-gray-900">{{ info.securitiesOptionsTxt ?: '—' }}</p>
                {% if info.securitiesOptionsCount %}
                  <p class="mt-1 text-xs text-gray-500">Nombre d'opérations: {{ info.securitiesOptionsCount }}</p>
                {% endif %}
              </div>
              <div class="bg-white rounded-xl p-4 border border-gray-100">
                <h3 class="text-sm font-semibold text-gray-700 mb-2">Connaissances minimales</h3>
                <ul class="text-sm text-gray-900 space-y-1">
                  <li>Montant minimum: {{ info.awarenessMinimumAmount ? 'Oui' : 'Non' }}</li>
                  <li>Durée minimale: {{ info.awarenessMinimumTime ? 'Oui' : 'Non' }}</li>
                  <li>Transactions minimales: {{ info.awarenessTransactions ? 'Oui' : 'Non' }}</li>
                </ul>
              </div>
            </div>

            <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-white rounded-xl p-4 border border-gray-100">
                <h3 class="text-sm font-semibold text-gray-700 mb-2">Adéquation (connaissances)</h3>
                <ul class="text-sm text-gray-900 space-y-1">
                  <li>Q1: {{ info.adequacy1 ?: '—' }}</li>
                  <li>Q2: {{ info.adequacy2 ?: '—' }}</li>
                  <li>Q3: {{ info.adequacy3 is same as(null) ? '—' : (info.adequacy3 ? 'Oui' : 'Non') }}</li>
                  <li>Q4: {{ info.adequacy4 is same as(null) ? '—' : (info.adequacy4 ? 'Oui' : 'Non') }}</li>
                  <li>Q5: {{ info.adequacy5 ?: '—' }}</li>
                </ul>
              </div>
              <div class="bg-white rounded-xl p-4 border border-gray-100">
                <h3 class="text-sm font-semibold text-gray-700 mb-2">Attestations</h3>
                <ul class="text-sm text-gray-900 space-y-1">
                  <li>Revenus suffisants: {{ info.attestIncome ? 'Oui' : 'Non' }}</li>
                  <li>Transactions significatives: {{ info.attestSignificantTransaction ? 'Oui' : 'Non' }}</li>
                  <li>Compréhension des risques: {{ info.attestAware ? 'Oui' : 'Non' }}</li>
                  <li>Sincérité des informations: {{ info.attestTruth ? 'Oui' : 'Non' }}</li>
                </ul>
              </div>
            </div>

            {% if ik %}
            <div class="mt-6 grid grid-cols-1 gap-6">
              <!-- Questionnaire de connaissances: Produits financiers -->
              <div class="bg-gradient-to-br from-violet-50 to-fuchsia-50 rounded-xl p-5 border border-violet-100">
                <div class="flex items-center justify-between mb-3">
                  <h3 class="text-sm font-semibold text-gray-800">Questionnaire — Connaissance des produits financiers</h3>
                  <button type="button" class="text-xs px-2 py-1 rounded bg-violet-600 text-white" onclick="document.getElementById('modal-knowledge').classList.remove('hidden')">Voir les réponses</button>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-gray-900">
                  {% for i in 1..8 %}
                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                      <div class="text-gray-700 mb-1">{{ financialLabels[i-1] }}</div>
                      <div class="font-semibold">{{ financialProducts ? (answerMap[attribute(financialProducts, 'getQuestion' ~ i)] ?? '—') : '—' }}</div>
                    </div>
                  {% endfor %}
                </div>
              </div>

              <!-- Questionnaire de connaissances: Produits complexes -->
              <div class="bg-gradient-to-br from-violet-50 to-fuchsia-50 rounded-xl p-5 border border-violet-100">
                <h3 class="text-sm font-semibold text-gray-800 mb-3">Questionnaire — Connaissance des produits complexes</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-gray-900">
                  {% for i in 1..10 %}
                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                      <div class="text-gray-700 mb-1">{{ complexLabels[i-1] }}</div>
                      <div class="font-semibold">{{ complexProducts ? (answerMap[attribute(complexProducts, 'getQuestion' ~ i)] ?? '—') : '—' }}</div>
                    </div>
                  {% endfor %}
                </div>
              </div>

              <!-- Expérience de marché détaillée -->
              <div class="bg-gradient-to-br from-violet-50 to-fuchsia-50 rounded-xl p-5 border border-violet-100">
                <h3 class="text-sm font-semibold text-gray-800 mb-3">Expérience des marchés</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-gray-900">
                  <div class="bg-white rounded-lg p-3 border border-gray-100"><span>Actions</span><span class="float-right font-semibold">{{ marketExperience and marketExperience.hasStocksExperience ? 'Oui' : 'Non' }}</span></div>
                  <div class="bg-white rounded-lg p-3 border border-gray-100"><span>Obligations</span><span class="float-right font-semibold">{{ marketExperience and marketExperience.hasBondsExperience ? 'Oui' : 'Non' }}</span></div>
                  <div class="bg-white rounded-lg p-3 border border-gray-100"><span>OPCVM</span><span class="float-right font-semibold">{{ marketExperience and marketExperience.hasUcitsExperience ? 'Oui' : 'Non' }}</span></div>
