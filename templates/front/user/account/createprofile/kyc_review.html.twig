            <div class="space-y-3">
              
              
              <a id="btn-pdf" href="{{ path('user_kyc_pdf', { open: 1 }) }}" 
                 class="block w-full px-4 py-2.5 rounded-xl text-white font-semibold text-center shadow-lg transition-all duration-200 bg-gradient-to-r from-emerald-600 to-teal-600 hover:from-emerald-700 hover:to-teal-700" 
                 target="_blank">
                <svg class="w-5 h-5 inline mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/>
                </svg>
                Télécharger le PDF
              </a>
              
              <a id="btn-next" href="{{ path('user_investor_profile') }}" 
                 class="block w-full px-4 py-2.5 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold text-center shadow-lg hover:shadow-xl transition-all duration-200">
                <span class="inline-flex items-center">
                  Continuer
                  <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
