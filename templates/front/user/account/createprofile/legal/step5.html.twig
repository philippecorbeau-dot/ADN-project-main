{% extends 'front/layouts/funnel.layout.html.twig' %}
{% import 'macro/alert.html.twig' as alert %}

{% block body %}
<div class="container pb-10 mt-24 md:mt-0">
    <div class="rounded-xl bg-white p-6 sm:p-10 shadow-md transition-opacity transition-transform">
        <!-- Header moderne cohérent avec le parcours Particulier -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-r from-indigo-600 to-blue-600 rounded-full mb-4">
                <i class="fa-solid fa-file-shield text-white text-2xl"></i>
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">
                {% trans %}Vos documents justificatifs{% endtrans %}
            </h1>
            <p class="text-lg text-gray-600">{% trans %}Vous y êtes presque ! Il reste à téléverser les documents légaux de votre société.{% endtrans %}</p>
        </div>

        <!-- Encart conseils (design proche natural) -->
        <div class="bg-gradient-to-br from-blue-500 via-blue-600 to-indigo-600 rounded-2xl p-8 mb-8 text-white shadow-xl">
            <div class="flex items-center mb-6">
                <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center">
                    <i class="fa-solid fa-lightbulb text-white text-xl"></i>
                </div>
                <div class="ml-4">
                    <h3 class="text-xl font-bold">Conseils pour l'upload</h3>
                    <p class="text-blue-100 text-sm">Formats acceptés: PDF, PNG, JPG, JPEG. Taille max 10 Mo</p>
                </div>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
                <div class="flex items-start"><div class="w-6 h-6 bg-white/20 rounded-full flex items-center justify-center mr-3"><i class="fa-solid fa-check text-white text-xs"></i></div><span class="text-blue-50">Assurez‑vous que le document est lisible et complet</span></div>
                <div class="flex items-start"><div class="w-6 h-6 bg-white/20 rounded-full flex items-center justify-center mr-3"><i class="fa-solid fa-check text-white text-xs"></i></div><span class="text-blue-50">Photographiez ou exportez en PDF/PNG/JPG (pas de scan flou)</span></div>
                <div class="flex items-start"><div class="w-6 h-6 bg-white/20 rounded-full flex items-center justify-center mr-3"><i class="fa-solid fa-check text-white text-xs"></i></div><span class="text-blue-50">Un seul fichier par rubrique suffit</span></div>
            </div>
        </div>

        {% if documents is defined and documents|length > 0 %}
            <div class="mb-8">
                <h2 class="text-xl font-semibold mb-4 text-gray-800 flex items-center">
                    <i class="fa-solid fa-folder-open text-indigo-600 mr-3"></i>
                    Documents déjà envoyés
                </h2>
                <div class="space-y-3">
                    {% for doc in documents %}
                        <div class="bg-white border-2 border-gray-200 rounded-xl p-4 hover:border-indigo-300 transition-all duration-200">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center">
                                    <i class="fa-solid fa-file text-indigo-600 text-lg"></i>
                                    <div class="ml-3">
                                        <p class="font-medium text-gray-800">
                                            {{ doc.type == 'registration_proof' ? 'KBIS' : (doc.type == 'articles_of_association' ? 'Statuts' : 'Déclaration des bénéficiaires effectifs') }}
                                        </p>
                                        <p class="text-sm text-gray-500">Envoyé le {{ doc.uploadedAt|date('d/m/Y à H:i') }}</p>
                                    </div>
                                </div>
                                <span class="px-3 py-1 rounded-full text-xs font-semibold {{ doc.status == 'pending' ? 'bg-yellow-100 text-yellow-800 border border-yellow-200' : (doc.status == 'validated' ? 'bg-green-100 text-green-800 border border-green-200' : 'bg-red-100 text-red-800 border border-red-200') }}">
                                    {{ doc.status == 'pending' ? 'En attente' : (doc.status == 'validated' ? 'Validé' : 'Refusé') }}
                                </span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <!-- Formulaire (design harmonisé) -->
        {{ form_start(form, {'attr': {'id': 'form-step5', 'enctype': 'multipart/form-data'}}) }}

        <!-- Pièce d'identité -->
        <div class="mb-8">
            <label class="block text-base font-semibold mb-4 text-gray-800"><i class="fa-solid fa-id-card text-blue-600 mr-2"></i>Pièce d'identité</label>
            <div class="relative border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-blue-400 transition-colors duration-200 bg-gray-50 hover:bg-blue-50">
                <i class="fa-solid fa-cloud-upload-alt text-4xl text-gray-400 mb-4"></i>
                <p class="text-lg font-medium text-gray-700 mb-2">Glissez votre fichier ici</p>
                <p class="text-sm text-gray-500 mb-4">ou cliquez pour sélectionner</p>
                <div class="flex items-center justify-center space-x-2 text-xs text-gray-500"><i class="fa-solid fa-file"></i><span>PDF, PNG, JPG, JPEG - Max 10Mo</span></div>
                {{ form_widget(form.identityProof, { 'attr': { 'class': 'absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10', 'accept': 'application/pdf,image/*' } }) }}
            </div>
            <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date d'expiration</label>
                    {{ form_widget(form.identityExpirationDate, { 'attr': { 'class': 'w-full border border-gray-300 rounded-md px-3 py-2 date-mask', 'placeholder': 'JJ/MM/AAAA' } }) }}
                    {{ form_errors(form.identityExpirationDate) }}
                    <p class="text-xs text-gray-500 mt-1">La pièce d'identité doit être en cours de validité.</p>
                </div>
            </div>
            <div id="identity-preview" class="hidden mt-4">
                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                    <div class="flex items-center">
                        <i class="fa-solid fa-check-circle text-green-600 mr-3"></i>
                        <span class="text-green-800 font-medium">Fichier identité sélectionné</span>
                    </div>
                </div>
            </div>
            {{ form_errors(form.identityProof) }}
        </div>

        <!-- KBIS -->
        <div class="mb-8">
            <label class="block text-base font-semibold mb-4 text-gray-800"><i class="fa-solid fa-briefcase text-indigo-600 mr-2"></i>KBIS (moins de 3 mois)</label>
            <div class="relative border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-indigo-400 transition-colors duration-200 bg-gray-50 hover:bg-indigo-50">
                <i class="fa-solid fa-cloud-upload-alt text-4xl text-gray-400 mb-4"></i>
                <p class="text-lg font-medium text-gray-700 mb-2">Glissez votre fichier ici</p>
                <p class="text-sm text-gray-500 mb-4">ou cliquez pour sélectionner</p>
                <div class="flex items-center justify-center space-x-2 text-xs text-gray-500"><i class="fa-solid fa-file"></i><span>PDF, PNG, JPG, JPEG - Max 10Mo</span></div>
                {{ form_widget(form.registrationProof, { 'attr': { 'class': 'absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10', 'accept': 'application/pdf,image/*' } }) }}
            </div>
            <div id="reg-preview" class="hidden mt-4">
                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                    <div class="flex items-center">
                        <i class="fa-solid fa-check-circle text-green-600 mr-3"></i>
                        <span class="text-green-800 font-medium">KBIS sélectionné</span>
                    </div>
                </div>
            </div>
            {{ form_errors(form.registrationProof) }}
        </div>

        <!-- Statuts -->
        <div class="mb-8">
            <label class="block text-base font-semibold mb-4 text-gray-800"><i class="fa-solid fa-scale-balanced text-purple-600 mr-2"></i>Statuts à jour et signés</label>
            <div class="relative border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-purple-400 transition-colors duration-200 bg-gray-50 hover:bg-purple-50">
                <i class="fa-solid fa-cloud-upload-alt text-4xl text-gray-400 mb-4"></i>
                <p class="text-lg font-medium text-gray-700 mb-2">Glissez votre fichier ici</p>
                <p class="text-sm text-gray-500 mb-4">ou cliquez pour sélectionner</p>
                <div class="flex items-center justify-center space-x-2 text-xs text-gray-500"><i class="fa-solid fa-file"></i><span>PDF, PNG, JPG, JPEG - Max 10Mo</span></div>
                {{ form_widget(form.articlesOfAssociation, { 'attr': { 'class': 'absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10', 'accept': 'application/pdf,image/*' } }) }}
            </div>
            <div id="articles-preview" class="hidden mt-4">
                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                    <div class="flex items-center">
                        <i class="fa-solid fa-check-circle text-green-600 mr-3"></i>
                        <span class="text-green-800 font-medium">Statuts sélectionnés</span>
                    </div>
                </div>
            </div>
            {{ form_errors(form.articlesOfAssociation) }}
        </div>

        <!-- Déclaration des bénéficiaires effectifs -->
        <div class="mb-8">
            <label class="block text-base font-semibold mb-4 text-gray-800"><i class="fa-solid fa-users text-emerald-600 mr-2"></i>Déclaration des bénéficiaires effectifs</label>
            <div class="relative border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-emerald-400 transition-colors duration-200 bg-gray-50 hover:bg-emerald-50">
                <i class="fa-solid fa-cloud-upload-alt text-4xl text-gray-400 mb-4"></i>
                <p class="text-lg font-medium text-gray-700 mb-2">Glissez votre fichier ici</p>
                <p class="text-sm text-gray-500 mb-4">ou cliquez pour sélectionner</p>
                <div class="flex items-center justify-center space-x-2 text-xs text-gray-500"><i class="fa-solid fa-file"></i><span>PDF, PNG, JPG, JPEG - Max 10Mo</span></div>
                {{ form_widget(form.shareholderDeclaration, { 'attr': { 'class': 'absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10', 'accept': 'application/pdf,image/*' } }) }}
            </div>
            <div id="ubo-preview" class="hidden mt-4">
                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                    <div class="flex items-center">
                        <i class="fa-solid fa-check-circle text-green-600 mr-3"></i>
                        <span class="text-green-800 font-medium">Déclaration UBO sélectionnée</span>
                    </div>
                </div>
            </div>
            {{ form_errors(form.shareholderDeclaration) }}
        </div>

        <div class="flex justify-between items-center pt-6 border-t border-gray-200">
            <a href="{{ path('user_create_profile', {'step' : 4 }) }}" class="flex items-center px-6 py-3 text-gray-700 bg-white border-2 border-gray-300 rounded-xl hover:border-gray-400 hover:bg-gray-50 transition-all duration-200 font-medium">
                <i class="fa-solid fa-arrow-left mr-2"></i>
                {% trans %}Précédent{% endtrans %}
            </a>
            <button id="btn-submit-pro5" type="submit" class="flex items-center px-8 py-3 bg-gradient-to-r from-indigo-600 to-blue-600 text-white rounded-xl hover:from-indigo-700 hover:to-blue-700 transition-all duration-200 font-medium shadow-lg hover:shadow-xl">
                <i class="fa-solid fa-paper-plane mr-2"></i>
                {% trans %}Envoyer{% endtrans %}
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>

{% include 'front/partials/modals/finish-profile.html.twig' %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    function bindPreview(inputSelector, previewId) {
        const input = document.querySelector(inputSelector);
        if (!input) return;
        const preview = document.getElementById(previewId);
        const dropZone = input.closest('.relative').querySelector('.border-dashed');
        input.addEventListener('change', function(e) {
            if (e.target.files && e.target.files.length > 0) {
                if (preview) preview.classList.remove('hidden');
                if (dropZone) { dropZone.classList.add('border-green-400','bg-green-50'); dropZone.classList.remove('border-gray-300'); }
            } else {
                if (preview) preview.classList.add('hidden');
                if (dropZone) { dropZone.classList.remove('border-green-400','bg-green-50'); dropZone.classList.add('border-gray-300'); }
            }
        });
    }

    bindPreview('input[name$="[identityProof]"]', 'identity-preview');
    bindPreview('input[name$="[registrationProof]"]', 'reg-preview');
    bindPreview('input[name$="[articlesOfAssociation]"]', 'articles-preview');
    bindPreview('input[name$="[shareholderDeclaration]"]', 'ubo-preview');
});
</script>
{% endblock %}

