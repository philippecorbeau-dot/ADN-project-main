{% extends 'front/user/dashboard/base.html.twig' %}

{% block title %}Refaire le parcours KYC - ADN Family Office{% endblock %}
{% block page_title %}🔄 Refaire le parcours KYC{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto">
    <!-- Info Banner (édition non destructive) -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 mb-8">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="ml-3 flex-1">
                <h3 class="text-sm font-medium text-amber-800">Mettre à jour vos informations KYC</h3>
                <div class="mt-2 text-sm text-amber-700">
                    <p>Vous pouvez reprendre le parcours pour modifier vos informations et documents. Vos données existantes sont conservées. Le nom et le prénom restent non modifiables.</p>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Current KYC Status -->
    <div class="bg-white shadow-sm rounded-xl p-6 mb-8">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Statut actuel de votre KYC</h3>
        
        {% set currentStep = user.stepKyc ?? 0 %}
        {% set progressPercent = (currentStep / 5 * 100)|round %}
        
        <div class="mb-4">
            <div class="flex items-center justify-between text-sm text-gray-600 mb-2">
                <span>Étape {{ currentStep }}/5</span>
                <span>{{ progressPercent }}% complété</span>
            </div>
            
            <!-- Progress Bar -->
            <div class="w-full bg-gray-200 rounded-full h-3">
                <div class="h-3 rounded-full bg-gradient-to-r from-adn-blue to-adn-blue-light transition-all duration-700" 
                     style="width: {{ progressPercent }}%"></div>
            </div>
        </div>
        
        <!-- Current Step Info -->
        <div class="bg-blue-50 rounded-lg p-4">
            <h4 class="text-sm font-medium text-blue-900 mb-1">
                {% if currentStep == 0 %}
                    Parcours non commencé
                {% elseif currentStep == 1 %}
                    Étape 1 : Profil personnel
                {% elseif currentStep == 2 %}
                    Étape 2 : Objectifs d'investissement
                {% elseif currentStep == 3 %}
                    Étape 3 : Situation patrimoniale
                {% elseif currentStep == 4 %}
                    Étape 4 : Expérience d'investissement
                {% elseif currentStep == 5 %}
                    Étape 5 : Documents - Parcours complété
                {% endif %}
            </h4>
            <p class="text-sm text-blue-700">
                {% if currentStep == 5 %}
                    Votre parcours KYC est terminé. Vous pouvez néanmoins le refaire si vous souhaitez mettre à jour vos informations.
                {% else %}
                    Vous pouvez continuer votre parcours actuel ou le recommencer depuis le début.
                {% endif %}
            </p>
        </div>
    </div>
    
    <!-- Restart Reason -->
    {% if restartMessage %}
    <div class="bg-orange-50 border border-orange-200 rounded-xl p-6 mb-8">
        <h3 class="text-sm font-medium text-orange-800 mb-2">Motif suggéré pour refaire le parcours</h3>
        <p class="text-sm text-orange-700">{{ restartMessage }}</p>
    </div>
    {% endif %}
    
    <!-- Action Buttons -->
    <div class="bg-white shadow-sm rounded-xl p-6">
        <h3 class="text-lg font-medium text-gray-900 mb-6">Que souhaitez-vous faire ?</h3>
        
        <div class="space-y-4">
            <!-- Continue Current KYC -->
            {% if currentStep < 5 %}
            <div class="flex items-center justify-between p-4 bg-green-50 border border-green-200 rounded-lg">
                <div>
                    <h4 class="text-sm font-medium text-green-900">Continuer le parcours actuel</h4>
                    <p class="text-sm text-green-700">Reprenez là où vous vous êtes arrêté (étape {{ currentStep + 1 }})</p>
                </div>
                <a href="{{ path('user_create_profile', {step: currentStep + 1}) }}" 
                   class="bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-green-700 transition-colors">
                    Continuer
                </a>
            </div>
            {% endif %}
            
            <!-- Reprendre depuis le début (sans effacer les données) -->
            <div class="flex items-center justify-between p-4 bg-red-50 border border-red-200 rounded-lg">
                <div>
                    <h4 class="text-sm font-medium text-red-900">Reprendre depuis l'étape 1</h4>
                    <p class="text-sm text-red-700">Revenir à l'étape 1 pour mise à jour, sans supprimer vos données existantes</p>
                </div>
                <form method="POST" action="{{ path('user_kyc_restart_confirm') }}" style="display: inline;">
                    <button type="submit"
                            onclick="return confirm('Confirmez-vous la reprise du parcours à l\'étape 1 ? Vos données existantes seront conservées.')"
                            class="bg-red-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-red-700 transition-colors">
                        Reprendre
                    </button>
                </form>
            </div>
            
            <!-- Cancel -->
            <div class="flex items-center justify-between p-4 bg-gray-50 border border-gray-200 rounded-lg">
                <div>
                    <h4 class="text-sm font-medium text-gray-900">Annuler</h4>
                    <p class="text-sm text-gray-700">Revenir au dashboard sans modification</p>
                </div>
                <a href="{{ path('user_dashboard') }}" 
                   class="bg-gray-200 text-gray-800 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-300 transition-colors">
                    Annuler
                </a>
            </div>
        </div>
    </div>
    
    <!-- FAQ Section -->
    <div class="mt-8 bg-blue-50 rounded-xl p-6">
        <h3 class="text-lg font-medium text-blue-900 mb-4">Questions fréquentes</h3>
        
        <div class="space-y-4 text-sm">
            <div>
                <h4 class="font-medium text-blue-800">Pourquoi refaire le parcours KYC ?</h4>
                <p class="text-blue-700 mt-1">Vous pourriez avoir besoin de refaire le parcours si vos informations personnelles ont changé, si des documents ont été refusés, ou pour mettre à jour votre profil d'investisseur.</p>
            </div>
            
            <div>
                <h4 class="font-medium text-blue-800">Que se passe-t-il si je recommence ?</h4>
                <p class="text-blue-700 mt-1">Votre progression actuelle sera effacée et vous devrez remplir à nouveau toutes les étapes du parcours KYC. Vos documents précédemment envoyés resteront accessibles.</p>
            </div>
            
            <div>
                <h4 class="font-medium text-blue-800">Combien de temps cela prend-il ?</h4>
                <p class="text-blue-700 mt-1">Le parcours KYC complet prend généralement 10-15 minutes. La validation des documents peut prendre 1-3 jours ouvrés.</p>
            </div>
        </div>
        
        <div class="mt-6 pt-4 border-t border-blue-200">
            <p class="text-sm text-blue-700">
                <strong>Besoin d'aide ?</strong> 
                <a href="{{ path('user_advisor') }}" class="text-blue-800 hover:text-blue-900 underline">Contactez notre équipe support</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}


