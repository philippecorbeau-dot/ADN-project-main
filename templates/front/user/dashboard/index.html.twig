            </div>
            <div class="space-y-2 mb-4">
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Rendement</span>
                    <span class="font-bold text-emerald-600">6-8%</span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Ticket</span>
                    <span class="font-medium text-gray-700">1 000€</span>
