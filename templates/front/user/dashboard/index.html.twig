                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
        </a>

        {# PEA-PME #}
        <a href="{{ path('user_investment_pea_pme') }}" class="dash-card group p-5 block" onclick="trackOpportunityClick('PEA-PME', 'discover');">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(37,99,235,0.15));">
                    <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4 4a2 2 0 00-2 2v4a2 2 0 002 2V6h10a2 2 0 00-2-2H4zm2 6a2 2 0 012-2h8a2 2 0 012 2v4a2 2 0 01-2 2H8a2 2 0 01-2-2v-4zm6 4a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="min-w-0">
                    <h3 class="font-bold text-gray-900 text-sm group-hover:text-blue-700 transition-colors">PEA-PME</h3>
                    <p class="text-xs text-gray-400 truncate">PME françaises</p>
                </div>
            </div>
            <div class="space-y-2 mb-4">
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Fiscalité</span>
                    <span class="font-bold text-blue-600">Exonération</span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Plafond</span>
                    <span class="font-medium text-gray-700">225 000€</span>
                </div>
            </div>
            <div class="flex items-center justify-center gap-1.5 text-xs font-semibold text-indigo-600 group-hover:text-indigo-700 pt-3 border-t border-gray-100/80 transition-colors">
                Découvrir
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
        </a>

        {# Assurance-vie #}
        <a href="{{ path('user_investment_assurance_vie') }}" class="dash-card group p-5 block" onclick="trackOpportunityClick('Assurance-vie', 'discover');">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(124,58,237,0.15));">
                    <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M3 6a3 3 0 013-3h10a1 1 0 01.8 1.6L14.25 8l2.55 3.4A1 1 0 0116 13H6a1 1 0 00-1 1v3a1 1 0 11-2 0V6z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="min-w-0">
                    <h3 class="font-bold text-gray-900 text-sm group-hover:text-purple-700 transition-colors">Assurance-vie</h3>
                    <p class="text-xs text-gray-400 truncate">Épargne flexible</p>
                </div>
            </div>
            <div class="space-y-2 mb-4">
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Fiscalité</span>
                    <span class="font-bold text-purple-600">Après 8 ans</span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Transmission</span>
                    <span class="font-medium text-gray-700">Hors succession</span>
                </div>
            </div>
            <div class="flex items-center justify-center gap-1.5 text-xs font-semibold text-indigo-600 group-hover:text-indigo-700 pt-3 border-t border-gray-100/80 transition-colors">
                Découvrir
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
        </a>

        {# PER #}
        <a href="{{ path('user_investment_per') }}" class="dash-card group p-5 block" onclick="trackOpportunityClick('PER', 'discover');">
            <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, rgba(245,158,11,0.1), rgba(234,88,12,0.15));">
                    <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 20 20">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <div class="min-w-0">
                    <h3 class="font-bold text-gray-900 text-sm group-hover:text-amber-700 transition-colors">PER</h3>
                    <p class="text-xs text-gray-400 truncate">Plan retraite</p>
                </div>
            </div>
            <div class="space-y-2 mb-4">
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Déduction</span>
                    <span class="font-bold text-amber-600">10% du revenu</span>
                </div>
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Sortie</span>
                    <span class="font-medium text-gray-700">Rente / Capital</span>
                </div>
            </div>
            <div class="flex items-center justify-center gap-1.5 text-xs font-semibold text-indigo-600 group-hover:text-indigo-700 pt-3 border-t border-gray-100/80 transition-colors">
                Découvrir
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
        </a>
    </div>

    {# CTA Banner #}
    <div class="mt-6 rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-between gap-4" style="background: linear-gradient(135deg, #4f46e5 0%, #6366f1 50%, #818cf8 100%);">
        <div class="flex items-center gap-4 text-white">
            <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center flex-shrink-0 backdrop-blur-sm">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
