                    <div class="w-1.5 h-1.5 rounded-full bg-gray-300 animate-pulse"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-gray-300 animate-pulse" style="animation-delay: 0.2s"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-gray-300 animate-pulse" style="animation-delay: 0.4s"></div>
                </div>
            </div>
        </div>

        {# Épargne bancaire #}
        <div id="synthese-epargne-bancaire" class="dash-account-card dash-animate-in dash-delay-4">
            <div class="dash-account-header">
                <div class="flex items-center gap-3">
                    <div class="dash-icon" style="background: linear-gradient(135deg, rgba(59,130,246,0.08), rgba(99,102,241,0.08));">
                        <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <span class="font-semibold text-gray-900 text-sm">Épargne bancaire</span>
                </div>
                <div class="flex items-center gap-2">
                    <span id="synthese-eb-total" class="text-base font-bold text-gray-400"></span>
                    <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </div>
            </div>
            <div id="synthese-eb-body" class="dash-account-body text-center">
                <div class="flex items-center justify-center gap-2 py-2">
                    <div class="w-1.5 h-1.5 rounded-full bg-gray-300 animate-pulse"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-gray-300 animate-pulse" style="animation-delay: 0.2s"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-gray-300 animate-pulse" style="animation-delay: 0.4s"></div>
                </div>
            </div>
        </div>

        {# Placements financiers — lien vers l'onglet Détails #}
        <a href="#" @click.prevent="activeTab = 'details'" class="block dash-account-card group dash-animate-in dash-delay-5">
            <div class="dash-account-header">
                <div class="flex items-center gap-3">
                    <div class="dash-icon" style="background: linear-gradient(135deg, rgba(16,185,129,0.08), rgba(20,184,166,0.08));">
                        <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
                        </svg>
                    </div>
                    <span class="font-semibold text-gray-900 text-sm group-hover:text-emerald-700 transition-colors">Placements financiers</span>
                </div>
                <div class="flex items-center gap-3">
                    <span id="total-placements" class="text-base font-bold text-gray-900">{{ totalEncoursAll|number_format(2, ',', ' ') }}&nbsp;€</span>
                    <svg class="w-4 h-4 text-gray-300 group-hover:text-emerald-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </div>
            </div>
        </a>
    </div>
</div>

{# ═══════════════════════════════════════════════════════════════════
   SECTION OPPORTUNITÉS D'INVESTISSEMENT
   ═══════════════════════════════════════════════════════════════════ #}
