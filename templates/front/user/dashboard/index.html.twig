</div>

</div>{# fin onglet synthèse #}

{# ═══════════════════════════════════════════════════════════════════
   ONGLET 2 : DÉTAILS — Vue détaillée des contrats
   ═══════════════════════════════════════════════════════════════════ #}
<div x-show="activeTab === 'details'" x-cloak x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform translate-y-2" x-transition:enter-end="opacity-100 transform translate-y-0">

<div class="mb-8">
    {# Header #}
    <div class="flex items-center justify-between mb-6 dash-animate-in">
        <div class="flex items-center gap-3">
            <div class="dash-icon" style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(20,184,166,0.1));">
                <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
                </svg>
            </div>
            <h2 class="dash-section-title">Placements financiers</h2>
        </div>
        <span class="dash-badge dash-badge-emerald">
            {{ totalEncoursAll|number_format(2, ',', ' ') }}&nbsp;€
        </span>
    </div>

    {# Distributor Accordions #}
    {% if productsByDistributor is defined and productsByDistributor|length > 0 %}
    <div class="space-y-4" x-data="{ openDist: '{{ productsByDistributor|keys|first }}' }">
        {% for distName, distData in productsByDistributor %}
        <div class="dash-dist-card dash-animate-in dash-delay-{{ loop.index }}">
            {# Header distributeur #}
            <button @click="openDist = openDist === '{{ distName }}' ? '' : '{{ distName }}'"
                    class="dash-dist-header">
                <div class="flex items-center gap-3">
                    <div class="dash-icon" style="background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(139,92,246,0.08));">
                        <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                        </svg>
                    </div>
                    <span class="font-bold text-gray-900">{{ distName }}</span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="font-bold text-gray-900 text-lg" data-dist-total="{{ distName }}">{{ distData.total|number_format(2, ',', ' ') }}&nbsp;€</span>
                    <svg class="w-5 h-5 text-gray-400 transition-transform duration-300"
                         :class="openDist === '{{ distName }}' ? 'rotate-180' : ''"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </div>
            </button>

            {# Produits sous ce distributeur #}
            <div x-show="openDist === '{{ distName }}'" x-collapse>
                {% for p in distData.products %}
                <div class="border-t border-gray-100/80">
                    <a href="{{ path('user_product_show', {id: p.id}) }}"
                       class="dash-product-row group"
                       data-product-id="{{ p.id }}">
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-1">
                                <span class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors truncate text-sm">{{ p.alias ?? ('Produit #' ~ p.id) }}</span>
                            </div>
                            <div class="flex items-center gap-2 text-xs text-gray-500">
                                <span class="px-2 py-0.5 bg-gray-100/80 rounded-md text-gray-600 font-medium text-[11px]">{{ p.type|replace({'_': ' '}) }}</span>
                                <span class="text-gray-400" data-valuation-date="{{ p.id }}">
                                    {% if p.o2sValuationDate is defined and p.o2sValuationDate %}
                                    Val. {{ p.o2sValuationDate|date('d/m/Y') }}
                                    {% endif %}
                                </span>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 flex-shrink-0 ml-4 text-right">
                            {% if p.versements is defined and p.versements is not null and p.versements > 0 %}
                            <div class="hidden sm:block">
                                <span class="text-[10px] text-gray-400 block uppercase tracking-wide">Versements</span>
                                <span class="text-xs text-gray-600 font-medium">{{ p.versements|number_format(2, ',', ' ') }}&nbsp;€</span>
                            </div>
                            {% endif %}
                            <div>
                                <span class="font-bold text-gray-900 text-sm dash-number-glow" data-product-amount="{{ p.id }}">{{ p.encours|number_format(2, ',', ' ') }}&nbsp;€</span>
                            </div>
                            <svg class="w-4 h-4 text-gray-300 group-hover:text-indigo-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </a>
