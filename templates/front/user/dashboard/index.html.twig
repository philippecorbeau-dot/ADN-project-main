                    createLineChart('product-chart-' + productId, h.chart.map(p => p.date), h.chart.map(p => p.value), {
                        lineWidth: 1.5, hoverRadius: 3, hideScales: true,
                        color: h.evoPct >= 0 ? '#10b981' : '#ef4444'
                    });
                }
            }
        });
    })
    .catch(err => {
        console.warn('Data load error:', err);
        document.querySelectorAll('#o2s-loading-indicator, #o2s-loading-details').forEach(el => el.remove());
    });
}
{% else %}
function loadO2SEnrichedData() { /* Non-O2S user: rien à charger */ }
{% endif %}
</script>
{% endblock %}
