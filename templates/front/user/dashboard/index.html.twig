        <a href="{{ path('user_advisor') }}" class="bg-white text-indigo-700 px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-indigo-50 transition-colors flex-shrink-0 shadow-lg shadow-indigo-900/20">
            Prendre rendez-vous
        </a>
