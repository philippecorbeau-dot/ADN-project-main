{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
/* ─── Tracking des clics opportunités ─── */
function trackOpportunityClick(productType, action) {
    fetch('/api/investment/track-click', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ product: productType, action: action })
    }).catch(() => {});
}

const fmt = (n) => new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);
const fmtPct = (n) => (n >= 0 ? '+' : '') + fmt(n) + ' %';

{# ─── Patrimoine KYC chart (rendu immédiat si données KYC disponibles) ─── #}
{% if patrimoineData is defined and patrimoineData and patrimoineData.hasData %}
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('patrimoineChart');
    if (ctx) {
        const patrimoineLinks = [
            '{{ path('user_patrimoine_immobilier') }}',
            '{{ path('user_patrimoine_financier') }}'
        ];
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Immobilier', 'Actifs financiers'],
                datasets: [{
                    data: [{{ patrimoineData.immobilier.pourcentage }}, {{ patrimoineData.actifs_financiers.pourcentage }}],
                    backgroundColor: [
                        createGradientForDoughnut(ctx, '#3b82f6', '#6366f1'),
                        createGradientForDoughnut(ctx, '#06b6d4', '#22d3ee')
                    ],
                    borderWidth: 4,
                    borderColor: '#fff',
                    hoverOffset: 12,
                    hoverBorderWidth: 2,
                    borderRadius: 4,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                cutout: '72%',
                animation: {
                    animateRotate: true,
                    duration: 1400,
                    easing: 'easeOutQuart'
                },
                onHover: (event, elements) => {
                    event.native.target.style.cursor = elements.length ? 'pointer' : 'default';
                },
                onClick: (event, elements) => {
                    if (elements.length > 0) {
                        const idx = elements[0].index;
                        if (patrimoineLinks[idx]) window.location.href = patrimoineLinks[idx];
                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.95)',
                        padding: 14,
                        cornerRadius: 10,
                        displayColors: true,
                        boxPadding: 6,
                        titleFont: { size: 13, weight: '600' },
                        bodyFont: { size: 12 },
                        callbacks: {
                            label: (ctx) => `${ctx.label}: ${ctx.parsed}% — Cliquer pour détails`
                        }
                    }
                }
            }
        });
    }
});

function createGradientForDoughnut(canvas, color1, color2) {
    const el = canvas instanceof HTMLCanvasElement ? canvas : document.getElementById(canvas);
    if (!el) return color1;
    const ctx2d = el.getContext('2d');
    const gradient = ctx2d.createLinearGradient(0, 0, el.width, el.height);
    gradient.addColorStop(0, color1);
    gradient.addColorStop(1, color2);
    return gradient;
}
{% endif %}

/* ─── Helpers graphiques ─── */
function createLineChart(canvasId, labels, dataPoints, options = {}) {
    const ctx = document.getElementById(canvasId);
    if (!ctx) return null;
    const fmtLabels = labels.map(d => { const p = d.split('-'); return p[2]+'/'+p[1]; });

    // Gradient fill
    const ctx2d = ctx.getContext('2d');
    const gradient = ctx2d.createLinearGradient(0, 0, 0, ctx.parentElement?.clientHeight || 64);
    const baseColor = options.color || '#6366f1';
    gradient.addColorStop(0, baseColor + '18');
    gradient.addColorStop(1, baseColor + '02');

    return new Chart(ctx, {
        type: 'line',
        data: {
            labels: fmtLabels,
            datasets: [{
                data: dataPoints,
                borderColor: baseColor,
                backgroundColor: gradient,
                fill: true,
                tension: 0.4,
                borderWidth: options.lineWidth || 2,
                pointRadius: 0,
                pointHoverRadius: options.hoverRadius || 5,
                pointHoverBackgroundColor: baseColor,
                pointHoverBorderColor: '#fff',
                pointHoverBorderWidth: 2,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: 'rgba(15,23,42,0.95)', padding: 12, cornerRadius: 8, displayColors: false,
                    titleFont: { size: 11 }, bodyFont: { size: 12, weight: '600' },
                    callbacks: { label: (c) => fmt(c.parsed.y) + ' €' }
                }
            },
            scales: options.hideScales ? { x: { display: false }, y: { display: false } } : {
                x: { grid: { display: false }, ticks: { font: { size: 10, weight: '500' }, color: '#94a3b8', maxTicksLimit: 8 } },
                y: { grid: { color: 'rgba(241,245,249,0.8)', drawBorder: false }, ticks: { font: { size: 10 }, color: '#94a3b8', callback: (v) => (v / 1000).toFixed(0) + ' k€' } }
            },
            interaction: {
                intersect: false,
                mode: 'index'
            }
        }
    });
}

{% if not (patrimoineData is defined and patrimoineData and patrimoineData.hasData) %}
function createGradientForDoughnut(canvas, color1, color2) {
    const el = canvas instanceof HTMLCanvasElement ? canvas : document.getElementById(canvas);
    if (!el) return color1;
    const ctx2d = el.getContext('2d');
    const gradient = ctx2d.createLinearGradient(0, 0, el.width, el.height);
    gradient.addColorStop(0, color1);
    gradient.addColorStop(1, color2);
    return gradient;
}
{% endif %}

/* ─── 1. Rafraîchissement asynchrone des valorisations ─── */
/* ─── 2. Chargement AJAX des données enrichies ─── */
/* Les deux appels sont chaînés : refresh d'abord → puis enrichissement.
   Cela garantit la cohérence entre les totaux produits et le patrimoine O2S. */
document.addEventListener('DOMContentLoaded', function() {
    const spinner = document.getElementById('refresh-spinner');
    const statusText = document.getElementById('refresh-text');

    if (spinner) spinner.classList.remove('hidden');
    if (statusText) statusText.textContent = 'Mise à jour…';

    // ─── Étape 1 : Rafraîchir les valorisations depuis l'API O2S ───
    fetch('{{ path("user_api_refresh_valuations") }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/json' }
    })
    .then(r => r.json())
    .then(data => {
        if (!data.success) return;
        let anyChanged = false;

        // Regrouper les encours par distributeur pour mettre à jour les sous-totaux
        const distTotals = {};

        (data.products || []).forEach(p => {
            // Toujours mettre à jour les montants individuels (même si « pas changé » pour corriger le cache)
            const amountEl = document.querySelector('[data-product-amount="' + p.id + '"]');
            if (amountEl) {
                amountEl.textContent = fmt(p.encours) + ' €';
                if (p.changed) {
                    amountEl.classList.add('updated');
                    setTimeout(() => amountEl.classList.remove('updated'), 2500);
                }
            }
            const dateEl = document.querySelector('[data-valuation-date="' + p.id + '"]');
            if (dateEl && p.valuationDate) dateEl.textContent = 'Val. ' + p.valuationDate;

            // Accumuler pour les sous-totaux distributeur
            if (p.distributor) {
                distTotals[p.distributor] = (distTotals[p.distributor] || 0) + (p.encours || 0);
            }

            if (p.changed) anyChanged = true;
        });

        // Mettre à jour les totaux globaux
        const totalStr = fmt(data.totalEncours) + ' €';
        ['total-badge', 'total-placements', 'kpi-encours'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.textContent = totalStr;
        });

        // Mettre à jour les sous-totaux distributeur
        Object.entries(distTotals).forEach(([dist, total]) => {
            const distEl = document.querySelector('[data-dist-total="' + dist + '"]');
            if (distEl) distEl.textContent = fmt(total) + ' €';
        });

        if (spinner) spinner.classList.add('hidden');
        if (statusText) {
            statusText.textContent = anyChanged ? '✓ Mis à jour' : '✓ À jour';
            statusText.classList.add('text-emerald-600');
            setTimeout(() => { if (statusText) statusText.textContent = ''; }, 4000);
        }
    })
    .catch(err => {
        console.warn('Refresh valuations error:', err);
        if (spinner) spinner.classList.add('hidden');
        if (statusText) statusText.textContent = '';
    })
    .finally(() => {
        // ─── Étape 2 : Charger les données enrichies APRÈS le refresh ───
        loadO2SEnrichedData();
    });
});

{% if isO2SUser is defined and isO2SUser %}
function loadO2SEnrichedData() {
    fetch('{{ path("user_api_dashboard_o2s_data") }}', {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
        if (!data.success || !data.hasO2S) return;

        // ─── AUTO-SYNC: Si des comptes ont été créés automatiquement, rafraîchir la page ───
        if (data.autoSynced) {
            console.info('Auto-sync: nouveaux comptes créés, rechargement de la page…');
            window.location.reload();
            return;
        }

        // ─── Mettre à jour le total des placements si disponible ───
        if (data.totalPlacementsFinanciers !== undefined && data.totalPlacementsFinanciers > 0) {
            const totalStr = fmt(data.totalPlacementsFinanciers) + ' €';
            ['total-badge', 'total-placements'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.textContent = totalStr;
            });
        }

        // Masquer les skeletons
        document.querySelectorAll('#o2s-loading-indicator, #o2s-loading-details').forEach(el => el.remove());

        // ═══ ONGLET SYNTHÈSE : patrimoine ═══

        // ─── Patrimoine dans Synthèse ───
        if (data.patrimoineData && data.patrimoineData.hasData) {
            const pd = data.patrimoineData;
            const o2sZone = document.getElementById('patrimoine-o2s-zone');
            const defaultZone = document.getElementById('patrimoine-default-zone');
            if (o2sZone) {
                if (defaultZone) defaultZone.classList.add('hidden');

                const immoPct = pd.immobilier?.pourcentage || 0;
                const finPct  = pd.actifs_financiers?.pourcentage || 0;
                const immoMontant = pd.immobilier?.montant || 0;
                const finMontant  = pd.actifs_financiers?.montant || 0;
                const passifMontant = pd.passif || 0;

                // Mise à jour du titre Patrimoine avec le montant
                const patrimoineHeader = o2sZone.closest('div')?.querySelector('h2');
                if (patrimoineHeader && patrimoineHeader.textContent.trim() === 'Patrimoine') {
                    patrimoineHeader.insertAdjacentHTML('afterend',
                        `<span class="dash-badge dash-badge-indigo ml-3">${fmt(pd.patrimoine)} €</span>`);
                }

                o2sZone.innerHTML = `
                <div class="dash-card dash-card-accent p-0">
                    {# Card Header #}
                    <div class="px-7 pt-6 pb-0">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm font-medium text-gray-400 uppercase tracking-wide">Actif</span>
                            <span class="dash-amount-hero">${fmt(pd.actif)} €</span>
                        </div>
                    </div>

                    <div class="dash-divider"></div>

                    {# Donut + Legend #}
                    <div class="px-7 py-6">
                        <div class="flex items-center gap-10 dash-patrimoine-grid" style="justify-content: center;">
                            <div class="donut-wrapper" style="width: 180px; height: 180px; flex-shrink: 0;">
                                <canvas id="patrimoine-o2s-donut"></canvas>
                                <div class="donut-center-text">
                                    <div class="donut-amount">${fmt(pd.actif)} €</div>
                                    <div class="donut-label">Actif total</div>
                                </div>
                            </div>
                            <div class="space-y-2 flex-1 min-w-0">
                                <a href="{{ path('user_patrimoine_immobilier') }}" class="dash-legend group hover:bg-indigo-50/60">
                                    <div class="dash-legend-dot" style="background: linear-gradient(135deg, #3b82f6, #6366f1);"></div>
                                    <div class="flex-1 min-w-0">
                                        <span class="text-sm font-semibold text-gray-700 group-hover:text-indigo-700 transition-colors">Immobilier</span>
                                    </div>
                                    <span class="text-sm font-bold text-gray-900">${immoPct} %</span>
                                    <svg class="w-4 h-4 text-gray-300 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </a>
                                <a href="{{ path('user_patrimoine_financier') }}" class="dash-legend group hover:bg-cyan-50/60">
                                    <div class="dash-legend-dot" style="background: linear-gradient(135deg, #06b6d4, #22d3ee);"></div>
                                    <div class="flex-1 min-w-0">
                                        <span class="text-sm font-semibold text-gray-700 group-hover:text-cyan-700 transition-colors">Actifs financiers</span>
                                    </div>
                                    <span class="text-sm font-bold text-gray-900">${finPct} %</span>
                                    <svg class="w-4 h-4 text-gray-300 group-hover:text-cyan-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </a>
                            </div>
                        </div>
                    </div>

                    {# Passif #}
                    <div class="dash-divider"></div>
                    <div class="px-7 py-4">
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-medium text-gray-400 uppercase tracking-wide">Passif</span>
                            <span class="text-xl font-bold ${passifMontant > 0 ? 'text-red-500' : 'text-gray-900'}">${fmt(passifMontant)} €</span>
                        </div>
                    </div>

                    {# Data badge #}
                    <div class="px-7 pb-5">
                        <div class="flex items-center gap-2.5 text-xs text-gray-400">
                            <div class="dash-pulse"></div>
                            <span>${pd.stockCount || 0} éléments patrimoniaux</span>
                        </div>
                    </div>
                </div>`;
                o2sZone.classList.remove('hidden');

                // Initialiser le donut
                const donutCtx = document.getElementById('patrimoine-o2s-donut');
                const patrimoineLinks = [
                    '{{ path('user_patrimoine_immobilier') }}',
                    '{{ path('user_patrimoine_financier') }}'
                ];
                if (donutCtx && (immoPct > 0 || finPct > 0)) {
                    new Chart(donutCtx, {
                        type: 'doughnut',
                        data: {
                            labels: ['Immobilier', 'Actifs financiers'],
                            datasets: [{
                                data: [immoPct, finPct],
                                backgroundColor: [
                                    createGradientForDoughnut(donutCtx, '#3b82f6', '#6366f1'),
                                    createGradientForDoughnut(donutCtx, '#06b6d4', '#22d3ee')
                                ],
                                borderWidth: 4,
                                borderColor: '#fff',
                                hoverOffset: 12,
                                hoverBorderWidth: 2,
                                borderRadius: 4,
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: true,
                            cutout: '72%',
                            animation: { animateRotate: true, duration: 1400, easing: 'easeOutQuart' },
                            onHover: (event, elements) => {
                                event.native.target.style.cursor = elements.length ? 'pointer' : 'default';
                            },
                            onClick: (event, elements) => {
                                if (elements.length > 0) {
                                    const idx = elements[0].index;
                                    if (patrimoineLinks[idx]) window.location.href = patrimoineLinks[idx];
                                }
                            },
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: 'rgba(15,23,42,0.95)', padding: 14, cornerRadius: 10,
                                    displayColors: true, boxPadding: 6,
                                    callbacks: {
                                        label: function(ctx) {
                                            const val = ctx.dataIndex === 0 ? immoMontant : finMontant;
                                            return ` ${ctx.parsed}% — ${fmt(val)} € — Cliquer pour détails`;
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
            }

            // ─── Remplir Comptes courants dans Synthèse ───
            const ccTotal = document.getElementById('synthese-cc-total');
            const ccBody = document.getElementById('synthese-cc-body');
            const ccMontant = pd.actifs_financiers?.comptes_courants || 0;
            const ccStocks = pd.stocksByFinCategorie?.comptes_courants || [];
            if (ccTotal) ccTotal.textContent = fmt(ccMontant) + ' €';
            if (ccBody) {
                if (ccStocks.length > 0) {
                    ccBody.innerHTML = ccStocks.map(s => `
                        <div class="flex items-center justify-between py-2.5 px-1 border-b border-gray-50 last:border-0">
                            <div class="flex items-center gap-2.5">
                                <div class="w-2 h-2 rounded-full" style="background: linear-gradient(135deg, #94a3b8, #64748b);"></div>
                                <span class="text-sm text-gray-700">${s.libelle}</span>
                            </div>
                            <span class="text-sm font-bold text-gray-900">${fmt(s.valeur)} €</span>
                        </div>
                    `).join('');
                } else {
                    ccBody.innerHTML = '<p class="text-sm text-gray-400 py-2">Aucun compte courant.</p>';
                }
            }

            // ─── Remplir Épargne bancaire dans Synthèse ───
            const ebTotal = document.getElementById('synthese-eb-total');
            const ebBody = document.getElementById('synthese-eb-body');
            const ebMontant = pd.actifs_financiers?.epargne_bancaire || 0;
            const ebStocks = pd.stocksByFinCategorie?.epargne_bancaire || [];
            if (ebTotal) ebTotal.textContent = fmt(ebMontant) + ' €';
            if (ebBody) {
                if (ebStocks.length > 0) {
                    ebBody.innerHTML = ebStocks.map(s => `
                        <div class="flex items-center justify-between py-2.5 px-1 border-b border-gray-50 last:border-0">
                            <div class="flex items-center gap-2.5">
                                <div class="w-2 h-2 rounded-full" style="background: linear-gradient(135deg, #3b82f6, #6366f1);"></div>
                                <span class="text-sm text-gray-700">${s.libelle}</span>
                            </div>
                            <span class="text-sm font-bold text-gray-900">${fmt(s.valeur)} €</span>
                        </div>
                    `).join('');
                } else {
                    ebBody.innerHTML = '<p class="text-sm text-gray-400 py-2">Aucune épargne bancaire.</p>';
                }
            }
        } else {
            // Pas de données patrimoine : afficher messages par défaut pour CC et EB
            const ccBody = document.getElementById('synthese-cc-body');
            const ebBody = document.getElementById('synthese-eb-body');
            if (ccBody) ccBody.innerHTML = '<p class="text-sm text-gray-400 py-2">Aucun compte courant.</p>';
            if (ebBody) ebBody.innerHTML = '<p class="text-sm text-gray-400 py-2">Aucune épargne bancaire.</p>';
        }

        // ═══ ONGLET DÉTAILS : sparklines par contrat ═══
        const histories = data.perProductHistories || {};
        Object.keys(histories).forEach(productId => {
            const h = histories[productId];

            if (h.chart && h.chart.length > 1) {
                const wrap = document.querySelector('[data-product-chart-wrap="' + productId + '"]');
                if (wrap) {
                    wrap.classList.remove('hidden');
                    if (h.evoPct !== null) {
                        const evoEl = document.querySelector('[data-product-evo="' + productId + '"]');
                        if (evoEl) {
                            evoEl.textContent = fmtPct(h.evoPct);
                            evoEl.className = 'text-xs font-semibold ' + (h.evoPct >= 0 ? 'text-emerald-600' : 'text-red-500');
