            <span id="total-badge" class="dash-badge dash-badge-emerald">
                {{ totalEncoursAll|number_format(2, ',', ' ') }}&nbsp;€
            </span>
        </div>

        {# Comptes courants #}
        <div id="synthese-comptes-courants" class="dash-account-card dash-animate-in dash-delay-3">
            <div class="dash-account-header">
                <div class="flex items-center gap-3">
                    <div class="dash-icon" style="background: linear-gradient(135deg, rgba(100,116,139,0.08), rgba(148,163,184,0.08));">
                        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                        </svg>
                    </div>
                    <span class="font-semibold text-gray-900 text-sm">Comptes courants</span>
                </div>
