<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}ADN Family Office - Dashboard{% endblock %}</title>
    {{ encore_entry_link_tags('app') }}
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    {{ encore_entry_link_tags('user_dashboard') }}
    {{ encore_entry_script_tags('user_dashboard') }}
    {% block stylesheets %}
    <style>
        .nav-item-active {
            background: linear-gradient(135deg, #1C29A1 0%, #3B82F6 100%);
        }
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        .glass {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #1C29A1 0%, #3B82F6 100%);
        }
        [x-cloak] { display: none !important; }
    </style>
    {% endblock %}
</head>
<body class="h-full" 
      x-data="{ 
          sidebarOpen: false, 
          sidebarCollapsed: localStorage.getItem('sidebarCollapsed') === 'true',
          toggleSidebar() {
              this.sidebarCollapsed = !this.sidebarCollapsed;
              localStorage.setItem('sidebarCollapsed', this.sidebarCollapsed);
          }
      }" 
      x-cloak>
    <div class="flex h-full">
        {% if is_granted('ROLE_PREVIOUS_ADMIN') %}
        <div class="fixed top-3 left-1/2 -translate-x-1/2 z-50">
          <div class="flex items-center gap-3 px-3 py-2 rounded-full shadow-lg glass border-purple-200/50">
            <span class="inline-flex items-center gap-2 text-purple-700 text-sm font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Contrôle: {{ app.user.firstName ?? app.user.email }}
            </span>
            <div class="flex items-center gap-2">
              <a href="{{ path('user_dashboard', {'_switch_user': '_exit'}) }}" class="inline-flex items-center px-3 py-1 rounded-full bg-purple-600 text-white text-xs font-semibold hover:bg-purple-700">
                Quitter
              </a>
            </div>
          </div>
        </div>
        {% endif %}
        
        <!-- Sidebar Navigation -->
        <div class="fixed inset-y-0 left-0 z-50 bg-white border-r border-gray-200 transform transition-all duration-300 ease-in-out flex flex-col" 
             :class="{ 
                 '-translate-x-full lg:translate-x-0': !sidebarOpen, 
                 'translate-x-0': sidebarOpen,
                 'w-64': !sidebarCollapsed || sidebarOpen,
                 'lg:w-20': sidebarCollapsed && !sidebarOpen,
                 'lg:w-64': !sidebarCollapsed
             }">
            
            <!-- Mobile Close Button -->
            <button @click="sidebarOpen = false" 
                    class="lg:hidden absolute top-4 right-4 z-50 p-2 rounded-full bg-gray-50 text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-adn-blue shadow-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>

            <!-- Desktop Toggle Button (Bubble) -->
            <button @click="toggleSidebar()" 
                    class="hidden lg:flex absolute top-10 -right-3 z-50 w-6 h-6 bg-white border border-gray-200 rounded-full items-center justify-center text-gray-500 hover:text-adn-blue hover:border-adn-blue shadow-sm transition-all duration-200 focus:outline-none"
                    :class="sidebarCollapsed ? 'rotate-180' : ''"
                    title="Plier/Déplier le menu">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </button>
            
            <!-- Logo Section -->
            <div class="flex items-center justify-center h-24 mb-2 transition-all duration-300"
                 :class="sidebarCollapsed ? 'px-2' : 'px-6'">
                <!-- Full Logo -->
                <img src="{{ asset('build/theme/images/ADN_Logo_enlarged_x5.png') }}" 
                     alt="ADN Family Office" 
                     class="h-12 w-auto max-w-full transition-opacity duration-300"
                     x-show="!sidebarCollapsed && !sidebarOpen"
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 transform scale-90"
                     x-transition:enter-end="opacity-100 transform scale-100">
                     
                <!-- Mobile Full Logo (always show when mobile sidebar is open) -->
                <img src="{{ asset('build/theme/images/ADN_Logo_enlarged_x5.png') }}" 
                     alt="ADN Family Office" 
                     class="h-12 w-auto max-w-full lg:hidden"
                     x-show="sidebarOpen">

                <!-- Collapsed Icon Logo -->
                <img src="{{ asset('assets/favicon-192.png') }}" 
                     alt="ADN" 
                     class="h-10 w-10 object-contain transition-opacity duration-300 hidden lg:block"
                     x-show="sidebarCollapsed && !sidebarOpen"
                     x-transition:enter="transition ease-out duration-200 delay-100"
                     x-transition:enter-start="opacity-0 transform scale-90"
                     x-transition:enter-end="opacity-100 transform scale-100">
            </div>

            <!-- Navigation Items -->
            <div class="flex-1 overflow-y-auto py-4">
                <nav class="space-y-2 px-3">
                    <!-- Accueil Site -->
                    <a href="{{ path('app_home') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg transition-all hover-lift text-indigo-600 hover:text-indigo-700 hover:bg-indigo-50 border border-indigo-100"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Accueil du site' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Accueil du site</span>
                    </a>

                    <div class="border-t border-gray-100 my-2"></div>

                    <!-- Synthèse -->
                    <a href="{{ path('user_dashboard') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg transition-all hover-lift {% if app.request.get('_route') in ['user_dashboard', 'user_patrimoine_immobilier', 'user_patrimoine_financier'] %}nav-item-active text-white{% else %}text-gray-600 hover:text-adn-blue hover:bg-blue-50{% endif %}"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Synthèse' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Synthèse</span>
                    </a>

                    <!-- Documents -->
                    <a href="{{ path('user_documents') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg transition-all hover-lift {% if app.request.get('_route') == 'user_documents' %}nav-item-active text-white{% else %}text-gray-600 hover:text-adn-blue hover:bg-blue-50{% endif %}"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Documents' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Documents</span>
                    </a>

                    <!-- Placements -->
                    <a href="{{ path('user_portfolio') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg transition-all hover-lift {% if app.request.get('_route') == 'user_portfolio' or app.request.get('_route') == 'user_product_show' %}nav-item-active text-white{% else %}text-gray-600 hover:text-adn-blue hover:bg-blue-50{% endif %}"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Placements' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Placements</span>
                    </a>

                    <!-- Opportunités -->
                    <a href="{{ path('user_opportunities') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg transition-all hover-lift {% if app.request.get('_route') == 'user_opportunities' %}nav-item-active text-white{% else %}text-gray-600 hover:text-adn-blue hover:bg-blue-50{% endif %}"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Opportunités' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Opportunités</span>
                    </a>

                    <!-- Conseiller -->
                    <a href="{{ path('user_advisor') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg transition-all hover-lift {% if app.request.get('_route') == 'user_advisor' %}nav-item-active text-white{% else %}text-gray-600 hover:text-adn-blue hover:bg-blue-50{% endif %}"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Conseiller' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Conseiller</span>
                    </a>

                    <!-- Paramètres -->
                    <a href="{{ path('user_settings') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg transition-all hover-lift {% if app.request.get('_route') == 'user_settings' or app.request.get('_route') == 'user_profile' %}nav-item-active text-white{% else %}text-gray-600 hover:text-adn-blue hover:bg-blue-50{% endif %}"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Paramètres' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Paramètres</span>
                    </a>
                </nav>

                <!-- Footer Actions -->
                <div class="mt-auto border-t border-gray-200 p-3 space-y-2">
                    <!-- Admin Access (visible pour tous les rôles admin) -->
                    {% if is_granted('ROLE_SUPER_ADMIN') or is_granted('ROLE_ADMIN') or is_granted('ROLE_ADMIN_OPERATOR') or is_granted('ROLE_ADMIN_KYC') or is_granted('ROLE_ADMIN_SUPPORT') or is_granted('ROLE_ADMIN_MARKETING') %}
                    <a href="{{ path('admin_modern_dashboard') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg text-yellow-600 hover:text-yellow-700 hover:bg-yellow-50 transition-all hover-lift"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Administration' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Administration</span>
                    </a>
                    {% endif %}

                    <!-- Logout -->
                    <a href="{{ path('app_logout') }}" 
                       class="group flex items-center px-3 py-3 text-sm font-medium rounded-lg text-red-600 hover:text-red-700 hover:bg-red-50 transition-all hover-lift"
                       :class="sidebarCollapsed ? 'justify-center' : 'justify-start gap-3'"
                       :title="sidebarCollapsed ? 'Déconnexion' : ''">
                        <svg class="h-6 w-6 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        <span x-show="!sidebarCollapsed" class="truncate">Déconnexion</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Mobile overlay -->
        <div x-show="sidebarOpen" 
             x-transition:enter="transition-opacity ease-linear duration-300"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition-opacity ease-linear duration-300"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             class="fixed inset-0 z-40 lg:hidden" 
             style="display: none;">
            <div class="absolute inset-0 bg-gray-600 opacity-75" @click="sidebarOpen = false"></div>
        </div>

        <!-- Main Content -->
        <div class="flex-1 transition-all duration-300 ease-in-out" 
             :class="sidebarCollapsed ? 'lg:ml-20' : 'lg:ml-64'">
            <!-- Top Header -->
            <header class="bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80 shadow-sm border-b border-gray-200 sticky top-0 z-40">
                <div class="flex items-center justify-between h-16 px-4 sm:px-6 lg:px-8">
                    <!-- Mobile menu button -->
                    <button @click="sidebarOpen = !sidebarOpen" 
                            class="lg:hidden -ml-0.5 -mt-0.5 h-12 w-12 inline-flex items-center justify-center rounded-md text-gray-500 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-adn-blue">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>

                    <!-- Logo + Page Title -->
                    <div class="flex-1 min-w-0 flex items-center ml-4 lg:ml-0">
                        <a href="{{ path('user_dashboard') }}" class="flex-shrink-0 mr-4 group" title="ADN Family Office" style="text-decoration: none;">
                            <span style="display: inline-flex; align-items: center; gap: 6px;">
                                <span style="font-size: 1.15rem; font-weight: 700; color: #1C29A1; letter-spacing: -0.02em;">ADN</span>
                                <span style="font-size: 1.15rem; font-weight: 300; color: #a0aec0;">|</span>
                                <span style="font-size: 0.85rem; font-weight: 500; color: #1C29A1; letter-spacing: 0.04em;">Family Office</span>
                            </span>
                        </a>
                        <div style="width: 1px; height: 24px; background: #e2e8f0; margin-right: 16px; flex-shrink: 0;"></div>
                        <h1 class="text-xl font-semibold text-gray-900 truncate">
                            {% block page_title %}Dashboard{% endblock %}
                        </h1>
                    </div>

                    <!-- User Menu -->
                    <div class="flex items-center space-x-4" x-data="{ userMenuOpen: false }">
                        <!-- Notifications Bell -->
                        <a href="{{ path('user_dashboard_notifications') }}" class="relative p-2 text-gray-500 hover:text-gray-700 transition-colors duration-200">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9zM13.73 21a2 2 0 01-3.46 0"/>
                            </svg>
                            {% if notificationsCount is defined and notificationsCount > 0 %}
                            <span class="absolute -top-1 -right-1 inline-flex items-center justify-center px-1.5 py-0.5 text-xs font-bold leading-none text-white bg-red-600 rounded-full min-w-[18px]">{{ notificationsCount }}</span>
                            {% endif %}
                        </a>

                        <!-- Messages (Chat) -->
                        {% set chatUnreadCount = unreadMessagesCount is defined ? unreadMessagesCount : globalUnreadMessagesCount %}
                        <a href="{{ path('user_chat_index') }}" class="relative p-2 text-gray-500 hover:text-gray-700 transition-colors duration-200" title="Chat avec l'équipe ADN">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                            </svg>
                            {% if chatUnreadCount > 0 %}
                            <span class="absolute -top-1 -right-1 inline-flex items-center justify-center px-1.5 py-0.5 text-xs font-bold leading-none text-white bg-blue-600 rounded-full min-w-[18px]">{{ chatUnreadCount }}</span>
                            {% endif %}
                        </a>

                        <!-- User Dropdown -->
                        <div class="relative">
                            <button @click="userMenuOpen = !userMenuOpen" 
                                    class="flex items-center text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-adn-blue focus:ring-offset-2">
                                <div class="h-9 w-9 rounded-full bg-gradient-to-br from-indigo-600 to-blue-600 flex items-center justify-center ring-2 ring-indigo-100">
                                    <span class="text-white font-semibold text-sm">
                                        {{ (user.firstName ? user.firstName|slice(0,1) : user.email|slice(0,1))|upper }}{{ (user.lastName ? user.lastName|slice(0,1) : '')|upper }}
                                    </span>
                                </div>
                                <span class="ml-2 text-sm font-medium text-gray-800 hidden sm:block">{{ user.firstName ? (user.firstName ~ ' ' ~ (user.lastName ?? '')) : user.email }}</span>
                                <svg class="ml-1 h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                                </svg>
                            </button>

                            <div x-show="userMenuOpen" 
                                 @click.away="userMenuOpen = false"
                                 x-transition:enter="transition ease-out duration-100"
                                 x-transition:enter-start="transform opacity-0 scale-95"
                                 x-transition:enter-end="transform opacity-100 scale-100"
                                 x-transition:leave="transition ease-in duration-75"
                                 x-transition:leave-start="transform opacity-100 scale-100"
                                 x-transition:leave-end="transform opacity-0 scale-95"
                                 class="origin-top-right absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 z-50"
                                 style="display: none;">
                                <div class="py-1">
                                    <a href="{{ path('app_home') }}" class="block px-4 py-2 text-sm text-indigo-600 hover:bg-indigo-50 font-medium">
                                        🏠 Accueil du site
                                    </a>
                                    <div class="border-t border-gray-100"></div>
                                    <a href="{{ path('user_profile') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                        👤 Mon profil
                                    </a>
                                    <a href="{{ path('user_settings') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                        ⚙️ Paramètres
                                    </a>
                                    {% if is_granted('ROLE_SUPER_ADMIN') %}
                                    <div class="border-t border-gray-100"></div>
                                    <a href="{{ path('admin_modern_dashboard') }}" class="block px-4 py-2 text-sm text-yellow-700 hover:bg-yellow-50">
                                        👑 Administration
                                    </a>
                                    {% endif %}
                                    <div class="border-t border-gray-100"></div>
                                    <a href="{{ path('app_logout') }}" class="block px-4 py-2 text-sm text-red-700 hover:bg-red-50">
                                        🚪 Déconnexion
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Main Content Area -->
            <main class="flex-1 relative overflow-y-auto focus:outline-none">
                <div class="py-3 sm:py-4 lg:py-6">
                    <div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-8">
                        {% block content %}{% endblock %}
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Système de Toast Unifié -->
    {% include 'components/toast_system.html.twig' %}

    {% block javascripts %}{% endblock %}
    
    <script>
    // Scroll vers les fragments après le chargement de la page
    document.addEventListener('DOMContentLoaded', function() {
        if (window.location.hash) {
            const hash = window.location.hash.substring(1);
            setTimeout(function() {
                const element = document.getElementById(hash);
                if (element) {
                    element.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    // Ajouter un highlight temporaire
                    element.style.transition = 'background-color 0.3s';
                    const originalBg = element.style.backgroundColor;
                    element.style.backgroundColor = '#fef3c7';
                    setTimeout(function() {
                        element.style.backgroundColor = originalBg;
                    }, 2000);
                }
            }, 100);
        }
    });
    </script>
</body>
