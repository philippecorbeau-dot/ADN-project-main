{% extends 'front/user/dashboard/base.html.twig' %}

{% block title %}Mes Documents - ADN Family Office{% endblock %}
{% block page_title %}📄 Mes Documents{% endblock %}

{% block content %}
<!-- Page Description -->
<div class="mb-6">
    <p class="text-sm text-gray-500">Gérez vos documents KYC et suivez leur statut de validation.</p>
</div>

<!-- Document Status Overview -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    {% set validatedCount = 0 %}
    {% set pendingCount = 0 %}
    {% set refusedCount = 0 %}
    
    {% for document in kycDocuments %}
        {% if document.status == 'VALIDATED' %}
            {% set validatedCount = validatedCount + 1 %}
        {% elseif document.status == 'PENDING' or document.status == 'VALIDATION_ASKED' %}
            {% set pendingCount = pendingCount + 1 %}
        {% elseif document.status == 'REFUSED' %}
            {% set refusedCount = refusedCount + 1 %}
        {% endif %}
    {% endfor %}

    <!-- Documents Validés -->
    <div class="bg-white overflow-hidden shadow-sm rounded-xl hover-lift">
        <div class="p-6">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                </div>
                <div class="ml-4">
                    <p class="text-2xl font-bold text-gray-900">{{ validatedCount }}</p>
                    <p class="text-sm text-gray-500">Documents validés</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Documents en attente -->
    <div class="bg-white overflow-hidden shadow-sm rounded-xl hover-lift">
        <div class="p-6">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-yellow-100 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                </div>
                <div class="ml-4">
                    <p class="text-2xl font-bold text-gray-900">{{ pendingCount }}</p>
                    <p class="text-sm text-gray-500">En cours de validation</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Documents refusés -->
    <div class="bg-white overflow-hidden shadow-sm rounded-xl hover-lift">
        <div class="p-6">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                </div>
                <div class="ml-4">
                    <p class="text-2xl font-bold text-gray-900">{{ refusedCount }}</p>
                    <p class="text-sm text-gray-500">Documents refusés</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Documents par type -->
<div class="space-y-6">
    {% for type, typeName in documentTypes %}
        {% set typeDocuments = documentsByType[type] ?? [] %}
        
        <div class="bg-white shadow-sm rounded-xl p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center">
                    <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center mr-3">
                        {% if type == 'identity' %}
                            <svg class="w-6 h-6 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                            </svg>
                        {% elseif type == 'address' or type == 'ADDRESS_PROOF' %}
                            <svg class="w-6 h-6 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                            </svg>
                        {% else %}
                            <svg class="w-6 h-6 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
                            </svg>
                        {% endif %}
                    </div>
                    <div>
                        <h3 class="text-lg font-medium text-gray-900">{{ typeName }}</h3>
                        <p class="text-sm text-gray-500">
                            {% if typeDocuments|length > 0 %}
                                {{ typeDocuments|length }} document(s) envoyé(s)
                            {% else %}
                                Aucun document envoyé
                            {% endif %}
                        </p>
                    </div>
                </div>
                
                <!-- Action button: ouvre un mini-formulaire d'upload inline -->
                <button type="button" class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors"
                        onclick="document.getElementById('upload-{{ type }}').classList.toggle('hidden')">
                    {% if typeDocuments|length == 0 %}Ajouter{% else %}Renvoyer{% endif %}
                </button>
            </div>
            
            <!-- Formulaire d'upload inline -->
            <div id="upload-{{ type }}" class="hidden border border-blue-100 rounded-lg p-4 mb-4 bg-blue-50">
                <form action="{{ path('user_document_upload') }}" method="post" enctype="multipart/form-data" class="flex items-center space-x-3">
                    <input type="hidden" name="type" value="{{ type }}"/>
                    <input type="file" name="file" accept="image/*,application/pdf" required
                           class="block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-blue-700"/>
                    <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-green-700">Envoyer</button>
                    <button type="button" class="text-gray-600 text-sm" onclick="document.getElementById('upload-{{ type }}').classList.add('hidden')">Annuler</button>
                </form>
                <p class="text-xs text-gray-500 mt-2">Formats acceptés: PDF, JPG, PNG. Taille entre 36 Ko et 10 Mo.</p>
            </div>

            <!-- Documents de ce type -->
            {% if typeDocuments|length > 0 %}
            <div class="space-y-3">
                {% for document in typeDocuments %}
                <div id="document-{{ document.id }}" class="border border-gray-200 rounded-lg p-4">
                    <div class="flex items-center justify-between">
                        <div class="flex-1">
                            <div class="flex items-center space-x-3 mb-2">
                                <!-- Status -->
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                    {% if document.status == 'VALIDATED' %}bg-green-100 text-green-800
                                    {% elseif document.status == 'PENDING' or document.status == 'VALIDATION_ASKED' %}bg-yellow-100 text-yellow-800
                                    {% elseif document.status == 'REFUSED' %}bg-red-100 text-red-800
                                    {% else %}bg-gray-100 text-gray-800{% endif %}">
                                    {% if document.status == 'VALIDATED' %}✅ Validé
                                    {% elseif document.status == 'PENDING' %}⏳ En attente
                                    {% elseif document.status == 'VALIDATION_ASKED' %}🔍 En cours de validation
                                    {% elseif document.status == 'REFUSED' %}❌ Refusé
                                    {% else %}{{ document.status }}{% endif %}
                                </span>
                                
                                <!-- Upload date -->
                                <span class="text-xs text-gray-500">
                                    Envoyé le {{ document.uploadedAt ? document.uploadedAt|date('d/m/Y à H:i') : document.createdAt|date('d/m/Y à H:i') }}
                                </span>
                                {% if document.type == 'identity' and document.expirationDate %}
                                    <span class="text-xs text-gray-500">• Expire le {{ document.expirationDate|date('d/m/Y') }}</span>
                                {% endif %}
                            </div>
                            
                            <!-- Filename -->
                            {% if document.filename %}
                            <p class="text-sm text-gray-600 truncate">
                                📎 {{ document.filename }}
                            </p>
                            {% endif %}
                            
                            <!-- Refusal reason -->
                            {% if document.status == 'REFUSED' and document.refusedReasonMessage %}
                            <div class="mt-2 p-2 bg-red-50 rounded border border-red-200">
                                <p class="text-sm text-red-800">
                                    <strong>Motif du refus :</strong> {{ document.refusedReasonMessageName ?? document.refusedReasonMessage }}
                                </p>
                            </div>
                            {% endif %}
                        </div>
                        
                        <!-- Actions -->
                        <div class="flex items-center space-x-2 ml-4">
                            {% if document.filename %}
                            <a href="{{ path('user_document_view', {id: document.id}) }}" 
                               target="_blank"
                               class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                                👁️ Voir
                            </a>
                            {% endif %}
                            
                            {# l'action Renvoyer se fait via le formulaire inline ci-dessus #}
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <!-- Empty state -->
            <div class="text-center py-8 bg-gray-50 rounded-lg">
                <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p class="text-gray-500 text-sm">Aucun document de ce type n'a encore été envoyé</p>
                <a href="{{ path('user_create_profile', {step: 5}) }}" 
                   class="mt-2 inline-flex items-center text-sm text-blue-600 hover:text-blue-800">
                    Ajouter un document →
                </a>
            </div>
            {% endif %}
        </div>
    {% endfor %}
</div>

<!-- Actions Footer -->
<div class="mt-8 bg-blue-50 rounded-xl p-6">
    <div class="flex items-center justify-between">
        <div>
            <h3 class="text-lg font-medium text-blue-900">Besoin d'aide avec vos documents ?</h3>
            <p class="text-blue-700 text-sm">Notre équipe peut vous accompagner dans la constitution de votre dossier.</p>
        </div>
        <div class="flex space-x-3">
            <a href="{{ path('user_create_profile', {step: 5}) }}" 
               class="bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-blue-700 transition-colors">
                Ajouter des documents
            </a>
            <a href="{{ path('user_advisor') }}" 
               class="bg-white text-blue-600 px-4 py-2 rounded-md text-sm font-medium border border-blue-200 hover:bg-blue-50 transition-colors">
                Contacter un conseiller
            </a>
        </div>
    </div>
</div>
{% endblock %}

