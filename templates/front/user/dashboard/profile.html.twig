{% extends 'front/user/dashboard/base.html.twig' %}

{% block title %}Mon Profil - ADN Family Office{% endblock %}
{% block page_title %}👤 Mon Profil{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Profile Header -->
    <div class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 rounded-2xl shadow-xl overflow-hidden mb-8">
        <div class="bg-white/10 backdrop-blur-sm p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row items-center sm:items-start space-y-4 sm:space-y-0 sm:space-x-6">
                <!-- Avatar -->
                <div class="relative">
                    <div class="w-24 h-24 sm:w-32 sm:h-32 bg-white/20 backdrop-blur-md rounded-2xl flex items-center justify-center shadow-lg ring-4 ring-white/30">
                        <span class="text-white font-bold text-3xl sm:text-4xl">
                            {{ (user.firstName ? user.firstName|slice(0,1) : user.email|slice(0,1))|upper }}{{ (user.lastName ? user.lastName|slice(0,1) : '')|upper }}
                        </span>
                    </div>
                    {% if user.isVerified %}
                    <div class="absolute -bottom-2 -right-2 bg-green-500 rounded-full p-2 shadow-lg ring-4 ring-white">
                        <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                    </div>
                    {% endif %}
                </div>
                
                <!-- Basic Info -->
                <div class="flex-1 text-center sm:text-left">
                    <h2 class="text-2xl sm:text-3xl font-bold text-white mb-2">
                        {% if user.firstName and user.lastName %}
                            {{ user.firstName }} {{ user.lastName }}
                        {% else %}
                            {{ user.email }}
                        {% endif %}
                    </h2>
                    <p class="text-white/90 text-sm sm:text-base mb-4">{{ user.email }}</p>
                    
                    <!-- Status badges -->
                    <div class="flex flex-wrap items-center justify-center sm:justify-start gap-2">
                        {% if user.isVerified %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-green-500/90 text-white backdrop-blur-sm shadow-md">
                                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                                Email vérifié
                            </span>
                        {% else %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-red-500/90 text-white backdrop-blur-sm shadow-md">
                                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                </svg>
                                Email non vérifié
                            </span>
                        {% endif %}
                        
                        {% if is_granted('ROLE_USER_IDENTIFIED') %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-blue-500/90 text-white backdrop-blur-sm shadow-md">
                                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                                </svg>
                                Identité vérifiée
                            </span>
                        {% endif %}
                        
                        {% if user.investorProfile %}
                            {% set profileColors = {
                                'PRUDENT': 'bg-gray-500/90',
                                'EQUILIBRE': 'bg-yellow-500/90',
                                'DYNAMIQUE': 'bg-orange-500/90',
                                'SPE': 'bg-red-500/90'
                            } %}
                            {% set profileIcons = {
                                'PRUDENT': '🛡️',
                                'EQUILIBRE': '⚖️',
                                'DYNAMIQUE': '🚀',
                                'SPE': '⚡'
                            } %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold {{ profileColors[user.investorProfile] ?? 'bg-gray-500/90' }} text-white backdrop-blur-sm shadow-md">
                                {{ profileIcons[user.investorProfile] ?? '' }} {{ user.investorProfile|title }}
                            </span>
                        {% endif %}
                    </div>
                </div>
                
                <!-- Actions -->
                <div class="w-full sm:w-auto">
                    <a href="{{ path('user_profile_edit') }}" 
                       class="inline-flex items-center justify-center w-full sm:w-auto bg-white text-blue-600 px-6 py-3 rounded-xl text-sm font-semibold hover:bg-white/90 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Modifier le profil
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Profile Details -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Personal Information -->
        <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100 hover:shadow-xl transition-shadow duration-300">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4">
                <h3 class="text-xl font-semibold text-white flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Informations personnelles
                </h3>
            </div>
            
            <div class="p-6">
                <dl class="space-y-5">
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Prénom</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">{{ user.firstName ?? 'Non renseigné' }}</dd>
                        </div>
                    </div>
                    
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">{{ user.lastName ?? 'Non renseigné' }}</dd>
                        </div>
                    </div>
                    
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Email</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900 break-all">{{ user.email }}</dd>
                        </div>
                    </div>
                    
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Téléphone</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">{{ user.phone ?? 'Non renseigné' }}</dd>
                        </div>
                    </div>
                    
                    {% if user.birthday %}
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-pink-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Date de naissance</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">{{ user.birthday|date('d/m/Y') }}</dd>
                        </div>
                    </div>
                    {% endif %}
                    
                    {% if user.gender %}
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Genre</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">{{ user.gender == 'male' ? 'Homme' : 'Femme' }}</dd>
                        </div>
                    </div>
                    {% endif %}
                </dl>
            </div>
        </div>
        
        <!-- Address Information -->
        <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100 hover:shadow-xl transition-shadow duration-300">
            <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-4">
                <h3 class="text-xl font-semibold text-white flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Adresse
                </h3>
            </div>
            
            <div class="p-6">
                <dl class="space-y-5">
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Adresse</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">{{ user.address ?? 'Non renseignée' }}</dd>
                        </div>
                    </div>
                    
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Ville</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">{{ user.city ?? 'Non renseignée' }}</dd>
                        </div>
                    </div>
                    
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-pink-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Code postal</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">{{ user.postalCode ?? 'Non renseigné' }}</dd>
                        </div>
                    </div>
                    
                    <div class="flex items-start">
                        <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <div class="ml-4 flex-1">
                            <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Pays</dt>
                            <dd class="mt-1 text-base font-medium text-gray-900">
                                {% if user.country %}
                                    {% if user.country == 'FR' %}France
                                    {% elseif user.country == 'BE' %}Belgique
                                    {% elseif user.country == 'LU' %}Luxembourg
                                    {% elseif user.country == 'CH' %}Suisse
                                    {% else %}{{ user.country }}
                                    {% endif %}
                                {% else %}
                                    Non renseigné
                                {% endif %}
                            </dd>
                        </div>
                    </div>
                </dl>
            </div>
        </div>
    </div>

    <!-- KYC Progress -->
    <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100 mb-8">
        <div class="bg-gradient-to-r from-emerald-600 to-teal-600 px-6 py-4">
            <h3 class="text-xl font-semibold text-white flex items-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Progression KYC
            </h3>
        </div>
        
        <div class="p-6">
            {% set currentStep = user.stepKyc ?? 0 %}
            {% set progressPercent = (currentStep / 5 * 100)|round %}
            
            <!-- Progress Header -->
            <div class="mb-6">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-lg font-semibold text-gray-900">Étape {{ currentStep }}/5</span>
                    <span class="text-2xl font-bold bg-gradient-to-r from-emerald-600 to-teal-600 bg-clip-text text-transparent">
                        {{ progressPercent }}%
                    </span>
                </div>
                
                <!-- Enhanced Progress Bar -->
                {% set progressGradient = 
                    progressPercent < 20 ? 'from-red-500 via-red-400 to-red-300' :
                    (progressPercent < 40 ? 'from-orange-500 via-orange-400 to-orange-300' :
                    (progressPercent < 60 ? 'from-yellow-500 via-yellow-400 to-yellow-300' :
                    (progressPercent < 80 ? 'from-blue-600 via-blue-500 to-blue-400' : 'from-emerald-600 via-green-500 to-teal-400'))) 
                %}
                <div class="relative w-full bg-gray-200 rounded-full h-6 overflow-hidden shadow-inner">
                    <div class="absolute inset-0 bg-gradient-to-r from-gray-100 to-gray-200 rounded-full"></div>
                    <div class="relative h-6 rounded-full bg-gradient-to-r {{ progressGradient }} transition-all duration-1000 ease-out shadow-lg flex items-center justify-end pr-2" 
                         style="width: {{ progressPercent }}%">
                        {% if progressPercent > 10 %}
                        <div class="w-4 h-4 bg-white rounded-full shadow-md"></div>
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <!-- KYC Steps -->
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-6">
                {% set steps = [
                    {
                        number: 1, 
                        title: 'Profil', 
                        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>',
                        color: 'blue'
                    },
                    {
                        number: 2, 
                        title: 'Objectifs', 
                        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>',
                        color: 'purple'
                    },
                    {
                        number: 3, 
                        title: 'Patrimoine', 
                        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>',
                        color: 'yellow'
                    },
                    {
                        number: 4, 
                        title: 'Expérience', 
                        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>',
                        color: 'indigo'
                    },
                    {
                        number: 5, 
                        title: 'Documents', 
                        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>',
                        color: 'green'
                    }
                ] %}
                
                {% for step in steps %}
                <div class="text-center group">
                    <div class="relative inline-block mb-3">
                        <div class="w-20 h-20 mx-auto rounded-2xl flex items-center justify-center transition-all duration-300 transform group-hover:scale-110 shadow-xl
                            {% if step.number <= currentStep %}bg-gradient-to-br from-green-500 to-emerald-600 text-white shadow-green-300 ring-2 ring-green-200
                            {% elseif step.number == currentStep + 1 %}bg-gradient-to-br from-blue-500 to-indigo-600 text-white shadow-blue-300 ring-4 ring-blue-200 animate-pulse
                            {% else %}bg-gradient-to-br from-gray-100 to-gray-200 text-gray-400 shadow-gray-200{% endif %}">
                            {% if step.number <= currentStep %}
                                <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                </svg>
                            {% else %}
                                <svg class="w-10 h-10 {% if step.number == currentStep + 1 %}text-white{% else %}text-gray-500{% endif %}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    {{ step.icon|raw }}
                                </svg>
                            {% endif %}
                        </div>
                        {% if step.number == currentStep + 1 %}
                        <div class="absolute -top-2 -right-2 w-6 h-6 bg-blue-500 rounded-full animate-pulse ring-4 ring-white shadow-lg flex items-center justify-center">
                            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                        {% endif %}
                        {% if step.number <= currentStep %}
                        <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-green-500 rounded-full ring-2 ring-white shadow-md flex items-center justify-center">
                            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                        {% endif %}
                    </div>
                    <p class="text-sm font-bold {% if step.number <= currentStep %}text-green-700{% elseif step.number == currentStep + 1 %}text-blue-700{% else %}text-gray-500{% endif %}">
                        {{ step.title }}
                    </p>
                    {% if step.number == currentStep + 1 %}
                    <p class="text-xs text-blue-600 font-medium mt-1">En cours</p>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
            
            <!-- KYC Actions -->
            <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-gray-200">
                {% if currentStep < 5 %}
                <a href="{{ path('user_create_profile', {step: currentStep + 1}) }}" 
                   class="flex-1 inline-flex items-center justify-center bg-gradient-to-r from-emerald-600 to-teal-600 text-white px-6 py-3 rounded-xl text-sm font-semibold hover:from-emerald-700 hover:to-teal-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                    </svg>
                    Continuer le parcours KYC
                </a>
                {% endif %}
                
                {% if currentStep > 1 %}
                <a href="{{ path('user_kyc_restart') }}" 
                   class="flex-1 inline-flex items-center justify-center bg-gray-100 text-gray-800 px-6 py-3 rounded-xl text-sm font-semibold hover:bg-gray-200 transition-all duration-300 shadow-sm hover:shadow-md">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    Refaire le parcours
                </a>
                {% endif %}
                
                <a href="{{ path('user_documents') }}" 
                   class="flex-1 inline-flex items-center justify-center bg-white text-emerald-600 px-6 py-3 rounded-xl text-sm font-semibold border-2 border-emerald-600 hover:bg-emerald-50 transition-all duration-300 shadow-sm hover:shadow-md">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    Voir mes documents
                </a>
            </div>
        </div>
    </div>

    <!-- Account Information -->
    <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100">
        <div class="bg-gradient-to-r from-gray-700 to-gray-800 px-6 py-4">
            <h3 class="text-xl font-semibold text-white flex items-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Informations du compte
            </h3>
        </div>
        
        <div class="p-6">
            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Date de création</dt>
                        <dd class="mt-1 text-base font-medium text-gray-900">{{ user.createdAt|date('d/m/Y à H:i') }}</dd>
                    </div>
                </div>
                
                {% if user.updatedAt %}
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Dernière mise à jour</dt>
                        <dd class="mt-1 text-base font-medium text-gray-900">{{ user.updatedAt|date('d/m/Y à H:i') }}</dd>
                    </div>
                </div>
                {% endif %}
                
                {% if user.lastLogin is defined and user.lastLogin %}
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Dernière connexion</dt>
                        <dd class="mt-1 text-base font-medium text-gray-900">{{ user.lastLogin|date('d/m/Y à H:i') }}</dd>
                    </div>
                </div>
                {% endif %}
                
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <dt class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Type de compte</dt>
                        <dd class="mt-1 text-base font-medium text-gray-900">
                            {% if user.isPro %}
                                <span class="inline-flex items-center">
                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                    </svg>
                                    Professionnel
                                </span>
                            {% else %}
                                <span class="inline-flex items-center">
                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                    </svg>
                                    Particulier
                                </span>
                            {% endif %}
                        </dd>
                    </div>
                </div>
            </dl>
        </div>
    </div>
</div>
{% endblock %}


