{% extends 'front/user/dashboard/base.html.twig' %}

{% block title %}Mon Conseiller - ADN Family Office{% endblock %}
{% block page_title %}👤 Mon Conseiller{% endblock %}

{% block content %}
<!-- Advisor Contact Card -->
<div class="bg-white shadow-sm rounded-xl p-8 mb-8 text-center">
    <div class="w-24 h-24 bg-gradient-to-br from-adn-blue to-adn-blue-light rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="text-white font-bold text-2xl">ADN</span>
    </div>
    
    <h2 class="text-2xl font-bold text-gray-900 mb-2">Équipe ADN Family Office</h2>
    <p class="text-gray-600 mb-6">Votre équipe de conseillers dédiés</p>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="text-center">
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mx-auto mb-2">
                <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
            </div>
            <h3 class="font-medium text-gray-900">Téléphone</h3>
            <p class="text-gray-600">+33 6 26 48 25 91</p>
        </div>
        
        <div class="text-center">
            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mx-auto mb-2">
                <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                </svg>
            </div>
            <h3 class="font-medium text-gray-900">Email</h3>
            <p class="text-gray-600">contact@adnfamilyoffice.fr</p>
        </div>
        
        <div class="text-center">
            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mx-auto mb-2">
                <svg class="w-6 h-6 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                </svg>
            </div>
            <h3 class="font-medium text-gray-900">Horaires</h3>
            <p class="text-gray-600">Lun-Ven 9h-18h</p>
        </div>
    </div>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+33626482591" 
           class="bg-adn-blue text-white px-6 py-3 rounded-md font-medium hover:bg-adn-blue-dark transition-colors flex items-center justify-center">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            Appeler maintenant
        </a>
        <a href="mailto:contact@adnfamilyoffice.fr" 
           class="bg-gray-200 text-gray-800 px-6 py-3 rounded-md font-medium hover:bg-gray-300 transition-colors flex items-center justify-center">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
            </svg>
            Envoyer un email
        </a>
    </div>
</div>

<!-- Quick Actions -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <!-- Schedule Appointment -->
    <div class="bg-white shadow-sm rounded-xl p-6 hover-lift">
        <div class="flex items-center mb-4">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-medium text-gray-900">Prendre rendez-vous</h3>
                <p class="text-sm text-gray-500">Planifiez un entretien avec votre conseiller</p>
            </div>
        </div>
        <button class="w-full bg-blue-600 text-white py-2 px-4 rounded-md font-medium hover:bg-blue-700 transition-colors">
            Réserver un créneau
        </button>
    </div>
    
    <!-- Quick Question -->
    <div class="bg-white shadow-sm rounded-xl p-6 hover-lift">
        <div class="flex items-center mb-4">
            <div class="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mr-4">
                <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 5v8a2 2 0 01-2 2h-5l-5 4v-4H4a2 2 0 01-2-2V5a2 2 0 012-2h12a2 2 0 012 2zM7 8H5v2h2V8zm2 0h2v2H9V8zm6 0h-2v2h2V8z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div>
                <h3 class="text-lg font-medium text-gray-900">Question rapide</h3>
                <p class="text-sm text-gray-500">Posez une question par message</p>
            </div>
        </div>
        <a href="{{ path('user_message_new') }}" class="w-full bg-green-600 text-white py-2 px-4 rounded-md font-medium hover:bg-green-700 transition-colors block text-center">
            Envoyer un message
        </a>
    </div>
</div>

<!-- FAQ Section -->
<div class="bg-white shadow-sm rounded-xl p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-6">Questions fréquentes</h3>
    
    <div class="space-y-4" x-data="{ openFaq: null }">
        <!-- FAQ Item 1 -->
        <div class="border border-gray-200 rounded-lg">
            <button @click="openFaq = openFaq === 1 ? null : 1" 
                    class="w-full text-left px-4 py-3 flex items-center justify-between hover:bg-gray-50">
                <span class="font-medium text-gray-900">Comment puis-je suivre mes investissements ?</span>
                <svg class="w-5 h-5 text-gray-500 transform transition-transform" :class="{ 'rotate-180': openFaq === 1 }" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </button>
            <div x-show="openFaq === 1" x-collapse class="px-4 pb-3">
                <p class="text-gray-600">Vous pouvez suivre vos investissements directement dans votre espace client, dans la section "Portfolio". Vous recevrez également des rapports trimestriels par email.</p>
            </div>
        </div>
        
        <!-- FAQ Item 2 -->
        <div class="border border-gray-200 rounded-lg">
            <button @click="openFaq = openFaq === 2 ? null : 2" 
                    class="w-full text-left px-4 py-3 flex items-center justify-between hover:bg-gray-50">
                <span class="font-medium text-gray-900">Quels sont les frais appliqués ?</span>
                <svg class="w-5 h-5 text-gray-500 transform transition-transform" :class="{ 'rotate-180': openFaq === 2 }" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </button>
            <div x-show="openFaq === 2" x-collapse class="px-4 pb-3">
                <p class="text-gray-600">Nos frais sont transparents et compétitifs. Ils varient selon le type d'investissement. Contactez votre conseiller pour obtenir le détail des frais applicables à votre situation.</p>
            </div>
        </div>
        
        <!-- FAQ Item 3 -->
        <div class="border border-gray-200 rounded-lg">
            <button @click="openFaq = openFaq === 3 ? null : 3" 
                    class="w-full text-left px-4 py-3 flex items-center justify-between hover:bg-gray-50">
                <span class="font-medium text-gray-900">Comment modifier mes objectifs d'investissement ?</span>
                <svg class="w-5 h-5 text-gray-500 transform transition-transform" :class="{ 'rotate-180': openFaq === 3 }" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </button>
            <div x-show="openFaq === 3" x-collapse class="px-4 pb-3">
                <p class="text-gray-600">Vous pouvez modifier vos objectifs d'investissement en refaisant votre parcours KYC ou en contactant directement votre conseiller qui vous accompagnera dans cette démarche.</p>
            </div>
        </div>
        
        <!-- FAQ Item 4 -->
        <div class="border border-gray-200 rounded-lg">
            <button @click="openFaq = openFaq === 4 ? null : 4" 
                    class="w-full text-left px-4 py-3 flex items-center justify-between hover:bg-gray-50">
                <span class="font-medium text-gray-900">Combien de temps pour valider mes documents ?</span>
                <svg class="w-5 h-5 text-gray-500 transform transition-transform" :class="{ 'rotate-180': openFaq === 4 }" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
            </button>
            <div x-show="openFaq === 4" x-collapse class="px-4 pb-3">
                <p class="text-gray-600">La validation de vos documents KYC prend généralement 1 à 3 jours ouvrés. En cas de document non conforme, nous vous contacterons rapidement pour vous guider.</p>
            </div>
        </div>
    </div>
</div>

<!-- Support Section -->
<div class="mt-8 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-6">
    <div class="text-center">
        <h3 class="text-lg font-medium text-gray-900 mb-2">Une question spécifique ?</h3>
        <p class="text-gray-600 mb-4">Notre équipe support est disponible pour vous aider</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="{{ path('user_chat_index') }}" class="bg-blue-600 text-white px-6 py-2 rounded-md font-medium hover:bg-blue-700 transition-colors inline-flex items-center justify-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                Chat en ligne
            </a>
            <a href="{{ path('user_message_new') }}" class="bg-white text-blue-600 px-6 py-2 rounded-md font-medium border border-blue-200 hover:bg-blue-50 transition-colors inline-flex items-center justify-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Créer un ticket
            </a>
        </div>
    </div>
</div>
{% endblock %}


