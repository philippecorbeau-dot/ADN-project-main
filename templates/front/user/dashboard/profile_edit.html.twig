{% extends 'front/user/dashboard/base.html.twig' %}

{% block title %}Modifier mon Profil - ADN Family Office{% endblock %}
{% block page_title %}✏️ Modifier mon Profil{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <form method="POST" action="{{ path('user_profile_edit') }}" class="space-y-8">
        <!-- Personal Information -->
        <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4">
                <h3 class="text-xl font-semibold text-white flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Informations personnelles
                </h3>
            </div>
            
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- First Name - Verrouillé -->
                    <div>
                        <label for="firstName" class="block text-sm font-semibold text-gray-700 mb-2 flex items-center">
                            Prénom *
                            <span class="ml-2 text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded">Verrouillé</span>
                        </label>
                        <input type="text" 
                               id="firstName" 
                               name="firstName" 
                               value="{{ user.firstName ?? '' }}"
                               readonly
                               disabled
                               class="block w-full px-4 py-3 border-2 border-gray-200 rounded-lg bg-gray-50 text-gray-600 cursor-not-allowed sm:text-sm">
                        <p class="mt-1 text-xs text-gray-500">Ce champ ne peut pas être modifié</p>
                    </div>
                    
                    <!-- Last Name - Verrouillé -->
                    <div>
                        <label for="lastName" class="block text-sm font-semibold text-gray-700 mb-2 flex items-center">
                            Nom *
                            <span class="ml-2 text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded">Verrouillé</span>
                        </label>
                        <input type="text" 
                               id="lastName" 
                               name="lastName" 
                               value="{{ user.lastName ?? '' }}"
                               readonly
                               disabled
                               class="block w-full px-4 py-3 border-2 border-gray-200 rounded-lg bg-gray-50 text-gray-600 cursor-not-allowed sm:text-sm">
                        <p class="mt-1 text-xs text-gray-500">Ce champ ne peut pas être modifié</p>
                    </div>
                    
                    <!-- Email -->
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email *</label>
                        <input type="email" 
                               id="email" 
                               name="email" 
                               value="{{ user.email }}"
                               required
                               class="block w-full px-4 py-3 border-2 border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all sm:text-sm">
                    </div>
                    
                    <!-- Phone -->
                    <div>
                        <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">Téléphone</label>
                        <input type="tel" 
                               id="phone" 
                               name="phone" 
                               value="{{ user.phone ?? '' }}"
                               placeholder="+33 6 12 34 56 78"
                               class="block w-full px-4 py-3 border-2 border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all sm:text-sm">
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Address Information -->
        <div class="bg-white shadow-lg rounded-2xl overflow-hidden border border-gray-100">
            <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-4">
                <h3 class="text-xl font-semibold text-white flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Adresse
                </h3>
            </div>
            
            <div class="p-6">
                <div class="space-y-6">
                    <!-- Address -->
                    <div>
                        <label for="address" class="block text-sm font-semibold text-gray-700 mb-2">Adresse complète</label>
                        <input type="text" 
                               id="address" 
                               name="address" 
                               value="{{ user.address ?? '' }}"
                               placeholder="123 Rue de la République"
                               class="block w-full px-4 py-3 border-2 border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all sm:text-sm">
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <!-- City -->
                        <div>
                            <label for="city" class="block text-sm font-semibold text-gray-700 mb-2">Ville</label>
                            <input type="text" 
                                   id="city" 
                                   name="city" 
                                   value="{{ user.city ?? '' }}"
                                   placeholder="Paris"
                                   class="block w-full px-4 py-3 border-2 border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all sm:text-sm">
                        </div>
                        
                        <!-- Postal Code -->
                        <div>
                            <label for="postalCode" class="block text-sm font-semibold text-gray-700 mb-2">Code postal</label>
                            <input type="text" 
                                   id="postalCode" 
                                   name="postalCode" 
                                   value="{{ user.postalCode ?? '' }}"
                                   placeholder="75001"
                                   class="block w-full px-4 py-3 border-2 border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all sm:text-sm">
                        </div>
                        
                        <!-- Country -->
                        <div>
                            <label for="country" class="block text-sm font-semibold text-gray-700 mb-2">Pays</label>
                            <select id="country" 
                                    name="country"
                                    class="block w-full px-4 py-3 border-2 border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all sm:text-sm bg-white">
                                <option value="">Sélectionner un pays</option>
                                <option value="FR" {% if user.country == 'FR' %}selected{% endif %}>France</option>
                                <option value="BE" {% if user.country == 'BE' %}selected{% endif %}>Belgique</option>
                                <option value="LU" {% if user.country == 'LU' %}selected{% endif %}>Luxembourg</option>
                                <option value="CH" {% if user.country == 'CH' %}selected{% endif %}>Suisse</option>
                                <option value="CA" {% if user.country == 'CA' %}selected{% endif %}>Canada</option>
                                <option value="US" {% if user.country == 'US' %}selected{% endif %}>États-Unis</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Form Actions -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 bg-white shadow-lg rounded-2xl p-6 border border-gray-100">
            <a href="{{ path('user_profile') }}" 
               class="w-full sm:w-auto inline-flex items-center justify-center bg-gray-100 text-gray-800 px-6 py-3 rounded-xl text-sm font-semibold hover:bg-gray-200 transition-all duration-300 shadow-sm hover:shadow-md">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
                Annuler
            </a>
            
            <button type="submit" 
                    class="w-full sm:w-auto inline-flex items-center justify-center bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-6 py-3 rounded-xl text-sm font-semibold hover:from-blue-700 hover:to-indigo-700 transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                Enregistrer les modifications
            </button>
        </div>
    </form>

<!-- Information Box -->
<div class="mt-8 bg-blue-50 border border-blue-200 rounded-xl p-6">
    <div class="flex items-start">
        <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
        </div>
        <div class="ml-3">
            <h3 class="text-sm font-medium text-blue-800">Information importante</h3>
            <div class="mt-2 text-sm text-blue-700">
                <ul class="list-disc list-inside space-y-1">
                    <li>Assurez-vous que vos informations personnelles sont exactes pour éviter tout problème lors de la validation de votre compte.</li>
                    <li>Si vous modifiez votre email, vous devrez le vérifier à nouveau.</li>
                    <li>Certaines modifications peuvent nécessiter une nouvelle vérification de vos documents KYC.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Auto-format phone number
    const phoneInput = document.getElementById('phone');
    if (phoneInput) {
        phoneInput.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length > 0) {
                if (value.startsWith('33')) {
                    value = '+' + value;
                } else if (value.startsWith('0')) {
                    value = '+33' + value.substring(1);
                }
            }
            e.target.value = value;
        });
    }
    
    // Form validation
    const form = document.querySelector('form');
    if (form) {
        form.addEventListener('submit', function(e) {
            const firstName = document.getElementById('firstName').value.trim();
            const lastName = document.getElementById('lastName').value.trim();
            const email = document.getElementById('email').value.trim();
            
            if (!firstName || !lastName || !email) {
                e.preventDefault();
                alert('Veuillez remplir tous les champs obligatoires (*)');
                return false;
            }
            
            // Email validation
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                e.preventDefault();
                alert('Veuillez saisir une adresse email valide');
                return false;
            }
        });
    }
});
</script>
{% endblock %}


