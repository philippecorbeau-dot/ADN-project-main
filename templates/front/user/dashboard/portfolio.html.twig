{% extends 'front/user/dashboard/base.html.twig' %}

{% block title %}Placements - ADN Family Office{% endblock %}
{% block page_title %}
    <span class="text-gray-900">Placements</span>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* ═══════════════════════════════════════════
   PORTFOLIO PAGE — PREMIUM DESIGN SYSTEM
   ═══════════════════════════════════════════ */

/* ── Ambient background ── */
.pf-page::before {
    content: '';
    position: fixed;
    top: 0; right: 0;
    width: 50vw; height: 50vh;
    background: radial-gradient(ellipse at top right, rgba(99,102,241,0.04) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
}
.pf-page::after {
    content: '';
    position: fixed;
    bottom: 0; left: 0;
    width: 40vw; height: 40vh;
    background: radial-gradient(ellipse at bottom left, rgba(16,185,129,0.03) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
}

/* ── Tabs ── */
.pf-tab {
    padding-bottom: 0.875rem;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    transition: all 0.3s ease;
    border-bottom: 2.5px solid transparent;
    color: #94a3b8;
}
.pf-tab:hover { color: #475569; }
.pf-tab-active {
    color: #0f172a;
    border-bottom-color: #6366f1;
}

/* ── Hero header ── */
.pf-hero {
    background: white;
    border-radius: 1.25rem;
    border: 1px solid rgba(226,232,240,0.7);
    box-shadow: 0 1px 2px rgba(0,0,0,0.02), 0 4px 16px rgba(0,0,0,0.03);
    position: relative;
    overflow: hidden;
}
.pf-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, #6366f1, #8b5cf6, #06b6d4);
}

/* ── Amount Hero ── */
.pf-amount {
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #0f172a;
}

/* ── Premium Card ── */
.pf-card {
    background: white;
    border-radius: 1.25rem;
    border: 1px solid rgba(226,232,240,0.7);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.01), 0 1px 2px rgba(0,0,0,0.02), 0 4px 16px rgba(0,0,0,0.03);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
}
.pf-card:hover {
    box-shadow: 0 0 0 1px rgba(0,0,0,0.02), 0 4px 8px rgba(0,0,0,0.04), 0 16px 48px rgba(0,0,0,0.06);
}

/* ── Section Title ── */
.pf-section-title {
    font-weight: 800;
    font-size: 1.125rem;
    color: #0f172a;
    letter-spacing: -0.025em;
    line-height: 1.3;
}

/* ── Icon Container ── */
.pf-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

/* ── Distributor Accordion ── */
.pf-dist-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    background: transparent;
    text-align: left;
}
.pf-dist-btn:hover {
    background: rgba(248,250,252,0.8);
}
.pf-dist-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

/* ── Product Row ── */
.pf-product-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.5rem;
    transition: all 0.2s ease;
    border-top: 1px solid rgba(241,245,249,0.8);
    text-decoration: none;
    color: inherit;
}
.pf-product-row:hover {
    background: linear-gradient(90deg, rgba(238,242,255,0.3), rgba(248,250,252,0.2));
}
.pf-product-row:hover .pf-product-name {
    color: #4f46e5;
}
.pf-product-row:hover .pf-product-arrow {
    background: rgba(199,210,254,0.4);
    color: #6366f1;
}
.pf-product-name {
    font-weight: 700;
    font-size: 0.875rem;
    color: #0f172a;
    transition: color 0.2s ease;
}
.pf-product-arrow {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(241,245,249,0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    color: #94a3b8;
}

/* ── Chart Card ── */
.pf-chart-card {
    background: white;
    border-radius: 1.25rem;
    border: 1px solid rgba(226,232,240,0.7);
    box-shadow: 0 1px 2px rgba(0,0,0,0.02), 0 4px 16px rgba(0,0,0,0.03);
    overflow: hidden;
    transition: all 0.3s ease;
}
.pf-chart-card:hover {
    box-shadow: 0 4px 8px rgba(0,0,0,0.04), 0 16px 48px rgba(0,0,0,0.06);
}
.pf-chart-header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(241,245,249,0.8);
    display: flex;
    align-items: center;
    justify-content: space-between;
}

/* ── Legend Grid — Responsive for many accounts ── */
.pf-legend-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
}
.pf-legend-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    background: rgba(248,250,252,0.5);
    border: 1px solid transparent;
    min-width: 0;
}
.pf-legend-item:hover {
    background: rgba(238,242,255,0.3);
    border-color: rgba(199,210,254,0.4);
}
.pf-legend-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 0.25rem;
    flex-shrink: 0;
}
.pf-legend-info {
    min-width: 0;
    flex: 1;
}
.pf-legend-label {
    font-size: 0.6875rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    display: block;
}
.pf-legend-value {
    font-size: 0.8125rem;
    font-weight: 800;
    color: #0f172a;
    display: block;
}

/* ── Dropdown Styled ── */
.pf-dropdown-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    background: rgba(248,250,252,0.8);
    border: 1px solid rgba(226,232,240,0.7);
    border-radius: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #475569;
    transition: all 0.2s ease;
    cursor: pointer;
}
.pf-dropdown-btn:hover {
    background: white;
    border-color: rgba(199,210,254,0.5);
    box-shadow: 0 2px 8px rgba(99,102,241,0.06);
}
.pf-dropdown-menu {
    position: absolute;
    right: 0;
    margin-top: 0.375rem;
    width: 14rem;
    background: white;
    border: 1px solid rgba(226,232,240,0.7);
    border-radius: 0.75rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
    z-index: 20;
    padding: 0.375rem;
    overflow: hidden;
}
.pf-dropdown-item {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    color: #475569;
    border-radius: 0.5rem;
    transition: all 0.15s ease;
    cursor: pointer;
    border: none;
    background: none;
}
.pf-dropdown-item:hover {
    background: rgba(238,242,255,0.5);
    color: #4f46e5;
}
.pf-dropdown-active {
    background: rgba(238,242,255,0.4);
    color: #4f46e5;
    font-weight: 700;
}

/* ── Animate In ── */
.pf-animate {
    animation: pfSlideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
}
@keyframes pfSlideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
}
.pf-delay-1 { animation-delay: 0.05s; }
.pf-delay-2 { animation-delay: 0.1s; }
.pf-delay-3 { animation-delay: 0.15s; }
.pf-delay-4 { animation-delay: 0.2s; }

[x-cloak] { display: none !important; }

/* ── Responsive ── */
@media (max-width: 639px) {
    .pf-amount { font-size: 1.75rem; }
    .pf-legend-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 380px) {
    .pf-legend-grid { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block content %}
<div class="pf-page relative z-10" x-data="portfolioApp()" x-init="initCharts()">

    {# ═══════════════════════════════════════════
       TABS — Premium Navigation
       ═══════════════════════════════════════════ #}
    <div class="mb-8 pf-animate">
        <nav class="flex gap-8 border-b border-gray-200/60">
            <button @click="tab = 'portefeuille'"
                    :class="tab === 'portefeuille' ? 'pf-tab-active' : ''"
                    class="pf-tab">
                <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                    Portefeuille
                </span>
            </button>
            <button @click="tab = 'analyse'"
                    :class="tab === 'analyse' ? 'pf-tab-active' : ''"
                    class="pf-tab">
                <span class="flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    Analyse
                </span>
            </button>
        </nav>
    </div>

    {# ═══════════════════════════════════════════════════════
       TAB 1 : PORTEFEUILLE
       ═══════════════════════════════════════════════════════ #}
    <div x-show="tab === 'portefeuille'" x-cloak>

        {# ─── Hero Header ─── #}
        <div class="pf-hero mb-8 pf-animate pf-delay-1">
            <div class="p-6 sm:p-8">
                <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
                    <div>
                        <div class="flex items-center gap-3 mb-2">
                            <div class="pf-icon" style="background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1));">
                                <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                                </svg>
                            </div>
                            <h2 class="text-xl font-extrabold text-gray-900 tracking-tight">Portefeuille</h2>
                        </div>
                        <p class="text-sm text-gray-400 ml-[3.25rem]">Au {{ "now"|date('d/m/Y') }}</p>
                    </div>
                    <div class="sm:text-right">
                        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Valorisation globale</p>
                        <p id="portfolio-total" class="pf-amount">{{ totalValue|number_format(0, ' ', ' ') }} €</p>
                        <div id="portfolio-refresh" class="flex items-center sm:justify-end gap-1.5 mt-2">
                            <svg id="portfolio-spinner" class="animate-spin w-3.5 h-3.5 text-indigo-500 hidden" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                            </svg>
                            <span id="portfolio-refresh-text" class="text-xs text-gray-400 font-medium"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# ─── KPI: Encours Card ─── #}
        <div class="pf-card mb-8 pf-animate pf-delay-2">
            <div class="p-5 sm:p-6">
                <div class="flex items-center gap-3 mb-3">
                    <div class="pf-icon" style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(20,184,166,0.1));">
                        <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Encours total</span>
                </div>
                <p class="text-2xl font-extrabold text-gray-900 tracking-tight" id="pf-kpi-encours">{{ totalValue|number_format(2, ',', ' ') }} €</p>
            </div>
        </div>

        {# ─── Comptes suivis par votre conseiller ─── #}
        <div class="pf-animate pf-delay-3">
            <div class="flex items-center gap-3 mb-5">
                <div class="pf-icon" style="background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(99,102,241,0.1));">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <h3 class="pf-section-title">Comptes suivis par votre conseiller</h3>
            </div>

            {% if products|length > 0 %}
            {# ─── Distributors Accordion ─── #}
            {% set distGradients = [
                'linear-gradient(135deg, #6366f1, #8b5cf6)',
                'linear-gradient(135deg, #3b82f6, #06b6d4)',
                'linear-gradient(135deg, #10b981, #14b8a6)',
                'linear-gradient(135deg, #f59e0b, #f97316)',
                'linear-gradient(135deg, #ec4899, #f43f5e)',
                'linear-gradient(135deg, #8b5cf6, #a855f7)',
            ] %}
            <div class="space-y-4" x-data="{ openDist: Object.keys({{ productsByDistributor|keys|json_encode() }})[0] || '' }">
                {% for distName, distData in productsByDistributor %}
                <div class="pf-card">
                    {# Distributor Header #}
                    <button @click="openDist = openDist === '{{ distName|e('js') }}' ? '' : '{{ distName|e('js') }}'"
                            class="pf-dist-btn">
                        <div class="flex items-center gap-3 min-w-0">
                            <div class="pf-dist-avatar" style="background: {{ distGradients[loop.index0 % 6] }};">
                                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                </svg>
                            </div>
                            <div class="min-w-0">
                                <p class="font-bold text-gray-900 text-sm">{{ distName }}</p>
                                <p class="text-xs text-gray-400 font-semibold mt-0.5">{{ distData.total|number_format(2, ',', ' ') }} €</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 flex-shrink-0">
                            <span class="hidden sm:inline-block text-xs font-semibold px-2.5 py-1 rounded-lg" style="background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(139,92,246,0.06)); color: #6366f1;">
                                {{ distData.products|length }} {{ distData.products|length > 1 ? 'comptes' : 'compte' }}
                            </span>
                            <svg class="w-5 h-5 text-gray-300 transition-transform duration-300" 
                                 :class="openDist === '{{ distName|e('js') }}' ? 'rotate-180' : ''"
                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </div>
                    </button>

                    {# Products under distributor #}
                    <div x-show="openDist === '{{ distName|e('js') }}'" 
                         x-transition:enter="transition ease-out duration-200" 
                         x-transition:enter-start="opacity-0 -translate-y-1" 
                         x-transition:enter-end="opacity-100 translate-y-0" 
                         x-transition:leave="transition ease-in duration-150" 
                         x-transition:leave-start="opacity-100 translate-y-0" 
                         x-transition:leave-end="opacity-0 -translate-y-1">
                        {% for p in distData.products %}
                        <a href="{{ path('user_product_show', {id: p.id}) }}" 
                           class="pf-product-row"
                           data-product-id="{{ p.id }}">
                            <div class="flex-1 min-w-0">
                                <p class="pf-product-name">{{ p.name }}</p>
                                <div class="flex items-center gap-2 text-xs text-gray-400 mt-0.5">
                                    <span class="font-medium">{{ p.type|replace({'_': ' '}) }}</span>
                                    {% if p.reference is defined and p.reference %}
                                    <span class="text-gray-300">·</span>
                                    <span>{{ p.reference }}</span>
                                    {% endif %}
                                    <span data-valuation-date="{{ p.id }}">
                                        {% if p.o2sValuationDate is defined and p.o2sValuationDate %}
                                        <span class="text-gray-300">·</span>
                                        Val. {{ p.o2sValuationDate|date('d/m/Y') }}
                                        {% endif %}
                                    </span>
                                </div>
                            </div>
                            <div class="flex items-center gap-3 flex-shrink-0 ml-4">
                                <div class="text-right">
                                    <span class="hidden sm:block text-[10px] uppercase tracking-wider text-gray-400 font-medium mb-0.5">Évaluation</span>
                                    <span class="text-base font-extrabold text-gray-900 tabular-nums" data-product-amount="{{ p.id }}">{{ p.encours|number_format(2, ',', ' ') }} €</span>
                                </div>
                                <div class="pf-product-arrow">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </div>
                            </div>
                        </a>
                        {% endfor %}
                    </div>
                </div>
                {% endfor %}
            </div>

            {% else %}
            {# ─── Empty State ─── #}
            <div class="pf-card">
                <div class="p-10 text-center">
                    <div class="w-16 h-16 mx-auto mb-5 rounded-2xl flex items-center justify-center" style="background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1));">
                        <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-extrabold text-gray-900 mb-2">Votre portefeuille est vide</h3>
                    <p class="text-gray-500 text-sm mb-6 max-w-md mx-auto">Explorez nos opportunités d'investissement pour commencer à construire votre patrimoine.</p>
                    <a href="{{ path('user_opportunities') }}" 
                       class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-bold text-sm text-white transition-all hover:shadow-lg hover:shadow-indigo-500/25"
                       style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                        Explorer les opportunités
                    </a>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════
       TAB 2 : ANALYSE
       ═══════════════════════════════════════════════════════ #}
    <div x-show="tab === 'analyse'" x-cloak>

        {# ─── Section Header ─── #}
        <div class="flex items-center gap-3 mb-8 pf-animate">
            <div class="pf-icon" style="background: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(168,85,247,0.1));">
                <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
            </div>
            <h2 class="text-xl font-extrabold text-gray-900 tracking-tight">Analyse du portefeuille</h2>
        </div>

        {# ── Répartition des comptes (Donut + Légende) ── #}
        <div class="mb-8 pf-animate pf-delay-1">
            <div class="pf-chart-card">
                <div class="pf-chart-header">
                    <div class="flex items-center gap-3">
                        <div class="pf-icon" style="background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1));">
                            <svg class="w-4.5 h-4.5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
                            </svg>
                        </div>
                        <h3 class="pf-section-title">Répartition des comptes</h3>
                    </div>
                    {# View Selector Dropdown #}
                    <div class="relative" x-data="{ open: false }">
                        <button @click="open = !open" class="pf-dropdown-btn">
                            <svg class="w-3.5 h-3.5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                            </svg>
                            <span x-text="analyseView === 'type' ? 'Par type' : (analyseView === 'distributor' ? 'Par établissement' : 'Par compte')"></span>
                            <svg class="w-3.5 h-3.5 text-gray-400 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                        <div x-show="open" @click.away="open = false" class="pf-dropdown-menu"
                             x-transition:enter="transition ease-out duration-150"
                             x-transition:enter-start="opacity-0 scale-95"
                             x-transition:enter-end="opacity-100 scale-100"
                             x-transition:leave="transition ease-in duration-100"
                             x-transition:leave-start="opacity-100 scale-100"
                             x-transition:leave-end="opacity-0 scale-95">
                            <button @click="analyseView = 'type'; open = false" 
                                    :class="analyseView === 'type' ? 'pf-dropdown-active' : ''"
                                    class="pf-dropdown-item">Par type de produit</button>
                            <button @click="analyseView = 'distributor'; open = false" 
                                    :class="analyseView === 'distributor' ? 'pf-dropdown-active' : ''"
                                    class="pf-dropdown-item">Par établissement</button>
                            <button @click="analyseView = 'account'; open = false" 
                                    :class="analyseView === 'account' ? 'pf-dropdown-active' : ''"
                                    class="pf-dropdown-item">Par compte</button>
                        </div>
                    </div>
                </div>

                <div class="p-6 sm:p-8">
                    <div class="flex flex-col lg:flex-row items-center gap-8">
                        {# Donut chart — centered #}
                        <div class="relative flex-shrink-0" style="width: 240px; height: 240px;">
                            <canvas id="analyseDonut"></canvas>
                            <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
                                <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Total</span>
                                <span class="text-xl font-extrabold text-gray-900">{{ totalValue|number_format(0, ' ', ' ') }} €</span>
                            </div>
                        </div>

                        {# Legend — Responsive grid (fixes the many-accounts problem!) #}
                        <div class="flex-1 w-full" id="analyseLegend">
                            {# Filled dynamically by JS #}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# ── Répartition (barres) ── #}
        <div class="mb-8 pf-animate pf-delay-2">
            <div class="pf-chart-card">
                <div class="pf-chart-header">
                    <div class="flex items-center gap-3">
                        <div class="pf-icon" style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(20,184,166,0.1));">
                            <svg class="w-4.5 h-4.5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                            </svg>
                        </div>
                        <h3 class="pf-section-title">
                            <span x-text="analyseView === 'type' ? 'Répartition par type de produit' : (analyseView === 'distributor' ? 'Répartition par établissement' : 'Répartition par compte')"></span>
                        </h3>
                    </div>
                </div>
                <div class="p-6 sm:p-8">
                    <div class="relative" style="height: 320px;">
                        <canvas id="supportBarChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    const pfmt = (n) => new Intl.NumberFormat('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);

    const CHART_COLORS = [
        '#7c3aed', '#3b82f6', '#14b8a6', '#f59e0b', '#ef4444',
        '#ec4899', '#8b5cf6', '#06b6d4', '#84cc16', '#f97316',
        '#6366f1', '#10b981', '#e11d48', '#0ea5e9', '#a855f7'
    ];

    const ANALYSE_DATA = {
        type: {
            {% for type, data in totalsByType %}
            '{{ type|replace({"'": "\\'"}) }}': {{ data.encours|number_format(2, '.', '') }}{{ not loop.last ? ',' : '' }}
            {% endfor %}
        },
        distributor: {
            {% for dist, data in productsByDistributor %}
            '{{ dist|replace({"'": "\\'"}) }}': {{ data.total|number_format(2, '.', '') }}{{ not loop.last ? ',' : '' }}
            {% endfor %}
        },
        account: {
            {% for p in products %}
            '{{ p.name|replace({"'": "\\'"}) }}': {{ p.encours|number_format(2, '.', '') }}{{ not loop.last ? ',' : '' }}
            {% endfor %}
        }
    };

    const BAR_DATA = {
        type: {
            labels: [{% for type, data in totalsByType %}'{{ type|replace({"'": "\\'"}) }}'{{ not loop.last ? ',' : '' }}{% endfor %}],
            values: [{% for type, data in totalsByType %}{{ data.encours|number_format(2, '.', '') }}{{ not loop.last ? ',' : '' }}{% endfor %}]
        },
        distributor: {
            labels: [{% for dist, data in productsByDistributor %}'{{ dist|replace({"'": "\\'"}) }}'{{ not loop.last ? ',' : '' }}{% endfor %}],
            values: [{% for dist, data in productsByDistributor %}{{ data.total|number_format(2, '.', '') }}{{ not loop.last ? ',' : '' }}{% endfor %}]
        },
        account: {
            labels: [{% for p in products %}'{{ p.name|replace({"'": "\\'"}) }}'{{ not loop.last ? ',' : '' }}{% endfor %}],
            values: [{% for p in products %}{{ p.encours|number_format(2, '.', '') }}{{ not loop.last ? ',' : '' }}{% endfor %}]
        }
    };

    function portfolioApp() {
        return {
            tab: 'portefeuille',
            analyseView: 'type',
            _donutChart: null,
            _barChart: null,

            initCharts() {
                this.$watch('analyseView', (val) => {
                    this.renderDonut(val);
                    this.renderBar(val);
                });

                this.$watch('tab', (val) => {
                    if (val === 'analyse') {
                        this.$nextTick(() => {
                            this.renderDonut(this.analyseView);
                            this.renderBar(this.analyseView);
                        });
                    }
                });

                this.refreshValuations();
            },

            renderDonut(view) {
                const canvas = document.getElementById('analyseDonut');
                if (!canvas) return;

                const dataObj = ANALYSE_DATA[view] || ANALYSE_DATA.type;
                const labels = Object.keys(dataObj);
                const values = Object.values(dataObj);
                const total = values.reduce((a, b) => a + b, 0);
                const colors = labels.map((_, i) => CHART_COLORS[i % CHART_COLORS.length]);

                if (this._donutChart) this._donutChart.destroy();

                this._donutChart = new Chart(canvas, {
                    type: 'doughnut',
                    data: {
                        labels,
                        datasets: [{
                            data: values,
                            backgroundColor: colors,
                            borderWidth: 4,
                            borderColor: '#fff',
                            hoverOffset: 10,
                            borderRadius: 4,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        cutout: '68%',
                        animation: {
                            animateRotate: true,
                            duration: 1000,
                            easing: 'easeOutQuart'
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(15,23,42,0.95)',
                                padding: 14,
                                cornerRadius: 10,
                                titleFont: { size: 12, weight: '700' },
                                bodyFont: { size: 11 },
                                boxPadding: 6,
                                callbacks: {
                                    label: (ctx) => {
                                        const pct = total > 0 ? ((ctx.parsed / total) * 100).toFixed(1) : '0.0';
                                        return ` ${new Intl.NumberFormat('fr-FR').format(Math.round(ctx.parsed))} € (${pct}%)`;
                                    }
                                }
                            }
                        }
                    }
                });

                // ─── Custom Legend — Responsive Grid ───
                const legend = document.getElementById('analyseLegend');
                if (legend) {
                    legend.innerHTML = '<div class="pf-legend-grid">' + labels.map((label, i) => {
                        const pct = total > 0 ? ((values[i] / total) * 100).toFixed(1) : '0.0';
                        const displayLabel = label.replace(/_/g, ' ');
                        return `
                            <div class="pf-legend-item">
                                <div class="pf-legend-dot" style="background-color: ${colors[i]}"></div>
                                <div class="pf-legend-info">
                                    <span class="pf-legend-label" title="${displayLabel}">${displayLabel}</span>
                                    <span class="pf-legend-value">${new Intl.NumberFormat('fr-FR').format(Math.round(values[i]))} € <span style="font-weight:500;font-size:0.6875rem;color:#94a3b8;">(${pct}%)</span></span>
                                </div>
                            </div>
                        `;
                    }).join('') + '</div>';
                }
            },

            renderBar(view) {
                const canvas = document.getElementById('supportBarChart');
                if (!canvas) return;

                const barSet = BAR_DATA[view] || BAR_DATA.type;
                const colors = barSet.labels.map((_, i) => CHART_COLORS[i % CHART_COLORS.length]);
                const useHorizontal = barSet.labels.length > 4;

                if (this._barChart) this._barChart.destroy();

                this._barChart = new Chart(canvas, {
                    type: 'bar',
                    data: {
                        labels: barSet.labels.map(l => {
                            const clean = l.replace(/_/g, ' ');
                            return clean.length > 22 ? clean.substring(0, 22) + '…' : clean;
                        }),
                        datasets: [{
                            data: barSet.values,
                            backgroundColor: colors.map(c => c + 'BB'),
                            borderColor: colors,
                            borderWidth: 1.5,
                            borderRadius: 8,
                            maxBarThickness: 60,
                            barPercentage: 0.65
                        }]
                    },
                    options: {
                        indexAxis: useHorizontal ? 'y' : 'x',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(15,23,42,0.95)',
                                padding: 14,
                                cornerRadius: 10,
                                boxPadding: 6,
                                callbacks: {
                                    label: (ctx) => {
                                        const val = useHorizontal ? ctx.parsed.x : ctx.parsed.y;
                                        return ` ${new Intl.NumberFormat('fr-FR').format(Math.round(val))} €`;
                                    }
                                }
                            }
                        },
                        scales: {
                            [useHorizontal ? 'x' : 'y']: {
                                beginAtZero: true,
                                grid: { color: 'rgba(241,245,249,0.8)', drawBorder: false },
                                ticks: {
                                    callback: (v) => new Intl.NumberFormat('fr-FR', {
                                        notation: 'compact', compactDisplay: 'short',
                                        style: 'currency', currency: 'EUR', maximumFractionDigits: 0
                                    }).format(v),
                                    font: { size: 10, weight: '500' },
                                    color: '#94a3b8'
                                }
                            },
                            [useHorizontal ? 'y' : 'x']: {
                                grid: { display: false },
                                ticks: { 
                                    font: { size: 10, weight: '500' },
                                    color: '#64748b'
                                }
                            }
                        }
                    }
                });
            },

            /* ─── Async valuation refresh ─── */
            refreshValuations() {
                const pSpinner = document.getElementById('portfolio-spinner');
                const pText = document.getElementById('portfolio-refresh-text');

                if (pSpinner) pSpinner.classList.remove('hidden');
                if (pText) pText.textContent = 'Mise à jour…';

                fetch('{{ path("user_api_refresh_valuations") }}', {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/json' }
                })
                .then(r => r.json())
                .then(data => {
                    if (!data.success) return;
                    let anyChanged = false;

                    (data.products || []).forEach(p => {
                        if (!p.changed) return;
                        anyChanged = true;

                        const amountEl = document.querySelector('[data-product-amount="' + p.id + '"]');
                        if (amountEl) {
                            amountEl.textContent = pfmt(p.encours) + ' €';
                            amountEl.classList.add('text-indigo-600');
                            setTimeout(() => amountEl.classList.remove('text-indigo-600'), 2000);
                        }

                        const dateEl = document.querySelector('[data-valuation-date="' + p.id + '"]');
                        if (dateEl && p.valuationDate) {
                            dateEl.textContent = '· Val. ' + p.valuationDate;
                        }
                    });

                    if (anyChanged) {
                        const total = document.getElementById('portfolio-total');
                        if (total) total.textContent = pfmt(data.totalEncours) + ' €';
                        const kpi = document.getElementById('pf-kpi-encours');
                        if (kpi) kpi.textContent = pfmt(data.totalEncours) + ' €';
                    }

                    if (pSpinner) pSpinner.classList.add('hidden');
                    if (pText) {
                        pText.textContent = anyChanged ? '✓ Mis à jour' : '✓ À jour';
                        pText.classList.add(anyChanged ? 'text-emerald-600' : 'text-gray-400');
                        setTimeout(() => { if (pText) pText.textContent = ''; }, 4000);
                    }
                })
                .catch(err => {
                    console.warn('Portfolio refresh error:', err);
                    if (pSpinner) pSpinner.classList.add('hidden');
                    if (pText) pText.textContent = '';
                });
            },

        };
    }
</script>
{% endblock %}
