{% extends 'front/user/dashboard/base.html.twig' %}

{% block page_title %}✉️ Envoyer un message{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* Styles pour les dropdowns sur mobile */
.message-form-container {
    position: relative;
    z-index: 1;
}

/* Style des selects natifs améliorés */
.custom-select-wrapper {
    position: relative;
}

.custom-select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    width: 100%;
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: #374151;
    background-color: #fff;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.75rem center;
    background-repeat: no-repeat;
    background-size: 1.25rem;
    border: 2px solid #e5e7eb;
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    cursor: pointer;
}

.custom-select:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
}

.custom-select:hover {
    border-color: #d1d5db;
}

/* Fix pour que les options restent dans l'écran sur mobile */
@media (max-width: 640px) {
    .custom-select {
        font-size: 16px; /* Empêche le zoom sur iOS */
    }
    
    .custom-select option {
        padding: 0.75rem;
        font-size: 16px;
    }
}

/* Input et Textarea styles */
.custom-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    color: #374151;
    background-color: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 0.75rem;
    transition: all 0.2s ease;
}

.custom-input:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
}

.custom-input:hover {
    border-color: #d1d5db;
}

.custom-input::placeholder {
    color: #9ca3af;
}

.custom-textarea {
    min-height: 150px;
    resize: vertical;
}

/* Label styles */
.form-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.5rem;
}

/* Submit button */
.submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: white;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3);
}

.submit-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 10px -1px rgba(59, 130, 246, 0.4);
}

.submit-btn:active {
    transform: translateY(0);
}

/* Card styles */
.form-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    border: 1px solid #f1f5f9;
    overflow: hidden;
}

.form-card-header {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #e5e7eb;
}

.form-card-body {
    padding: 1.25rem;
}

@media (min-width: 640px) {
    .form-card-body {
        padding: 1.5rem;
    }
}

/* User info card */
.user-info-card {
    background: linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
    border-radius: 0.75rem;
    padding: 1rem;
    border: 1px solid #e0e7ff;
}

/* Tips card */
.tips-card {
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border-radius: 0.75rem;
    padding: 1rem;
    border: 1px solid #bfdbfe;
}

/* Back button */
.back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #6b7280;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.625rem;
    transition: all 0.2s;
    text-decoration: none;
}

.back-btn:hover {
    background: #f9fafb;
    color: #374151;
    border-color: #d1d5db;
}
</style>
{% endblock %}

{% block content %}
<div class="message-form-container max-w-2xl mx-auto px-1 sm:px-0">
    <!-- Breadcrumb -->
    {% include 'partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'path': 'user_dashboard', 'icon': 'dashboard'},
            {'label': 'Mes messages', 'path': 'user_messages', 'icon': 'messages'},
            {'label': 'Nouveau message'}
        ]
    } %}

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Envoyer un message</h1>
            <p class="mt-1 text-sm text-gray-600">Contactez notre équipe pour toute question ou assistance</p>
        </div>
        <a href="{{ path('user_messages') }}" class="back-btn self-start sm:self-auto">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
            Retour aux messages
        </a>
    </div>

    <!-- Formulaire -->
    <div class="form-card mb-6">
        <div class="form-card-body">
            {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}
            
            <!-- Catégorie et Priorité -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Catégorie -->
                <div>
                    <label class="form-label">Catégorie</label>
                    <div class="custom-select-wrapper">
                        {{ form_widget(form.category, {
                            'attr': {
                                'class': 'custom-select'
                            }
                        }) }}
                    </div>
                    {{ form_errors(form.category) }}
                </div>

                <!-- Priorité -->
                <div>
                    <label class="form-label">Priorité</label>
                    <div class="custom-select-wrapper">
                        {{ form_widget(form.priority, {
                            'attr': {
                                'class': 'custom-select'
                            }
                        }) }}
                    </div>
                    {{ form_errors(form.priority) }}
                </div>
            </div>

            <!-- Objet -->
            <div>
                <label class="form-label">Objet</label>
                {{ form_widget(form.subject, {
                    'attr': {
                        'class': 'custom-input',
                        'placeholder': 'Décrivez brièvement votre demande...'
                    }
                }) }}
                {{ form_errors(form.subject) }}
            </div>

            <!-- Message -->
            <div>
                <label class="form-label">Message</label>
                {{ form_widget(form.message, {
                    'attr': {
                        'class': 'custom-input custom-textarea',
                        'placeholder': 'Détaillez votre demande ou question...',
                        'rows': '6'
                    }
                }) }}
                {{ form_errors(form.message) }}
                <p class="mt-2 text-xs text-gray-500">Décrivez votre demande de manière détaillée pour nous permettre de vous aider au mieux.</p>
            </div>

            <!-- Informations utilisateur -->
            <div class="user-info-card">
                <h3 class="text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
                    <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Vos informations
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
                    <div class="flex items-center gap-2">
                        <span class="text-gray-500">Nom :</span>
                        <span class="font-medium text-gray-900">{{ user.firstName }} {{ user.lastName }}</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="text-gray-500">Email :</span>
                        <span class="font-medium text-gray-900 truncate">{{ user.email }}</span>
                    </div>
                </div>
            </div>

            <!-- Boutons -->
            <div class="flex flex-col-reverse sm:flex-row sm:justify-end gap-3 pt-4 border-t border-gray-100">
                <a href="{{ path('user_messages') }}" class="back-btn justify-center">
                    Annuler
                </a>
                <button type="submit" class="submit-btn">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                    </svg>
                    Envoyer le message
                </button>
            </div>

            {{ form_rest(form) }}
            {{ form_end(form, {'render_rest': false}) }}
        </div>
    </div>

    <!-- Conseils -->
    <div class="tips-card">
        <div class="flex gap-3">
            <div class="flex-shrink-0">
                <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                    </svg>
                </div>
            </div>
            <div>
                <h3 class="text-sm font-semibold text-blue-900 mb-2">Conseils pour votre message</h3>
                <ul class="text-sm text-blue-800 space-y-1">
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                        Soyez précis dans votre objet pour une réponse plus rapide
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                        Notre équipe vous répondra sous 24-48h ouvrées
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-blue-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                        Pour les urgences, sélectionnez la priorité "Urgente"
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
