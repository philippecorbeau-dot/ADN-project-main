{% extends 'front/user/dashboard/base.html.twig' %}

{% block page_title %}Mes messages{% endblock %}

{% block content %}
<div class="max-w-6xl mx-auto">
    <!-- Breadcrumb moderne -->
    {% include 'partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'path': 'user_dashboard', 'icon': 'dashboard'},
            {'label': 'Mes messages'}
        ]
    } %}

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Mes messages</h1>
            <p class="mt-1 text-sm text-gray-600">Historique de vos échanges avec notre équipe</p>
        </div>
        <a href="{{ path('user_message_new') }}" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm bg-adn-blue text-sm font-medium text-white hover:bg-adn-blue-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-adn-blue">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouveau message
        </a>
    </div>

    {% if messages is empty %}
        <!-- État vide -->
        <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Aucun message</h3>
            <p class="mt-1 text-sm text-gray-500">Commencez une conversation avec notre équipe.</p>
            <div class="mt-6">
                <a href="{{ path('user_message_new') }}" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-adn-blue hover:bg-adn-blue-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-adn-blue">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Envoyer un message
                </a>
            </div>
        </div>
    {% else %}
        <!-- Liste des messages -->
        <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-lg overflow-hidden">
            <ul id="user_messages_list" class="divide-y divide-gray-200">
                {% for message in messages %}
                <li class="hover:bg-gray-50 transition-colors duration-150">
                    <a href="{{ path('user_message_show', {'id': message.id}) }}" class="block px-6 py-4">
                        <div class="flex items-center justify-between">
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center space-x-3">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {% if message.category == 'technical' %}bg-red-100 text-red-800
                                        {% elseif message.category == 'investment' %}bg-green-100 text-green-800
                                        {% elseif message.category == 'account' %}bg-blue-100 text-blue-800
                                        {% elseif message.category == 'kyc' %}bg-purple-100 text-purple-800
                                        {% else %}bg-gray-100 text-gray-800{% endif %}">
                                        {{ message.categoryLabel }}
                                    </span>
                                    {% if message.priority != 'normal' %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {% if message.priority == 'urgent' %}bg-red-100 text-red-800
                                        {% elseif message.priority == 'high' %}bg-orange-100 text-orange-800
                                        {% else %}bg-yellow-100 text-yellow-800{% endif %}">
                                        {{ message.priorityLabel }}
                                    </span>
                                    {% endif %}
                                    {% if message.hasResponse %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                        Répondu
                                    </span>
                                    {% endif %}
                                </div>
                                <div class="mt-2">
                                    <h3 class="text-sm font-medium text-gray-900">{{ message.subject }}</h3>
                                    <p class="mt-1 text-sm text-gray-500 line-clamp-2">{{ message.message|slice(0, 150) }}{% if message.message|length > 150 %}...{% endif %}</p>
                                </div>
                            </div>
                            <div class="flex flex-col items-end space-y-1">
                                <time class="text-sm text-gray-500">{{ message.formattedCreatedAt }}</time>
                                {% if message.hasResponse %}
                                    <div class="flex items-center text-sm text-green-600">
                                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                                            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                                        </svg>
                                        Réponse
                                    </div>
                                {% else %}
                                    <div class="flex items-center text-sm text-orange-600">
                                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                                        </svg>
                                        En attente
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>

        <!-- Aide -->
        <div class="mt-8 bg-gray-50 border border-gray-200 rounded-md p-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-gray-700">Informations</h3>
                    <div class="mt-2 text-sm text-gray-600">
                        <p>Notre équipe traite vos messages dans l'ordre de priorité. Les réponses sont généralement envoyées sous 24-48h ouvrées.</p>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
