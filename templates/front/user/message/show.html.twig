{% extends 'front/user/dashboard/base.html.twig' %}

{% block page_title %}Message: {{ message.subject }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto">
    <!-- Breadcrumb moderne -->
    {% include 'partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'path': 'user_dashboard', 'icon': 'dashboard'},
            {'label': 'Mes messages', 'path': 'user_messages', 'icon': 'messages'},
            {'label': message.subject|slice(0, 50) ~ (message.subject|length > 50 ? '...' : '')}
        ]
    } %}

    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">{{ message.subject }}</h1>
            </div>
            <a href="{{ path('user_messages') }}" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-adn-blue">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Retour aux messages
            </a>
        </div>

        <!-- Métadonnées -->
        <div class="flex items-center space-x-4 text-sm text-gray-500">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                {% if message.category == 'technical' %}bg-red-100 text-red-800
                {% elseif message.category == 'investment' %}bg-green-100 text-green-800
                {% elseif message.category == 'account' %}bg-blue-100 text-blue-800
                {% elseif message.category == 'kyc' %}bg-purple-100 text-purple-800
                {% else %}bg-gray-100 text-gray-800{% endif %}">
                {{ message.categoryLabel }}
            </span>
            {% if message.priority != 'normal' %}
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                {% if message.priority == 'urgent' %}bg-red-100 text-red-800
                {% elseif message.priority == 'high' %}bg-orange-100 text-orange-800
                {% else %}bg-yellow-100 text-yellow-800{% endif %}">
                Priorité {{ message.priorityLabel }}
            </span>
            {% endif %}
            <time>Envoyé le {{ message.formattedCreatedAt }}</time>
        </div>
    </div>

    <!-- Message original -->
    <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-lg mb-6">
        <div class="px-6 py-6">
            <div class="flex items-start space-x-4">
                <div class="flex-shrink-0">
                    <div class="h-10 w-10 rounded-full bg-adn-blue flex items-center justify-center">
                        <span class="text-white font-medium text-sm">
                            {{ user.firstName|slice(0,1)|upper }}{{ user.lastName|slice(0,1)|upper }}
                        </span>
                    </div>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                        <div>
                            <h3 class="text-sm font-medium text-gray-900">{{ user.firstName }} {{ user.lastName }}</h3>
                            <p class="text-sm text-gray-500">{{ user.email }}</p>
                        </div>
                        <time class="text-sm text-gray-500">{{ message.formattedCreatedAt }}</time>
                    </div>
                    <div class="mt-4">
                        <div class="prose prose-sm max-w-none text-gray-700">
                            {{ message.message|nl2br }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if message.hasResponse %}
        <!-- Réponse admin -->
        <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-lg mb-6">
            <div class="px-6 py-6">
                <div class="flex items-start space-x-4">
                    <div class="flex-shrink-0">
                        <div class="h-10 w-10 rounded-full bg-green-500 flex items-center justify-center">
                            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                            <div>
                                <h3 class="text-sm font-medium text-gray-900">Équipe ADN</h3>
                                <p class="text-sm text-gray-500">Réponse officielle</p>
                            </div>
                            <time class="text-sm text-gray-500">{{ message.adminResponseAt.format('d/m/Y à H:i') }}</time>
                        </div>
                        <div class="mt-4">
                            <div class="prose prose-sm max-w-none text-gray-700">
                                {{ message.adminResponse|nl2br }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action -->
        <div class="bg-green-50 border border-green-200 rounded-md p-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-green-800">Message traité</h3>
                    <div class="mt-2 text-sm text-green-700">
                        <p>Notre équipe a répondu à votre demande. Si vous avez d'autres questions, n'hésitez pas à envoyer un nouveau message.</p>
                    </div>
                    <div class="mt-4">
                        <a href="{{ path('user_message_new') }}" class="text-sm font-medium text-green-800 hover:text-green-700">
                            Envoyer un nouveau message →
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <!-- En attente -->
        <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-yellow-800">Message en attente de traitement</h3>
                    <div class="mt-2 text-sm text-yellow-700">
                        <p>Notre équipe a bien reçu votre message et vous répondra sous 24-48h ouvrées. Merci pour votre patience.</p>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
