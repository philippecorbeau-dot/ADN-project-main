{% extends 'front/user/dashboard/base.html.twig' %}

{% block title %}{{ product.displayAlias ?? ('Produit #' ~ product.id) }} - ADN Family Office{% endblock %}
{% block page_title %}
    <span class="text-gray-900">Détail du produit</span>
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* ═══════════════════════════════════════════
   PRODUCT DETAIL — PREMIUM DESIGN SYSTEM
   ═══════════════════════════════════════════ */

/* ── Ambient background ── */
.prod-page-bg {
    position: relative;
}
.prod-page-bg::before {
    content: '';
    position: fixed;
    top: 0; right: 0;
    width: 50vw; height: 50vh;
    background: radial-gradient(ellipse at top right, rgba(99,102,241,0.04) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
}
.prod-page-bg::after {
    content: '';
    position: fixed;
    bottom: 0; left: 0;
    width: 40vw; height: 40vh;
    background: radial-gradient(ellipse at bottom left, rgba(16,185,129,0.03) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
}

/* ── Premium Card ── */
.prod-card {
    background: white;
    border-radius: 1.25rem;
    border: 1px solid rgba(226,232,240,0.7);
    box-shadow:
        0 0 0 1px rgba(0,0,0,0.01),
        0 1px 2px rgba(0,0,0,0.02),
        0 4px 16px rgba(0,0,0,0.03);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    position: relative;
    overflow: hidden;
}
.prod-card:hover {
    box-shadow:
        0 0 0 1px rgba(0,0,0,0.02),
        0 4px 8px rgba(0,0,0,0.04),
        0 16px 48px rgba(0,0,0,0.06);
    transform: translateY(-1px);
}

/* ── Hero header gradient accent ── */
.prod-hero {
    background: white;
    border-radius: 1.25rem;
    border: 1px solid rgba(226,232,240,0.7);
    box-shadow: 0 1px 2px rgba(0,0,0,0.02), 0 4px 16px rgba(0,0,0,0.03);
    position: relative;
    overflow: hidden;
}
.prod-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, #6366f1, #8b5cf6, #06b6d4);
}

/* ── Hero Amount ── */
.prod-amount-hero {
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #0f172a;
}

/* ── Badge styles ── */
.prod-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3125rem 0.75rem;
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
}
.prod-badge-blue {
    background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(59,130,246,0.1));
    color: #4338ca;
}
.prod-badge-emerald {
    background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(5,150,105,0.1));
    color: #047857;
}
.prod-badge-gray {
    background: rgba(241,245,249,0.8);
    color: #64748b;
    font-weight: 600;
    text-transform: none;
    font-size: 0.8125rem;
}

/* ── KPI Card ── */
.prod-kpi {
    background: white;
    border-radius: 1rem;
    border: 1px solid rgba(226,232,240,0.7);
    padding: 1.25rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.prod-kpi:hover {
    border-color: rgba(199,210,254,0.5);
    box-shadow: 0 4px 16px rgba(99,102,241,0.06);
    transform: translateY(-1px);
}

/* ── Icon Container ── */
.prod-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

/* ── Divider ── */
.prod-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(226,232,240,0.8), transparent);
}

/* ── Support Avatar ── */
.prod-support-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.625rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-weight: 800;
    font-size: 0.65rem;
    color: white;
    letter-spacing: 0.02em;
}

/* ── PnL ── */
.prod-pnl-pos { color: #059669; }
.prod-pnl-neg { color: #dc2626; }
.prod-pnl-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: 0.75rem;
}
.prod-pnl-badge-pos {
    background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(5,150,105,0.08));
    color: #059669;
}
.prod-pnl-badge-neg {
    background: linear-gradient(135deg, rgba(239,68,68,0.1), rgba(220,38,38,0.08));
    color: #dc2626;
}

/* ── Table styles ── */
.prod-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
}
.prod-table thead th {
    padding: 0.875rem 1rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #64748b;
    background: rgba(248,250,252,0.8);
    border-bottom: 1px solid rgba(226,232,240,0.8);
}
.prod-table thead th:first-child { border-radius: 0.75rem 0 0 0; }
.prod-table thead th:last-child { border-radius: 0 0.75rem 0 0; }
.prod-table tbody td {
    padding: 0.875rem 1rem;
    font-size: 0.8125rem;
    border-bottom: 1px solid rgba(241,245,249,0.8);
}
.prod-table tbody tr {
    transition: background 0.2s ease;
}
.prod-table tbody tr:hover {
    background: linear-gradient(90deg, rgba(238,242,255,0.3), rgba(248,250,252,0.2));
}
.prod-table tbody tr:last-child td {
    border-bottom: none;
}
.prod-table tfoot td {
    padding: 1rem;
    background: rgba(248,250,252,0.8);
    border-top: 2px solid rgba(226,232,240,0.8);
    font-weight: 800;
    font-size: 0.8125rem;
}
.prod-table tfoot td:first-child { border-radius: 0 0 0 0.75rem; }
.prod-table tfoot td:last-child { border-radius: 0 0 0.75rem 0; }

/* ── Section Title ── */
.prod-section-title {
    font-weight: 800;
    font-size: 1.125rem;
    color: #0f172a;
    letter-spacing: -0.025em;
    line-height: 1.3;
}

/* ── Chart Card ── */
.prod-chart-card {
    background: white;
    border-radius: 1.25rem;
    border: 1px solid rgba(226,232,240,0.7);
    box-shadow: 0 1px 2px rgba(0,0,0,0.02), 0 4px 16px rgba(0,0,0,0.03);
    overflow: hidden;
    transition: all 0.3s ease;
}
.prod-chart-card:hover {
    box-shadow: 0 4px 8px rgba(0,0,0,0.04), 0 16px 48px rgba(0,0,0,0.06);
}
.prod-chart-header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(241,245,249,0.8);
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

/* ── Mobile card support ── */
.prod-mobile-card {
    background: white;
    border-radius: 1rem;
    border: 1px solid rgba(226,232,240,0.7);
    overflow: hidden;
    transition: all 0.3s ease;
}
.prod-mobile-card:hover {
    border-color: rgba(199,210,254,0.5);
    box-shadow: 0 4px 16px rgba(99,102,241,0.06);
}

/* ── Animate In ── */
.prod-animate {
    animation: prodSlideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
}
@keyframes prodSlideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
}
.prod-delay-1 { animation-delay: 0.05s; }
.prod-delay-2 { animation-delay: 0.1s; }
.prod-delay-3 { animation-delay: 0.15s; }
.prod-delay-4 { animation-delay: 0.2s; }
.prod-delay-5 { animation-delay: 0.25s; }

/* ── Responsive ── */
@media (max-width: 639px) {
    .prod-amount-hero {
        font-size: 1.75rem;
    }
}
</style>
{% endblock %}

{% block content %}
<div class="prod-page-bg relative z-10">

{# ═══════════════════════════════════════════
   BACK BUTTON — Elegant breadcrumb
   ═══════════════════════════════════════════ #}
<div class="mb-6 prod-animate">
    <a href="{{ path('user_portfolio') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-indigo-600 hover:text-indigo-700 transition-colors group px-3 py-1.5 rounded-lg hover:bg-indigo-50/60">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour au portefeuille
    </a>
</div>

{# ═══════════════════════════════════════════
   HERO HEADER CARD
   ═══════════════════════════════════════════ #}
<div class="prod-hero mb-8 prod-animate prod-delay-1">
    <div class="p-6 sm:p-8">
        {# Badges row #}
        <div class="flex flex-wrap items-center gap-2 mb-5">
            <span class="prod-badge prod-badge-blue">
                {{ product.productType|replace({'_': ' '}) }}
            </span>
            {% if product.distributor %}
            <span class="prod-badge prod-badge-gray">{{ product.distributor }}</span>
            {% endif %}
        </div>
            
        {# Title + Valuation #}
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5">
            <div class="min-w-0">
                <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 tracking-tight leading-tight">
                    {{ product.displayAlias ?? product.internalName ?? ('Produit #' ~ product.id) }}
                </h1>
                {% if accountNumber is defined and accountNumber %}
                <p class="text-gray-500 text-sm mt-1.5 font-mono tracking-wide">N° {{ accountNumber }}</p>
                {% endif %}
                {% if o2sValuationDate is defined and o2sValuationDate %}
                <p class="text-gray-400 text-xs mt-1.5 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Situation de compte au {{ o2sValuationDate|date('d/m/Y') }}
                </p>
                {% endif %}
                {% if o2sSnapshotDate is defined and o2sSnapshotDate and o2sValuationDate is defined and o2sValuationDate and o2sSnapshotDate|date('Y-m-d') != o2sValuationDate|date('Y-m-d') %}
                <p class="text-gray-300 text-[10px] mt-0.5 flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Détail des supports au {{ o2sSnapshotDate|date('d/m/Y') }}
                </p>
                {% endif %}
            </div>
            <div class="sm:text-right flex-shrink-0">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-2">Évaluation</p>
                <p class="prod-amount-hero">
                    {{ encours|number_format(2, ',', ' ') }}
                    <span class="text-lg font-medium text-gray-400 ml-1">EUR</span>
                </p>
                {% if plusMinus is not null %}
                <div class="flex items-center gap-2 mt-2 {{ 'sm:justify-end' }}">
                    <span class="text-sm font-bold {{ plusMinus >= 0 ? 'prod-pnl-pos' : 'prod-pnl-neg' }}">
                        {{ plusMinus >= 0 ? '+' : '' }}{{ plusMinus|number_format(2, ',', ' ') }} €
                    </span>
                    {% if plusMinusPct is defined and plusMinusPct is not null %}
                    <span class="prod-pnl-badge {{ plusMinusPct >= 0 ? 'prod-pnl-badge-pos' : 'prod-pnl-badge-neg' }}">
                        {{ plusMinusPct >= 0 ? '+' : '' }}{{ plusMinusPct|number_format(2, ',', ' ') }}%
                    </span>
                    {% endif %}
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════
   KPI CARDS — Key metrics
   ═══════════════════════════════════════════ #}
{% set kpiCards = [] %}

{% if initial is not null %}
    {% set kpiCards = kpiCards|merge([{'label': 'Versements', 'value': initial|number_format(2, ',', ' ') ~ ' €', 'icon': 'upload', 'color': 'blue'}]) %}
{% endif %}

{% if retraits is defined and retraits is not null and retraits > 0 %}
    {% set kpiCards = kpiCards|merge([{'label': 'Retraits', 'value': retraits|number_format(2, ',', ' ') ~ ' €', 'icon': 'download', 'color': 'orange'}]) %}
{% endif %}

{% if o2sLiquidity is defined and o2sLiquidity is not null and o2sLiquidity > 0 %}
    {% set kpiCards = kpiCards|merge([{'label': 'Liquidité', 'value': o2sLiquidity|number_format(2, ',', ' ') ~ ' €', 'icon': 'shield', 'color': 'purple'}]) %}
{% endif %}

{% if euroFund is not null %}
    {% set kpiCards = kpiCards|merge([{'label': 'Fonds euros', 'value': euroFund|number_format(2, ',', ' ') ~ ' €', 'icon': 'shield', 'color': 'purple'}]) %}
{% endif %}

{% if uc is not null %}
    {% set kpiCards = kpiCards|merge([{'label': 'Unités de compte', 'value': uc|number_format(2, ',', ' ') ~ ' €', 'icon': 'chart', 'color': 'amber'}]) %}
{% endif %}

{% if dateOuverture is defined and dateOuverture is not null %}
    {% set kpiCards = kpiCards|merge([{'label': 'Date ouverture', 'value': dateOuverture|date('d/m/Y'), 'icon': 'calendar', 'color': 'gray'}]) %}
{% endif %}

{% if kpiCards|length > 0 %}
<div class="grid grid-cols-2 lg:grid-cols-{{ kpiCards|length > 4 ? 4 : kpiCards|length }} gap-4 mb-8 prod-animate prod-delay-2">
    {% for card in kpiCards %}
    <div class="prod-kpi">
        <div class="flex items-center gap-3 mb-3">
            {% set gradients = {
                'blue': 'linear-gradient(135deg, rgba(59,130,246,0.1), rgba(99,102,241,0.1))',
                'orange': 'linear-gradient(135deg, rgba(249,115,22,0.1), rgba(245,158,11,0.1))',
                'purple': 'linear-gradient(135deg, rgba(139,92,246,0.1), rgba(99,102,241,0.1))',
                'amber': 'linear-gradient(135deg, rgba(245,158,11,0.1), rgba(249,115,22,0.1))',
                'gray': 'linear-gradient(135deg, rgba(100,116,139,0.1), rgba(148,163,184,0.1))'
            } %}
            {% set iconColors = {
                'blue': 'text-blue-600',
                'orange': 'text-orange-500',
                'purple': 'text-violet-600',
                'amber': 'text-amber-500',
                'gray': 'text-slate-500'
            } %}
            <div class="prod-icon" style="background: {{ gradients[card.color] ?? gradients['blue'] }};">
                {% if card.icon == 'upload' %}
                <svg class="w-4.5 h-4.5 {{ iconColors[card.color] ?? 'text-blue-600' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"/>
                </svg>
                {% elseif card.icon == 'download' %}
                <svg class="w-4.5 h-4.5 {{ iconColors[card.color] ?? 'text-blue-600' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"/>
                </svg>
                {% elseif card.icon == 'shield' %}
                <svg class="w-4.5 h-4.5 {{ iconColors[card.color] ?? 'text-blue-600' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
                {% elseif card.icon == 'chart' %}
                <svg class="w-4.5 h-4.5 {{ iconColors[card.color] ?? 'text-blue-600' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                {% elseif card.icon == 'calendar' %}
                <svg class="w-4.5 h-4.5 {{ iconColors[card.color] ?? 'text-blue-600' }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                {% endif %}
            </div>
            <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">{{ card.label }}</span>
        </div>
        <p class="text-lg font-extrabold text-gray-900 tracking-tight">{{ card.value }}</p>
    </div>
    {% endfor %}
</div>
{% endif %}

{# ═══════════════════════════════════════════════════════════════════
   SUPPORTS D'INVESTISSEMENT — Holdings Table
   ═══════════════════════════════════════════════════════════════════ #}
{% if holdings|length > 0 %}
<div class="mb-8 prod-animate prod-delay-3">
    {# Section Header #}
    <div class="flex items-center justify-between mb-5">
        <div class="flex items-center gap-3">
            <div class="prod-icon" style="background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(99,102,241,0.1));">
                <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
            </div>
            <h2 class="prod-section-title">Supports d'investissement</h2>
        </div>
        <span class="prod-badge prod-badge-blue" style="font-size: 0.8125rem; text-transform: none; letter-spacing: 0;">
            {{ holdings|length }} {{ holdings|length > 1 ? 'lignes' : 'ligne' }}
        </span>
    </div>

    {# ─── Computed flags ─── #}
    {% set hasAvgBuyPrice = holdings|filter(h => h.avgBuyPrice is defined and h.avgBuyPrice is not null)|length > 0 %}
    {% set hasPnl = holdings|filter(h => h.pnl is defined and h.pnl is not null)|length > 0 %}
    {% set hasPnlEstimated = false %}
    {% set hasPamComputed = hasPamComputed|default(false) %}

    {# ─── MOBILE VIEW: Premium cards ─── #}
    <div class="space-y-4 lg:hidden">
        {% set avatarGradients = [
            'linear-gradient(135deg, #6366f1, #8b5cf6)',
            'linear-gradient(135deg, #3b82f6, #06b6d4)',
            'linear-gradient(135deg, #ec4899, #f43f5e)',
            'linear-gradient(135deg, #f59e0b, #f97316)',
            'linear-gradient(135deg, #10b981, #14b8a6)',
            'linear-gradient(135deg, #ef4444, #f97316)',
            'linear-gradient(135deg, #8b5cf6, #a855f7)',
            'linear-gradient(135deg, #06b6d4, #22d3ee)',
        ] %}
        {% for h in holdings %}
        {% set pnl = h.pnl %}
        {% set pnlPositive = pnl is not null and pnl >= 0 %}
        <div class="prod-mobile-card">
            {# Card Header #}
            <div class="p-4 border-b border-gray-100/80">
                <div class="flex items-center gap-3">
                    <div class="prod-support-avatar" style="background: {{ avatarGradients[loop.index0 % 8] }};">
                        {{ h.name|slice(0, 2)|upper }}
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="font-bold text-gray-900 text-sm truncate">{{ h.name }}</p>
                        <p class="text-xs text-gray-400 font-mono mt-0.5">{{ h.isin ?? h.symbol }}</p>
                        {% if h.assetType is defined and h.assetType %}
                        <span class="inline-block mt-1 px-2 py-0.5 bg-indigo-50 text-indigo-600 rounded text-[10px] font-semibold">{{ h.assetType }}</span>
                        {% endif %}
                    </div>
                    {% if pnl is not null %}
                    <div class="flex-shrink-0">
                        <span class="prod-pnl-badge {{ pnlPositive ? 'prod-pnl-badge-pos' : 'prod-pnl-badge-neg' }}">
                            {{ pnlPositive ? '+' : '' }}{{ pnl|number_format(2, ',', ' ') }} €
                        </span>
                    </div>
                    {% endif %}
                </div>
            </div>
            {# Card Body — Grid metrics #}
            <div class="p-4 grid grid-cols-2 gap-x-4 gap-y-3">
                <div>
                    <span class="text-[10px] uppercase tracking-wider text-gray-400 font-medium">Nb parts</span>
                    <p class="text-sm font-bold text-gray-900 tabular-nums">{{ h.units|number_format(2, ',', ' ') }}</p>
                </div>
                <div>
                    <span class="text-[10px] uppercase tracking-wider text-gray-400 font-medium">Cours (€)</span>
                    <p class="text-sm font-bold text-gray-900 tabular-nums">{{ h.price|number_format(4, ',', ' ') }}</p>
                </div>
                {% if h.avgBuyPrice is defined and h.avgBuyPrice is not null %}
                <div>
                    <span class="text-[10px] uppercase tracking-wider text-gray-400 font-medium">Prix moyen (€)</span>
                    <p class="text-sm font-bold text-gray-900 tabular-nums">{{ h.avgBuyPrice|number_format(2, ',', ' ') }}</p>
                </div>
                {% endif %}
                {% if h.avgBuyPriceDate is defined and h.avgBuyPriceDate is not null %}
                <div>
                    <span class="text-[10px] uppercase tracking-wider text-gray-400 font-medium">Date PM</span>
                    <p class="text-sm text-gray-600">{{ h.avgBuyPriceDate|date('d/m/Y') }}</p>
                </div>
                {% endif %}
                <div>
                    <span class="text-[10px] uppercase tracking-wider text-gray-400 font-medium">Date VL</span>
                    <p class="text-sm text-gray-600">{{ h.priceDate ? h.priceDate|date('d/m/Y') : '—' }}</p>
                </div>
                <div>
                    <span class="text-[10px] uppercase tracking-wider text-gray-400 font-medium">Répartition</span>
                    <p class="text-sm font-bold text-gray-900 tabular-nums">
                        {% if h.percentage is defined and h.percentage is not null %}
                            {{ h.percentage|number_format(2, ',', ' ') }}%
                        {% else %}
                            {% set share = encours > 0 ? ((h.amount / encours) * 100) : 0 %}
                            {{ share|number_format(2, ',', ' ') }}%
                        {% endif %}
                    </p>
                </div>
                {% if pnl is not null %}
                <div>
                    <span class="text-[10px] uppercase tracking-wider text-gray-400 font-medium">+/- value (€)</span>
                    <p class="text-sm font-bold {{ pnlPositive ? 'prod-pnl-pos' : 'prod-pnl-neg' }} tabular-nums">
                        {{ pnlPositive ? '+' : '' }}{{ pnl|number_format(2, ',', ' ') }}
                    </p>
                </div>
                {% endif %}
                {% if h.pnlPct is defined and h.pnlPct is not null %}
                <div>
                    <span class="text-[10px] uppercase tracking-wider text-gray-400 font-medium">+/- value (%)</span>
                    <p class="text-sm font-bold {{ h.pnlPct >= 0 ? 'prod-pnl-pos' : 'prod-pnl-neg' }} tabular-nums">
                        {{ h.pnlPct >= 0 ? '+' : '' }}{{ h.pnlPct|number_format(2, ',', ' ') }}%
                    </p>
                </div>
                {% endif %}
            </div>
            {# Card Footer — Total #}
            <div class="px-4 py-3 border-t border-gray-100/80 flex justify-between items-center" style="background: rgba(248,250,252,0.5);">
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Évaluation</span>
                <span class="font-extrabold text-gray-900 text-base tabular-nums">{{ h.amount|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>
        {% endfor %}
    </div>

    {# ─── DESKTOP VIEW: Premium table ─── #}
    <div class="hidden lg:block prod-card p-0">
        <div class="overflow-x-auto">
            <table class="prod-table">
                <thead>
                    <tr>
                        <th class="text-left">ISIN</th>
                        <th class="text-left">Libellé</th>
                        <th class="text-right">Nb parts</th>
                        <th class="text-right">Cours (€)</th>
                        {% if hasAvgBuyPrice %}
                        <th class="text-right">Prix moyen (€)</th>
                        <th class="text-right">Date PM</th>
                        {% endif %}
                        <th class="text-right">Évaluation (€)</th>
                        <th class="text-right">Répartition</th>
                        {% if hasPnl %}
                        <th class="text-right">+/- value (€)</th>
                        <th class="text-right">+/- value (%)</th>
                        {% endif %}
                        <th class="text-right">Date VL</th>
                    </tr>
                </thead>
                <tbody>
                    {% for h in holdings %}
                    {% set pnl = h.pnl %}
                    {% set pnlPositive = pnl is not null and pnl >= 0 %}
                    <tr>
                        <td class="font-mono text-xs text-gray-400 whitespace-nowrap">{{ h.isin ?? '--' }}</td>
                        <td class="max-w-[240px]">
                            <div class="flex items-center gap-3">
                                <div class="prod-support-avatar" style="background: {{ avatarGradients[loop.index0 % 8] }};">
                                    {{ h.name|slice(0, 2)|upper }}
                                </div>
                                <div class="min-w-0">
                                    <p class="font-bold text-gray-900 text-sm truncate" title="{{ h.name }}">{{ h.name }}</p>
                                    {% if h.assetType is defined and h.assetType %}
                                    <span class="text-[10px] text-indigo-500 font-medium">{{ h.assetType }}</span>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td class="text-right font-semibold text-gray-700 tabular-nums">{{ h.units|number_format(2, ',', ' ') }}</td>
                        <td class="text-right font-semibold text-gray-700 tabular-nums">{{ h.price|number_format(4, ',', ' ') }}</td>
                        {% if hasAvgBuyPrice %}
                        <td class="text-right font-semibold text-gray-700 tabular-nums">
                            {% if h.avgBuyPrice is defined and h.avgBuyPrice is not null %}
                            {{ h.avgBuyPrice|number_format(2, ',', ' ') }}
                            {% else %}
                            <span class="text-gray-300">—</span>
                            {% endif %}
                        </td>
                        <td class="text-right text-xs text-gray-400 whitespace-nowrap">
                            {% if h.avgBuyPriceDate is defined and h.avgBuyPriceDate is not null %}
                            {{ h.avgBuyPriceDate|date('d/m/Y') }}
                            {% else %}
                            <span class="text-gray-300">—</span>
                            {% endif %}
                        </td>
                        {% endif %}
                        <td class="text-right font-extrabold text-gray-900 tabular-nums">{{ h.amount|number_format(2, ',', ' ') }}</td>
                        <td class="text-right text-gray-500 tabular-nums">
                            {% if h.percentage is defined and h.percentage is not null %}
                                {{ h.percentage|number_format(2, ',', ' ') }}%
                            {% else %}
                                {% set share = encours > 0 ? ((h.amount / encours) * 100) : 0 %}
                                {{ share|number_format(2, ',', ' ') }}%
                            {% endif %}
                        </td>
                        {% if hasPnl %}
                        <td class="text-right tabular-nums">
                            {% if pnl is not null %}
                            <span class="font-bold {{ pnlPositive ? 'prod-pnl-pos' : 'prod-pnl-neg' }}">
                                {{ pnlPositive ? '+' : '' }}{{ pnl|number_format(2, ',', ' ') }}
                            </span>
                            {% else %}
                            <span class="text-gray-300">—</span>
                            {% endif %}
                        </td>
                        <td class="text-right tabular-nums">
                            {% if h.pnlPct is defined and h.pnlPct is not null %}
                            <span class="prod-pnl-badge {{ h.pnlPct >= 0 ? 'prod-pnl-badge-pos' : 'prod-pnl-badge-neg' }}">
                                {{ h.pnlPct >= 0 ? '+' : '' }}{{ h.pnlPct|number_format(2, ',', ' ') }}%
                            </span>
                            {% else %}
                            <span class="text-gray-300">—</span>
                            {% endif %}
                        </td>
                        {% endif %}
                        <td class="text-right text-xs text-gray-400 whitespace-nowrap">
                            {{ h.priceDate ? h.priceDate|date('d/m/Y') : '—' }}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td class="text-gray-900" colspan="{{ hasAvgBuyPrice ? 6 : 4 }}">Total</td>
                        <td class="text-right text-gray-900 tabular-nums">{{ encours|number_format(2, ',', ' ') }}</td>
                        <td class="text-right text-gray-900">100,00%</td>
                        {% if hasPnl %}
                        <td class="text-right">
                            {% if plusMinus is not null %}
                            <span class="font-extrabold {{ plusMinus >= 0 ? 'prod-pnl-pos' : 'prod-pnl-neg' }}">
                                {{ plusMinus >= 0 ? '+' : '' }}{{ plusMinus|number_format(2, ',', ' ') }}
                            </span>
                            {% endif %}
                        </td>
                        <td class="text-right">
                            {% if plusMinusPct is defined and plusMinusPct is not null %}
                            <span class="prod-pnl-badge {{ plusMinusPct >= 0 ? 'prod-pnl-badge-pos' : 'prod-pnl-badge-neg' }}">
                                {{ plusMinusPct >= 0 ? '+' : '' }}{{ plusMinusPct|number_format(2, ',', ' ') }}%
                            </span>
                            {% endif %}
                        </td>
                        {% endif %}
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
        {% if hasPamComputed %}
        <div class="px-6 py-3 border-t border-gray-100/80 bg-amber-50/50">
            <p class="text-xs text-amber-700">
                <span class="font-semibold">*</span> Prix moyen d'achat calculé à partir de l'historique des positions. Ce calcul est une approximation basée sur les données disponibles (~1 an).
            </p>
        </div>
        {% endif %}
    </div>
</div>
{% else %}
{# ─── No holdings — Elegant empty state ─── #}
<div class="prod-card mb-8 prod-animate prod-delay-3">
    <div class="px-6 py-5 border-b border-gray-100/80">
        <div class="flex items-center gap-3">
            <div class="prod-icon" style="background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(99,102,241,0.1));">
                <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
            </div>
            <h2 class="prod-section-title">Supports d'investissement</h2>
        </div>
    </div>
    <div class="p-10 text-center">
        {% if accountDetailsFailed is defined and accountDetailsFailed %}
        <div class="w-16 h-16 mx-auto mb-5 rounded-2xl flex items-center justify-center" style="background: linear-gradient(135deg, rgba(245,158,11,0.1), rgba(249,115,22,0.1));">
            <svg class="w-8 h-8 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
            </svg>
        </div>
        <p class="text-gray-800 font-bold text-base mb-2">Détail des supports temporairement indisponible</p>
        <p class="text-gray-500 text-sm max-w-lg mx-auto mb-5 leading-relaxed">La répartition détaillée pour ce contrat est temporairement indisponible en raison d'un problème de données côté fournisseur. Les informations de valorisation globale restent à jour.</p>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-xs font-semibold" style="background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(249,115,22,0.06)); color: #b45309;">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Erreur source données — situation sera disponible dès correction par le fournisseur
        </div>
        {% else %}
        <div class="w-16 h-16 mx-auto mb-5 rounded-2xl flex items-center justify-center" style="background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1));">
            <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
        </div>
        <p class="text-gray-500 text-sm">Aucun détail de supports disponible pour ce contrat.</p>
        {% endif %}
    </div>
</div>
{% endif %}

{# ═══════════════════════════════════════════════════════════════════
   CHARTS — Visual data representation
   ═══════════════════════════════════════════════════════════════════ #}
{% if holdings|length > 0 %}
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8 prod-animate prod-delay-4">
    {# ─── Donut: Portfolio distribution ─── #}
    <div class="prod-chart-card">
        <div class="prod-chart-header">
            <div class="prod-icon" style="background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1));">
                <svg class="w-4.5 h-4.5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
                </svg>
            </div>
            <h3 class="prod-section-title">Répartition du portefeuille</h3>
        </div>
        <div class="p-6">
            <div class="relative mx-auto" style="height: 300px; max-width: 400px;">
                <canvas id="portfolioChart"></canvas>
            </div>
        </div>
    </div>

    {# ─── Bar: Contract composition ─── #}
    <div class="prod-chart-card">
        <div class="prod-chart-header">
            <div class="prod-icon" style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(20,184,166,0.1));">
                <svg class="w-4.5 h-4.5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
            </div>
            <h3 class="prod-section-title">Composition du contrat</h3>
        </div>
        <div class="p-6">
            <div class="relative" style="height: 300px">
                <canvas id="compositionChart"></canvas>
            </div>
        </div>
    </div>
</div>

{# ─── Chart: +/- value per holding ─── #}
{% set holdingsWithPnl = holdings|filter(h => h.pnl is defined and h.pnl is not null) %}
{% if holdingsWithPnl|length > 0 %}
<div class="prod-chart-card mb-8 prod-animate prod-delay-5">
    <div class="prod-chart-header">
        <div class="prod-icon" style="background: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(168,85,247,0.1));">
            <svg class="w-4.5 h-4.5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
        </div>
        <h3 class="prod-section-title">+/- value par support</h3>
    </div>
    <div class="p-6">
        <div class="relative" style="height: {{ (holdingsWithPnl|length * 44) + 60 }}px; min-height: 220px">
            <canvas id="pnlChart"></canvas>
        </div>
    </div>
</div>
{% endif %}
{% endif %}

</div>{# fin prod-page-bg #}
{% endblock %}

{% block javascripts %}
{% if holdings|length > 0 %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const chartColors = [
        '#7c3aed', '#3b82f6', '#ec4899', '#f59e0b', '#10b981',
        '#ef4444', '#8b5cf6', '#14b8a6', '#f97316', '#06b6d4',
        '#6366f1', '#84cc16', '#e11d48', '#0ea5e9', '#a855f7'
    ];

    const fmt = (v) => new Intl.NumberFormat('fr-FR', {style:'currency',currency:'EUR',minimumFractionDigits:2}).format(v);

    const holdingsData = [
        {% for h in holdings %}
        {
            name: '{{ h.name|e('js') }}',
            isin: '{{ (h.isin ?? '')|e('js') }}',
            amount: {{ h.amount }},
            percentage: {{ (h.percentage ?? (encours > 0 ? ((h.amount / encours) * 100) : 0))|number_format(2, '.', '') }},
            pnl: {{ h.pnl ?? 'null' }},
            pnlPct: {{ h.pnlPct ?? 'null' }}
        }{{ not loop.last ? ',' : '' }}
        {% endfor %}
    ];

    // ─── Donut: Portfolio Distribution ───
    const ctxPortfolio = document.getElementById('portfolioChart');
    if (ctxPortfolio) {
        new Chart(ctxPortfolio, {
            type: 'doughnut',
            data: {
                labels: holdingsData.map(h => h.name.length > 24 ? h.name.substring(0, 24) + '…' : h.name),
                datasets: [{
                    data: holdingsData.map(h => h.amount),
                    backgroundColor: chartColors.slice(0, holdingsData.length),
                    borderWidth: 4,
                    borderColor: '#fff',
                    hoverOffset: 12,
                    hoverBorderWidth: 2,
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '68%',
                animation: {
                    animateRotate: true,
                    duration: 1200,
                    easing: 'easeOutQuart'
                },
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 16,
                            font: { size: 11, family: "'Inter', sans-serif", weight: '500' },
                            usePointStyle: true,
                            pointStyle: 'circle',
                            boxWidth: 8,
                            color: '#475569'
                        }
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.95)',
                        padding: 14,
                        cornerRadius: 10,
                        titleFont: { size: 12, weight: '700' },
                        bodyFont: { size: 11 },
                        boxPadding: 6,
                        callbacks: {
                            label: (ctx) => {
                                const d = holdingsData[ctx.dataIndex];
                                return ` ${fmt(d.amount)} (${d.percentage.toFixed(2)}%)`;
                            }
                        }
                    }
                }
            }
        });
    }

    // ─── Bar: Contract Composition (horizontal) ───
    const ctxComp = document.getElementById('compositionChart');
    if (ctxComp) {
        const sorted = [...holdingsData].sort((a, b) => b.amount - a.amount);
        
        new Chart(ctxComp, {
            type: 'bar',
            data: {
                labels: sorted.map(h => h.name.length > 20 ? h.name.substring(0, 20) + '…' : h.name),
                datasets: [{
                    label: 'Évaluation',
                    data: sorted.map(h => h.amount),
                    backgroundColor: sorted.map((_, i) => {
                        const c = chartColors[i % chartColors.length];
                        return c + 'BB';
                    }),
                    borderColor: sorted.map((_, i) => chartColors[i % chartColors.length]),
                    borderWidth: 1.5,
                    borderRadius: 6,
                    barPercentage: 0.65
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.95)',
                        padding: 14,
                        cornerRadius: 10,
                        boxPadding: 6,
                        callbacks: {
                            title: (items) => sorted[items[0].dataIndex].name,
                            label: (ctx) => {
                                const d = sorted[ctx.dataIndex];
                                let lines = [` ${fmt(d.amount)} (${d.percentage.toFixed(2)}%)`];
                                if (d.pnl !== null) {
                                    lines.push(` +/- value: ${d.pnl >= 0 ? '+' : ''}${fmt(d.pnl)}`);
                                }
                                return lines;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        grid: { color: 'rgba(241,245,249,0.8)', drawBorder: false },
                        ticks: {
                            callback: (v) => new Intl.NumberFormat('fr-FR', {notation:'compact',style:'currency',currency:'EUR',maximumFractionDigits:0}).format(v),
                            font: { size: 10, weight: '500' },
                            color: '#94a3b8'
                        }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { font: { size: 10, weight: '500' }, color: '#64748b' }
                    }
                }
            }
        });
    }

    // ─── Bar: +/- Value per holding ───
    const ctxPnl = document.getElementById('pnlChart');
    if (ctxPnl) {
        const pnlData = holdingsData.filter(h => h.pnl !== null).sort((a, b) => b.pnl - a.pnl);
        
        new Chart(ctxPnl, {
            type: 'bar',
            data: {
                labels: pnlData.map(h => h.name.length > 20 ? h.name.substring(0, 20) + '…' : h.name),
                datasets: [{
                    label: '+/- value',
                    data: pnlData.map(h => h.pnl),
                    backgroundColor: pnlData.map(h => h.pnl >= 0 ? 'rgba(16, 185, 129, 0.65)' : 'rgba(239, 68, 68, 0.65)'),
                    borderColor: pnlData.map(h => h.pnl >= 0 ? '#059669' : '#dc2626'),
                    borderWidth: 1.5,
                    borderRadius: 6,
                    barPercentage: 0.55
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(15,23,42,0.95)',
                        padding: 14,
                        cornerRadius: 10,
                        boxPadding: 6,
                        callbacks: {
                            title: (items) => pnlData[items[0].dataIndex].name,
                            label: (ctx) => {
                                const d = pnlData[ctx.dataIndex];
                                let lines = [` ${d.pnl >= 0 ? '+' : ''}${fmt(d.pnl)}`];
                                if (d.pnlPct !== null) {
                                    lines.push(` ${d.pnlPct >= 0 ? '+' : ''}${d.pnlPct.toFixed(2)}%`);
                                }
                                return lines;
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(241,245,249,0.8)', drawBorder: false },
                        ticks: {
                            callback: (v) => fmt(v),
                            font: { size: 10, weight: '500' },
                            color: '#94a3b8'
                        }
                    },
                    y: {
                        grid: { display: false },
                        ticks: { font: { size: 10, weight: '500' }, color: '#64748b' }
                    }
                }
            }
        });
    }
});
</script>
{% endif %}
{% endblock %}
