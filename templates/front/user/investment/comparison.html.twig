    <!-- Scripts interactifs -->
    <script>
        // Debug - Vérifier si le script se charge
        console.log('Script comparison loaded');
        
        // Variables du carousel
        let currentSlide = 0;
        const totalSlides = {{ products|length }};
        let startX = 0;
        let isDragging = false;
        
        // Debug - Afficher les infos
        console.log('Total slides:', totalSlides);
        console.log('Window width:', window.innerWidth);
        
        // Fonction pour aller à un slide spécifique
        function goToSlide(slideIndex) {
            currentSlide = slideIndex;
            updateCarousel();
        }
        
        // Fonction pour aller au slide précédent
        function prevSlide() {
            currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
            updateCarousel();
        }
        
        // Fonction pour aller au slide suivant
        function nextSlide() {
            currentSlide = (currentSlide + 1) % totalSlides;
            updateCarousel();
        }
        
        // Fonction pour mettre à jour l'affichage du carousel
        function updateCarousel() {
            const slides = document.getElementById('carouselSlides');
            if (slides) {
                const translateX = -currentSlide * 100;
                slides.style.transform = `translateX(${translateX}%)`;
                
                // Mettre à jour les indicateurs
                document.querySelectorAll('.indicator').forEach((indicator, index) => {
                    if (index === currentSlide) {
                        indicator.classList.add('bg-blue-600', 'w-8');
                        indicator.classList.remove('bg-gray-300');
                    } else {
                        indicator.classList.remove('bg-blue-600', 'w-8');
                        indicator.classList.add('bg-gray-300');
                    }
                });
                
                // Mettre à jour les boutons de navigation
                const prevBtn = document.querySelector('.carousel-prev');
                const nextBtn = document.querySelector('.carousel-next');
                if (prevBtn && nextBtn) {
                    prevBtn.style.opacity = currentSlide === 0 ? '0.5' : '1';
                    nextBtn.style.opacity = currentSlide === totalSlides - 1 ? '0.5' : '1';
                }
            }
        }
        
        // Gestion du swipe tactile
        document.addEventListener('DOMContentLoaded', function() {
            const carouselWrapper = document.querySelector('.carousel-wrapper');
            const carouselSlides = document.getElementById('carouselSlides');
            
            if (carouselWrapper && carouselSlides) {
                // Touch events pour mobile
                carouselWrapper.addEventListener('touchstart', handleTouchStart, {passive: true});
                carouselWrapper.addEventListener('touchmove', handleTouchMove, {passive: true});
                carouselWrapper.addEventListener('touchend', handleTouchEnd, {passive: true});
                
                // Mouse events pour desktop (test)
                carouselWrapper.addEventListener('mousedown', handleMouseDown);
                carouselWrapper.addEventListener('mousemove', handleMouseMove);
                carouselWrapper.addEventListener('mouseup', handleMouseUp);
                carouselWrapper.addEventListener('mouseleave', handleMouseUp);
            }
            
            // Auto-play (optionnel)
            // setInterval(() => {
            //     if (!isDragging) {
            //         nextSlide();
            //     }
            // }, 5000);

            // Mise à jour initiale du carousel (indicateurs, position, boutons)
            try {
                updateCarousel();
            } catch (e) {
                console.warn('updateCarousel init error', e);
            }
        });
        
        function handleTouchStart(e) {
            startX = e.touches[0].clientX;
            isDragging = true;
        }
        
        function handleTouchMove(e) {
            if (!isDragging) return;
            const currentX = e.touches[0].clientX;
            const diff = startX - currentX;
            
            // Ajouter un effet de résistance pendant le swipe
            const slides = document.getElementById('carouselSlides');
            if (slides) {
                const baseTranslate = -currentSlide * 100;
                const dragTranslate = -(diff / window.innerWidth) * 100;
                slides.style.transform = `translateX(${baseTranslate + dragTranslate}%)`;
                slides.style.transition = 'none';
            }
        }
        
        function handleTouchEnd(e) {
            if (!isDragging) return;
            const endX = e.changedTouches[0].clientX;
            const diff = startX - endX;
            const threshold = window.innerWidth / 4; // Seuil de 25% de la largeur
            
            const slides = document.getElementById('carouselSlides');
            if (slides) {
                slides.style.transition = 'transform 0.3s ease-out';
            }
            
            if (Math.abs(diff) > threshold) {
                if (diff > 0 && currentSlide < totalSlides - 1) {
                    nextSlide();
                } else if (diff < 0 && currentSlide > 0) {
                    prevSlide();
                } else {
                    updateCarousel(); // Revenir à la position actuelle
                }
            } else {
                updateCarousel(); // Revenir à la position actuelle
            }
            
            isDragging = false;
        }
        
        function handleMouseDown(e) {
            startX = e.clientX;
            isDragging = true;
            e.preventDefault();
        }
        
        function handleMouseMove(e) {
            if (!isDragging) return;
            const currentX = e.clientX;
            const diff = startX - currentX;
            
            const slides = document.getElementById('carouselSlides');
            if (slides) {
                const baseTranslate = -currentSlide * 100;
                const dragTranslate = -(diff / window.innerWidth) * 100;
                slides.style.transform = `translateX(${baseTranslate + dragTranslate}%)`;
                slides.style.transition = 'none';
            }
        }
        
        function handleMouseUp(e) {
            if (!isDragging) return;
            const endX = e.clientX;
            const diff = startX - endX;
            const threshold = window.innerWidth / 4;
            
            const slides = document.getElementById('carouselSlides');
            if (slides) {
                slides.style.transition = 'transform 0.3s ease-out';
            }
            
            if (Math.abs(diff) > threshold) {
                if (diff > 0 && currentSlide < totalSlides - 1) {
                    nextSlide();
                } else if (diff < 0 && currentSlide > 0) {
                    prevSlide();
                } else {
                    updateCarousel();
                }
            } else {
                updateCarousel();
            }
            
            isDragging = false;
        }
        
        // Fonction pour mettre en évidence un produit (desktop uniquement)
        function highlightProduct(color) {
            // Retirer toutes les classes de mise en évidence précédentes
            document.querySelectorAll('.product-cell').forEach(cell => {
                cell.classList.remove('highlight-active', 'highlight-inactive');
            });
            
            document.querySelectorAll('.product-column').forEach(col => {
                col.classList.remove('highlight-active');
            });
            
            // Ajouter la classe active aux cellules du produit sélectionné
            document.querySelectorAll(`[data-product="${color}"]`).forEach(element => {
                if (element.classList.contains('product-cell')) {
                    element.classList.add('highlight-active');
                } else if (element.classList.contains('product-column')) {
                    element.classList.add('highlight-active');
                }
            });
            
            // Ajouter la classe inactive aux autres cellules
            document.querySelectorAll('.product-cell').forEach(cell => {
                if (!cell.classList.contains('highlight-active')) {
                    cell.classList.add('highlight-inactive');
                }
            });
            
            // Animation de scroll vers le tableau si nécessaire
            const table = document.querySelector('.overflow-x-auto');
            if (table) {
                table.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }
        
        // Fonction pour réinitialiser la mise en évidence
        function resetHighlight() {
            document.querySelectorAll('.product-cell, .product-column').forEach(element => {
                element.classList.remove('highlight-active', 'highlight-inactive');
            });
        }
        
        // Ajout d'un double-clic pour réinitialiser
        document.addEventListener('dblclick', function(e) {
            if (e.target.closest('table')) {
                resetHighlight();
            }
        });
        
        // Effet de survol amélioré pour les lignes
        document.querySelectorAll('tbody tr').forEach(row => {
            row.addEventListener('mouseenter', function() {
                this.style.transform = 'scale(1.01)';
                this.style.boxShadow = '0 4px 12px rgba(0, 0, 0, 0.1)';
                this.style.zIndex = '5';
            });
            
            row.addEventListener('mouseleave', function() {
                this.style.transform = 'scale(1)';
                this.style.boxShadow = 'none';
                this.style.zIndex = 'auto';
            });
        });
        
        // Animation d'apparition au scroll
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };
        
        const observer = new IntersectionObserver(function(entries) {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);
        
        // Observer les lignes du tableau
        document.querySelectorAll('tbody tr').forEach((row, index) => {
            row.style.opacity = '0';
            row.style.transform = 'translateY(20px)';
            row.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
            observer.observe(row);
        });
    </script>
    
    <!-- Styles CSS pour les interactions -->
    <style>
        /* Empêcher les débordements horizontaux */
        * {
            box-sizing: border-box;
        }
        
        body,
        html {
            overflow-x: hidden;
            max-width: 100vw;
        }
        
        /* S'assurer que tous les containers ne débordent pas */
        .max-w-7xl,
        .max-w-3xl,
        .max-w-4xl {
            max-width: 100%;
        }
        
        @media (min-width: 1280px) {
            .max-w-7xl {
                max-width: 80rem;
            }
        }
        
        @media (min-width: 768px) and (max-width: 1279px) {
            .max-w-7xl {
                max-width: 100%;
                padding-left: 2rem;
                padding-right: 2rem;
            }
        }
        
        /* Images responsive */
        img,
        svg {
            max-width: 100%;
            height: auto;
        }
        
        .highlight-active {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(99, 102, 241, 0.1)) !important;
            border: 2px solid rgba(59, 130, 246, 0.3) !important;
            box-shadow: 0 4px 20px rgba(59, 130, 246, 0.2) !important;
            transform: scale(1.02) !important;
            z-index: 10 !important;
            position: relative !important;
        }
        
        .highlight-inactive {
            opacity: 0.4 !important;
            filter: grayscale(0.3) !important;
        }
        
        .product-column.highlight-active {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.2), rgba(99, 102, 241, 0.2)) !important;
            transform: scale(1.05) !important;
        }
        
        tbody tr {
            transition: all 0.3s ease !important;
        }
        
        .product-cell {
            transition: all 0.3s ease !important;
        }
        
        /* Animation de pulsation pour les boutons */
        @keyframes pulse-soft {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.02); }
        }
        
        .group:hover {
            animation: pulse-soft 2s infinite;
        }
        
        /* Amélioration du scroll horizontal sur mobile */
        .overflow-x-auto {
            scrollbar-width: thin;
            scrollbar-color: rgba(59, 130, 246, 0.3) rgba(0, 0, 0, 0.1);
        }
        
        .overflow-x-auto::-webkit-scrollbar {
            height: 8px;
        }
        
        .overflow-x-auto::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
        }
        
        .overflow-x-auto::-webkit-scrollbar-thumb {
            background: rgba(59, 130, 246, 0.3);
            border-radius: 10px;
        }
        
        .overflow-x-auto::-webkit-scrollbar-thumb:hover {
            background: rgba(59, 130, 246, 0.5);
        }
        
        /* Initialisation des éléments */
        .comparison-carousel-mobile {
            display: none;
        }
        
        .comparison-table-desktop {
            display: block;
        }
        
        .carousel-container {
            position: relative;
            margin: 0;
            width: 100%;
            max-width: 100%;
        }
        
        .carousel-wrapper {
            overflow: hidden;
            position: relative;
        }
        
        .carousel-slides {
            display: flex;
            transition: transform 0.3s ease-out;
            will-change: transform;
        }
        
        .carousel-slide {
            width: 100%;
            min-width: 100%;
            flex-shrink: 0;
        }
        
        .carousel-indicators {
            padding: 1.5rem 0;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 0.5rem;
        }
        
        .indicator {
            width: 0.75rem;
            height: 0.75rem;
            border-radius: 50%;
            background-color: #d1d5db;
            border: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .indicator.bg-blue-600 {
            background-color: #2563eb;
            width: 2rem;
            border-radius: 0.5rem;
        }
        
        .carousel-prev,
        .carousel-next {
            position: absolute;
