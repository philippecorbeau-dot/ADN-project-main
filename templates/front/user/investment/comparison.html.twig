{% extends 'front/user/dashboard/base.html.twig' %}

{% block page_title %}Comparaison des produits d'investissement{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-0">
    <!-- Breadcrumb moderne -->
    {% include 'partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'path': 'user_dashboard', 'icon': 'dashboard'},
            {'label': 'Investissements', 'path': 'user_portfolio', 'icon': 'investment'},
            {'label': 'Comparaison des produits'}
        ]
    } %}

    <!-- En-tête amélioré avec hiérarchie visuelle -->
    <div class="text-center mb-6 sm:mb-8 md:mb-12 relative px-2 sm:px-4">
        <!-- Badge d'introduction -->
        <div class="inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 bg-gradient-to-r from-blue-100 to-indigo-100 text-blue-800 rounded-full text-xs sm:text-sm font-medium mb-4 sm:mb-6 border border-blue-200">
            <svg class="w-3 h-3 sm:w-4 sm:h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            COMPARATIF COMPLET
        </div>
        
        <!-- Titre principal avec gradient -->
        <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-4 sm:mb-6 leading-tight px-2">
            <span class="bg-gradient-to-r from-gray-900 via-blue-900 to-indigo-900 bg-clip-text text-transparent">
                Comparaison des produits
            </span>
            <br>
            <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
                d'investissement
            </span>
        </h1>
        
        <!-- Sous-titre enrichi -->
        <div class="max-w-3xl mx-auto mb-6 sm:mb-8 px-4">
            <p class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-600 mb-3 sm:mb-4 leading-relaxed">
                Découvrez et comparez nos différentes solutions d'investissement pour choisir celle qui correspond le mieux à vos objectifs patrimoniaux.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center space-y-2 sm:space-y-0 sm:space-x-4 md:space-x-6 text-xs sm:text-sm text-gray-500">
                <div class="flex items-center space-x-2">
                    <svg class="w-3 h-3 sm:w-4 sm:h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span>4 produits comparés</span>
                </div>
                <div class="flex items-center space-x-2">
                    <svg class="w-3 h-3 sm:w-4 sm:h-4 text-blue-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span>6 critères analysés</span>
                </div>
                <div class="flex items-center space-x-2">
                    <svg class="w-3 h-3 sm:w-4 sm:h-4 text-purple-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    <span>Conseils personnalisés</span>
                </div>
            </div>
        </div>
        
        <!-- Indicateur de scroll (caché sur mobile) -->
        <div class="hidden md:block animate-bounce">
            <svg class="w-5 h-5 md:w-6 md:h-6 text-gray-400 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
        </div>
        
        <!-- Décoration de fond (cachée sur mobile) -->
        <div class="hidden md:block absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-4 w-32 h-32 bg-gradient-to-br from-blue-100 to-purple-100 rounded-full opacity-20 -z-10"></div>
        <div class="hidden md:block absolute bottom-0 right-1/4 w-24 h-24 bg-gradient-to-br from-indigo-100 to-blue-100 rounded-full opacity-15 -z-10"></div>
    </div>

    <!-- Tableau de comparaison amélioré -->
    <div class="comparison-table-desktop hidden lg:block bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <!-- En-tête avec gradient moderne -->
        <div class="bg-gradient-to-r from-slate-800 via-blue-900 to-indigo-900 px-6 py-6">
            <h2 class="text-xl font-bold text-white text-center">
                Comparatif détaillé des solutions d'investissement
            </h2>
            <p class="text-blue-100 text-center mt-2 text-sm">
                Cliquez sur une colonne pour mettre en évidence un produit
            </p>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gradient-to-r from-gray-50 to-gray-100 border-b-2 border-gray-200">
                    <tr>
                        <th class="px-8 py-5 text-left text-sm font-bold text-gray-800 bg-gray-100 sticky left-0 z-10 shadow-sm">
                            <div class="flex items-center space-x-2">
                                <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                                <span>Critères de comparaison</span>
                            </div>
                        </th>
                        {% for product in products %}
                            <th class="px-6 py-5 text-center cursor-pointer hover:bg-{{ product.color }}-50 transition-all duration-300 group product-column" 
                                data-product="{{ product.name }}" 
                                onclick="highlightProduct('{{ product.color }}')">
                                <div class="flex flex-col items-center space-y-2">
                                    <div class="w-12 h-12 bg-{{ product.color }}-100 rounded-full flex items-center justify-center group-hover:bg-{{ product.color }}-200 transition-colors">
                                        {% if product.name == 'SCPI' %}
                                            <svg class="w-6 h-6 text-{{ product.color }}-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                            </svg>
                                        {% elseif product.name == 'PEA' %}
                                            <svg class="w-6 h-6 text-{{ product.color }}-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                                            </svg>
                                        {% elseif product.name == 'Assurance-vie' %}
                                            <svg class="w-6 h-6 text-{{ product.color }}-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.031 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                            </svg>
                                        {% else %}
                                            <svg class="w-6 h-6 text-{{ product.color }}-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                                            </svg>
                                        {% endif %}
                                    </div>
                                    <div class="text-center">
                                        <span class="text-sm font-bold text-{{ product.color }}-700 block">{{ product.name }}</span>
                                        <span class="text-xs text-gray-500 group-hover:text-{{ product.color }}-600 transition-colors">Cliquez pour comparer</span>
                                    </div>
                                </div>
                            </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <!-- Rendement avec amélioration visuelle -->
                    <tr class="hover:bg-gray-50 transition-colors duration-200 group">
                        <td class="px-8 py-6 font-bold text-gray-900 bg-gray-50 sticky left-0 z-10 border-r border-gray-200">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
                                    <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="font-semibold text-gray-900">Rendement attendu</div>
                                    <div class="text-xs text-gray-500">Performance annuelle</div>
                                </div>
                            </div>
                        </td>
                        {% for product in products %}
                            <td class="px-6 py-6 text-center product-cell" data-product="{{ product.color }}">
                                <div class="flex flex-col items-center space-y-1">
                                    <span class="text-2xl font-bold text-{{ product.color }}-600">{{ product.yield }}</span>
                                    <span class="text-xs text-gray-500 bg-{{ product.color }}-50 px-2 py-1 rounded-full">par an</span>
                                </div>
                            </td>
                        {% endfor %}
                    </tr>

                    <!-- Risque avec amélioration visuelle -->
                    <tr class="hover:bg-gray-50 transition-colors duration-200 group">
                        <td class="px-8 py-6 font-bold text-gray-900 bg-gray-50 sticky left-0 z-10 border-r border-gray-200">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 bg-yellow-100 rounded-lg flex items-center justify-center">
                                    <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="font-semibold text-gray-900">Niveau de risque</div>
                                    <div class="text-xs text-gray-500">Volatilité du placement</div>
                                </div>
                            </div>
                        </td>
                        {% for product in products %}
                            <td class="px-6 py-6 text-center product-cell" data-product="{{ product.color }}">
                                <div class="flex justify-center">
                                    <span class="px-4 py-2 rounded-xl text-sm font-bold shadow-sm
                                        {% if product.risk == 'Faible' or product.risk == 'Faible à Modéré' %}bg-green-100 text-green-800 border border-green-200
                                        {% elseif product.risk == 'Modéré' or product.risk == 'Faible à Élevé' %}bg-yellow-100 text-yellow-800 border border-yellow-200
                                        {% else %}bg-red-100 text-red-800 border border-red-200{% endif %}">
                                    {{ product.risk }}
                                </span>
                                </div>
                            </td>
                        {% endfor %}
                    </tr>

                    <!-- Liquidité avec amélioration visuelle -->
                    <tr class="hover:bg-gray-50 transition-colors duration-200 group">
                        <td class="px-8 py-6 font-bold text-gray-900 bg-gray-50 sticky left-0 z-10 border-r border-gray-200">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
                                    <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="font-semibold text-gray-900">Liquidité</div>
                                    <div class="text-xs text-gray-500">Facilité de récupération</div>
                                </div>
                            </div>
                        </td>
                        {% for product in products %}
                            <td class="px-6 py-6 text-center product-cell" data-product="{{ product.color }}">
                                <div class="flex justify-center">
                                    <span class="px-4 py-2 rounded-xl text-sm font-bold shadow-sm
                                        {% if product.liquidity == 'Totale' or product.liquidity == 'Bonne' %}bg-green-100 text-green-800 border border-green-200
                                        {% elseif product.liquidity == 'Limitée' %}bg-yellow-100 text-yellow-800 border border-yellow-200
                                        {% else %}bg-red-100 text-red-800 border border-red-200{% endif %}">
                                    {{ product.liquidity }}
                                </span>
                                </div>
                            </td>
                        {% endfor %}
                    </tr>

                    <!-- Fiscalité avec amélioration visuelle -->
                    <tr class="hover:bg-gray-50 transition-colors duration-200 group">
                        <td class="px-8 py-6 font-bold text-gray-900 bg-gray-50 sticky left-0 z-10 border-r border-gray-200">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center">
                                    <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="font-semibold text-gray-900">Fiscalité</div>
                                    <div class="text-xs text-gray-500">Optimisation fiscale</div>
                                </div>
                            </div>
                        </td>
                        {% for product in products %}
                            <td class="px-6 py-6 text-center product-cell" data-product="{{ product.color }}">
                                <div class="bg-{{ product.color }}-50 rounded-lg p-3 border border-{{ product.color }}-100">
                                    <span class="text-sm font-medium text-{{ product.color }}-700">{{ product.taxation }}</span>
                                </div>
                            </td>
                        {% endfor %}
                    </tr>

                    <!-- Investment minimum avec amélioration visuelle -->
                    <tr class="hover:bg-gray-50 transition-colors duration-200 group">
                        <td class="px-8 py-6 font-bold text-gray-900 bg-gray-50 sticky left-0 z-10 border-r border-gray-200">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center">
                                    <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="font-semibold text-gray-900">Investissement minimum</div>
                                    <div class="text-xs text-gray-500">Montant de départ</div>
                                </div>
                            </div>
                        </td>
                        {% for product in products %}
                            <td class="px-6 py-6 text-center product-cell" data-product="{{ product.color }}">
                                <div class="flex flex-col items-center space-y-1">
                                    <span class="text-xl font-bold text-{{ product.color }}-600">{{ product.minInvestment }}</span>
                                    <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-full">minimum</span>
                                </div>
                            </td>
                        {% endfor %}
                    </tr>

                    <!-- Actions avec design amélioré -->
                    <tr class="bg-gradient-to-r from-gray-50 to-gray-100 border-t-2 border-gray-200">
                        <td class="px-8 py-8 font-bold text-gray-900 bg-gray-100 sticky left-0 z-10 border-r border-gray-200">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 bg-gray-200 rounded-lg flex items-center justify-center">
                                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="font-semibold text-gray-900">Actions disponibles</div>
                                    <div class="text-xs text-gray-500">Découvrir et investir</div>
                                </div>
                            </div>
                        </td>
                        {% for product in products %}
                            <td class="px-6 py-8 text-center product-cell" data-product="{{ product.color }}">
                                <div class="space-y-3">
                                    {% set productPath = '' %}
                                    {% if product.name == 'SCPI' %}
                                        {% set productPath = 'user_investment_scpi' %}
                                    {% elseif product.name == 'PEA' %}
                                        {% set productPath = 'user_investment_pea_pme' %}
                                    {% elseif product.name == 'Assurance-vie' %}
                                        {% set productPath = 'user_investment_assurance_vie' %}
                                    {% elseif product.name == 'PER' %}
                                        {% set productPath = 'user_investment_per' %}
                                    {% endif %}
                                    
                                    <a href="{{ path(productPath) }}" 
                                       class="group inline-flex items-center justify-center w-full bg-{{ product.color }}-600 text-white py-3 px-4 rounded-xl text-sm font-bold hover:bg-{{ product.color }}-700 transform hover:scale-105 transition-all duration-300 shadow-lg hover:shadow-xl">
                                        <svg class="w-4 h-4 mr-2 group-hover:rotate-12 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                                        </svg>
                                        Découvrir
                                    </a>
                                    
                                    <div class="text-xs text-gray-500 bg-white rounded-lg p-2 border border-gray-200">
                                        <div class="font-medium text-{{ product.color }}-600">En savoir plus</div>
                                        <div>Détails & simulation</div>
                                    </div>
                                </div>
                            </td>
                        {% endfor %}
                    </tr>
                </tbody>
            </table>
        </div>
        
        <!-- Légende interactive -->
        <div class="mt-6 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-4 border border-blue-200">
            <div class="flex flex-col sm:flex-row items-center justify-center space-y-3 sm:space-y-0 sm:space-x-6 text-sm">
                <div class="flex items-center space-x-2">
                    <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                    <span class="text-gray-700">Excellent</span>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                    <span class="text-gray-700">Modéré</span>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                    <span class="text-gray-700">Attention</span>
                </div>
                <div class="text-gray-500 text-xs text-center sm:text-left sm:ml-4 mt-2 sm:mt-0">
                    💡 Astuce : Cliquez sur un en-tête de produit pour le mettre en évidence
                </div>
            </div>
        </div>
    </div>

    <!-- Version mobile : Carousel (masquée sur desktop) -->
    <!-- Debug: Nombre de produits = {{ products|length }} -->
    <div class="comparison-carousel-mobile block lg:hidden">
        <!-- Carousel Container -->
        <div class="carousel-container relative bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
            <!-- Carousel Wrapper -->
            <div class="carousel-wrapper relative">
                <!-- Slides Container -->
                <div class="carousel-slides flex transition-transform duration-300 ease-out" id="carouselSlides">
                    {% for product in products %}
                        <div class="carousel-slide w-full flex-shrink-0" data-slide="{{ loop.index0 }}">
                            <!-- Product Header -->
                            <div class="bg-gradient-to-r from-{{ product.color }}-500 to-{{ product.color }}-600 text-white p-6">
                                <div class="flex items-center justify-center space-x-3 mb-3">
                                    <div class="w-16 h-16 bg-white/20 backdrop-blur rounded-full flex items-center justify-center">
                                        {% if product.name == 'SCPI' %}
                                            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                            </svg>
                                        {% elseif product.name == 'PEA' %}
                                            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                                            </svg>
                                        {% elseif product.name == 'Assurance-vie' %}
                                            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.031 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                            </svg>
                                        {% else %}
                                            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
