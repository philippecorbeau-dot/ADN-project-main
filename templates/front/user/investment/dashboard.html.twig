    <!-- JavaScript for mobile sidebar -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const mobileMenuButton = document.getElementById('mobile-menu-button');
            const mobileMenuButtonClosed = document.getElementById('mobile-menu-button-closed');
            const sidebar = document.getElementById('sidebar');
            const overlay = document.createElement('div');
            
            overlay.className = 'fixed inset-0 bg-black bg-opacity-50 z-30 lg:hidden';
            overlay.style.display = 'none';
            document.body.appendChild(overlay);

            function openSidebar() {
                sidebar.classList.remove('-translate-x-full');
                sidebar.classList.add('translate-x-0');
                overlay.style.display = 'block';
                // Hide the closed button
                mobileMenuButtonClosed.style.display = 'none';
            }

            function closeSidebar() {
                sidebar.classList.remove('translate-x-0');
                sidebar.classList.add('-translate-x-full');
                overlay.style.display = 'none';
                // Show the closed button
                mobileMenuButtonClosed.style.display = 'block';
            }

            // Open sidebar from outside button
            mobileMenuButtonClosed.addEventListener('click', openSidebar);
            
            // Close sidebar from inside button
            mobileMenuButton.addEventListener('click', closeSidebar);
            
            // Close sidebar when clicking overlay
            overlay.addEventListener('click', closeSidebar);

            // Handle window resize
            window.addEventListener('resize', function() {
                if (window.innerWidth >= 1024) { // lg breakpoint
                    sidebar.classList.remove('-translate-x-full');
                    sidebar.classList.add('translate-x-0');
                    overlay.style.display = 'none';
                    mobileMenuButtonClosed.style.display = 'none';
                } else {
                    sidebar.classList.remove('translate-x-0');
                    sidebar.classList.add('-translate-x-full');
                    overlay.style.display = 'none';
                    mobileMenuButtonClosed.style.display = 'block';
                }
            });

            // Initialize state
            if (window.innerWidth < 1024) {
                mobileMenuButtonClosed.style.display = 'block';
            }
        });

        // Function to track investment opportunity clicks
        function trackClick(product, action) {
            fetch('/api/investment/track-click', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    product: product,
                    action: action
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    /* log removed */
                } else {
                    console.error('Failed to track click:', data.error);
                }
            })
            .catch(error => {
                console.error('Error tracking click:', error);
            });
        }
    </script>
