<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ADN Family Office - Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'homblue-normal': '#1e40af',
                        'homblue-light': '#dbeafe',
                        'homblue-alternate': '#1d4ed8'
                    }
                }
            }
        }
    </script>
</head>
<body class="h-full">
    {% set stepKyc = user.stepKyc|default(1) %}
    {% set isStepKycDocuments = (stepKyc == constant('App\\Entity\\User\\User::STEP_KYC_DOCUMENTS')) %}
    <div class="flex h-full">


        <!-- Sidebar Navigation -->
        <div id="sidebar" class="fixed inset-y-0 left-0 z-40 w-16 lg:w-20 bg-white border-r border-gray-200 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
            <div class="flex flex-col flex-grow pt-5 pb-4 overflow-y-auto">
                <!-- Mobile menu button inside sidebar -->
                <div class="lg:hidden flex justify-center mb-4">
                    <button id="mobile-menu-button" class="bg-gray-100 p-2 rounded-md hover:bg-gray-200 transition-colors">
                        <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>
                <nav class="flex-1 px-2 space-y-1">
                    <a href="#" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Documents">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </a>
                    <a href="#" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Investissements">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                        </svg>
                    </a>
                    <a href="#" class="bg-blue-100 text-blue-600 group flex items-center px-2 py-2 text-sm font-medium rounded-md" title="Dashboard">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </a>
                    <a href="#" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Opportunités">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                        </svg>
                    </a>
                    <a href="#" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Portfolio">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5a2 2 0 012-2h4a2 2 0 012 2v6H8V5z" />
                        </svg>
                    </a>
                    <a href="#" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Conseiller">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                    </a>
                    <a href="#" class="group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Paramètres">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </a>
                    
                    <!-- Mobile-only user actions -->
                    <div class="lg:hidden mt-8 pt-4 border-t border-gray-200">
                        <!-- Notifications -->
                        <button type="button" class="w-full group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Notifications">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5zM4 19h6v-6H4v6z" />
                            </svg>
                            <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-red-400 ring-2 ring-white"></span>
                        </button>
                        
                        <!-- Messages -->
                        <button type="button" class="w-full group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Messages">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                            </svg>
                            <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-blue-400 ring-2 ring-white"></span>
                        </button>

                        <!-- Admin Access -->
                        {% if is_granted('ROLE_SUPER_ADMIN') %}
                        <a href="{{ path('admin') }}" class="w-full group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Admin">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                        </a>
                        {% endif %}

                        <!-- User Profile -->
                        <button type="button" class="w-full group flex items-center px-2 py-2 text-sm font-medium rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-50" title="Profil">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </button>

                        <!-- Logout -->
                        <a href="{{ path('app_logout') }}" class="w-full group flex items-center px-2 py-2 text-sm font-medium rounded-md text-red-600 hover:text-red-700 hover:bg-red-50" title="Déconnexion">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                        </a>
                    </div>
                </nav>
            </div>
        </div>

                        <!-- Mobile menu button (when sidebar is closed) -->
        <div class="lg:hidden fixed top-2 left-2 z-50" id="mobile-menu-button-closed">
            <button class="bg-white p-2 rounded-md shadow-lg hover:bg-gray-50 transition-colors">
                <svg class="h-6 w-6 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>

        <!-- Main Content Area -->
        <div class="lg:pl-16 flex flex-col flex-1">
                        <!-- Top Header -->
            <div class="sticky top-0 z-10 flex-shrink-0 flex h-12 sm:h-16 bg-white shadow-sm border-b border-gray-200 w-full lg:ml-0">
                <div class="flex-1 px-2 sm:px-3 lg:px-8 flex justify-between items-center">
                    <!-- Mobile: Centered logo -->
                    <div class="lg:hidden flex-1 flex justify-center">
                        <img class="h-6 w-auto" src="{{ asset('build/theme/images/ADN_Logo_enlarged_x5.png') }}" alt="ADN Family Office">
                    </div>
                    
                    <!-- Desktop: Left-aligned logo and search -->
                    <div class="hidden lg:flex flex-1 flex items-center min-w-0">
                        <div class="flex items-center">
                            <img class="h-8 w-auto" src="{{ asset('build/theme/images/ADN_Logo_enlarged_x5.png') }}" alt="ADN Family Office">
                        </div>
                        <div class="ml-8 flex-1 max-w-lg">
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 flex items-center pointer-events-none">
                                    <svg class="h-5 w-5 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <input id="search-field" class="block w-full pl-8 pr-3 py-2 border border-gray-300 rounded-md text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm" placeholder="Rechercher..." type="search" name="search">
                            </div>
                        </div>
                    </div>
                    
                    <!-- Desktop: Right-aligned actions -->
                    <div class="hidden lg:flex items-center space-x-4">
                        <!-- Notifications -->
                        <button type="button" class="relative bg-white p-1 rounded-full text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            <span class="sr-only">Voir les notifications</span>
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5zM4 19h6v-6H4v6z" />
                            </svg>
                            <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-red-400 ring-2 ring-white"></span>
                        </button>
                        
                        <!-- Messages -->
                        <button type="button" class="relative bg-white p-1 rounded-full text-gray-400 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            <span class="sr-only">Voir les messages</span>
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                            </svg>
                            <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-blue-400 ring-2 ring-white"></span>
                        </button>

                        <!-- Admin Access -->
                        {% if is_granted('ROLE_SUPER_ADMIN') %}
                        <a href="{{ path('admin') }}" class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            Admin
                        </a>
                        {% endif %}

                        <!-- User Menu -->
                        <div class="relative">
                            <div class="relative">
                                <button type="button" class="max-w-xs bg-white flex items-center text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" id="user-menu" aria-expanded="false" aria-haspopup="true">
                                    <span class="sr-only">Ouvrir le menu utilisateur</span>
                                    <img class="h-8 w-8 rounded-full" src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="">
                                </button>
                            </div>
                        </div>

                        <!-- Logout Button -->
                        <a href="{{ path('app_logout') }}" class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                            Déconnexion
                        </a>
                    </div>
                </div>
            </div>

            <!-- Main Dashboard Content -->
            <main class="flex-1 relative overflow-y-auto focus:outline-none">
                <div class="py-3 sm:py-4 lg:py-6">
                    <div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-8">
                        <!-- Welcome Section -->
                        <div class="mb-4 sm:mb-6 lg:mb-8">
                            <h1 class="text-xl sm:text-2xl font-bold text-gray-900">👋 Bienvenue, {{ app.user.firstName }}</h1>
                            <p class="mt-1 text-xs sm:text-sm text-gray-500">Retrouvez ici vos investissements et opportunités du moment.</p>
                        </div>

                        <!-- KYC Notification for New Users -->
                        {% if not is_granted('ROLE_USER_IDENTIFIED') %}
                            <div class="mb-6 bg-blue-50 border-l-4 border-blue-400 p-4 rounded-md shadow-sm">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0">
                                        <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <h3 class="text-sm font-medium text-blue-800">
                                            Complétez votre profil KYC
                                        </h3>
                                        <div class="mt-2 text-sm text-blue-700">
                                            <p>Pour accéder à nos offres d'investissement, vous devez compléter votre profil de vérification d'identité.</p>
                                        </div>
                                        <div class="mt-4">
                                            <a href="{{ path('user_create_profile', {'step': stepKyc}) }}" 
                                               class="bg-blue-100 px-3 py-2 rounded-md text-sm font-medium text-blue-800 hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-blue-50 focus:ring-blue-600">
                                                Commencer le parcours KYC
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                        <!-- Notifications KYC -->
                        {% include 'front/partials/kyc-notifications.html.twig' %}

                        {# Notification de reprise du parcours KYC #}
                        {% if restartKycNotification is defined and restartKycNotification %}
                            <div class="mb-6 bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded-md shadow-sm">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0">
                                        <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <h3 class="text-sm font-medium text-yellow-800">
                                            {{ restartKycNotification.title }}
                                        </h3>
                                        <div class="mt-2 text-sm text-yellow-700">
                                            <p>{{ restartKycNotification.message }}</p>
                                        </div>
                                        <div class="mt-4">
                                            <div class="-mx-2 -my-1.5 flex">
                                                <a href="{{ path(restartKycNotification.action.url, restartKycNotification.action.params) }}" 
                                                   class="bg-yellow-50 px-2 py-1.5 rounded-md text-sm font-medium text-yellow-800 hover:bg-yellow-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-yellow-50 focus:ring-yellow-600">
                                                    {{ restartKycNotification.action.text }}
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                        <!-- Bloc profil incomplet -->
                        {% if not is_granted('ROLE_USER_IDENTIFIED') and not isCompleted %}
                            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-8">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <h2 class="text-lg font-semibold text-gray-900 mb-2">
                                            Complétez votre profil pour commencer à investir.
                                        </h2>
                                        <p class="text-gray-600 text-sm">
                                            Quelques minutes suffisent pour répondre à nos questions. Une fois votre profil vérifié, vous aurez accès à nos offres d'investissement.
                                        </p>
                                    </div>
                                    <a href="{{ path('user_create_profile', {'step': stepKyc}) }}"
                                       class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg shadow-sm transition-colors duration-200">
                                        Compléter mon profil
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        {% endif %}

                        <!-- Analytics Overview -->
                        <div class="mb-6 sm:mb-8">
                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 sm:mb-6">
                                <h2 class="text-lg sm:text-xl font-bold text-gray-900 mb-3 sm:mb-0">Aperçu de vos investissements</h2>
                                <div class="flex space-x-1">
                                    <button class="px-2 sm:px-3 py-1 text-xs sm:text-sm font-medium text-gray-500 hover:text-gray-700">Hebdomadaire</button>
                                    <button class="px-2 sm:px-3 py-1 text-xs sm:text-sm font-medium bg-blue-100 text-blue-600 rounded-md">Mensuel</button>
                                    <button class="px-2 sm:px-3 py-1 text-xs sm:text-sm font-medium text-gray-500 hover:text-gray-700">Annuel</button>
                                </div>
                            </div>

                            <!-- Metric Cards -->
                            <div class="grid grid-cols-1 gap-3 sm:gap-4 lg:gap-5 sm:grid-cols-2 lg:grid-cols-4">
                                <div class="bg-white overflow-hidden shadow rounded-lg">
                                    <div class="p-3 sm:p-4 lg:p-5">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0">
                                                <div class="w-6 h-6 sm:w-8 sm:h-8 bg-purple-100 rounded-lg flex items-center justify-center">
                                                    <svg class="w-4 h-4 sm:w-5 sm:h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
                                                    </svg>
                                                </div>
                                            </div>
                                            <div class="ml-3 sm:ml-5 w-0 flex-1">
                                                <dl>
                                                    <dt class="text-xs sm:text-sm font-medium text-gray-500 truncate">Montant total investi</dt>
                                                    <dd class="text-base sm:text-lg font-medium text-gray-900">{{ totalInvest|number_format(0, '', ' ') }} €</dd>
                                                </dl>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="bg-gray-50 px-3 sm:px-4 lg:px-5 py-2 sm:py-3">
                                        <div class="text-xs sm:text-sm">
                                            <span class="text-green-600 font-medium">▲ 48,71%</span>
                                            <span class="text-gray-500">vs mois dernier</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="bg-white overflow-hidden shadow rounded-lg">
                                    <div class="p-5">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0">
                                                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
