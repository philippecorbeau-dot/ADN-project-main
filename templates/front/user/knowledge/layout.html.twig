{% extends 'front/layouts/funnel.layout.html.twig' %}
{% import 'macro/alert.html.twig' as alert %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-indigo-50">
    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <!-- Header avec titre moderne -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full mb-4">
                <i class="fa-solid fa-graduation-cap text-white text-2xl"></i>
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">
                {% trans %}Connaissance des marchés financiers{% endtrans %}
            </h1>
            <p class="text-lg text-gray-600">
                {% trans %}Afin de définir votre profil de risque, nous vous invitons à répondre aux questions suivantes{% endtrans %}
            </p>
        </div>

        <!-- Barre de progression -->
        <div class="mb-8">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-700">Étape {{ step }} sur {{ totalSteps }}</span>
                <span class="text-sm text-gray-500">{{ (step / totalSteps * 100) | round }}% complété</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-gradient-to-r from-blue-600 to-indigo-600 h-2 rounded-full transition-all duration-300" 
                     style="width: {{ (step / totalSteps * 100) | round }}%"></div>
            </div>
        </div>

        <!-- Étapes du questionnaire -->
        <div class="flex justify-between mb-8">
            <div class="flex items-center space-x-2 {{ step >= 1 ? 'text-blue-600' : 'text-gray-400' }}">
                <div class="w-8 h-8 rounded-full flex items-center justify-center {{ step >= 1 ? 'bg-blue-600 text-white' : 'bg-gray-200' }}">
                    <i class="fa-solid fa-shield-check text-sm"></i>
                </div>
                <span class="text-sm font-medium">Abus de marché</span>
            </div>
            <div class="flex items-center space-x-2 {{ step >= 2 ? 'text-blue-600' : 'text-gray-400' }}">
                <div class="w-8 h-8 rounded-full flex items-center justify-center {{ step >= 2 ? 'bg-blue-600 text-white' : 'bg-gray-200' }}">
                    <i class="fa-solid fa-graduation-cap text-sm"></i>
                </div>
                <span class="text-sm font-medium">Niveau d'éducation</span>
            </div>
            <div class="flex items-center space-x-2 {{ step >= 3 ? 'text-blue-600' : 'text-gray-400' }}">
                <div class="w-8 h-8 rounded-full flex items-center justify-center {{ step >= 3 ? 'bg-blue-600 text-white' : 'bg-gray-200' }}">
                    <i class="fa-solid fa-chart-line text-sm"></i>
                </div>
                <span class="text-sm font-medium">Expérience</span>
            </div>
            <div class="flex items-center space-x-2 {{ step >= 4 ? 'text-blue-600' : 'text-gray-400' }}">
                <div class="w-8 h-8 rounded-full flex items-center justify-center {{ step >= 4 ? 'bg-blue-600 text-white' : 'bg-gray-200' }}">
                    <i class="fa-solid fa-coins text-sm"></i>
                </div>
                <span class="text-sm font-medium">Produits</span>
            </div>
            <div class="flex items-center space-x-2 {{ step >= 5 ? 'text-blue-600' : 'text-gray-400' }}">
                <div class="w-8 h-8 rounded-full flex items-center justify-center {{ step >= 5 ? 'bg-blue-600 text-white' : 'bg-gray-200' }}">
                    <i class="fa-solid fa-cube text-sm"></i>
                </div>
                <span class="text-sm font-medium">Complexes</span>
            </div>
            <div class="flex items-center space-x-2 {{ step >= 6 ? 'text-blue-600' : 'text-gray-400' }}">
                <div class="w-8 h-8 rounded-full flex items-center justify-center {{ step >= 6 ? 'bg-blue-600 text-white' : 'bg-gray-200' }}">
                    <i class="fa-solid fa-chart-bar text-sm"></i>
                </div>
                <span class="text-sm font-medium">Marchés</span>
            </div>
        </div>

        <!-- Carte principale -->
        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
            <!-- Header de la carte -->
            <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <i class="fa-solid fa-brain text-white text-xl"></i>
                        <h2 class="text-white font-semibold text-lg">
                            {% block step_title %}{% endblock %}
                        </h2>
                    </div>
                    <div class="flex items-center space-x-2">
                        <span class="text-blue-100 text-sm">Étape {{ step }} sur {{ totalSteps }}</span>
                        <div class="w-2 h-2 bg-blue-200 rounded-full"></div>
                    </div>
                </div>
            </div>

            <!-- Contenu de la carte -->
            <div class="p-6 md:p-8">
                <!-- Avertissement -->
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6">
                    <div class="flex items-start space-x-3">
                        <i class="fa-solid fa-exclamation-triangle text-yellow-600 mt-1"></i>
                        <div class="flex-1">
                            <p class="text-sm text-yellow-800">
                                <strong>Important :</strong> Le but de ce questionnaire étant d'évaluer votre connaissance réelle des marchés et instruments financiers, vous ne pourrez plus modifier vos réponses après cette validation.
                            </p>
                        </div>
                    </div>
                </div>

                {% block content %}{% endblock %}
            </div>
        </div>
    </div>
</div>
{% endblock %} 