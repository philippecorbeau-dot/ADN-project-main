{% extends 'base.html.twig' %}

{# =============== SEO OPTIMISÉ POUR LA PAGE EXPERTISE =============== #}
{% block title %}Expertise ADN Family Office | {{ annees_expertise() }} ans, {{ clients_accompagnes() }} familles, {{ actifs_geres() }}M€{% endblock %}

{% block meta_description %}{{ annees_expertise() }} ans d'expertise en gestion de patrimoine, immobilier, transmission, private equity. {{ clients_accompagnes() }} familles accompagnées, {{ actifs_geres() }}M€ d'actifs gérés à Paris.{% endblock %}

{% block og_title %}Notre Expertise - Family Office Indépendant | ADN Family Office{% endblock %}
{% block og_description %}Une équipe d'experts passionnés : gestion de patrimoine, immobilier, transmission, private equity. 92% de clients satisfaits.{% endblock %}

{# JSON-LD pour la page Expertise #}
{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "Notre Expertise - ADN Family Office",
    "description": "Découvrez l'expertise et la méthodologie d'ADN Family Office, premier family office accessible à toutes les familles.",
    "url": "{{ url('app_expertise') }}",
    "mainEntity": {
        "@type": "Organization",
        "name": "ADN Family Office",
        "foundingDate": "2009",
        "numberOfEmployees": {
            "@type": "QuantitativeValue",
            "value": "10+"
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "reviewCount": "{{ clients_accompagnes() }}"
        }
    }
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Accueil",
            "item": "{{ url('app_home') }}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "Expertise",
            "item": "{{ url('app_expertise') }}"
        }
    ]
}
</script>
{% endblock %}

{% block header %}
    {% include 'partials/modern-header-module.html.twig' %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
    /* ===== Variables CSS et Reset ===== */
    :root {
        /* Dégradé bleu conforme à la charte ADN (même que les autres pages) */
        --primary-gradient: linear-gradient(135deg, #101A50 0%, #0057FF 40%, #1F299C 70%, #0D5EED 100%);
        --brand-blue: #1C29A1;
        --brand-blue-strong: #0057FF;
        --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        --accent-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        --dark-gradient: linear-gradient(135deg, #2D3436 0%, #000000 100%);
        --light-gradient: linear-gradient(135deg, #ffffff 0%, #f5f5f5 100%);
        --glass-bg: rgba(255, 255, 255, 0.25);
        --glass-border: rgba(255, 255, 255, 0.18);
        --shadow-xl: 0 20px 40px rgba(0, 0, 0, 0.1);
        --shadow-2xl: 0 25px 60px rgba(0, 0, 0, 0.15);
        --transition-smooth: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
        scroll-behavior: smooth;
    }

    /* ===== Bouton Retour Accueil Moderne ===== */
    .back-home-button {
        position: fixed;
        top: 100px;
        left: 30px;
        z-index: 999;
        background: var(--glass-bg);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid var(--glass-border);
        border-radius: 100px;
        padding: 14px 24px;
        will-change: transform, opacity;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--brand-blue);
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
        transition: var(--transition-smooth);
        box-shadow: 0 8px 32px rgba(102, 126, 234, 0.1);
    }

    .back-home-button:hover {
        transform: translateX(8px) scale(1.05);
        box-shadow: 0 12px 40px rgba(102, 126, 234, 0.2);
        background: rgba(255, 255, 255, 0.9);
    }

    .back-home-button svg {
        width: 18px;
        height: 18px;
        transition: transform 0.3s ease;
    }

    .back-home-button:hover svg {
        transform: translateX(-3px);
    }

    /* ===== Hero Section Moderne ===== */
        .expertise-hero {
        background: var(--primary-gradient);
            position: relative;
        padding: 200px 0 150px;
            overflow: hidden;
        min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .expertise-hero::before {
            content: '';
            position: absolute;
        width: 200%;
        height: 200%;
        top: -50%;
        left: -50%;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        animation: float 20s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(10deg); }
    }

    .floating-shapes {
        position: absolute;
        width: 100%;
        height: 100%;
        overflow: hidden;
            top: 0;
            left: 0;
    }

    .shape {
        position: absolute;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(5px);
        animation: float-shape 15s ease-in-out infinite;
    }

    .shape:nth-child(1) {
        width: 80px;
        height: 80px;
        left: 10%;
        top: 20%;
        animation-delay: 0s;
    }

    .shape:nth-child(2) {
        width: 120px;
        height: 120px;
        right: 10%;
        top: 30%;
        animation-delay: 3s;
    }

    .shape:nth-child(3) {
        width: 60px;
        height: 60px;
        left: 80%;
        bottom: 20%;
        animation-delay: 6s;
        }

    @keyframes float-shape {
        0%, 100% { 
            transform: translateY(0) translateX(0) rotate(0deg);
            opacity: 0.5;
        }
        33% { 
            transform: translateY(-30px) translateX(30px) rotate(120deg);
            opacity: 0.8;
        }
        66% { 
            transform: translateY(30px) translateX(-30px) rotate(240deg);
            opacity: 0.3;
        }
