{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Intersection Observer pour les animations au scroll
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -100px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                        // Ne pas désobserver pour permettre les animations répétées
                    }
                });
            }, observerOptions);

            // Observer tous les éléments avec la classe fade-in
            document.querySelectorAll('.fade-in').forEach(el => {
                observer.observe(el);
            });

            // Animation des statistiques au scroll
            const animateValue = (obj, start, end, duration) => {
                let startTimestamp = null;
                const step = (timestamp) => {
                    if (!startTimestamp) startTimestamp = timestamp;
                    const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                    const value = Math.floor(progress * (end - start) + start);
                    obj.innerHTML = value;
                    if (progress < 1) {
                        window.requestAnimationFrame(step);
                    }
                };
                window.requestAnimationFrame(step);
            };

            // Observer pour les statistiques
            const statsObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting && !entry.target.classList.contains('animated')) {
                        entry.target.classList.add('animated');
                        const value = entry.target.textContent;
                        if (value.includes('+')) {
                            const num = parseInt(value.replace('+', ''));
                            animateValue(entry.target, 0, num, 2000);
                setTimeout(() => {
                                entry.target.innerHTML = value;
                            }, 2000);
                        }
                    }
                });
            }, { threshold: 0.5 });

            // Smooth scroll pour les liens internes
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });

            // Parallax effect pour le hero (desktop seulement)
            if (window.innerWidth > 768) {
                window.addEventListener('scroll', () => {
                    const scrolled = window.pageYOffset;
                    const hero = document.querySelector('.expertise-hero');
                    if (hero) {
                        hero.style.transform = `translateY(${scrolled * 0.3}px)`;
                    }
                });
            }

            // Hover effects pour les cards
            const cards = document.querySelectorAll('.expertise-card, .team-member-card');
            cards.forEach(card => {
                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-15px)';
                });
                
                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0)';
                });
            });

            const backButton = document.querySelector('.back-home-button');
            if (backButton) {
                let isVisible = true;
                let lastScroll = 0;

                window.addEventListener('scroll', () => {
                    const currentScroll = window.pageYOffset;

                    if (currentScroll > lastScroll && currentScroll > 100) {
                        if (isVisible) {
                            backButton.style.transform = 'translateX(-100px)';
                            backButton.style.opacity = '0';
                            backButton.style.pointerEvents = 'none';
                            backButton.setAttribute('aria-hidden', 'true');
                            backButton.setAttribute('tabindex', '-1');
                            isVisible = false;
                        }
                    } else {
                        if (!isVisible) {
                            backButton.style.transform = 'translateX(0)';
                            backButton.style.opacity = '1';
                            backButton.style.pointerEvents = 'auto';
                            backButton.removeAttribute('aria-hidden');
                            backButton.removeAttribute('tabindex');
                            isVisible = true;
                        }
                    }

                    lastScroll = currentScroll;
                });
            }
        });
    </script>
{% endblock %}
