    /* ===== Methodologie Section Redesign ===== */
    .methodology-section {
        padding: 120px 0;
        background: #f8f9fa;
        position: relative;
        overflow: hidden;
    }
    
    /* Arrière-plan décoratif */
    .methodology-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at 50% 50%, rgba(13, 94, 237, 0.03) 0%, transparent 70%);
        pointer-events: none;
    }

    .process-timeline {
        max-width: 1000px;
        margin: 80px auto 0;
        position: relative;
        padding: 40px 20px;
    }

    /* Ligne centrale */
    .process-timeline::before {
        content: '';
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(180deg, 
            rgba(13, 94, 237, 0) 0%, 
            #0D5EED 15%, 
            #0D5EED 85%, 
            rgba(13, 94, 237, 0) 100%
        );
    }

    .process-step {
        display: flex;
        justify-content: center;
        align-items: flex-start; /* Changed from center to allow varying heights */
        margin-bottom: 60px; /* Reduced margin */
        position: relative;
        width: 100%;
    }

    .process-step:last-child {
        margin-bottom: 0;
    }

    /* Point central sur la ligne */
    .step-point {
        position: absolute;
        left: 50%;
        top: 30px; /* Align with top of card */
        transform: translate(-50%, 0);
        width: 20px;
        height: 20px;
        background: white;
        border: 4px solid var(--brand-blue);
        border-radius: 50%;
        z-index: 2;
        box-shadow: 0 0 0 4px rgba(13, 94, 237, 0.2);
        transition: all 0.3s ease;
    }

    .process-step:hover .step-point {
        background: var(--brand-blue);
        box-shadow: 0 0 0 8px rgba(13, 94, 237, 0.3);
        transform: translate(-50%, 0) scale(1.2);
    }

    /* Carte de contenu */
    .step-content {
        width: 45%;
        padding: 40px;
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
        position: relative;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 1px solid rgba(0,0,0,0.03);
        z-index: 1;
    }

    /* Flèche de connexion vers la ligne centrale */
    .step-content::after {
        content: '';
        position: absolute;
        top: 36px; /* Adjusted for top alignment */
        width: 0;
        height: 0;
        border-style: solid;
    }

    /* Positionnement Alterné */
    .process-step:nth-child(odd) {
        flex-direction: row;
    }
    
    .process-step:nth-child(even) {
        flex-direction: row-reverse;
    }

    .process-step:nth-child(odd) .step-content {
        margin-right: auto;
        text-align: right;
    }
    
    .process-step:nth-child(even) .step-content {
        margin-left: auto;
        text-align: left;
    }

    /* Position des flèches */
    .process-step:nth-child(odd) .step-content::after {
        right: -10px;
        border-width: 10px 0 10px 10px;
        border-color: transparent transparent transparent white;
    }

    .process-step:nth-child(even) .step-content::after {
        left: -10px;
        border-width: 10px 10px 10px 0;
        border-color: transparent white transparent transparent;
    }

    .step-content:hover {
        transform: translateY(-5px);
        box-shadow: 0 30px 60px rgba(13, 94, 237, 0.12);
    }

    /* Numéro stylisé en background */
    .step-number-bg {
        position: absolute;
        top: 10px;
        font-size: 8rem;
        font-weight: 900;
        color: rgba(13, 94, 237, 0.03);
        line-height: 1;
        user-select: none;
        pointer-events: none;
        transition: all 0.3s ease;
        font-family: system-ui, -apple-system, sans-serif;
    }

    .process-step:nth-child(odd) .step-number-bg {
        right: 20px;
    }

    .process-step:nth-child(even) .step-number-bg {
        left: 20px;
    }

    .step-content:hover .step-number-bg {
        color: rgba(13, 94, 237, 0.08);
        transform: scale(1.1);
    }

    .step-content h3 {
        font-size: 1.75rem;
        font-weight: 800;
        color: #1f2937;
        margin-bottom: 15px;
        position: relative;
        display: inline-block;
    }
    
    .step-content p {
        color: #4b5563;
        font-size: 1.1rem;
        line-height: 1.6;
        margin-bottom: 25px;
    }

    .step-meta {
        display: inline-flex;
        background: #f8fafc;
        padding: 12px 24px;
        border-radius: 12px;
        gap: 30px;
        border: 1px solid #e2e8f0;
    }

    .process-step:nth-child(odd) .step-meta {
        flex-direction: row-reverse;
    }

    .meta-item {
        display: flex;
        flex-direction: column;
    }

    .meta-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #94a3b8;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .meta-value {
        font-size: 0.95rem;
        color: var(--brand-blue);
        font-weight: 700;
    }
    
    .step-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 60px;
        height: 60px;
        background: var(--primary-gradient);
        border-radius: 16px;
        margin-bottom: 20px;
        box-shadow: 0 10px 20px rgba(13, 94, 237, 0.2);
        color: white;
    }
    
    .process-step:nth-child(odd) .step-icon {
        margin-left: auto;
    }

    /* ===== Results Section ===== */
    .results-section {
        padding: 120px 0;
        background: var(--primary-gradient);
        position: relative;
        overflow: hidden;
    }

    /* Ajout d'un motif subtil en background */
    .results-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.1) 1px, transparent 1px),
                          radial-gradient(circle at 80% 80%, rgba(255,255,255,0.1) 1px, transparent 1px);
        background-size: 40px 40px;
        opacity: 0.3;
    }

    .results-section .section-title {
        background: none;
        -webkit-text-fill-color: white;
        color: white;
        margin-bottom: 15px;
        text-shadow: 0 4px 12px rgba(0, 0, 0, 0.15);
    }

    .results-section .section-subtitle,
    .results-section p {
        color: rgba(255, 255, 255, 0.9) !important;
        font-size: 1.2rem;
        font-weight: 300;
    }

    .results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 30px;
        max-width: 1100px;
        margin: 70px auto 0;
        padding: 0 20px;
        position: relative;
        z-index: 2;
    }

    .result-item {
        text-align: center;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 24px;
        padding: 40px 25px;
        transition: all 0.4s ease;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    .result-item:hover {
        transform: translateY(-10px);
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.4);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
    }

    .result-value {
        font-size: 3.5rem;
        font-weight: 800;
        color: white;
        margin-bottom: 10px;
        display: block;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
        line-height: 1.1;
    }

    .result-description {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.9);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    /* ===== CTA Section ===== */
    .cta-final {
        padding: 120px 0;
        background: white;
        text-align: center;
        }

    .cta-final h2 {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 25px;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .cta-final p {
        font-size: 1.25rem;
        color: #6b7280;
        margin-bottom: 50px;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .cta-button-group {
        display: flex;
        gap: 20px;
        justify-content: center;
        flex-wrap: wrap;
            }

    .btn-gradient {
        background: var(--primary-gradient);
        color: white;
        padding: 18px 40px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 1.1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        transition: var(--transition-smooth);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
            }
            
    .btn-gradient:hover {
        transform: translateY(-3px) scale(1.05);
        box-shadow: 0 15px 40px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-outline {
        background: transparent;
        color: var(--brand-blue);
        padding: 18px 40px;
        border: 2px solid var(--brand-blue);
        border-radius: 100px;
        font-weight: 700;
                font-size: 1.1rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        transition: var(--transition-smooth);
            }
            
    .btn-outline:hover {
        background: var(--brand-blue-strong);
        color: white;
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(102, 126, 234, 0.3);
    }

    /* ===== Animations au scroll ===== */
    .fade-in {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s ease;
    }

    .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
            }
            
    /* ===== Responsive Design ===== */
    @media (max-width: 1024px) {
        .expertise-grid {
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            }
            
        .team-grid {
                grid-template-columns: 1fr;
            gap: 40px;
        }

        .process-timeline::before {
            left: 30px;
            }
            
        .process-step,
        .process-step:nth-child(even) {
            flex-direction: column;
            align-items: flex-start;
            padding-left: 70px;
            }
            
        .step-point {
            left: 30px;
        }

        .process-step:nth-child(odd) .step-content,
        .process-step:nth-child(even) .step-content {
            width: 100%;
            margin: 0;
            text-align: left;
            }

        .process-step:nth-child(odd) .step-content::after,
        .process-step:nth-child(even) .step-content::after {
            left: -10px;
            right: auto;
            border-width: 10px 10px 10px 0;
            border-color: transparent white transparent transparent;
        }

        .process-step:nth-child(odd) .step-meta {
            flex-direction: row;
        }

        .process-step:nth-child(odd) .step-icon {
            margin-left: 0;
        }
    }

    @media (max-width: 768px) {
        .back-home-button {
            display: none;
            }

        .expertise-hero {
            padding: 150px 0 100px;
            min-height: auto;
            }

        .expertise-hero h1 {
            font-size: 3rem;
            letter-spacing: -1px;
            }

        .expertise-hero .lead-text {
            font-size: 1.1rem;
            }

        .hero-stats {
            grid-template-columns: 1fr;
            gap: 20px;
            }
            
        .section-title {
                font-size: 2.5rem;
            }
            
        .expertise-card {
            padding: 32px;
            }
            
        .team-member-card {
            border-radius: 24px;
            }
            
        .member-image-container {
            height: 400px;
            }
            
        .member-info {
            padding: 30px;
            }
            
        .member-name {
            font-size: 1.75rem;
            }
            
        .results-grid {
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            }

        .result-value {
            font-size: 2.5rem;
            }

        .cta-button-group {
            flex-direction: column;
            align-items: center;
            }

        .btn-gradient,
        .btn-outline {
            width: 100%;
            max-width: 300px;
            justify-content: center;
            }
    }

    @media (max-width: 480px) {
        .expertise-hero h1 {
            font-size: 2.5rem;
        }

        .stat-number {
            font-size: 2.5rem;
            }

        .section-title {
            font-size: 2rem;
            }

        .expertise-grid {
            grid-template-columns: 1fr;
            padding: 0 15px;
        }

        .expertise-card {
            padding: 24px;
            }

        .member-image-container {
            height: 350px;
        }

        .process-step {
            margin-bottom: 60px;
            }
            
        .step-content {
            padding: 24px;
        }

        .result-item {
            padding: 30px 20px;
            }
            
        .cta-final h2 {
                font-size: 2rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
