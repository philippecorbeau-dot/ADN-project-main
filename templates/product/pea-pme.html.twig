{% extends 'product/base-product.html.twig' %}

{% block title %}{{ title }} - ADN Family Office{% endblock %}

{% block product_content %}
<!-- Hero Section -->
<div class="product-hero">
    <div class="product-hero-content">
        <h1>🚀 PEA</h1>
        <p>Investissez dans les PME et ETI françaises et européennes tout en bénéficiant d'une fiscalité avantageuse. Le PEA offre un potentiel de croissance élevé avec une exonération d'impôt après 5 ans.</p>
    </div>
</div>

<!-- Contenu principal -->
<div class="product-content">
    <!-- Contenu principal -->
    <div>
        <!-- Section présentation -->
        <div class="content-section">
            <h2>
                <span>📈</span>
                Qu'est-ce qu'un PEA ?
            </h2>
            
            <p>Le <strong>Plan d'Épargne en Actions PME-ETI</strong> est une enveloppe fiscale permettant d'investir dans les actions de petites et moyennes entreprises (PME) et entreprises de taille intermédiaire (ETI) françaises et européennes.</p>
            
            <h3>Entreprises éligibles</h3>
            <p>Le PEA est réservé aux entreprises employant moins de 5 000 salariés et dont le chiffre d'affaires annuel n'excède pas 1,5 milliard d'euros ou dont le total du bilan n'excède pas 2 milliards d'euros.</p>
            
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="stat-number">225 000€</span>
                    <span class="stat-label">Plafond de versement</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">5 ans</span>
                    <span class="stat-label">Durée mini. pour exonération</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">0%</span>
                    <span class="stat-label">Impôt après 5 ans</span>
                </div>
            </div>
        </div>

        <!-- Section avantages -->
        <div class="content-section">
            <h2>
                <span>✨</span>
                Avantages du PEA
            </h2>
            
            <ul>
                <li><strong>Fiscalité privilégiée</strong> - Exonération d'impôt sur les plus-values après 5 ans</li>
                <li><strong>Potentiel de croissance</strong> - Exposition aux PME/ETI en forte croissance</li>
                <li><strong>Diversification</strong> - Complément idéal au PEA classique</li>
                <li><strong>Liquidité</strong> - Rachats possibles (avec impact fiscal avant 5 ans)</li>
                <li><strong>Gestion libre ou déléguée</strong> - Choix de votre mode de gestion</li>
                <li><strong>Transmission</strong> - Possibilité de donation des titres</li>
            </ul>
        </div>

        <!-- Section stratégies -->
        <div class="content-section">
            <h2>
                <span>🎯</span>
                Stratégies d'investissement
            </h2>
            
            <h3>Gestion libre</h3>
            <p>Sélectionnez vous-même vos valeurs parmi les PME/ETI éligibles. Nécessite une expertise en analyse financière et un suivi régulier.</p>
            
            <h3>Gestion déléguée</h3>
            <p>Confiez la gestion à des professionnels spécialisés dans les PME/ETI. Idéal pour bénéficier de l'expertise sans contrainte de temps.</p>
            
            <h3>Fonds et SICAV</h3>
            <p>Investissez via des fonds spécialisés pour diversifier automatiquement vos investissements sur de nombreuses PME/ETI.</p>
            
            <h3>Approche sectorielle</h3>
            <p>Concentrez vos investissements sur des secteurs porteurs : tech, santé, transition énergétique, etc.</p>
        </div>

        <!-- Section risques -->
        <div class="content-section">
            <h2>
                <span>⚠️</span>
                Risques à considérer
            </h2>
            
            <ul>
                <li><strong>Volatilité élevée</strong> - Les PME/ETI sont plus sensibles aux fluctuations</li>
                <li><strong>Risque de liquidité</strong> - Certaines valeurs peuvent être peu liquides</li>
                <li><strong>Risque de concentration</strong> - Exposition limitée aux PME/ETI</li>
                <li><strong>Risque de perte en capital</strong> - Pas de garantie sur le capital investi</li>
                <li><strong>Risque réglementaire</strong> - Évolution possible des règles fiscales</li>
            </ul>
        </div>

        <!-- Section caractéristiques du PEA -->
        <div class="content-section">
            <h2>
                <span>⚖️</span>
                Caractéristiques du PEA
            </h2>
            
            <div style="display: grid; grid-template-columns: 1fr; gap: 2rem; margin: 1.5rem 0;">
                <div style="padding: 1.5rem; background: var(--gray-50); border-radius: 1rem;">
                    <h4 style="color: var(--primary-color); margin-bottom: 1rem;">PEA</h4>
                    <ul style="list-style: none; padding: 0;">
                        <li>✓ Plafond : 225 000€</li>
                        <li>✓ PME/ETI uniquement</li>
                        <li>✓ Potentiel de croissance élevé</li>
                        <li>✓ Fiscalité avantageuse après 5 ans</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="product-sidebar">
        <!-- Caractéristiques -->
        <div class="sidebar-card">
            <h3>
                <span>📋</span>
                Caractéristiques
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div>
                    <strong>Rendement attendu :</strong><br>
                    <span class="badge badge-info">Variable (potentiel élevé)</span>
                </div>
                
                <div>
                    <strong>Niveau de risque :</strong><br>
                    <span class="badge badge-danger">Élevé</span>
                </div>
                
                <div>
                    <strong>Liquidité :</strong><br>
                    <span class="badge badge-success">Bonne</span>
                </div>
                
                <div>
                    <strong>Investissement minimum :</strong><br>
                    <span class="badge badge-info">100 €</span>
                </div>
                
                <div>
                    <strong>Horizon recommandé :</strong><br>
                    <span class="badge badge-info">5-10 ans</span>
                </div>
            </div>
        </div>

        <!-- Fiscalité -->
        <div class="sidebar-card">
            <h3>
                <span>💰</span>
                Fiscalité
            </h3>
            
            <p><strong>Avant 5 ans :</strong> Clôture anticipée soumise au prélèvement forfaitaire unique (30%) ou option pour le barème progressif.</p>
            
            <p><strong>Après 5 ans :</strong> Exonération totale d'impôt sur le revenu. Seuls les prélèvements sociaux (17,2%) restent dus.</p>
            
            <p><strong>Dividendes :</strong> Réinvestissement automatique sans fiscalité pendant la vie du plan.</p>
        </div>

        <!-- Nos sélections -->
        <div class="sidebar-card">
            <h3>
                <span>⭐</span>
                Nos sélections
            </h3>
            
            <ul style="list-style: none; padding: 0;">
                <li style="margin-bottom: 1rem; padding: 1rem; background: var(--gray-50); border-radius: 0.75rem;">
                    <strong>Fonds PME Innovation</strong><br>
                    <small>Performance : +12,5% (3 ans)</small><br>
                    <small>Focus : Tech et innovation</small>
                </li>
                <li style="margin-bottom: 1rem; padding: 1rem; background: var(--gray-50); border-radius: 0.75rem;">
                    <strong>ETI Croissance</strong><br>
                    <small>Performance : +8,9% (3 ans)</small><br>
                    <small>Focus : ETI établies</small>
                </li>
                <li style="padding: 1rem; background: var(--gray-50); border-radius: 0.75rem;">
                    <strong>PME Transition</strong><br>
                    <small>Performance : +15,2% (3 ans)</small><br>
                    <small>Focus : Transition énergétique</small>
                </li>
            </ul>
        </div>

        <!-- Calendrier fiscal -->
        <div class="sidebar-card">
            <h3>
                <span>📅</span>
                Calendrier fiscal
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <div style="padding: 0.75rem; background: #fee2e2; border-radius: 0.5rem; border-left: 4px solid #ef4444;">
                    <strong>0-2 ans :</strong> 30% + 17,2%
                </div>
                <div style="padding: 0.75rem; background: #fef3c7; border-radius: 0.5rem; border-left: 4px solid #f59e0b;">
                    <strong>2-5 ans :</strong> 19% + 17,2%
                </div>
                <div style="padding: 0.75rem; background: #d1fae5; border-radius: 0.5rem; border-left: 4px solid #10b981;">
                    <strong>+5 ans :</strong> 0% + 17,2%
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Section CTA -->
<div class="cta-section">
    <h2>Prêt à booster votre épargne avec le PEA ?</h2>
    <p>Profitez du potentiel de croissance des PME/ETI avec l'accompagnement de nos experts en gestion de patrimoine.</p>
    <a href="{{ path('app_contact') }}" class="btn-cta">
        <span>🚀</span>
        Ouvrir mon PEA
    </a>
</div>
{% endblock %}
