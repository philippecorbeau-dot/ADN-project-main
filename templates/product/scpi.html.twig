{% extends 'product/base-product.html.twig' %}

{% block title %}{{ title }} - ADN Family Office{% endblock %}

{% block product_content %}
<!-- Hero Section -->
<div class="product-hero">
    <div class="product-hero-content">
        <h1>🏢 SCPI</h1>
        <p>Investissez dans l'immobilier sans les contraintes de la gestion directe. Les SCPI offrent un accès privilégié au marché immobilier avec des rendements attractifs et réguliers.</p>
    </div>
</div>

<!-- Contenu principal -->
<div class="product-content">
    <!-- Contenu principal -->
    <div>
        <!-- Section présentation -->
        <div class="content-section">
            <h2>
                <span>📊</span>
                Qu'est-ce qu'une SCPI ?
            </h2>
            
            <p>Les <strong>Sociétés Civiles de Placement Immobilier (SCPI)</strong> sont des véhicules d'investissement collectif qui permettent d'investir dans un patrimoine immobilier diversifié sans avoir à gérer directement les biens.</p>
            
            <h3>Principe de fonctionnement</h3>
            <p>En acquérant des parts de SCPI, vous devenez propriétaire d'une quote-part d'un patrimoine immobilier géré par des professionnels. Les loyers perçus sont redistribués aux associés proportionnellement à leur détention.</p>
            
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="stat-number">6-8%</span>
                    <span class="stat-label">Rendement moyen</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">90%</span>
                    <span class="stat-label">Taux d'occupation</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">500+</span>
                    <span class="stat-label">Biens en portefeuille</span>
                </div>
            </div>
        </div>

        <!-- Section avantages -->
        <div class="content-section">
            <h2>
                <span>✨</span>
                Avantages des SCPI
            </h2>
            
            <ul>
                <li><strong>Diversification</strong> - Accès à un portefeuille immobilier diversifié (bureaux, commerces, entrepôts)</li>
                <li><strong>Gestion professionnelle</strong> - Pas de gestion locative à prévoir</li>
                <li><strong>Revenus réguliers</strong> - Distribution trimestrielle des loyers</li>
                <li><strong>Accessibilité</strong> - Investissement possible dès 1 000€</li>
                <li><strong>Finançable</strong> - Bénéficier de l'effet de levier</li>
                <li><strong>Transparence</strong> - Reporting régulier et détaillé</li>
            </ul>
        </div>

        <!-- Section types -->
        <div class="content-section">
            <h2>
                <span>🏗️</span>
                Types de SCPI
            </h2>
            
            <h3>SCPI de rendement</h3>
            <p>Investissent dans des immeubles déjà construits et loués. Objectif : maximiser les revenus distribués.</p>
            
            <h3>SCPI de plus-value</h3>
            <p>Acquièrent des biens à rénover ou à valoriser. Objectif : réaliser des plus-values à la revente.</p>
            
            <h3>SCPI fiscales</h3>
            <p>Proposent des avantages fiscaux spécifiques (Pinel, Malraux, etc.) en contrepartie d'un engagement de détention.</p>
            
            <h3>SCPI européennes</h3>
            <p>Diversifient géographiquement en investissant dans l'immobilier européen.</p>
        </div>

        <!-- Section risques -->
        <div class="content-section">
            <h2>
                <span>⚠️</span>
                Risques à considérer
            </h2>
            
            <ul>
                <li><strong>Risque de liquidité</strong> - Délai possible pour la revente de parts</li>
                <li><strong>Risque immobilier</strong> - Variation de la valeur des biens</li>
                <li><strong>Risque locatif</strong> - Vacance possible des locaux</li>
                <li><strong>Risque de taux</strong> - Impact des variations de taux d'intérêt</li>
                <li><strong>Risque de crédit</strong> - Défaillance potentielle des locataires</li>
            </ul>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="product-sidebar">
        <!-- Caractéristiques -->
        <div class="sidebar-card">
            <h3>
                <span>📋</span>
                Caractéristiques
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div>
                    <strong>Rendement :</strong> <span style="color: #f59e0b; font-weight: 500;">moyen</span><br>
                    <span class="badge badge-success">6-8% par an</span>
                </div>
                
                <div>
                    <strong>Niveau de risque :</strong><br>
                    <span class="badge badge-warning">Modéré</span>
                </div>
                
                <div>
                    <strong>Liquidité :</strong><br>
                    <span class="badge badge-warning">Limitée</span>
                </div>
                
                <div>
                    <strong>Investissement minimum :</strong><br>
                    <span class="badge badge-info">1 000 €</span>
                </div>
                
                <div>
                    <strong>Horizon recommandé :</strong><br>
                    <span class="badge badge-info">8-12 ans</span>
                </div>
            </div>
        </div>

        <!-- Fiscalité -->
        <div class="sidebar-card">
            <h3>
                <span>💰</span>
                Fiscalité
            </h3>
            
            <p><strong>Revenus fonciers :</strong> Les distributions sont soumises au barème progressif de l'impôt sur le revenu + prélèvements sociaux (17,2%).</p>
            
            <p><strong>Plus-values :</strong> Taxation selon le régime des plus-values immobilières avec abattement pour durée de détention.</p>
            
            <p><strong>IFI :</strong> Les parts de SCPI sont soumises à l'Impôt sur la Fortune Immobilière.</p>
        </div>

        <!-- Nos SCPI recommandées -->
        <div class="sidebar-card">
            <h3>
                <span>⭐</span>
                Nos sélections
            </h3>
            
            <ul style="list-style: none; padding: 0;">
                <li style="margin-bottom: 1rem; padding: 1rem; background: var(--gray-50); border-radius: 0.75rem; cursor: pointer; transition: all 0.3s ease; position: relative;" onclick="window.open('{{ asset('plaquettes/epsicap-nano.pdf') }}', '_blank');" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)'; this.style.background='#f8f9fa';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'; this.style.background='var(--gray-50)';">
                    <strong>Epsicap Nano</strong> 📄<br>
                    <small>Rendement : <span style="color: #10b981; font-weight: 600;">8,07 %*</span></small><br>
                    <small>Focus : Tertiaire Smallcaps</small>
                </li>
                <li style="margin-bottom: 1rem; padding: 1rem; background: var(--gray-50); border-radius: 0.75rem; cursor: pointer; transition: all 0.3s ease; position: relative;" onclick="window.open('{{ asset('plaquettes/comete.pdf') }}', '_blank');" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)'; this.style.background='#f8f9fa';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'; this.style.background='var(--gray-50)';">
                    <strong>Comète</strong> 📄<br>
                    <small>Rendement : <span style="color: #10b981; font-weight: 600;">11,18 %*</span></small><br>
                    <small>Focus : Européenne</small>
                </li>
                <li style="padding: 1rem; background: var(--gray-50); border-radius: 0.75rem; cursor: pointer; transition: all 0.3s ease; position: relative;" onclick="window.open('{{ asset('plaquettes/neo.pdf') }}', '_blank');" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)'; this.style.background='#f8f9fa';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'; this.style.background='var(--gray-50)';">
                    <strong>Neo</strong> 📄<br>
                    <small>Rendement : <span style="color: #10b981; font-weight: 600;">6,01 %*</span></small><br>
                    <small>Focus : Transformation urbaine</small>
                </li>
            </ul>
            <p style="font-size: 0.75rem; color: #6b7280; margin-top: 1rem; font-style: italic;">
                * Taux de distribution sur valeur de marché (DVM) 2023. Les performances passées ne préjugent pas des performances futures.
            </p>
        </div>
    </div>
</div>

<!-- Section CTA -->
<div class="cta-section">
    <h2>Prêt à investir en SCPI ?</h2>
    <p>Nos conseillers vous accompagnent dans la sélection des meilleures SCPI adaptées à votre profil et vos objectifs patrimoniaux.</p>
    <a href="{{ path('app_contact') }}" class="btn-cta">
        <span>💬</span>
        Demander conseil
    </a>
</div>
{% endblock %}
