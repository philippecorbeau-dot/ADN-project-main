{% extends 'product/base-product.html.twig' %}

{% block title %}{{ title }} - ADN Family Office{% endblock %}

{% block product_content %}
<!-- Hero Section -->
<div class="product-hero">
    <div class="product-hero-content">
        <h1>🛡️ Assurance-vie</h1>
        <p>Le placement préféré des Français pour épargner, investir et transmettre. L'assurance-vie combine sécurité, performance et avantages fiscaux exceptionnels dans une enveloppe flexible et liquide.</p>
    </div>
</div>

<!-- Contenu principal -->
<div class="product-content">
    <!-- Contenu principal -->
    <div>
        <!-- Section présentation -->
        <div class="content-section">
            <h2>
                <span>💎</span>
                Qu'est-ce que l'assurance-vie ?
            </h2>
            
            <p>L'<strong>assurance-vie</strong> est un contrat d'épargne qui vous permet de vous constituer ou faire fructifier un capital, de le transmettre à un ou plusieurs bénéficiaires ou de le convertir en rente viagère.</p>
            
            <h3>Principe de fonctionnement</h3>
            <p>Vous versez des primes (versements) à un assureur qui les investit selon vos choix. À tout moment, vous pouvez effectuer des rachats partiels ou totaux, ou désigner des bénéficiaires pour la transmission.</p>
            
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="stat-number">1 800 Mds€</span>
                    <span class="stat-label">Encours total France</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">8 ans</span>
                    <span class="stat-label">Seuil d'optimisation fiscale</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">152 500€</span>
                    <span class="stat-label">Abattement transmission</span>
                </div>
            </div>
        </div>

        <!-- Section types de contrats -->
        <div class="content-section">
            <h2>
                <span>📊</span>
                Types de contrats
            </h2>
            
            <h3>Contrats en euros</h3>
            <p>Capital garanti avec rendement annuel. Sécurité maximale mais rendements modérés (1-3% actuellement).</p>
            
            <h3>Contrats multisupports</h3>
            <p>Combinaison fonds euros + unités de compte (actions, obligations, immobilier). Potentiel de rendement plus élevé avec une prise de risque maîtrisée.</p>
            
            <h3>Contrats DSK 2.0</h3>
            <p>Nouvelle génération avec diversification renforcée et gestion pilotée. Optimisation automatique selon votre profil de risque.</p>
            
            <h3>Contrats luxembourgeois</h3>
            <p>Pour les patrimoines importants : diversification internationale, monnaies étrangères, protection juridique renforcée.</p>
        </div>

        <!-- Section avantages -->
        <div class="content-section">
            <h2>
                <span>✨</span>
                Avantages de l'assurance-vie
            </h2>
            
            <ul>
                <li><strong>Liquidité totale</strong> - Rachats possibles à tout moment</li>
                <li><strong>Fiscalité privilégiée</strong> - Abattement de 4 600€/an après 8 ans (9 200€ pour un couple)</li>
                <li><strong>Transmission optimisée</strong> - Hors succession jusqu'à 152 500€ par bénéficiaire</li>
                <li><strong>Flexibilité</strong> - Versements libres ou programmés</li>
                <li><strong>Diversification</strong> - Accès à tous types d'actifs</li>
                <li><strong>Gestion déléguée</strong> - Gestion pilotée ou libre selon vos préférences</li>
            </ul>
        </div>

        <!-- Section gestion -->
        <div class="content-section">
            <h2>
                <span>🎯</span>
                Modes de gestion
            </h2>
            
            <h3>Gestion libre</h3>
            <p>Vous choisissez vos supports d'investissement et réalisez vos arbitrages. Contrôle total mais nécessite du temps et des compétences.</p>
            
            <h3>Gestion pilotée</h3>
            <p>Allocation d'actifs déterminée selon votre profil de risque et horizon d'investissement. Gestion automatique des arbitrages.</p>
            
            <h3>Gestion sous mandat</h3>
            <p>Délégation complète à un gérant professionnel. Stratégie personnalisée avec reporting régulier.</p>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin: 2rem 0;">
                <div style="padding: 1.5rem; background: var(--gray-50); border-radius: 1rem; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 1rem;">🛡️</div>
                    <h4>Profil Sécurité</h4>
                    <p style="margin: 0; color: var(--gray-600);">70% fonds euros, 30% UC obligataires</p>
                </div>
                <div style="padding: 1.5rem; background: var(--gray-50); border-radius: 1rem; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 1rem;">⚖️</div>
                    <h4>Profil Équilibré</h4>
                    <p style="margin: 0; color: var(--gray-600);">40% fonds euros, 60% UC diversifiées</p>
                </div>
                <div style="padding: 1.5rem; background: var(--gray-50); border-radius: 1rem; text-align: center;">
                    <div style="font-size: 2rem; margin-bottom: 1rem;">📈</div>
                    <h4>Profil Dynamique</h4>
                    <p style="margin: 0; color: var(--gray-600);">20% fonds euros, 80% UC actions</p>
                </div>
            </div>
        </div>

        <!-- Section stratégies -->
        <div class="content-section">
            <h2>
                <span>💡</span>
                Stratégies d'optimisation
            </h2>
            
            <h3>Versements programmés</h3>
            <p>Lissez le risque avec des versements réguliers. Idéal pour lisser les fluctuations de marché.</p>
            
            <h3>Arbitrages programmés</h3>
            <p>Sécurisez automatiquement les gains ou rééquilibrez votre allocation selon l'évolution des marchés.</p>
            
            <h3>Démembrement de propriété</h3>
            <p>Optimisation fiscale avancée : donation de la nue-propriété avec conservation de l'usufruit.</p>
            
            <h3>Assurance-vie cross-border</h3>
            <p>Pour les expatriés ou résidents multi-pays : optimisation selon les conventions fiscales.</p>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="product-sidebar">
        <!-- Caractéristiques -->
        <div class="sidebar-card">
            <h3>
                <span>📋</span>
                Caractéristiques
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div>
                    <strong>Rendement attendu :</strong><br>
                    <span class="badge badge-success">2-6% par an</span>
                </div>
                
                <div>
                    <strong>Niveau de risque :</strong><br>
                    <span class="badge badge-success">Faible à Modéré</span>
                </div>
                
                <div>
                    <strong>Liquidité :</strong><br>
                    <span class="badge badge-success">Totale</span>
                </div>
                
                <div>
                    <strong>Investissement minimum :</strong><br>
                    <span class="badge badge-info">500 €</span>
                </div>
                
                <div>
                    <strong>Horizon recommandé :</strong><br>
                    <span class="badge badge-info">8 ans et +</span>
                </div>
            </div>
        </div>

        <!-- Fiscalité détaillée -->
        <div class="sidebar-card">
            <h3>
                <span>💰</span>
                Fiscalité
            </h3>
            
            <p><strong>Pendant la vie du contrat :</strong></p>
            <ul style="font-size: 0.9rem; margin: 0.5rem 0;">
                <li>Capitalisatin sans fiscalité</li>
                <li>Prélèvements sociaux sur fonds euros</li>
            </ul>
            
            <p><strong>En cas de rachat :</strong></p>
            <div style="margin: 0.5rem 0;">
                <div style="padding: 0.5rem; background: #fee2e2; border-radius: 0.5rem; margin-bottom: 0.5rem;">
                    <small><strong>0-4 ans :</strong> 35% + 17,2% PS</small>
                </div>
                <div style="padding: 0.5rem; background: #fef3c7; border-radius: 0.5rem; margin-bottom: 0.5rem;">
                    <small><strong>4-8 ans :</strong> 15% + 17,2% PS</small>
                </div>
                <div style="padding: 0.5rem; background: #d1fae5; border-radius: 0.5rem;">
                    <small><strong>+8 ans :</strong> 7,5% + 17,2% PS<br>Abattement : 4 600€/an</small>
                </div>
            </div>
        </div>

        <!-- Nos contrats sélectionnés -->
        <div class="sidebar-card">
            <h3>
                <span>⭐</span>
                Nos contrats sélectionnés
            </h3>
            
            <ul style="list-style: none; padding: 0;">
                <li style="margin-bottom: 1rem; padding: 1rem; background: var(--gray-50); border-radius: 0.75rem;">
                    <strong>Excellence Multisupport</strong><br>
                    <small>Fonds euros : 2,1%</small><br>
                    <small>300+ supports UC</small><br>
                    <small>Gestion pilotée incluse</small>
                </li>
                <li style="margin-bottom: 1rem; padding: 1rem; background: var(--gray-50); border-radius: 0.75rem;">
                    <strong>Premium Luxembourg</strong><br>
                    <small>Multi-devises</small><br>
                    <small>Protection juridique</small><br>
                    <small>Gestion privée</small>
                </li>
                <li style="padding: 1rem; background: var(--gray-50); border-radius: 0.75rem;">
                    <strong>Éco-Responsable</strong><br>
                    <small>ISR et impact</small><br>
                    <small>Fonds euros vert : 1,8%</small><br>
                    <small>Labellisé FINANSOL</small>
                </li>
            </ul>
        </div>

        <!-- Transmission -->
        <div class="sidebar-card">
            <h3>
                <span>👨‍👩‍👧‍👦</span>
                Transmission
            </h3>
            
            <p><strong>Avantages :</strong></p>
            <ul style="font-size: 0.9rem;">
                <li>Hors succession</li>
                <li>Abattement 152 500€/bénéficiaire</li>
                <li>Taxation réduite : 20% puis 31,25%</li>
                <li>Libre désignation des bénéficiaires</li>
            </ul>
            
            <div style="margin-top: 1rem; padding: 1rem; background: #dbeafe; border-radius: 0.75rem; border-left: 4px solid var(--primary-color);">
                <small><strong>Conseil :</strong> Optimisez votre transmission en combinant plusieurs contrats et en échelonnant les versements après 70 ans.</small>
            </div>
        </div>
    </div>
</div>

<!-- Section CTA -->
<div class="cta-section">
    <h2>Optimisez votre épargne avec l'assurance-vie</h2>
    <p>Nos experts vous accompagnent dans le choix du contrat optimal et la définition de votre stratégie d'allocation personnalisée.</p>
    <a href="{{ path('app_contact') }}" class="btn-cta">
        <span>🛡️</span>
        Choisir mon contrat
    </a>
</div>
{% endblock %}
