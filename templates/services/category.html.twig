{% extends 'base.html.twig' %}

{# =============== SEO DYNAMIQUE PAR CATÉGORIE =============== #}
{# Descriptions SEO par catégorie (max 160 chars pour Google) #}
{% set category_seo = {
    'gestion-de-patrimoine': {
        'title_short': 'Gestion de patrimoine Paris',
        'meta_description': 'Gestion de patrimoine personnalisée à Paris : optimisation fiscale, stratégies d\'investissement, diversification. Conseil expert ADN Family Office.',
        'og_description': 'Optimisez votre patrimoine avec nos experts : fiscalité, investissement, diversification. 30 ans d\'expertise.'
    },
    'gestion-immobiliere': {
        'title_short': 'Gestion immobilière Paris',
        'meta_description': 'Immobilier résidentiel, commercial, SCPI, OPCI, défiscalisation : gestion immobilière complète par les experts ADN Family Office à Paris.',
        'og_description': 'Investissez dans l\'immobilier avec ADN Family Office : SCPI, immobilier commercial, défiscalisation. Rendement et sécurité.'
    },
    'transmission-succession': {
        'title_short': 'Transmission et succession',
        'meta_description': 'Transmission de patrimoine et planification successorale : donations, société familliale, optimisation des droits de succession. ADN Family Office Paris.',
        'og_description': 'Préparez l\'avenir de votre famille : transmission optimisée, donations, société familliale. Expertise juridique et fiscale.'
    },
    'private-equity': {
        'title_short': 'Private equity',
        'meta_description': 'Private equity et capital investissement : opportunités startups, fonds privés, capital-développement. Accès non-coté ADN Family Office Paris.',
        'og_description': 'Investissez dans le non-coté : private equity, startups, fonds d\'investissement sélectionnés. Rendements attractifs.'
    },
    'investissements-financiers': {
        'title_short': 'Investissements financiers',
        'meta_description': 'Gestion de portefeuille, assurance-vie, placements diversifiés : solutions d\'investissements financiers sur mesure par ADN Family Office.',
        'og_description': 'Faites fructifier votre épargne : portefeuille sur-mesure, assurance-vie optimisée, placements sécurisés.'
    },
    'conseil-strategique-du-dirigeant': {
        'title_short': 'Conseil stratégique dirigeant',
        'meta_description': 'Conseil stratégique pour dirigeants : optimisation rémunération, gestion trésorerie, développement et cession d\'entreprise. ADN Family Office Paris.',
        'og_description': 'Accompagnement des dirigeants : rémunération optimisée, trésorerie, développement, cession d\'entreprise.'
    }
} %}

{% set current_seo = category_seo[categoryKey] | default({
    'title_short': category.label,
    'meta_description': category.label ~ ' par ADN Family Office Paris. Solutions et accompagnement personnalisé pour votre patrimoine.',
    'og_description': category.label ~ ' - Services sur-mesure par ADN Family Office, votre family office à Paris.'
}) %}

{% block title %}{{ current_seo.title_short | default(category.label) }} | ADN Family Office Paris{% endblock %}

{% block meta_description %}{{ current_seo.meta_description }}{% endblock %}

{% block og_title %}{{ category.label }} - Services de Gestion Patrimoniale | ADN Family Office{% endblock %}
{% block og_description %}{{ current_seo.og_description }}{% endblock %}

{# JSON-LD pour la page Catégorie #}
{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "{{ category.label }}",
    "description": "{{ current_seo.meta_description }}",
    "url": "{{ url('service_category', {category: categoryKey}) }}",
    "numberOfItems": {{ category.items|length }},
    "itemListElement": [
        {% for sKey, sData in category.items %}
        {
            "@type": "ListItem",
            "position": {{ loop.index }},
            "item": {
                "@type": "Service",
                "name": "{{ sData.label }}",
                "url": "{{ url('service_detail', {category: categoryKey, slug: sKey}) }}",
                "provider": {
                    "@type": "Organization",
                    "name": "ADN Family Office"
                },
                "serviceType": "{{ category.label }}"
            }
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ]
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Accueil",
            "item": "{{ url('app_home') }}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "Services",
            "item": "{{ url('services_index') }}"
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": "{{ category.label }}",
            "item": "{{ url('service_category', {category: categoryKey}) }}"
        }
    ]
}
</script>
{% endblock %}

{% block body %}
<section class="modern-section bg-white">
    <div class="modern-container">
        {# Fil d'Ariane visible #}
        <nav class="text-sm text-gray-500 mb-6" aria-label="Fil d'Ariane">
            <a href="{{ path('app_home') }}" class="hover:text-blue-600">Accueil</a>
            <span class="mx-2">/</span>
            <a href="{{ path('services_index') }}" class="hover:text-blue-600">Services</a>
            <span class="mx-2">/</span>
            <span class="text-gray-900">{{ category.label }}</span>
        </nav>
        
        <h1 class="modern-section-title mb-6">{{ category.label }}</h1>
        <p class="modern-section-subtitle mb-10">Découvrez notre expertise et nos solutions personnalisées en {{ category.label | lower }}.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for sKey, sData in category.items %}
                <a class="group bg-white rounded-2xl p-6 shadow hover:shadow-lg transition-all block" href="{{ path('service_detail', {category: categoryKey, slug: sKey}) }}">
                    <h2 class="text-lg font-semibold text-gray-900 mb-2">{{ sData.label }}</h2>
                    <p class="text-gray-600">Découvrez notre approche et nos modalités d'accompagnement personnalisé.</p>
                    <span class="mt-3 inline-block text-blue-600 group-hover:translate-x-1 transition" aria-hidden="true">Découvrir →</span>
                </a>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Section CTA Prendre rendez-vous -->
<section class="py-16 md:py-20" style="background: linear-gradient(135deg, #101A50 0%, #0057FF 40%, #1F299C 70%, #0D5EED 100%);">
    <div class="modern-container">
        <div class="text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                Intéressé par nos services en {{ category.label | lower }} ?
            </h2>
            <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
                Prenez rendez-vous avec l'un de nos experts pour bénéficier d'un premier conseil personnalisé et gratuit.
            </p>
            
            <a href="{{ path('app_contact') }}" 
               class="group relative inline-flex items-center justify-center px-8 py-4 sm:px-10 sm:py-5 text-lg sm:text-xl font-bold rounded-2xl transform hover:scale-105 transition-all duration-300 shadow-2xl"
               style="background: linear-gradient(135deg, #ffffff 0%, #f0f4ff 100%); color: #1C29A1; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);">
                <svg class="w-5 h-5 sm:w-6 sm:h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <span>Prendre rendez-vous</span>
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
            
            <p class="mt-6 text-white/70 text-sm">
                ✓ Consultation gratuite &nbsp;&nbsp; ✓ Réponse sous 24h &nbsp;&nbsp; ✓ Sans engagement
            </p>
        </div>
    </div>
</section>
{% endblock %}


