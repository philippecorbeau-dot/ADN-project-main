{% extends 'base.html.twig' %}

{# =============== SEO OPTIMISÉ POUR LA PAGE SERVICES =============== #}
{% block title %}Services patrimoniaux | ADN Family Office Paris{% endblock %}

{% block meta_description %}Gestion de patrimoine, immobilier, private equity, transmission, conseil dirigeant : 6 pôles d'expertise sur mesure à Paris par ADN Family Office.{% endblock %}

{% block og_title %}Services de gestion patrimoniale | ADN Family Office{% endblock %}
{% block og_description %}6 pôles d'expertise sur mesure : gestion de patrimoine, immobilier, transmission, private equity, investissements financiers, conseil stratégique.{% endblock %}

{# JSON-LD pour la page Services #}
{% block structured_data %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Services ADN Family Office",
    "description": "Ensemble des services de gestion patrimoniale proposés par ADN Family Office",
    "url": "{{ url('services_index') }}",
    "numberOfItems": {{ catalog|length }},
    "itemListElement": [
        {% for key, cat in catalog %}
        {
            "@type": "ListItem",
            "position": {{ loop.index }},
            "item": {
                "@type": "Service",
                "name": "{{ cat.label }}",
                "url": "{{ url('service_category', {category: key}) }}",
                "provider": {
                    "@type": "Organization",
                    "name": "ADN Family Office"
                }
            }
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ]
}
</script>
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Accueil",
            "item": "{{ url('app_home') }}"
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "Services",
            "item": "{{ url('services_index') }}"
        }
    ]
}
</script>
{% endblock %}

{% block body %}
<section class="modern-section bg-white">
    <div class="modern-container">
        <h1 class="modern-section-title mb-6">Nos services de gestion patrimoniale</h1>
        <p class="modern-section-subtitle mb-10">Découvrez l'ensemble de notre accompagnement personnalisé, organisé en 6 pôles d'expertise pour répondre à tous vos besoins patrimoniaux.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for key, cat in catalog %}
                <a class="group bg-white rounded-2xl p-6 shadow hover:shadow-lg transition-all block" href="{{ path('service_category', {category: key}) }}">
                    <h2 class="text-xl font-bold text-gray-900 mb-3">{{ cat.label }}</h2>
                    <ul class="text-gray-600 space-y-1">
                        {% for sKey, sData in cat.items %}
                            <li class="flex items-center gap-2">
                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500" aria-hidden="true"></span>
                                <span>{{ sData.label }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                    <span class="mt-4 inline-block text-blue-600 group-hover:translate-x-1 transition" aria-hidden="true">En savoir plus →</span>
                </a>
            {% endfor %}
        </div>
    </div>
</section>

<!-- Section CTA Prendre rendez-vous -->
<section class="py-16 md:py-20" style="background: linear-gradient(135deg, #101A50 0%, #0057FF 40%, #1F299C 70%, #0D5EED 100%);">
    <div class="modern-container">
        <div class="text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                Besoin d'un accompagnement personnalisé ?
            </h2>
            <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
                Nos experts sont à votre disposition pour répondre à toutes vos questions et vous proposer des solutions sur-mesure.
            </p>
            
            <a href="{{ path('app_contact') }}" 
               class="group relative inline-flex items-center justify-center px-8 py-4 sm:px-10 sm:py-5 text-lg sm:text-xl font-bold rounded-2xl transform hover:scale-105 transition-all duration-300 shadow-2xl"
               style="background: linear-gradient(135deg, #ffffff 0%, #f0f4ff 100%); color: #1C29A1; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);">
                <svg class="w-5 h-5 sm:w-6 sm:h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <span>Prendre rendez-vous</span>
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
            
            <p class="mt-6 text-white/70 text-sm">
                ✓ Consultation gratuite &nbsp;&nbsp; ✓ Réponse sous 24h &nbsp;&nbsp; ✓ Sans engagement
            </p>
        </div>
    </div>
</section>
{% endblock %}


