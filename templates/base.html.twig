<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# =============== SEO META TAGS =============== #}
    <title>{% block title %}ADN Family Office - Gestion de patrimoine{% endblock %}</title>
    
    {# Meta description dynamique - à surcharger par page #}
    {% set default_description = "ADN Family Office, premier family office accessible à toutes les familles. Expertise en gestion de patrimoine, investissement immobilier, transmission, private equity et conseil stratégique à Paris." %}
    <meta name="description" content="{% block meta_description %}{{ default_description }}{% endblock %}">
    
    {# Meta author et robots #}
    <meta name="author" content="ADN Family Office">
    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
    
    {# Canonical URL - CRITIQUE pour éviter le duplicate content #}
    {% block canonical %}
    <link rel="canonical" href="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
    {% endblock %}

    {# =============== OPEN GRAPH (Facebook, LinkedIn) =============== #}
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:site_name" content="ADN Family Office">
    <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:url" content="{{ app.request.uri }}">
    <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('build/theme/images/og-image-adn.jpg')) }}{% endblock %}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:locale" content="fr_FR">
    
    {# =============== TWITTER CARD =============== #}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@ADNFamilyOffice">
    <meta name="twitter:title" content="{{ block('og_title') }}">
    <meta name="twitter:description" content="{{ block('og_description') }}">
    <meta name="twitter:image" content="{{ block('og_image') }}">
    
    {# =============== STRUCTURED DATA JSON-LD =============== #}
    {# Organisation de base présente sur toutes les pages #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "ADN Family Office",
        "alternateName": ["ADN FO", "Accessible Digital Novateur"],
        "url": "{{ url('app_home') }}",
        "logo": {
            "@type": "ImageObject",
            "url": "{{ absolute_url(asset('build/theme/images/ADN_Logo.png')) }}",
            "width": 1146,
            "height": 313,
            "caption": "ADN Family Office"
        },
        "image": "{{ absolute_url(asset('build/theme/images/og-image-adn.jpg')) }}",
        "description": "Premier family office ouvert à toutes les familles, spécialisé en gestion de patrimoine, investissement et transmission.",
        "foundingDate": "2009",
        "address": {
            "@type": "PostalAddress",
            "streetAddress": "140 bis rue de Rennes",
            "addressLocality": "Paris",
            "postalCode": "75006",
            "addressCountry": "FR"
        },
        "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+33-7-55-60-89-47",
            "contactType": "customer service",
            "availableLanguage": ["French", "English"],
            "email": "contact@adnfamilyoffice.fr"
        },
        "sameAs": [
            "https://www.linkedin.com/company/adn-family-office"
        ],
        "areaServed": {
            "@type": "Country",
            "name": "France"
        },
        "knowsAbout": [
            "Gestion de patrimoine",
            "Private equity",
            "Investissement immobilier",
            "Transmission successorale",
            "Conseil stratégique",
            "Optimisation fiscale"
        ]
    }
    </script>
    
    {# Données structurées spécifiques à la page #}
    {% block structured_data %}{% endblock %}

    {# =============== FAVICON (multi-tailles pour Google + tous navigateurs) =============== #}
    {# Standard ICO multi-r\u00e9solutions (16/32/48) #}
    <link rel="icon" href="{{ asset('assets/favicon.ico') }}" sizes="any">
    {# PNG \u2014 Google recommande des multiples de 48px #}
    <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('assets/favicon-16.png') }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('assets/favicon-32.png') }}">
    <link rel="icon" type="image/png" sizes="48x48" href="{{ asset('assets/favicon-48.png') }}">
    <link rel="icon" type="image/png" sizes="96x96" href="{{ asset('assets/favicon-96.png') }}">
    <link rel="icon" type="image/png" sizes="192x192" href="{{ asset('assets/favicon-192.png') }}">
    <link rel="icon" type="image/png" sizes="512x512" href="{{ asset('assets/favicon-512.png') }}">
    {# Apple Touch Icon (iOS Safari, ajout \u00e0 l'\u00e9cran d'accueil) #}
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('assets/apple-touch-icon.png') }}">
    <link rel="apple-touch-icon" sizes="152x152" href="{{ asset('assets/apple-touch-icon-152x152.png') }}">
    <link rel="apple-touch-icon" sizes="120x120" href="{{ asset('assets/apple-touch-icon-120x120.png') }}">
    {# PWA manifest #}
    <link rel="manifest" href="{{ asset('site.webmanifest') }}">
    <meta name="theme-color" content="#1c29a1">
    <meta name="msapplication-TileColor" content="#1c29a1">

    {# =============== PRECONNECT & DNS-PREFETCH =============== #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    
    {# =============== GOOGLE FONTS =============== #}
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet">

    {# =============== GOOGLE ANALYTICS 4 + CONSENT MODE V2 =============== #}
    {# L'ID GA4 est lu depuis la variable d'env GA4_MEASUREMENT_ID (format: G-XXXXXXXXXX).
       Pour activer GA4 :
         1. Cr\u00e9er une propri\u00e9t\u00e9 GA4 sur https://analytics.google.com/
         2. Copier le Measurement ID (G-XXXXXXXXXX)
         3. Ajouter GA4_MEASUREMENT_ID=G-XXXXXXXXXX dans .env.local sur la prod
       Tant qu'il n'est pas d\u00e9fini, aucun script GA n'est inject\u00e9. #}
    {% set ga4_id = ga4_measurement_id|default('') %}
    {% if ga4_id is not empty %}
        {# Consent Mode v2 : RGPD-compliant, charge GA mais sans pister tant qu'aucun consentement #}
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('consent', 'default', {
                'ad_storage': 'denied',
                'ad_user_data': 'denied',
                'ad_personalization': 'denied',
                'analytics_storage': 'denied',
                'functionality_storage': 'granted',
                'security_storage': 'granted',
                'wait_for_update': 500
            });
            try {
                var consent = localStorage.getItem('adn_cookie_consent_v1');
                if (consent === 'accepted') {
                    gtag('consent', 'update', {
                        'ad_storage': 'granted',
                        'ad_user_data': 'granted',
                        'ad_personalization': 'granted',
                        'analytics_storage': 'granted'
                    });
                }
            } catch(e) { /* localStorage indisponible */ }
            gtag('js', new Date());
            gtag('config', '{{ ga4_id }}', { 'anonymize_ip': true });
        </script>
        <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga4_id }}"></script>
    {% endif %}

    {# Styles personnalisés de page #}
    {% block page_styles %}{% endblock %}

    {# CSS Compilé par Tailwind (important) #}
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}

    {# CSS pour l'autocomplétion #}
    <link href="{{ asset('assets/css/autocomplete.css') }}" rel="stylesheet">
    {# CSS pour le sélecteur de pays moderne #}
    <link href="{{ asset('assets/css/modern-country-select.css') }}" rel="stylesheet">
    {# CSS pour les champs de date français #}
    <link href="{{ asset('assets/css/french-date-input.css') }}" rel="stylesheet">

    <!-- Alpine.js pour le système de toast -->
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- CSS Footer Global -->
    <style>
        /* Layout: coller le footer en bas même avec peu de contenu */
        html, body { height: 100%; }
        body { display: flex; min-height: 100vh; flex-direction: column; }
        main { flex: 1 0 auto; }

        /* Container global pour le footer */
        .modern-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }
        
        /* Styles pour le footer moderne avec couleur plus claire */
        .modern-footer {
            background: linear-gradient(135deg, #475569 0%, #334155 100%);
            color: #f1f5f9;
        }
        
        .footer-main {
            padding: 4rem 0 2rem;
        }
        
        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.5fr;
            gap: 3rem;
            margin-bottom: 2rem;
        }
        
        .footer-column h3.footer-title {
            color: white;
            font-size: 1.125rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        
        .footer-logo {
            display: flex;
            align-items: center;
            margin-bottom: 1.5rem;
        }
        
        .footer-logo-img {
            height: 50px;
            width: auto;
            filter: brightness(0) invert(1);
        }
        
        .footer-logo-text {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            color: white;
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }
        
        .footer-logo-subtitle {
            font-size: 0.8rem;
            font-weight: 500;
            color: #cbd5e1;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .footer-description {
            color: #e2e8f0;
            line-height: 1.7;
            margin-bottom: 2rem;
            font-size: 0.95rem;
        }
        
        .footer-social {
            display: flex;
            gap: 1rem;
        }
        
        .social-link {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #e2e8f0;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }
        
        .social-link:hover {
            background: #3b82f6;
            color: white;
            transform: translateY(-2px);
        }
        
        .social-icon {
            width: 20px;
            height: 20px;
        }
        
        .footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .footer-links li {
            margin-bottom: 0.75rem;
        }
        
        .footer-links a {
            color: #e2e8f0;
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            position: relative;
            padding-left: 0;
        }
        
        .footer-links a:hover {
            color: #60a5fa;
            padding-left: 0.5rem;
        }
        
        .footer-links a::before {
            content: '';
            position: absolute;
            left: -0.5rem;
            top: 50%;
            transform: translateY(-50%);
            width: 0;
            height: 2px;
            background: #60a5fa;
            transition: width 0.3s ease;
        }
        
        .footer-links a:hover::before {
            width: 0.25rem;
        }
        
        .footer-contact {
            margin-bottom: 2rem;
        }
        
        .contact-item {
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            margin-bottom: 1rem;
            color: #e2e8f0;
            font-size: 0.9rem;
            line-height: 1.6;
        }
        
        .contact-icon {
            width: 20px;
            height: 20px;
            color: #60a5fa;
            flex-shrink: 0;
            margin-top: 2px;
        }
        
        .footer-subtitle {
            color: white;
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 1rem;
            margin-top: 1.5rem;
        }
        
        .footer-links.small a {
            font-size: 0.85rem;
        }
        
        .footer-bottom {
            background: rgba(0, 0, 0, 0.2);
            padding: 1.5rem 0;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .footer-bottom-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }
        
        .copyright {
            color: #cbd5e1;
            font-size: 0.9rem;
        }
        
        .footer-certifications {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }
        
        .certification-badge {
            background: rgba(96, 165, 250, 0.15);
            color: #93c5fd;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            font-size: 0.8rem;
            font-weight: 600;
            border: 1px solid rgba(96, 165, 250, 0.3);
        }
        
        /* Responsive Footer */
        @media (max-width: 1024px) {
            .footer-grid {
                grid-template-columns: 1fr 1fr;
                gap: 2rem;
            }
            
            .footer-main {
                padding: 3rem 0 1.5rem;
            }
        }
        
        @media (max-width: 768px) {
            .footer-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            
            .footer-main {
                padding: 2rem 0 1rem;
            }
            
            .footer-logo {
                justify-content: center;
                text-align: center;
            }
            
            .footer-description {
                text-align: center;
            }
            
            .footer-social {
                justify-content: center;
            }
            
            .footer-bottom-content {
                flex-direction: column;
                text-align: center;
                gap: 1rem;
            }
            
            .footer-certifications {
                justify-content: center;
            }
            
            .footer-column { 
                text-align: center; 
            }
            
            .footer-links { 
                text-align: center;
                display: flex;
                flex-direction: column;
                align-items: center;
            }
            
            .footer-contact { 
                text-align: center;
                display: flex;
                flex-direction: column;
                align-items: center;
            }
            
            .contact-item {
                justify-content: center;
                text-align: center;
            }
            
            .footer-title {
                text-align: center;
            }
            
            .footer-subtitle {
                text-align: center;
            }
            
            .footer-legal-links {
                text-align: center;
            }
        }
        
        @media (max-width: 480px) {
            .footer-main {
                padding: 1.5rem 0 1rem;
            }
            
            .modern-container {
                padding: 0 1rem;
            }
            
            .footer-grid {
                gap: 1.5rem;
            }
            
            .footer-logo-text {
                font-size: 1.25rem;
            }
            
            .footer-logo-subtitle {
                font-size: 0.7rem;
            }
            
            .social-link {
                width: 36px;
                height: 36px;
            }
            
            .social-icon {
                width: 18px;
                height: 18px;
            }
            
            .certification-badge {
                padding: 0.4rem 0.8rem;
                font-size: 0.75rem;
            }
        }
    </style>
</head>

