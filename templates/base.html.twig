    <script>
        // Gestion simple du consentement cookies (localStorage)
        (function(){
            function ready(fn){ if(document.readyState!='loading'){fn();} else document.addEventListener('DOMContentLoaded',fn); }
            ready(function(){
                try {
                    var key = 'adn_cookie_consent_v1';
                    var banner = document.getElementById('cookie-banner');
                    if (!banner) return;
                    if (!localStorage.getItem(key)) {
                        banner.style.display = 'block';
                    }
                    function setChoice(val){
                        localStorage.setItem(key, val);
                        banner.style.opacity = '1';
                        banner.style.transition = 'opacity .3s ease, transform .3s ease';
                        banner.style.transform = 'translateY(0)';
                        setTimeout(function(){ banner.style.opacity='0'; banner.style.transform='translateY(10px)'; }, 0);
                        setTimeout(function(){ banner.remove(); }, 320);
                    }
                    var accept = document.getElementById('cookie-accept');
                    var decline = document.getElementById('cookie-decline');
                    accept && accept.addEventListener('click', function(){ setChoice('accepted'); });
                    decline && decline.addEventListener('click', function(){ setChoice('declined'); });
                } catch(e) { /* no-op */ }
            });
        })();
    </script>

    <script>
        // Filet de sécurité global: délégation d'événements pour le menu mobile
        (function() {
            // Si le module header moderne est présent, on n'attache pas le fallback
            if (window.__adnHeaderModulePresent) return;
            if (window.__adnHeaderDelegated) return; // éviter doublons
            window.__adnHeaderDelegated = true;
            function getEls() {
                return {
                    toggle: document.getElementById('mobileToggle'),
                    menu: document.getElementById('mobileMenu'),
                    close: document.getElementById('mobileClose')
                };
            }
            function openMenu(els) {
                els.menu && els.menu.classList.add('active');
                els.toggle && els.toggle.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
            function closeMenu(els) {
                els.menu && els.menu.classList.remove('active');
                els.toggle && els.toggle.classList.remove('active');
                document.body.style.overflow = '';
            }
            document.addEventListener('click', function(e) {
                var els = getEls();
                if (!els.toggle || !els.menu || !els.close) return;
                if (e.target.closest('#mobileToggle')) {
                    e.preventDefault();
                    els.menu.classList.contains('active') ? closeMenu(els) : openMenu(els);
                } else if (e.target.closest('#mobileClose')) {
                    e.preventDefault();
                    closeMenu(els);
                } else if (e.target === els.menu) {
                    // clic sur l'overlay
                    closeMenu(els);
                } else {
                    // Fallback pour les sous-menus
                    var toggleEl = e.target.closest('.mobile-dropdown-toggle');
                    if (toggleEl) {
                        e.preventDefault();
                        var dropdown = toggleEl.closest('.mobile-dropdown');
                        if (dropdown) {
                            var isActive = dropdown.classList.contains('active');
                            document.querySelectorAll('.mobile-dropdown.active').forEach(function(d){
                                if (d !== dropdown) {
                                    d.classList.remove('active');
                                    var sm = d.querySelector('.mobile-submenu');
                                    if (sm) sm.setAttribute('aria-hidden','true');
                                    var btn = d.querySelector('.mobile-dropdown-toggle');
                                    if (btn) btn.setAttribute('aria-expanded','false');
                                }
                            });
                            dropdown.classList.toggle('active', !isActive);
                            var submenu = dropdown.querySelector('.mobile-submenu');
                            if (submenu) submenu.setAttribute('aria-hidden', isActive ? 'true' : 'false');
                            toggleEl.setAttribute('aria-expanded', isActive ? 'false' : 'true');
                        }
                    }
                }
            }, true);
        })();
    </script>

