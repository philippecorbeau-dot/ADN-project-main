<div id="{% block id %}alert-{{ type }}{% endblock %}" class="rounded-xl mb-8 {{ bgClass|default((type == 'success') ? 'bg-homgreen-light/40' : (type == 'danger' ? 'bg-red-600/30' : (type == 'info' ? 'bg-homblue-light' : (type == 'warning' ? 'bg-orange-500/10' : ''))) ) }}">
    <div class="flex flex-col md:flex-row gap-x-4 gap-y-4 md:gap-y-0 p-6 bg-ellipse-w bg-no-repeat bg-[length:250px] bg-[bottom_-9rem_right_-6rem] {{ textClass|default('') }}">
        <div class="hidden flex-none md:flex justify-center ">
            {% block icon %}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 {% block icoColor %}{% endblock %}">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
                </svg>
            {% endblock %}
        </div>
        <div class="flex flex-col gap-y-2">
            <span class="text-lg font-bold block">{{ block('title') }}</span>
            {% if block('content') is defined and block('content') != "" %}
                <p class="text-sm md:text-base">{{ block('content') }}</p>
            {% endif %}
            {% if block('cta') is defined %}
                {{ block('cta') }}
            {% endif %}
        </div>
    </div>
</div>
