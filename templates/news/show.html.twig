{% extends 'base.html.twig' %}

{% block title %}{{ seo.title }}{% endblock %}
{% block meta_description %}{{ seo.description }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endblock %}

{% block head %}
    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content="{{ post.title }}">
    <meta property="og:description" content="{{ post.seoDescription }}">
    <meta property="og:type" content="article">
    <meta property="og:url" content="{{ seo.canonical }}">
    {% if seo.ogImage %}
        <meta property="og:image" content="{{ seo.ogImage }}">
    {% endif %}
    <meta property="article:published_time" content="{{ seo.publishedTime }}">
    {% if seo.modifiedTime %}
        <meta property="article:modified_time" content="{{ seo.modifiedTime }}">
    {% endif %}
    <meta property="article:author" content="ADN Family Office">
    <meta property="article:section" content="{{ post.category.name }}">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ post.title }}">
    <meta name="twitter:description" content="{{ post.seoDescription }}">
    {% if seo.ogImage %}
        <meta name="twitter:image" content="{{ seo.ogImage }}">
    {% endif %}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
        {{ jsonLd|json_encode|raw }}
    </script>
{% endblock %}

{% block page_styles %}
    <style>
        :root {
            --adn-primary: #1C29A1;
            --adn-primary-light: #2D3FDB;
            --adn-primary-dark: #0F1751;
            --adn-secondary: #3B82F6;
            --adn-accent: #6366F1;
            --adn-success: #10B981;
            --adn-warning: #F59E0B;
            --adn-error: #EF4444;
            --gradient-primary: linear-gradient(135deg, #1C29A1 0%, #3B82F6 40%, #6366F1 100%);
            --gradient-hero: linear-gradient(135deg, #0F1751 0%, #1C29A1 30%, #2D3FDB 70%, #3B82F6 100%);
            --shadow-soft: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            --shadow-medium: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --shadow-large: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            --border-radius: 1.5rem;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --font-primary: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            --font-secondary: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }

        /* Breadcrumb moderne - styles supprimés car utilisation du composant */

        /* Article Header */
        .article-header {
            background: white;
            padding: 4rem 0;
        }

        .article-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .article-category-badge {
            display: inline-block;
            background: var(--gradient-primary);
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 1rem;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2rem;
        }

        .article-title {
            font-family: var(--font-primary);
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 800;
            color: var(--adn-primary);
            line-height: 1.2;
            margin-bottom: 2rem;
        }

        .article-meta {
            display: flex;
            align-items: center;
            gap: 2rem;
            margin-bottom: 3rem;
            padding-bottom: 2rem;
            border-bottom: 2px solid #f1f5f9;
            flex-wrap: wrap;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: #64748b;
            font-weight: 500;
            transition: var(--transition);
        }
        
        .meta-item:hover {
            color: var(--adn-primary);
        }

        .meta-icon {
            flex-shrink: 0;
            color: var(--adn-primary);
            transition: var(--transition);
        }
        
        .meta-item:hover .meta-icon {
            color: var(--adn-secondary);
        }

        /* Image principale améliorée */
        .article-image-container {
            margin-bottom: 3rem;
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--shadow-large);
            position: relative;
            background: #f8fafc;
        }

        .article-image-wrapper {
            position: relative;
            width: 100%;
            height: 400px;
            background: linear-gradient(135deg, #f8fafc 0%, #e0e7ff 100%);
            border-radius: var(--border-radius);
            overflow: hidden;
        }

        .article-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            display: block;
            image-rendering: auto;
            -webkit-image-rendering: auto;
            image-rendering: -webkit-optimize-contrast;
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
            position: absolute;
            top: 0;
            left: 0;
            transform: none !important;
            will-change: auto;
        }

        /* Forcer l'image à rester dans son conteneur */
        .article-image-container * {
            transform: none !important;
        }

        .article-image-wrapper {
            contain: layout style paint;
        }

        /* Protection globale contre les animations d'image */
        .article-image-container,
        .article-image-wrapper,
        .article-image {
            transform: none !important;
            animation: none !important;
        }

        /* Assurer que l'image occupe tout le conteneur */
        .article-image-container {
            position: relative;
            contain: layout style;
        }

        /* Placeholder pour images manquantes */
        .image-placeholder {
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f8fafc 0%, #e0e7ff 100%);
            color: #9ca3af;
            min-height: 300px;
            border-radius: var(--border-radius);
        }

        .image-placeholder svg {
            opacity: 0.5;
        }

        /* Contenu principal */
        .article-main {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 4rem;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem 4rem;
        }

        .article-content {
            background: white;
            padding: 3rem;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow-soft);
        }

        .article-content h1,
        .article-content h2,
        .article-content h3,
        .article-content h4,
        .article-content h5,
        .article-content h6 {
            font-family: var(--font-primary);
            color: var(--adn-primary);
            margin: 2rem 0 1rem 0;
            font-weight: 700;
        }

        .article-content h2 {
            font-size: 1.75rem;
            position: relative;
            padding-left: 1rem;
        }

        .article-content h2::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 4px;
            height: 60%;
            background: var(--gradient-primary);
            border-radius: 2px;
        }

        .article-content h3 {
            font-size: 1.5rem;
            color: var(--adn-secondary);
        }

        .article-content h4 {
            font-size: 1.25rem;
            color: var(--adn-primary-dark);
        }

        .article-content p {
            line-height: 1.9;
            margin-bottom: 1.5rem;
            color: #374151;
            font-size: 1.1rem;
            text-align: justify;
        }

        /* Sous-titres avec flèche (➣) - style premium */
        .article-content p > strong:first-child {
            display: block;
            font-size: 1.2rem;
            color: var(--adn-primary);
            margin-bottom: 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #e0e7ff;
        }

        /* Listes modernes avec puces personnalisées */
        .article-content ul {
            margin: 1.5rem 0;
            padding-left: 0;
            list-style: none;
        }

        .article-content ul li {
            position: relative;
            padding-left: 2rem;
            margin-bottom: 1rem;
            line-height: 1.7;
            color: #374151;
        }

        .article-content ul li::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0.5rem;
            width: 8px;
            height: 8px;
            background: var(--gradient-primary);
            border-radius: 50%;
        }

        .article-content ol {
            margin: 1.5rem 0;
            padding-left: 0;
            list-style: none;
            counter-reset: item;
        }

        .article-content ol li {
            position: relative;
            padding-left: 2.5rem;
            margin-bottom: 1rem;
            line-height: 1.7;
            color: #374151;
            counter-increment: item;
        }

        .article-content ol li::before {
            content: counter(item);
            position: absolute;
            left: 0;
            top: 0;
            width: 1.75rem;
            height: 1.75rem;
            background: var(--gradient-primary);
            color: white;
            border-radius: 50%;
            font-size: 0.85rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Images intercalées dans le contenu */
        .article-content img {
            max-width: 100%;
            height: auto;
            border-radius: 1rem;
            margin: 2rem auto;
            display: block;
            box-shadow: var(--shadow-medium);
            transition: var(--transition);
        }

        .article-content img:hover {
            box-shadow: var(--shadow-large);
            transform: scale(1.02);
        }

        /* Images avec légende */
        .article-content figure {
            margin: 2.5rem 0;
            text-align: center;
        }

        .article-content figure img {
            margin-bottom: 1rem;
        }

        .article-content figcaption {
            font-size: 0.9rem;
            color: #64748b;
            font-style: italic;
        }

        /* Tableaux modernes */
        .article-content table {
            width: 100%;
            margin: 2rem 0;
            border-collapse: separate;
            border-spacing: 0;
            border-radius: 1rem;
            overflow: hidden;
            box-shadow: var(--shadow-soft);
        }

        .article-content table thead {
            background: var(--gradient-primary);
        }

        .article-content table th {
            padding: 1rem 1.25rem;
            color: white;
            font-weight: 700;
            text-align: left;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .article-content table td {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid #e5e7eb;
            color: #374151;
        }

        .article-content table tbody tr:nth-child(even) {
            background: #f8fafc;
        }

        .article-content table tbody tr:hover {
            background: #e0e7ff;
        }

        .article-content table tbody tr:last-child td {
            border-bottom: none;
        }

        /* Blocs de citation premium */
        .article-content blockquote {
            background: linear-gradient(135deg, #f0f4ff 0%, #e0e7ff 100%);
            border-left: 5px solid var(--adn-primary);
            padding: 2rem 2.5rem;
            margin: 2.5rem 0;
            border-radius: 0 1.5rem 1.5rem 0;
            font-style: italic;
            font-size: 1.15rem;
            color: var(--adn-primary-dark);
            position: relative;
        }

        .article-content blockquote::before {
            content: '"';
            position: absolute;
            top: -0.5rem;
            left: 1rem;
            font-size: 4rem;
            color: var(--adn-primary);
            opacity: 0.3;
            font-family: Georgia, serif;
            line-height: 1;
        }

        /* Séparateurs horizontaux */
        .article-content hr {
            border: none;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--adn-primary), var(--adn-secondary), transparent);
            margin: 3rem 0;
            border-radius: 2px;
        }

        /* Liens */
        .article-content a {
            color: var(--adn-primary);
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
            border-bottom: 2px solid transparent;
        }

        .article-content a:hover {
            color: var(--adn-secondary);
            border-bottom-color: var(--adn-secondary);
        }

        /* Code inline */
        .article-content code {
            background: #f1f5f9;
            padding: 0.2rem 0.5rem;
            border-radius: 0.375rem;
            font-family: 'Fira Code', monospace;
            font-size: 0.9rem;
            color: var(--adn-primary);
        }

        /* Bloc de code */
        .article-content pre {
            background: #1e293b;
            color: #e2e8f0;
            padding: 1.5rem;
            border-radius: 1rem;
            overflow-x: auto;
            margin: 2rem 0;
        }

        .article-content pre code {
            background: transparent;
            color: inherit;
            padding: 0;
        }

        /* Mise en évidence de texte */
        .article-content mark {
            background: linear-gradient(120deg, #fef08a 0%, #fde047 100%);
            padding: 0.1rem 0.3rem;
            border-radius: 0.25rem;
        }

        /* Texte en gras stylisé */
        .article-content strong {
            color: var(--adn-primary-dark);
            font-weight: 700;
        }

        /* Encadrés d'information */
        .article-content .info-box,
        .article-content div[style*="background"] {
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
            border: 1px solid #bae6fd;
            border-left: 4px solid #0ea5e9;
            padding: 1.5rem;
            border-radius: 0.75rem;
            margin: 2rem 0;
        }

        /* Amélioration de l'espacement des paragraphes après les listes */
        .article-content ul + p,
        .article-content ol + p {
            margin-top: 2rem;
        }

        /* Premier paragraphe en introduction */
        .article-content > p:first-of-type {
            font-size: 1.2rem;
            line-height: 1.9;
            color: #1f2937;
        }

        /* Sidebar */
        .article-sidebar {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .sidebar-widget {
            background: white;
            padding: 2rem;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow-soft);
        }

        .widget-title {
            font-family: var(--font-primary);
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--adn-primary);
            margin-bottom: 1.5rem;
            position: relative;
            display: flex;
            align-items: center;
        }
        
        .widget-title svg {
            color: var(--adn-primary);
            flex-shrink: 0;
        }

        .widget-title::after {
            content: '';
            position: absolute;
            bottom: -0.5rem;
            left: 0;
            width: 40px;
            height: 3px;
            background: var(--gradient-primary);
            border-radius: 2px;
        }

        /* Articles récents dans la sidebar */
        .recent-post {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid #f1f5f9;
        }

        .recent-post:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
            border-bottom: none;
        }

        .recent-image {
            width: 80px;
            height: 80px;
            border-radius: 0.75rem;
            overflow: hidden;
            flex-shrink: 0;
        }

        .recent-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .recent-content h4 {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--adn-primary);
            line-height: 1.4;
            margin-bottom: 0.5rem;
        }

        .recent-content a {
            text-decoration: none;
            color: inherit;
        }

        .recent-content a:hover h4 {
            color: var(--adn-secondary);
        }

        .recent-date {
            font-size: 0.8rem;
            color: #94a3b8;
        }

        /* Boutons de partage */
        .share-buttons {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .share-btn {
            padding: 0.75rem;
            border-radius: 50%;
            text-decoration: none;
            color: white;
            font-size: 1.2rem;
            transition: var(--transition);
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .share-btn.facebook { background: #1877f2; }
        .share-btn.twitter { background: #1da1f2; }
        .share-btn.linkedin { background: #0a66c2; }
        .share-btn.email { background: #ea4335; }

        .share-btn:hover {
            transform: translateY(-3px) scale(1.1);
            box-shadow: var(--shadow-medium);
        }

        /* Articles liés */
        .related-articles {
            background: #f8fafc;
            padding: 4rem 0;
        }

        .related-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1rem;
        }

        .related-title {
            font-family: var(--font-primary);
            font-size: 2rem;
            font-weight: 800;
            color: var(--adn-primary);
            text-align: center;
            margin-bottom: 3rem;
            position: relative;
        }

        .related-title::after {
            content: '';
            position: absolute;
            bottom: -1rem;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: var(--gradient-primary);
            border-radius: 2px;
        }

        .related-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
        }

        .related-card {
            background: white;
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: var(--shadow-soft);
            transition: var(--transition);
        }

        .related-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-large);
        }

        .related-image {
            height: 200px;
            overflow: hidden;
        }

        .related-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: var(--transition);
        }

        .related-card:hover .related-image img {
            transform: scale(1.1);
        }

        .related-content {
            padding: 1.5rem;
        }

        .related-content h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--adn-primary);
            margin-bottom: 0.75rem;
            line-height: 1.4;
        }

        .related-content a {
            text-decoration: none;
            color: inherit;
        }

        .related-content a:hover h3 {
            color: var(--adn-secondary);
        }

        .related-excerpt {
            color: #64748b;
            font-size: 0.9rem;
            line-height: 1.5;
            margin-bottom: 1rem;
        }

        .related-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
            color: #94a3b8;
            border-top: 1px solid #f1f5f9;
            padding-top: 1rem;
        }

        /* Responsive Design Amélioré */
        @media (max-width: 1200px) {
            .article-main {
                grid-template-columns: 1fr 300px;
                gap: 2rem;
                padding: 0 1.5rem;
            }
        }

        @media (max-width: 1024px) {
            .article-main {
                grid-template-columns: 1fr;
                gap: 3rem;
                padding: 0 1rem;
            }

            .article-sidebar {
                order: 2;
            }

            .article-body {
                order: 1;
            }
        }

        @media (max-width: 768px) {
            .breadcrumb-section {
                padding: 1rem 0;
            }

            .breadcrumb {
                font-size: 0.8rem;
                padding: 0 1rem;
                flex-wrap: wrap;
                gap: 0.5rem;
            }

            .article-header {
                padding: 2rem 0 1rem;
            }

            .article-container {
                padding: 0 1rem;
            }

            .article-title {
                font-size: 2rem;
                line-height: 1.3;
                margin-bottom: 1rem;
            }

            .article-meta {
                gap: 1rem;
                flex-wrap: wrap;
            }

            .meta-item {
                font-size: 0.85rem;
            }

            .article-image-container {
                margin: 0 1rem 2rem;
            }

            .article-image-wrapper {
                height: 300px;
            }

            .article-image {
                border-radius: 1rem;
            }

            .article-content {
                padding: 1.5rem;
                margin: 0 1rem;
                border-radius: 1.5rem;
            }

            .article-text {
                font-size: 1rem;
                line-height: 1.7;
            }

            .article-text h2 {
                font-size: 1.4rem;
                margin: 2rem 0 1rem;
            }

            .article-text h3 {
                font-size: 1.2rem;
                margin: 1.5rem 0 0.75rem;
            }

            .related-grid {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }

            .related-card {
                margin: 0 1rem;
            }

            .sidebar-widget {
                margin: 0 1rem 2rem;
            }

            .share-buttons {
                justify-content: center;
                gap: 1rem;
            }

            .share-btn {
                width: 45px;
                height: 45px;
            }
        }

        @media (max-width: 480px) {
            .breadcrumb {
                padding: 0 0.5rem;
                font-size: 0.75rem;
            }

            .article-header {
                padding: 1.5rem 0 1rem;
            }

            .article-container {
                padding: 0 0.5rem;
            }

            .article-title {
                font-size: 1.75rem;
                line-height: 1.25;
            }

            .article-meta {
                gap: 0.75rem;
            }

            .meta-item {
                font-size: 0.8rem;
            }

            .article-image-container {
                margin: 0 0.5rem 1.5rem;
            }

            .article-image-wrapper {
                height: 250px;
            }

            .article-image {
                border-radius: 0.75rem;
            }

            .article-content {
                padding: 1rem;
                margin: 0 0.5rem;
            }

            .article-text {
                font-size: 0.95rem;
                line-height: 1.6;
            }

            .related-card {
                margin: 0 0.5rem;
            }

            .sidebar-widget {
                margin: 0 0.5rem 1.5rem;
            }

            .widget-title {
                font-size: 1rem;
            }

            .share-buttons {
                gap: 0.75rem;
            }

            .share-btn {
                width: 40px;
                height: 40px;
            }

            .share-btn svg {
                width: 18px;
                height: 18px;
            }
        }
        
        /* Améliorations pour les boutons de partage */
        .share-buttons {
            display: flex;
            gap: 0.75rem;
            justify-content: flex-start;
            flex-wrap: wrap;
            margin-bottom: 0;
        }
        
        .share-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            border-radius: 0.75rem;
            transition: var(--transition);
            text-decoration: none;
            border: none;
            cursor: pointer;
        }
        
        .share-btn:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: var(--shadow-medium);
        }
        
        .share-btn.facebook {
            background: #1877F2;
            color: white;
        }
        
        .share-btn.facebook:hover {
            background: #166FE5;
        }
        
        .share-btn.twitter {
            background: #1DA1F2;
            color: white;
        }
        
        .share-btn.twitter:hover {
            background: #1A94DA;
        }
        
        .share-btn.linkedin {
            background: #0A66C2;
            color: white;
        }
        
        .share-btn.linkedin:hover {
            background: #095CAF;
        }
        
        .share-btn.email {
            background: #6B7280;
            color: white;
        }
        
        .share-btn.email:hover {
            background: #5B6470;
        }
        
        /* Bouton de navigation mobile */
        .mobile-nav-toggle {
            display: none;
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: var(--gradient-primary);
            color: white;
            border: none;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            box-shadow: var(--shadow-large);
            z-index: 1000;
            transition: var(--transition);
        }
        
        .mobile-nav-toggle:hover {
            transform: scale(1.1);
        }
        
        @media (max-width: 768px) {
            .mobile-nav-toggle {
                display: flex;
                align-items: center;
                justify-content: center;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <!-- Breadcrumb moderne avec fond -->
    <div style="background: #f8fafc; padding: 1rem 0; border-bottom: 1px solid #e5e7eb; position: relative; z-index: 50;" class="news-breadcrumb">
        <div class="max-w-6xl mx-auto px-4">
            {% include 'partials/breadcrumb.html.twig' with {
                'items': [
                    {'label': 'Accueil', 'path': 'app_home', 'icon': 'home'},
                    {'label': 'Actualités', 'path': 'news_index', 'icon': 'news'},
                    {'label': post.category.name, 'path': 'news_category', 'slug': post.category.seoSlug},
                    {'label': post.title|slice(0, 50) ~ (post.title|length > 50 ? '...' : '')}
                ]
            } %}
        </div>
    </div>

    <!-- En-tête de l'article -->
    <header class="article-header">
        <div class="article-container">
            <div class="article-category-badge">{{ post.category.name }}</div>
            <h1 class="article-title">{{ post.title }}</h1>
            <div class="article-meta">
                <div class="meta-item">
                    <svg class="w-4 h-4 meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                    </svg>
                    <span>{{ post.publicationDateStart|date('d F Y') }}</span>
                </div>
                <div class="meta-item">
                    <svg class="w-4 h-4 meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <span>{{ post.user ? post.user.firstName ~ ' ' ~ post.user.lastName : 'ADN Family Office' }}</span>
                </div>
                <div class="meta-item">
                    <svg class="w-4 h-4 meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                    <span>{{ post.category.name }}</span>
                </div>
                {% if post.updatedAt %}
                    <div class="meta-item">
                        <svg class="w-4 h-4 meta-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                        <span>Mis à jour le {{ post.updatedAt|date('d/m/Y') }}</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </header>

    <!-- Image principale -->
    {% if post.imageName %}
        <div class="article-container">
            <div class="article-image-container">
                <div class="article-image-wrapper">
                    <img src="{{ asset('uploads/images/' ~ post.imageName) }}" 
                         alt="{{ post.imageAlt ?: post.title }}"
                         class="article-image"
                         loading="lazy"
                         onload="this.style.opacity=1"
                         style="opacity: 0; transition: opacity 0.3s ease;">
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Contenu principal -->
    <div class="article-main">
        <main class="article-content">
            {{ post.content|raw }}
        </main>

        <!-- Sidebar -->
        <aside class="article-sidebar">
            <!-- Partage -->
            <div class="sidebar-widget">
                <h3 class="widget-title">
                    <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                    </svg>
                    Partager cet article
                </h3>
                <div class="share-buttons">
                    <a href="https://www.facebook.com/sharer/sharer.php?u={{ seo.canonical|url_encode }}" 
                       target="_blank" class="share-btn facebook" title="Partager sur Facebook">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                    </a>
                    <a href="https://twitter.com/intent/tweet?url={{ seo.canonical|url_encode }}&text={{ post.title|url_encode }}" 
                       target="_blank" class="share-btn twitter" title="Partager sur Twitter">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                        </svg>
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ seo.canonical|url_encode }}" 
                       target="_blank" class="share-btn linkedin" title="Partager sur LinkedIn">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                    </a>
                    <a href="mailto:?subject={{ post.title|url_encode }}&body={{ seo.canonical|url_encode }}" 
                       class="share-btn email" title="Partager par email">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Articles récents -->
            {% if recentPosts is not empty %}
                <div class="sidebar-widget">
                    <h3 class="widget-title">
                        <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                        </svg>
                        Articles récents
                    </h3>
                    {% for recentPost in recentPosts %}
                        <div class="recent-post">
                            {% if recentPost.imageName %}
                                <div class="recent-image">
                                    <img src="{{ asset('uploads/images/' ~ recentPost.imageName) }}" 
                                         alt="{{ recentPost.imageAlt ?: recentPost.title }}"
                                         loading="lazy">
                                </div>
                            {% endif %}
                            <div class="recent-content">
                                <a href="{{ path('news_show', {slug: recentPost.seoSlug}) }}">
                                    <h4>{{ recentPost.title|slice(0, 80) }}{% if recentPost.title|length > 80 %}...{% endif %}</h4>
                                </a>
                                <div class="recent-date">{{ recentPost.publicationDateStart|date('d/m/Y') }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            <!-- Liens vers nos services -->
            <div class="sidebar-widget">
                <h3 class="widget-title">
                    <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    Nos services
                </h3>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <a href="{{ path('product_scpi') }}" 
                       style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: #f8fafc; border-radius: 0.75rem; transition: var(--transition); border-left: 4px solid var(--adn-primary); display: flex; align-items: center; gap: 0.5rem;">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
                        </svg>
                        Investissement SCPI
                    </a>
                    <a href="{{ path('product_assurance_vie') }}" 
                       style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: #f8fafc; border-radius: 0.75rem; transition: var(--transition); border-left: 4px solid var(--adn-primary); display: flex; align-items: center; gap: 0.5rem;">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.031 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                        Assurance-vie
                    </a>
                    <a href="{{ path('product_pea_pme') }}" 
                       style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: #f8fafc; border-radius: 0.75rem; transition: var(--transition); border-left: 4px solid var(--adn-primary); display: flex; align-items: center; gap: 0.5rem;">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                        PEA-PME
                    </a>
                    <a href="{{ path('product_per') }}" 
                       style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: #f8fafc; border-radius: 0.75rem; transition: var(--transition); border-left: 4px solid var(--adn-primary); display: flex; align-items: center; gap: 0.5rem;">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                        </svg>
                        Plan Épargne Retraite
                    </a>
                </div>
            </div>
        </aside>
    </div>

    <!-- Articles liés -->
    {% if relatedPosts is not empty %}
        <section class="related-articles">
            <div class="related-container">
                <h2 class="related-title">📖 Articles similaires</h2>
                <div class="related-grid">
                    {% for relatedPost in relatedPosts %}
                        <article class="related-card">
                            {% if relatedPost.imageName %}
                                <div class="related-image">
                                    <img src="{{ asset('uploads/images/' ~ relatedPost.imageName) }}" 
                                         alt="{{ relatedPost.imageAlt ?: relatedPost.title }}"
                                         loading="lazy">
                                </div>
                            {% endif %}
                            <div class="related-content">
                                <a href="{{ path('news_show', {slug: relatedPost.seoSlug}) }}">
                                    <h3>{{ relatedPost.title }}</h3>
                                </a>
                                <p class="related-excerpt">
                                    {{ relatedPost.seoDescription|slice(0, 120) }}...
                                </p>
                                <div class="related-meta">
                                    <span>{{ relatedPost.publicationDateStart|date('d/m/Y') }}</span>
