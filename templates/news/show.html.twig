        </svg>
    </button>
{% endblock %}

{% block page_scripts %}
    <script>
        // Animation d'entrée du contenu
        document.addEventListener('DOMContentLoaded', function() {
            // Animation des éléments de contenu
            const elements = document.querySelectorAll('.article-content h2, .article-content h3, .article-content p, .article-content blockquote');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry, index) => {
                    if (entry.isIntersecting) {
                        setTimeout(() => {
                            entry.target.style.opacity = '1';
                            entry.target.style.transform = 'translateY(0)';
                        }, index * 50);
                    }
                });
            }, { threshold: 0.1 });

            elements.forEach(element => {
                element.style.opacity = '0';
                element.style.transform = 'translateY(20px)';
                element.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
                observer.observe(element);
            });

            // Animation des cartes liées
            const relatedCards = document.querySelectorAll('.related-card');
            relatedCards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(30px)';
                card.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
                
                setTimeout(() => {
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 150);
            });

            // Smooth scroll pour les ancres
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });

            // Bouton de retour en haut pour mobile
            const mobileToggle = document.getElementById('mobile-nav-toggle');
            let isVisible = false;
            
            function toggleMobileNav() {
                const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                
                if (scrollTop > 300 && !isVisible) {
                    mobileToggle.style.transform = 'scale(1)';
                    mobileToggle.style.opacity = '1';
                    isVisible = true;
                } else if (scrollTop <= 300 && isVisible) {
                    mobileToggle.style.transform = 'scale(0)';
                    mobileToggle.style.opacity = '0';
                    isVisible = false;
                }
            }
            
            // Initialiser le bouton comme caché
            mobileToggle.style.transform = 'scale(0)';
            mobileToggle.style.opacity = '0';
            
            window.addEventListener('scroll', toggleMobileNav);
            
            mobileToggle.addEventListener('click', function() {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            });

            // Gestion des images avec qualité optimisée
            const articleImage = document.querySelector('.article-image');
            if (articleImage) {
                // Gestion d'erreur de chargement
                articleImage.onerror = function() {
                    const wrapper = this.closest('.article-image-wrapper');
                    if (wrapper) {
                        wrapper.innerHTML = `
                            <div class="image-placeholder">
                                <div class="text-center">
                                    <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    <p class="text-sm text-gray-500">Image non disponible</p>
                                </div>
                            </div>
                        `;
                    }
                };
                
                // Amélioration de la qualité d'affichage
                articleImage.onload = function() {
                    this.style.opacity = '1';
                };
                
                // S'assurer que l'image reste dans son conteneur (pas d'effet parallax)
                articleImage.style.transform = 'none';
                articleImage.style.position = 'absolute';
                articleImage.style.top = '0';
                articleImage.style.left = '0';
                
                // Protection contre les transformations externes
                const observer = new MutationObserver(function(mutations) {
                    mutations.forEach(function(mutation) {
                        if (mutation.type === 'attributes' && mutation.attributeName === 'style') {
                            const target = mutation.target;
                            if (target.classList.contains('article-image')) {
                                // Réinitialiser la position si elle a été modifiée
                                target.style.transform = 'none';
                                target.style.position = 'absolute';
                                target.style.top = '0';
                                target.style.left = '0';
                            }
                        }
                    });
                });
                
                observer.observe(articleImage, {
                    attributes: true,
                    attributeFilter: ['style']
                });
            }
            
            // Animation des éléments de la sidebar
            const sidebarElements = document.querySelectorAll('.sidebar-widget');
            const sidebarObserver = new IntersectionObserver((entries) => {
                entries.forEach((entry, index) => {
                    if (entry.isIntersecting) {
                        setTimeout(() => {
                            entry.target.style.opacity = '1';
                            entry.target.style.transform = 'translateX(0)';
                        }, index * 150);
                    }
                });
            }, { threshold: 0.1 });
            
            sidebarElements.forEach(element => {
                element.style.opacity = '0';
                element.style.transform = 'translateX(20px)';
                element.style.transition = 'all 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
                sidebarObserver.observe(element);
            });
        });
    </script>
{% endblock %}
