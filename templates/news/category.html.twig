{% extends 'news/index.html.twig' %}

{% block title %}{{ seo.title }}{% endblock %}
{% block meta_description %}{{ seo.description }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ seo.canonical }}">{% endblock %}

{% block body %}
    <!-- Hero Section spécifique à la catégorie -->
    <section class="news-hero">
        <div class="hero-content">
            <h1 class="hero-title">
                Actualités {{ category.name }}
            </h1>
            <p class="hero-subtitle">
                {% if category.description %}
                    {{ category.description }}
                {% else %}
                    Découvrez nos dernières analyses et conseils sur {{ category.name|lower }}
                {% endif %}
            </p>
        </div>
    </section>

    <!-- Breadcrumb moderne avec fond (déplacé après le hero) -->
    <div style="background: #f8fafc; padding: 1rem 0; border-bottom: 1px solid #e5e7eb; position: relative; z-index: 50;" class="news-breadcrumb">
        <div class="max-w-6xl mx-auto px-4">
            {% include 'partials/breadcrumb.html.twig' with {
                'items': [
                    {'label': 'Accueil', 'path': 'app_home', 'icon': 'home'},
                    {'label': 'Actualités', 'path': 'news_index', 'icon': 'news'},
                    {'label': category.name}
                ]
            } %}
        </div>
    </div>

    <!-- Menu des catégories -->
    <nav class="categories-menu">
        <div class="categories-nav">
            <a href="{{ path('news_index') }}" class="category-link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                </svg>
                Toutes les actualités
            </a>
            {% for cat in categories %}
                <a href="{{ path('news_category', {slug: cat.seoSlug}) }}" 
                   class="category-link {{ cat.id == category.id ? 'active' : '' }}">
                    {% if cat.seoSlug == 'investissement' %}
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                    {% elseif cat.seoSlug == 'fiscalite' %}
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                        </svg>
                    {% elseif cat.seoSlug == 'immobilier' %}
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                        </svg>
                    {% elseif cat.seoSlug == 'scpi' %}
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
                        </svg>
                    {% elseif cat.seoSlug == 'assurance-vie' %}
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.031 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                    {% else %}
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                    {% endif %}
                    {{ cat.name }}
                </a>
            {% endfor %}
        </div>
    </nav>

    <!-- Contenu principal -->
    <main class="news-main">
        <div class="news-container">
            <div class="content-area">
                <!-- Description de la catégorie si disponible -->
                {% if category.description %}
                    <section style="background: white; padding: 2rem; border-radius: var(--border-radius); margin-bottom: 3rem; box-shadow: var(--shadow-soft);">
                        <h2 style="font-family: var(--font-primary); color: var(--adn-primary); margin-bottom: 1rem;">À propos de {{ category.name }}</h2>
                        <p style="color: #64748b; line-height: 1.6;">{{ category.description }}</p>
                    </section>
                {% endif %}

                <!-- Articles de la catégorie -->
                <section>
                    <h2 class="section-title">📚 Articles {{ category.name }}</h2>
                    
                    {% if posts.items is not empty %}
                        <div class="featured-grid">
                            {% for post in posts.items %}
                                <article class="article-card">
                                    {% if post.imageName %}
                                        <div class="article-image">
                                            <img src="{{ asset('uploads/images/' ~ post.imageName) }}" 
                                                 alt="{{ post.imageAlt ?: post.title }}"
                                                 loading="lazy">
                                        </div>
                                    {% endif %}
                                    <div class="article-content">
                                        <a href="{{ path('news_show', {slug: post.seoSlug}) }}" class="article-title">
                                            {{ post.title }}
                                        </a>
                                        <p class="article-excerpt">
                                            {{ post.seoDescription|slice(0, 150) }}...
                                        </p>
                                        <div class="article-meta">
                                            <div class="article-date">
                                                📅 {{ post.publicationDateStart|date('d/m/Y') }}
                                            </div>
                                            <a href="{{ path('news_show', {slug: post.seoSlug}) }}" class="read-more">
                                                Lire la suite →
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            {% endfor %}
                        </div>

                        <!-- Pagination -->
                        <div class="pagination-container">
                            {{ knp_pagination_render(posts) }}
                        </div>
                    {% else %}
                        <div style="text-align: center; padding: 4rem 0;">
                            <h3 style="color: #64748b; margin-bottom: 1rem;">Aucun article trouvé dans cette catégorie</h3>
                            <p style="color: #94a3b8; margin-bottom: 2rem;">Revenez bientôt pour découvrir nos dernières actualités sur {{ category.name|lower }} !</p>
                            <a href="{{ path('news_index') }}" style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--gradient-primary); color: white; padding: 1rem 2rem; border-radius: var(--border-radius); text-decoration: none; font-weight: 600;">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                                </svg>
                                Voir toutes les actualités
                            </a>
                        </div>
                    {% endif %}
                </section>
            </div>

            <!-- Sidebar avec contenu spécifique à la catégorie -->
            <aside class="sidebar">
                <!-- Liens vers nos services liés à la catégorie -->
                <div class="sidebar-section">
                    <h3 class="sidebar-title">
                        <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                        Services liés
                    </h3>
                    <div style="display: flex; flex-direction: column; gap: 1rem;">
                        {% if category.seoSlug == 'scpi' or category.seoSlug == 'immobilier' %}
                            <a href="{{ path('product_scpi') }}" style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: #f8fafc; border-radius: 0.75rem; transition: var(--transition); border-left: 4px solid var(--adn-primary); display: flex; align-items: center; gap: 0.5rem;">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
                                </svg>
                                Investissement SCPI
                            </a>
                        {% endif %}
                        
                        {% if category.seoSlug == 'assurance-vie' or category.seoSlug == 'fiscalite' %}
                            <a href="{{ path('product_assurance_vie') }}" style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: #f8fafc; border-radius: 0.75rem; transition: var(--transition); border-left: 4px solid var(--adn-primary); display: flex; align-items: center; gap: 0.5rem;">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.031 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                </svg>
                                Assurance-vie
                            </a>
                        {% endif %}
                        
                        {% if category.seoSlug == 'investissement' %}
                            <a href="{{ path('product_pea_pme') }}" style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: #f8fafc; border-radius: 0.75rem; transition: var(--transition); border-left: 4px solid var(--adn-primary); display: flex; align-items: center; gap: 0.5rem;">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                                </svg>
                                PEA-PME
                            </a>
                            <a href="{{ path('product_per') }}" style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: #f8fafc; border-radius: 0.75rem; transition: var(--transition); border-left: 4px solid var(--adn-primary); display: flex; align-items: center; gap: 0.5rem;">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                                </svg>
                                Plan Épargne Retraite
                            </a>
                        {% endif %}

                        <!-- Lien générique vers tous nos services -->
                        <a href="{{ path('app_home') }}#services" style="text-decoration: none; color: var(--adn-primary); font-weight: 600; padding: 1rem; background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); border-radius: 0.75rem; transition: var(--transition); border: 2px solid var(--adn-primary); text-align: center; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                            </svg>
                            Découvrir tous nos services
                        </a>
                    </div>
                </div>

                <!-- Autres catégories -->
                <div class="sidebar-section">
                    <h3 class="sidebar-title">
                        <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 7a2 2 0 012-2h10a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                        Autres catégories
                    </h3>
                    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                        {% for cat in categories %}
                            {% if cat.id != category.id %}
                                <a href="{{ path('news_category', {slug: cat.seoSlug}) }}" 
                                   style="text-decoration: none; color: #64748b; font-weight: 500; padding: 0.75rem 1rem; background: #f8fafc; border-radius: 0.5rem; transition: var(--transition); display: flex; align-items: center; gap: 0.5rem;">
                                    {% if cat.seoSlug == 'investissement' %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                                        </svg>
                                    {% elseif cat.seoSlug == 'fiscalite' %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"/>
                                        </svg>
                                    {% elseif cat.seoSlug == 'immobilier' %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                        </svg>
                                    {% elseif cat.seoSlug == 'scpi' %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
                                        </svg>
                                    {% elseif cat.seoSlug == 'assurance-vie' %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.031 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                        </svg>
                                    {% else %}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                                        </svg>
                                    {% endif %}
                                    {{ cat.name }}
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <!-- Contact -->
                <div class="sidebar-section">
                    <h3 class="sidebar-title">
                        <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                        </svg>
                        Besoin de conseils ?
                    </h3>
                    <div style="background: linear-gradient(135deg, var(--adn-primary) 0%, var(--adn-secondary) 100%); color: white; padding: 2rem; border-radius: var(--border-radius); text-align: center;">
                        <h4 style="margin-bottom: 1rem; font-size: 1.1rem;">Nos experts vous accompagnent</h4>
                        <p style="margin-bottom: 1.5rem; opacity: 0.9; line-height: 1.5;">Obtenez des conseils personnalisés sur {{ category.name|lower }} et optimisez vos investissements.</p>
                        <a href="{{ path('app_home') }}#contact" 
                           style="background: white; color: var(--adn-primary); padding: 0.75rem 1.5rem; border-radius: 0.75rem; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem; transition: var(--transition);">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                            Nous contacter
                        </a>
                    </div>
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
