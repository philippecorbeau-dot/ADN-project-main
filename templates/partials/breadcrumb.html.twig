{# 
    Composant Breadcrumb Réutilisable
    
    Usage:
    {% include 'partials/breadcrumb.html.twig' with {
        'items': [
            {'label': 'Dashboard', 'path': 'user_dashboard', 'icon': 'dashboard'},
            {'label': 'Investissements', 'path': 'user_portfolio'},
            {'label': 'SCPI'} // Élément actuel sans lien
        ]
    } %}
#}

{% set iconMap = {
    'dashboard': 'M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z M8 5a2 2 0 012-2h4a2 2 0 012 2v6a2 2 0 01-2 2H10a2 2 0 01-2-2V5z',
    'home': 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    'investment': 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
    'news': 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z',
    'admin': 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    'users': 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z',
    'messages': 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z'
} %}

{# =============== JSON-LD BreadcrumbList (SEO : fil d'Ariane dans Google SERP) =============== #}
{# Activable en passant `seo: true` aux items, ou par d\u00e9faut. Skip si aucun item n'a de path. #}
{% set seo_items = items|filter(i => i.label is defined) %}
{% if seo_items|length > 1 %}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {% for item in seo_items %}
        {
            "@type": "ListItem",
            "position": {{ loop.index }},
            "name": "{{ item.label|striptags|e('js') }}"{% if item.path is defined %},
            "item": "{{ absolute_url(item.slug is defined ? path(item.path, {slug: item.slug}) : path(item.path)) }}"{% endif %}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ]
}
</script>
{% endif %}

<nav class="breadcrumb-nav bg-white rounded-xl shadow-md border border-gray-200 px-6 py-4 mb-6" aria-label="Fil d'Ariane" style="position: relative; z-index: 100; display: block;">
    <div class="breadcrumb-track flex items-center space-x-2 text-sm overflow-x-auto scrollbar-hide">
        {% for item in items %}
            {% if item.path is defined %}
                <a href="{% if item.slug is defined %}{{ path(item.path, {slug: item.slug}) }}{% else %}{{ path(item.path) }}{% endif %}" class="flex items-center text-gray-500 hover:text-blue-600 transition-colors duration-200 whitespace-nowrap">
                    {% if item.icon is defined and item.icon in iconMap %}
                        <svg class="w-4 h-4 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ iconMap[item.icon] }}"/>
                        </svg>
                    {% endif %}
                    {{ item.label }}
                </a>
            {% else %}
                <span class="text-gray-900 font-medium whitespace-nowrap" aria-current="page">{{ item.label }}</span>
            {% endif %}

            {% if not loop.last %}
                <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            {% endif %}
        {% endfor %}
    </div>
</nav>

<style>
    /* Styles pour les breadcrumbs responsive */
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
    
    /* Animation d'entrée des breadcrumbs */
    .breadcrumb-nav {
        animation: slideInFromTop 0.5s ease-out;
    }
    
    @keyframes slideInFromTop {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Styles spéciaux pour les pages d'actualités */
    .news-breadcrumb .breadcrumb-nav {
        background: rgba(255, 255, 255, 0.95) !important;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1) !important;
        border: 1px solid rgba(255, 255, 255, 0.2) !important;
    }
    
    /* Responsive pour mobile */
    @media (max-width: 640px) {
        .breadcrumb-nav {
            margin: 0 -1rem 1.5rem;
            border-radius: 0;
            border-left: none;
            border-right: none;
        }
        
        .breadcrumb-nav > .breadcrumb-track {
            padding: 0 1rem;
        }
        
        .news-breadcrumb .breadcrumb-nav {
            margin: 0 0 1.5rem !important;
            border-radius: 0 !important;
        }
    }
    
    /* (Supprimé) Bouton de retour mobile */
</style>

{# Bouton de retour mobile retiré #}

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Animation d'entrée du breadcrumb
    const nav = document.querySelector('nav');
    if (nav) {
        nav.style.opacity = '0';
        nav.style.transform = 'translateY(-10px)';
        setTimeout(() => {
            nav.style.transition = 'all 0.5s ease';
            nav.style.opacity = '1';
            nav.style.transform = 'translateY(0)';
        }, 100);
    }
});
</script>
