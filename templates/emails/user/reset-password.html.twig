{% extends 'emails/base_layout.html.twig' %}

{% set header_title = 'Réinitialisation de votre mot de passe' %}

{% block content %}
    <h1>Réinitialisation de votre mot de passe</h1>
    
    <p>Bonjour,</p>
    
    <p>Vous avez demandé la réinitialisation de votre mot de passe pour votre compte ADN Family Office.</p>
    
    <div class="button-container">
        <a href="{{ resetUrl }}" class="button">Réinitialiser mon mot de passe</a>
    </div>
    
    <div class="warning-box">
        <p><strong>⚠️ Important :</strong></p>
        <p>Ce lien expire dans 1 heure pour des raisons de sécurité.</p>
        <p>Si vous n'avez pas demandé cette réinitialisation, ignorez simplement cet email.</p>
    </div>
    
    <p style="font-size: 13px; color: #64748b; margin-top: 30px;">
        Si le bouton ne fonctionne pas, copiez et collez ce lien dans votre navigateur :<br>
        <a href="{{ resetUrl }}" style="word-break: break-all; color: #3B82F6;">{{ resetUrl }}</a>
    </p>
{% endblock %}

