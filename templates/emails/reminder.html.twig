{% extends 'emails/base_layout.html.twig' %}

{% set header_title = reminder_title|default('Rappel important') %}

{% block content %}
    <h1>{{ reminder_title|default('📅 Rappel important') }}</h1>
    
    <p>Bonjour {% if user is defined %}{{ user.firstname }}{% endif %},</p>
    
    {{ reminder_message|raw }}
    
    {% if deadline is defined %}
    <div class="warning-box">
        <p><strong>⏰ Date limite :</strong></p>
        <p>{{ deadline|date('d/m/Y à H:i') }}</p>
    </div>
    {% endif %}
    
    {% if action_items is defined %}
    <h2>Actions à réaliser</h2>
    <ul style="margin: 20px 0; padding-left: 20px; color: #475569;">
        {% for item in action_items %}
        <li style="margin-bottom: 10px;">{{ item }}</li>
        {% endfor %}
    </ul>
    {% endif %}
    
    {% if action_url is defined %}
    <div class="button-container">
        <a href="{{ action_url }}" class="button">{{ action_button_text|default('Accéder à mon espace') }}</a>
    </div>
    {% endif %}
    
    <p style="margin-top: 30px; font-size: 14px; color: #64748b;">
        Pour toute question, n'hésitez pas à contacter votre conseiller.
    </p>
{% endblock %}

