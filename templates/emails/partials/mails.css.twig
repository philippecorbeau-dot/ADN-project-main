.header-img {
    padding-right: 0!important;
}

.logo {
    padding-top: 38px;
}

.main-menu {
    margin-top: 25px;
    margin-bottom: 30px;
}

.main-menu a {
    color: #273272!important;
}

span {
    border: 1px solid #66E0A0;
    background: #66E0A0;
    width: 1px;
    height: 19px;
    margin-left: 20px;
}

h1, h2, h3, h4, h5, h6, a {
    color: #273272;
}

.body-border h3 {
    margin-top: 15px;
}

p {
    text-align: center;
    font-size: 16px;
    color: #273272;
    font-family: "Montserrat-Regular", "Helvetica Neue", Helvetica, Arial, sans-serif;
}

ul, ol {
    font-size: 16px;
    color: #273272;
    font-family: "Montserrat-Regular", "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.alert {
    padding: 10px;
    background: #fce6e2;
    border-radius: 5px;
    margin-bottom: 30px;
}

.event {
    background: #273272;
}

.event h4 {
    margin-top: 15px;
}


.event p {
    color: #fff;
    margin-top: 10px;
}

.button td, .button tr {
    border:none!important;
    background: none!important;
}

button a, .button a {
    border: none!important;
    background: #273272!important;
    border-radius: 5px;
    margin: 20px auto;
}
.center {
    text-align: center;
}

.email-button {
    text-align: center;
}

.email-intro {
    font-weight: bold;
    text-align: start;
}

.email-paragraph {
    text-align: start;
    font-size: 14px;
    line-height: 22px;
    color: #061556;
}

.container {
    margin-left: 5%;
    margin-right: 5%;
}

.email-header {
    height: 15%;
    text-align: center;
    background-color: #EFF2FF;
    margin-bottom: 10%;
}

.email-footer {
    height: 25%;
    background-color: #061556;
}

.email-footer p {
    font-size: 12px;
}

.email-footer a {
    margin-right: 2%;
    margin-left: 2%;
}

.email-title {
    font-size: large;
    color: #061556;
}

.email-icons {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 2% auto;
    text-align: center;
}

.email-button a {
    display: inline-block;
    border-radius: 3px;
    font-weight: bold;
    background-color: #273272;
    color: #fefefe;
    margin: 10px auto;
    padding: 8px 16px 8px 16px;
}

.email-button-new {
    text-align: center;
}

.email-button-new a.btn {
    display: inline-block;
    border-radius: 3px;
    font-weight: bold;
    background-color: #6DDBC4;
    color: #061556;
    margin: 10px auto;
    padding: 8px 16px 8px 16px;
}

.pre-footer, .footer {
    font-family: "Montserrat-Regular", "Helvetica Neue", Helvetica, Arial, sans-serif;
    color: #ffffff;
}

.pre-footer , .footer{
    background: #061556;
}

.pre-footer a, .footer a {
    font-size: 12px;
    color: #ffffff!important;
    font-family: "Montserrat-Regular", "Helvetica Neue", Helvetica, Arial, sans-serif!important;
}

.pre-footer p, .footer p {
    font-size: 11px;
    color: #ffffff!important;
    font-family: "Montserrat-Regular", "Helvetica Neue", Helvetica, Arial, sans-serif!important;
}

.copyright p {
    margin-top: 10px;
}

.table-no-border {
    border-collapse: collapse;
    width: 50%;
}

.table-no-border th {
    padding-top: 12px;
    padding-bottom: 12px;
    text-align: left;
    background-color: #f0f0f0;
    font-size: 13px;
    color: #061556;
    font-weight: bold;
    padding-left: 5%;
}

.table-no-border th {
    padding-top: 12px;
    padding-bottom: 12px;
    text-align: left;
    background-color: #E0E5E9;
    padding-left: 5%;
}

.table-no-border td {
    padding-top: 12px;
    padding-bottom: 12px;
    color: #061556;
    text-align: left;
    padding-left: 5%;
}

.recap {
    background-color: #EFF2FF;
    padding: 5% 10%;
    border: 1px solid #E0E5E9;
}

.line {
    margin-top: 5%;
    margin-bottom: 3%;
    width: 100%;
    background-color: #E0E5E9;
    padding-top: 0.5%;
}

