{% extends 'admin_modern/base.html.twig' %}

{% block title %}⚙️ Paramètres - Admin{% endblock %}

{% block page_title %}Paramètres{% endblock %}

{% block header_icon %}
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center gap-4 mb-2">
            <div class="w-14 h-14 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-200">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
            </div>
            <div>
                <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 dark:text-white">Paramètres</h1>
                <p class="text-gray-500 dark:text-gray-400">Personnalisez votre expérience d'administration</p>
            </div>
        </div>
    </div>

    <form method="POST" action="{{ path('admin_modern_settings') }}" class="space-y-6">
        <!-- Section Apparence -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-700 overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-gray-50 to-white dark:from-gray-800 dark:to-gray-750">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-gradient-to-br from-violet-500 to-purple-600 rounded-xl flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Apparence</h2>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Personnalisez l'aspect visuel du back-office</p>
                    </div>
                </div>
            </div>
            
            <div class="p-6 space-y-6">
                <!-- Dark Mode Toggle -->
                <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-gray-700/50 rounded-xl border border-gray-100 dark:border-gray-600">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl flex items-center justify-center transition-all duration-300" id="dark-mode-icon-container">
                            <!-- Icône soleil (mode clair) -->
                            <svg id="sun-icon" class="w-6 h-6 text-amber-500 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                            <!-- Icône lune (mode sombre) -->
                            <svg id="moon-icon" class="w-6 h-6 text-indigo-400 hidden transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-gray-900 dark:text-white">Mode Sombre</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400">Réduisez la fatigue oculaire avec un thème sombre</p>
                        </div>
                    </div>
                    
                    <!-- Toggle Switch -->
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" name="dark_mode" value="1" class="sr-only peer" id="dark-mode-toggle" {{ darkMode ? 'checked' : '' }}>
                        <div class="w-14 h-7 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-300 dark:peer-focus:ring-indigo-800 rounded-full peer dark:bg-gray-600 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:start-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all dark:border-gray-500 peer-checked:bg-gradient-to-r peer-checked:from-indigo-500 peer-checked:to-purple-600"></div>
                    </label>
                </div>

                <!-- Preview Dark Mode -->
                <div id="dark-mode-preview" class="p-4 rounded-xl border-2 border-dashed border-gray-200 dark:border-gray-600 transition-all duration-500">
                    <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Aperçu du thème :</p>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="p-3 rounded-lg bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-sm">
                            <div class="w-full h-2 bg-gray-200 dark:bg-gray-600 rounded mb-2"></div>
                            <div class="w-3/4 h-2 bg-gray-100 dark:bg-gray-700 rounded"></div>
                        </div>
                        <div class="p-3 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 border border-indigo-100 dark:border-indigo-800">
                            <div class="w-full h-2 bg-indigo-200 dark:bg-indigo-700 rounded mb-2"></div>
                            <div class="w-2/3 h-2 bg-indigo-100 dark:bg-indigo-800 rounded"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section Profil Admin -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-700 overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-100 dark:border-gray-700 bg-gradient-to-r from-gray-50 to-white dark:from-gray-800 dark:to-gray-750">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-xl flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Profil Administrateur</h2>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Informations de votre compte admin</p>
                    </div>
                </div>
            </div>
            
            <div class="p-6">
                <div class="flex items-center gap-4 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-xl">
                    <div class="w-16 h-16 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-full flex items-center justify-center ring-4 ring-indigo-100 dark:ring-indigo-900">
                        <span class="text-white text-xl font-bold">
                            {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper|default('') }}
                        </span>
                    </div>
                    <div class="flex-1">
                        <h3 class="font-semibold text-gray-900 dark:text-white text-lg">
                            {{ app.user.firstName }} {{ app.user.lastName }}
                        </h3>
                        <p class="text-gray-500 dark:text-gray-400">{{ app.user.email }}</p>
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 mt-2 rounded-full text-xs font-semibold
                            {% if app.user.isSuperAdmin() %}bg-purple-100 text-purple-700 dark:bg-purple-900/50 dark:text-purple-300{% else %}bg-indigo-100 text-indigo-700 dark:bg-indigo-900/50 dark:text-indigo-300{% endif %}">
                            {% if app.user.isSuperAdmin() %}👑 Super Admin{% else %}🔑 {{ app.user.rolesDisplay }}{% endif %}
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bouton de sauvegarde -->
        <div class="flex justify-end gap-3">
            <a href="{{ path('admin_modern_dashboard') }}" class="px-6 py-3 text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-xl font-medium transition-all">
                Annuler
            </a>
            <button type="submit" class="px-8 py-3 bg-gradient-to-r from-indigo-600 to-purple-600 text-white rounded-xl font-semibold hover:from-indigo-700 hover:to-purple-700 transition-all shadow-lg shadow-indigo-200 dark:shadow-indigo-900/50 hover:shadow-xl transform hover:scale-105 active:scale-95">
                <span class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Sauvegarder les paramètres
                </span>
            </button>
        </div>
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.getElementById('dark-mode-toggle');
    const sunIcon = document.getElementById('sun-icon');
    const moonIcon = document.getElementById('moon-icon');
    const iconContainer = document.getElementById('dark-mode-icon-container');
    const form = document.querySelector('form');
    
    function updateIcons(isDark) {
        if (isDark) {
            sunIcon.classList.add('hidden');
            moonIcon.classList.remove('hidden');
            iconContainer.classList.add('bg-indigo-900/50');
            iconContainer.classList.remove('bg-amber-100');
        } else {
            sunIcon.classList.remove('hidden');
            moonIcon.classList.add('hidden');
            iconContainer.classList.remove('bg-indigo-900/50');
            iconContainer.classList.add('bg-amber-100');
        }
    }
    
    // État initial
    updateIcons(toggle.checked);
    
    // Changement avec sauvegarde automatique
    toggle.addEventListener('change', function() {
        updateIcons(this.checked);
        
        // Appliquer immédiatement
        if (this.checked) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
        
        // Sauvegarder automatiquement
        form.submit();
    });
});
</script>
{% endblock %}

