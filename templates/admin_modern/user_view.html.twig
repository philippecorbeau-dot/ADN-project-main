{% extends 'admin_modern/base.html.twig' %}

{% block title %}Profil utilisateur - {{ user.firstName }} {{ user.lastName }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">
    <!-- Header avec navigation -->
    <div class="mb-8">
        <nav class="flex" aria-label="Breadcrumb">
            <ol role="list" class="flex items-center space-x-4">
                <li>
                    <div>
                        <a href="{{ path('admin_modern_users') }}" class="text-gray-400 hover:text-gray-500">
                            <svg class="flex-shrink-0 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span class="sr-only">Utilisateurs</span>
                        </a>
                    </div>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        <a href="{{ path('admin_modern_users') }}" class="ml-4 text-sm font-medium text-gray-500 hover:text-gray-700">Utilisateurs</a>
                    </div>
                </li>
                <li>
                    <div class="flex items-center">
                        <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="ml-4 text-sm font-medium text-gray-900">{{ user.firstName }} {{ user.lastName }}</span>
                    </div>
                </li>
            </ol>
        </nav>
        
        <div class="mt-4 md:flex md:items-center md:justify-between">
            <div class="flex-1 min-w-0">
                <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                    👤 Profil utilisateur
                </h2>
                <p class="mt-1 text-sm text-gray-500">Détails complets du compte utilisateur</p>
            </div>
            <div class="mt-4 flex-shrink-0 flex md:mt-0 md:ml-4">
                <a href="{{ path('admin_modern_user_edit', {id: user.id}) }}" class="ml-3 inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    ✏️ Modifier
                </a>
                <form method="post" action="{{ path('admin_modern_user_impersonate', {id: user.id}) }}" class="ml-3">
                    <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500">
                        🎛️ Prendre le contrôle
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Colonne principale -->
        <div class="lg:col-span-2 space-y-8">
            <!-- Informations personnelles -->
            <div class="bg-white shadow rounded-xl border border-gray-100">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h3 class="text-lg font-medium text-gray-900">👤 Informations personnelles</h3>
                </div>
                <div class="px-6 py-4">
                    <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Prénom</dt>
                            <dd class="mt-1 text-sm text-gray-900">{{ user.firstName ?? 'Non renseigné' }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Nom</dt>
                            <dd class="mt-1 text-sm text-gray-900">{{ user.lastName ?? 'Non renseigné' }}</dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Email</dt>
                            <dd class="mt-1 text-sm text-gray-900">
                                <a href="mailto:{{ user.email }}" class="text-blue-600 hover:text-blue-500">{{ user.email }}</a>
                            </dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Téléphone</dt>
                            <dd class="mt-1 text-sm text-gray-900">
                                {% if user.phone %}
                                    {{ user.phone }}
                                {% else %}
                                    Non renseigné
                                {% endif %}
                            </dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Date de naissance</dt>
                            <dd class="mt-1 text-sm text-gray-900">
                                {% if user.birthday %}
                                    {{ user.birthday|date('d/m/Y') }}
                                {% else %}
                                    Non renseigné
                                {% endif %}
                            </dd>
                        </div>
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Adresse</dt>
                            <dd class="mt-1 text-sm text-gray-900">
                                {% if user.address %}
                                    {{ user.address }}
                                    {% if user.city %}<br>{{ user.postalCode }} {{ user.city }}{% endif %}
                                {% else %}
                                    Non renseigné
                                {% endif %}
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>

            <!-- Documents KYC -->
            <div class="bg-white shadow rounded-xl border border-gray-100">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h3 class="text-lg font-medium text-gray-900">📋 Documents KYC</h3>
                </div>
                <div class="px-6 py-4">
                    {% if kycDocuments|length > 0 %}
                        <div class="space-y-4">
                            {% for document in kycDocuments %}
                                <div class="border border-gray-200 rounded-lg p-4">
                                    <div class="flex items-center justify-between">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0">
                                                {% if document.status == 'VALIDATED' %}
                                                    <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                                                        <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                                        </svg>
                                                    </div>
                                                {% elseif document.status == 'REFUSED' %}
                                                    <div class="w-8 h-8 bg-red-100 rounded-full flex items-center justify-center">
                                                        <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                                                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                                        </svg>
                                                    </div>
                                                {% else %}
                                                    <div class="w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center">
                                                        <svg class="w-5 h-5 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
                                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                                                        </svg>
                                                    </div>
                                                {% endif %}
                                            </div>
                                            <div class="ml-3">
                                                <p class="text-sm font-medium text-gray-900">{{ document.type ?? 'Document' }}</p>
                                                <p class="text-sm text-gray-500">
                                                    Soumis le {{ document.createdAt|date('d/m/Y à H:i') }}
                                                </p>
                                            </div>
                                        </div>
                                        <div class="flex items-center space-x-2">
                                            {% if document.status == 'VALIDATED' %}
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                    Validé
                                                </span>
                                            {% elseif document.status == 'REFUSED' %}
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                    Refusé
                                                </span>
                                            {% else %}
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                                    En attente
                                                </span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if document.refusedReasonMessage %}
                                        <div class="mt-2 text-sm text-gray-700 bg-gray-50 p-2 rounded">
                                            <strong>Motif :</strong> {{ document.refusedReasonMessageName ?? document.refusedReasonMessage }}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-8">
                            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            <h3 class="mt-2 text-sm font-medium text-gray-900">Aucun document KYC</h3>
                            <p class="mt-1 text-sm text-gray-500">L'utilisateur n'a pas encore soumis de documents</p>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Récap KYC Step 2 & 3 #}
            <div class="bg-white shadow rounded-xl border border-gray-100">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h3 class="text-lg font-medium text-gray-900">🎯 Objectifs (Step 2) & 🧾 Patrimoine (Step 3)</h3>
                </div>
                <div class="px-6 py-4">
                    {% set info = user.info %}
                    {% if info or user.isPro %}
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <h4 class="text-sm font-semibold text-gray-900 mb-2">🎯 Objectifs & horizon</h4>
                                <div class="text-sm text-gray-700 space-y-2">
                                    <div>
                                        <span class="text-gray-500">Objectifs:</span>
                                        <div class="mt-1 flex flex-wrap gap-2">
                                            {% set objList = info.getObjectiveList() %}
                                            {% for k in (info.objective ?? []) %}
                                                <span class="px-2 py-1 bg-blue-50 text-blue-700 rounded border border-blue-100">{{ objList[k] ?? k }}</span>
                                            {% else %}
                                                <span class="text-gray-400">Non renseigné</span>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div>
                                        <span class="text-gray-500">Horizon:</span>
                                        <div class="mt-1 flex flex-wrap gap-2">
                                            {% set termsMap = {'0':'Moins de 2 ans','1':'Entre 2 et 6 ans','2':'Plus de 6 ans','3':'Je ne sais pas encore'} %}
                                            {% for t in (info.investmentTerm ?? []) %}
                                                <span class="px-2 py-1 bg-emerald-50 text-emerald-700 rounded border border-emerald-100">{{ termsMap[(t ~ '')] ?? t }}</span>
                                            {% else %}
                                                <span class="text-gray-400">Non renseigné</span>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    <div>
                                        <span class="text-gray-500">Épargne disponible:</span>
                                        <span class="ml-1 font-medium">{{ info.liquidity is not null ? (info.liquidity|number_format(0, ',', ' ') ~ ' €') : 'Non renseigné' }}</span>
                                    </div>
                                    <div>
                                        <span class="text-gray-500">Provenance des fonds:</span>
                                        <span class="ml-1">{{ info.getSourceOfFundsTxt() ?? 'Non renseigné' }}</span>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <h4 class="text-sm font-semibold text-gray-900 mb-2">🧾 Patrimoine & revenus</h4>
                                {% if user.isPro and user.pro %}
                                  {# Parcours PRO: afficher les valeurs Pro #}
                                  <div class="grid grid-cols-2 gap-3 text-sm">
                                    <div class="text-gray-500">CA {{ ("now"|date('Y')) - 1 }}</div>
                                    <div class="text-right font-medium">{{ user.pro.turnover is not null ? (user.pro.turnover|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Résultat {{ ("now"|date('Y')) - 1 }}</div>
                                    <div class="text-right font-medium">{{ user.pro.oldResult is not null ? (user.pro.oldResult|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Prévision CA {{ ("now"|date('Y')) }}</div>
                                    <div class="text-right font-medium">{{ user.pro.forecastTurnover is not null ? (user.pro.forecastTurnover|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Capital social</div>
                                    <div class="text-right font-medium">{{ user.pro.capital is not null ? (user.pro.capital|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Réserves</div>
                                    <div class="text-right font-medium">{{ user.pro.stocks is not null ? (user.pro.stocks|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                  </div>
                                {% else %}
                                  {# Parcours particulier: afficher Info #}
                                  <div class="grid grid-cols-2 gap-3 text-sm">
                                    <div class="text-gray-500">Immobilier</div>
                                    <div class="text-right font-medium">{{ info.realestate is not null ? (info.realestate|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Compte titres / épargne</div>
                                    <div class="text-right font-medium">{{ info.accountSecurities is not null ? (info.accountSecurities|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Capitalisation (AV)</div>
                                    <div class="text-right font-medium">{{ info.capitalisation is not null ? (info.capitalisation|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">SCPI</div>
                                    <div class="text-right font-medium">{{ info.scpi is not null ? (info.scpi|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Salaire mensuel net</div>
                                    <div class="text-right font-medium">{{ info.salary is not null ? (info.salary|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Revenus locatifs annuels</div>
                                    <div class="text-right font-medium">{{ info.realestateIncome is not null ? (info.realestateIncome|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Charges/prêts immobiliers annuels</div>
                                    <div class="text-right font-medium">{{ info.rent is not null ? (info.rent|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    <div class="text-gray-500">Revenus annuels estimés</div>
                                    <div class="text-right font-medium">{{ info.income is not null ? (info.income|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                  </div>
                                {% endif %}
                            </div>
                        </div>
                    {% else %}
                        <div class="text-sm text-gray-500">Pas de données KYC Step 2/3 pour cet utilisateur.</div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
            <!-- Status Overview -->
            <div class="bg-white shadow rounded-xl border border-gray-100">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h3 class="text-lg font-medium text-gray-900">📊 Statut du compte</h3>
                </div>
                <div class="px-6 py-4 space-y-4">
                    <!-- Statut du compte (actif/suspendu) -->
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-500">Statut du compte</span>
                        {% if user.isSuspended() %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                🚫 Suspendu
                            </span>
                        {% else %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                ✓ Actif
                            </span>
                        {% endif %}
                    </div>

                    <!-- Email Verification -->
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-500">Email vérifié</span>
                        {% if user.isVerified %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                ✓ Oui
                            </span>
                        {% else %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                ✗ Non
                            </span>
                        {% endif %}
                    </div>

                    <!-- KYC Step -->
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-500">Étape KYC</span>
                        <span class="text-sm font-medium text-gray-900">
                            {{ kycSteps[user.stepKyc] ?? (user.stepKyc ?? 'Non commencé') }}
                        </span>
                    </div>

                    <!-- Investor Profile -->
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-500">Profil investisseur</span>
                        {% if user.investorProfile %}
                            {% set profileColors = {
                                'PRUDENT': 'bg-gray-100 text-gray-800',
                                'EQUILIBRE': 'bg-yellow-100 text-yellow-800',
                                'DYNAMIQUE': 'bg-orange-100 text-orange-800',
                                'SPE': 'bg-red-100 text-red-800'
                            } %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ profileColors[user.investorProfile] ?? 'bg-gray-100 text-gray-800' }}">
                                {{ user.investorProfile }}
                            </span>
                        {% else %}
                            <span class="text-sm text-gray-500">Non défini</span>
                        {% endif %}
                    </div>

                    <!-- Registration Date -->
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-500">Inscription</span>
                        <span class="text-sm text-gray-900">{{ user.createdAt|date('d/m/Y') }}</span>
                    </div>

                    <!-- Last Login -->
                    {% if user.updatedAt %}
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-gray-500">Dernière mise à jour</span>
                            <span class="text-sm text-gray-900">{{ user.updatedAt|date('d/m/Y H:i') }}</span>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Statut de suspension -->
            {% if user.isSuspended() %}
            <div class="bg-red-50 shadow rounded-xl border border-red-200">
                <div class="px-6 py-4 border-b border-red-200 bg-red-100">
                    <h3 class="text-lg font-medium text-red-900">🚫 Compte suspendu</h3>
                </div>
                <div class="px-6 py-4 space-y-3">
                    <div class="text-sm text-red-700">
                        <p><strong>Date de suspension :</strong> {{ user.suspendedAt|date('d/m/Y à H:i') }}</p>
                        {% if user.suspendedReason %}
                            <p class="mt-2"><strong>Raison :</strong> {{ user.suspendedReason }}</p>
                        {% endif %}
                    </div>
                    <form method="post" action="{{ path('admin_modern_user_unsuspend', {id: user.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('unsuspend_user_' ~ user.id) }}">
                        <button type="submit" class="block w-full text-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                            ✅ Réactiver le compte
                        </button>
                    </form>
                </div>
            </div>
            {% endif %}

            <!-- Quick Actions -->
            <div class="bg-white shadow rounded-xl border border-gray-100">
                <div class="px-6 py-4 border-b border-gray-200">
                    <h3 class="text-lg font-medium text-gray-900">⚡ Actions rapides</h3>
                </div>
                <div class="px-6 py-4 space-y-3">
                    <a href="{{ path('admin_modern_user_edit', {id: user.id}) }}" class="block w-full text-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                        ✏️ Modifier le profil
                    </a>
                    
                    {% if not user.isVerified %}
                        <form method="post" action="{{ path('admin_modern_user_verify_email', {id: user.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('verify_email_' ~ user.id) }}">
                            <button type="submit" class="block w-full text-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                                ✅ Vérifier l'email
                            </button>
                        </form>
                    {% endif %}
                    
                    {% if not user.isSuspended() %}
                        <!-- Bouton pour suspendre -->
                        <button type="button" 
                                onclick="document.getElementById('suspend-modal').classList.remove('hidden')"
                                class="block w-full text-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500">
                            🚫 Suspendre le compte
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de suspension -->
<div id="suspend-modal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-full max-w-md shadow-lg rounded-xl bg-white">
        <div class="mt-3">
            <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-orange-100">
                <svg class="h-6 w-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
            </div>
            <h3 class="text-lg font-bold text-gray-900 text-center mt-4">Suspendre le compte</h3>
            <p class="text-sm text-gray-500 text-center mt-2">
                L'utilisateur ne pourra plus se connecter jusqu'à la réactivation du compte.
            </p>
            <form method="post" action="{{ path('admin_modern_user_suspend', {id: user.id}) }}" class="mt-4">
                <input type="hidden" name="_token" value="{{ csrf_token('suspend_user_' ~ user.id) }}">
                <div class="mb-4">
                    <label for="reason" class="block text-sm font-medium text-gray-700 mb-1">Raison de la suspension (optionnel)</label>
                    <textarea name="reason" id="reason" rows="3" 
                              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm"
                              placeholder="Ex: Violation des conditions d'utilisation..."></textarea>
                </div>
                <div class="flex gap-3">
                    <button type="button" 
                            onclick="document.getElementById('suspend-modal').classList.add('hidden')"
                            class="flex-1 px-4 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                        Annuler
                    </button>
                    <button type="submit" 
                            class="flex-1 px-4 py-2 bg-orange-600 text-white text-sm font-medium rounded-md hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500">
                        Suspendre
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Fermer la modal en cliquant en dehors
document.getElementById('suspend-modal').addEventListener('click', function(e) {
    if (e.target === this) {
        this.classList.add('hidden');
    }
});
</script>
{% endblock %}

