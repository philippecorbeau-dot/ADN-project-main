<!-- Notifications Component -->
<div x-data="notifications()" x-init="init()" 
     class="fixed z-50 space-y-3 top-4 right-4" 
     style="max-width: 420px;">
    
    <template x-for="notification in notifications" :key="notification.id">
        <div x-show="notification.show"
             x-transition:enter="transform ease-out duration-300 transition"
             x-transition:enter-start="translate-y-2 opacity-0 sm:translate-y-0 sm:translate-x-2"
             x-transition:enter-end="translate-y-0 opacity-100 sm:translate-x-0"
             x-transition:leave="transition ease-in duration-100"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             class="max-w-sm w-full shadow-xl rounded-xl pointer-events-auto overflow-hidden ring-1"
             :class="{
                'bg-gradient-to-r from-emerald-600 to-emerald-700 text-white ring-emerald-800/30': notification.type === 'success',
                'bg-gradient-to-r from-red-600 to-red-700 text-white ring-red-800/30': notification.type === 'error',
                'bg-gradient-to-r from-amber-500 to-amber-600 text-white ring-amber-800/30': notification.type === 'warning',
                'bg-gradient-to-r from-sky-600 to-sky-700 text-white ring-sky-800/30': notification.type === 'info'
             }">
            
            <div class="p-4">
                <div class="flex items-start">
                    <div class="flex-shrink-0">
                        <!-- Success Icon -->
                        <svg x-show="notification.type === 'success'" class="h-6 w-6 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        
                        <!-- Error Icon -->
                        <svg x-show="notification.type === 'error'" class="h-6 w-6 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        
                        <!-- Warning Icon -->
                        <svg x-show="notification.type === 'warning'" class="h-6 w-6 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 15c-.77.833.192 2.5 1.732 2.5z"></path>
                        </svg>
                        
                        <!-- Info Icon -->
                        <svg x-show="notification.type === 'info'" class="h-6 w-6 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    
                    <div class="ml-3 w-0 flex-1 pt-0.5">
                        <p class="text-sm font-semibold text-white" x-text="notification.title"></p>
                        <p class="mt-1 text-sm text-white/90" x-text="notification.message"></p>
                    </div>
                    
                    <div class="ml-4 flex-shrink-0 flex">
                        <button @click="removeNotification(notification.id)" 
                                class="rounded-md inline-flex focus:outline-none focus:ring-2 focus:ring-offset-0 text-white/70 hover:text-white focus:ring-white/40">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </template>
</div>

<script>
function notifications() {
    return {
        notifications: [],
        notificationId: 0,
        seenKeys: new Set(),
        
        init() {
            // Listen for flash messages from Symfony
            this.checkFlashMessages();
            
            // Set up global notification system
            window.showNotification = (title, message, type = 'info', duration = 5000) => {
                this.addNotification(title, message, type, duration);
            };
        },
        
        checkFlashMessages() {
            // Check for Symfony flash messages
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    this.addNotification(
                        '{{ type|title }}', 
                        '{{ message|e('js') }}', 
                        '{{ type == 'error' ? 'error' : (type == 'success' ? 'success' : (type == 'warning' ? 'warning' : 'info')) }}'
                    );
                {% endfor %}
            {% endfor %}
        },
        
        addNotification(title, message, type = 'info', duration = 5000) {
            const key = `${type}:${title}:${message}`;
            if (this.seenKeys.has(key)) {
                return; // éviter les doublons
            }
            this.seenKeys.add(key);

            const id = ++this.notificationId;
            const notification = {
                id,
                title,
                message,
                type,
                show: true
            };
            
            this.notifications.push(notification);
            
            // Auto-remove after duration
            setTimeout(() => {
                this.removeNotification(id);
            }, duration);
        },
        
        removeNotification(id) {
            const index = this.notifications.findIndex(n => n.id === id);
            if (index > -1) {
                this.notifications[index].show = false;
                setTimeout(() => {
                    this.notifications.splice(index, 1);
                }, 300);
            }
        }
    }
}
</script>

