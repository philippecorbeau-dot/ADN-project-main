{% extends 'admin_modern/base.html.twig' %}

{% block title %}Dashboard - Back-office ADN{% endblock %}
{% block page_title %}📊 Dashboard{% endblock %}

{% block content %}

{# ─── Bandeau synchronisation O2S ─── #}
<div id="sync-banner" class="mb-6 flex items-center justify-between bg-white rounded-xl shadow-sm px-5 py-3 border border-gray-100">
    <div class="flex items-center gap-3 text-sm text-gray-600">
        <div id="sync-icon" class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
        </div>
        <span id="sync-text">
            {% if lastO2sSync %}
            Dernière synchronisation O2S / Harvest : <strong class="text-gray-900" id="sync-date">{{ lastO2sSync|date('d/m/Y à H:i') }}</strong>
            {% else %}
            Aucune synchronisation O2S effectuée
            {% endif %}
        </span>
    </div>
    <div class="flex items-center gap-3">
        <span id="sync-status" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            Connecté
        </span>
        <button id="sync-btn" onclick="triggerO2sSync()" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium bg-blue-600 text-white hover:bg-blue-700 transition-colors">
            <svg id="sync-btn-icon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            <span id="sync-btn-text">Synchroniser</span>
        </button>
        {% if placeholderEmailsCount is defined and placeholderEmailsCount > 0 %}
        <button id="fix-emails-btn" onclick="triggerFixEmails()" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium bg-amber-600 text-white hover:bg-amber-700 transition-colors">
            <svg id="fix-emails-icon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span id="fix-emails-text">Corriger emails (<span id="placeholder-count">{{ placeholderEmailsCount }}</span>)</span>
        </button>
        {% endif %}
    </div>
</div>

{# ─── Ligne 1 : Contacts (comme Harvest) ─── #}
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
    {# Total Contacts O2S #}
    <a href="{{ path('admin_modern_users') }}" class="bg-white rounded-xl shadow-sm hover-lift p-6 border border-gray-100 block transition-transform duration-200 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500">
        <div class="flex items-center">
            <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-blue-500 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/>
                    </svg>
                </div>
            </div>
            <div class="ml-5 w-0 flex-1">
                <dl>
                    <dt class="text-sm font-medium text-gray-500 truncate">Contacts O2S</dt>
                    <dd id="stat-contacts" class="text-3xl font-bold text-gray-900">{{ totalContacts }}</dd>
                </dl>
            </div>
        </div>
    </a>

    {# Nombre de clients et prospects retiré — écart non résolu avec le back-office Harvest #}

    {# Inscriptions 7j #}
    <div class="bg-white rounded-xl shadow-sm hover-lift p-6 border border-gray-100">
        <div class="flex items-center">
            <div class="flex-shrink-0">
                <div class="w-12 h-12 bg-violet-500 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                    </svg>
                </div>
            </div>
            <div class="ml-5 w-0 flex-1">
                <dl>
                    <dt class="text-sm font-medium text-gray-500 truncate">Inscriptions 7j</dt>
                    <dd class="text-3xl font-bold text-gray-900">{{ userCount7 }}</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

{# ─── Ligne 2 : Détail contacts + KYC ─── #}
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-sm p-4 border border-gray-100">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-blue-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-500">Personnes physiques</p>
                <p id="stat-pp" class="text-lg font-bold text-gray-900">{{ personnesPhysiquesCount }}</p>
            </div>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-4 border border-gray-100">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-indigo-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-500">Personnes morales</p>
                <p id="stat-pm" class="text-lg font-bold text-gray-900">{{ personnesMoralesCount }}</p>
            </div>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-4 border border-gray-100">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-orange-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-500">KYC en attente</p>
                <p class="text-lg font-bold text-gray-900">{{ kycPending }}</p>
            </div>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-4 border border-gray-100">
        <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-emerald-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div>
                <p class="text-xs text-gray-500">KYC validés</p>
                <p class="text-lg font-bold text-gray-900">{{ kycValidated }}</p>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
    <!-- Users Registration Chart -->
    <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-semibold text-gray-900">Inscriptions sur 30 jours</h3>
            <div class="flex items-center space-x-1">
                <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
                <span class="text-sm text-gray-600">Nouvelles inscriptions</span>
            </div>
        </div>
        <div class="relative h-80">
            <canvas id="usersChart"></canvas>
        </div>
    </div>

    <!-- KYC Status Chart -->
    <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-900">Statut des documents KYC</h3>
            <div class="flex items-center space-x-4 text-sm">
                <div class="flex items-center space-x-1">
                    <div class="w-3 h-3 bg-green-500 rounded-full"></div>
                    <span class="text-gray-600">Validés</span>
                </div>
                <div class="flex items-center space-x-1">
                    <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
                    <span class="text-gray-600">En attente</span>
                </div>
                <div class="flex items-center space-x-1">
                    <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                    <span class="text-gray-600">Refusés</span>
                </div>
            </div>
        </div>
        
        <!-- KYC Explanation -->
        <div class="mb-4 p-3 bg-blue-50 rounded-lg border-l-4 border-blue-400">
            <p class="text-sm text-blue-700">
                <strong>📋 Documents KYC (Know Your Customer)</strong> : Documents d'identité, justificatifs de domicile, KBIS, statuts et déclarations UBO soumis par les utilisateurs pour validation.
            </p>
        </div>
        
        <div class="relative h-80 flex items-center justify-center">
            <canvas id="kycChart"></canvas>
        </div>
        
        <!-- KYC Stats Summary -->
        <div class="mt-4 grid grid-cols-3 gap-4 text-center">
            <div class="p-3 bg-green-50 rounded-lg">
                <p class="text-2xl font-bold text-green-600">{{ kycValidated }}</p>
                <p class="text-xs text-green-700">Validés</p>
            </div>
            <div class="p-3 bg-yellow-50 rounded-lg">
                <p class="text-2xl font-bold text-yellow-600">{{ kycPending }}</p>
                <p class="text-xs text-yellow-700">En attente</p>
            </div>
            <div class="p-3 bg-red-50 rounded-lg">
                <p class="text-2xl font-bold text-red-600">{{ kycRefused }}</p>
                <p class="text-xs text-red-700">Refusés</p>
            </div>
        </div>
    </div>
</div>

<!-- Investment Opportunities Stats -->
<div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 mb-8">
    <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-semibold text-gray-900">📈 Opportunités d'Investissement - Clics</h3>
        <div class="text-sm text-gray-500">
            Total : {{ investmentClicks.total }} clics
        </div>
    </div>
    
    <!-- Investment Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-gradient-to-r from-green-50 to-green-100 p-4 rounded-lg border border-green-200">
            <div class="flex items-center">
                <div class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center mr-3">
                    <span class="text-white text-lg">🏢</span>
                </div>
                <div>
                    <p class="text-sm text-green-600 font-medium">SCPI</p>
                    <p class="text-lg font-bold text-green-800">
                        {% set scpiClicks = 0 %}
                        {% for product in investmentClicks.by_product %}
                            {% if product['productType'] == 'SCPI' %}
                                {% set scpiClicks = product['clicks'] %}
                            {% endif %}
                        {% endfor %}
                        {{ scpiClicks }}
                    </p>
                </div>
            </div>
        </div>
        
        <div class="bg-gradient-to-r from-blue-50 to-blue-100 p-4 rounded-lg border border-blue-200">
            <div class="flex items-center">
                <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center mr-3">
                    <span class="text-white text-lg">📈</span>
                </div>
                <div>
                    <p class="text-sm text-blue-600 font-medium">PEA-PME</p>
                    <p class="text-lg font-bold text-blue-800">
                        {% set peaClicks = 0 %}
                        {% for product in investmentClicks.by_product %}
                            {% if product['productType'] == 'PEA-PME' %}
                                {% set peaClicks = product['clicks'] %}
                            {% endif %}
                        {% endfor %}
                        {{ peaClicks }}
                    </p>
                </div>
            </div>
        </div>
        
        <div class="bg-gradient-to-r from-purple-50 to-purple-100 p-4 rounded-lg border border-purple-200">
            <div class="flex items-center">
                <div class="w-10 h-10 bg-purple-500 rounded-lg flex items-center justify-center mr-3">
                    <span class="text-white text-lg">🛡️</span>
                </div>
                <div>
                    <p class="text-sm text-purple-600 font-medium">Assurance-vie</p>
                    <p class="text-lg font-bold text-purple-800">
                        {% set assuranceClicks = 0 %}
                        {% for product in investmentClicks.by_product %}
                            {% if product['productType'] == 'Assurance-vie' %}
                                {% set assuranceClicks = product['clicks'] %}
                            {% endif %}
                        {% endfor %}
                        {{ assuranceClicks }}
                    </p>
                </div>
            </div>
        </div>
        
        <div class="bg-gradient-to-r from-orange-50 to-orange-100 p-4 rounded-lg border border-orange-200">
            <div class="flex items-center">
                <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center mr-3">
                    <span class="text-white text-lg">⏰</span>
                </div>
                <div>
                    <p class="text-sm text-orange-600 font-medium">PER</p>
                    <p class="text-lg font-bold text-orange-800">
                        {% set perClicks = 0 %}
                        {% for product in investmentClicks.by_product %}
                            {% if product['productType'] == 'PER' %}
                                {% set perClicks = product['clicks'] %}
                            {% endif %}
                        {% endfor %}
                        {{ perClicks }}
                    </p>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Action Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="text-center">
            <p class="text-2xl font-bold text-gray-900">
                {% set discoverClicks = 0 %}
                {% for action in investmentClicks.by_action %}
                    {% if action['action'] == 'discover' %}
                        {% set discoverClicks = action['clicks'] %}
                    {% endif %}
                {% endfor %}
                {{ discoverClicks }}
            </p>
            <p class="text-sm text-gray-600">Boutons "Découvrir"</p>
        </div>
        <div class="text-center">
            <p class="text-2xl font-bold text-gray-900">
                {% set documentsClicks = 0 %}
                {% for action in investmentClicks.by_action %}
                    {% if action['action'] == 'documents' %}
                        {% set documentsClicks = action['clicks'] %}
                    {% endif %}
                {% endfor %}
                {{ documentsClicks }}
            </p>
            <p class="text-sm text-gray-600">Boutons "Documents"</p>
        </div>
        <div class="text-center">
            <p class="text-2xl font-bold text-indigo-600">{{ investmentClicks.last_7_days }}</p>
            <p class="text-sm text-gray-600">Clics (7 derniers jours)</p>
        </div>
    </div>
</div>

<!-- Recent Activity & Profile Distribution -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Recent Users -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900">Derniers inscrits</h3>
        </div>
        <div class="p-6">
            {% if lastUsers is not empty %}
                <div class="space-y-4">
                    {% for user in lastUsers %}
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 bg-indigo-600 rounded-full flex items-center justify-center">
                                <span class="text-white font-medium">{{ user.email|slice(0, 1)|upper }}</span>
                            </div>
                            <div>
                                <p class="text-sm font-medium text-gray-900">{{ user.email }}</p>
                                <p class="text-xs text-gray-500">{{ user.firstName ? (user.firstName ~ ' ' ~ user.lastName) : 'Profil incomplet' }}</p>
                            </div>
                        </div>
                        <div class="text-right">
                            <p class="text-sm text-gray-900">{{ user.createdAt|date('d/m/Y') }}</p>
                            <p class="text-xs text-gray-500">{{ user.createdAt|date('H:i') }}</p>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-8">
                    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                    </svg>
                    <p class="mt-2 text-sm text-gray-500">Aucun utilisateur récent</p>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Investor Profiles Distribution -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900">Distribution des profils investisseurs</h3>
        </div>
        <div class="p-6">
            {% if profilesData is not empty %}
                <div class="space-y-4">
                    {% for profile in profilesData %}
                        {% set profileInfo = {
                            'PRUDENT': {'label': 'Prudent', 'color': 'bg-blue-500', 'desc': 'Placements sécurisés'},
                            'EQUILIBRE': {'label': 'Équilibré', 'color': 'bg-green-500', 'desc': 'Risque modéré'},
                            'DYNAMIQUE': {'label': 'Dynamique', 'color': 'bg-orange-500', 'desc': 'Appétence pour le risque'},
                            'SPE': {'label': 'SPE', 'color': 'bg-purple-500', 'desc': 'Expert des marchés'}
                        } %}
                        {% set info = profileInfo[profile.investorProfile] ?? {'label': profile.investorProfile, 'color': 'bg-gray-500', 'desc': 'Profil inconnu'} %}
                        
                        <div class="flex items-center justify-between">
                            <div class="flex items-center space-x-3">
                                <div class="w-4 h-4 {{ info.color }} rounded-full"></div>
                                <div>
                                    <p class="text-sm font-medium text-gray-900">{{ info.label }}</p>
                                    <p class="text-xs text-gray-500">{{ info.desc }}</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-lg font-semibold text-gray-900">{{ profile.count }}</p>
                                <p class="text-xs text-gray-500">utilisateurs</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-8">
                    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                    <p class="mt-2 text-sm text-gray-500">Aucun profil calculé</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="mt-8">
    <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Actions rapides</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <a href="{{ path('admin_modern_users') }}" class="flex items-center p-4 bg-blue-50 rounded-lg hover:bg-blue-100 transition-colors">
                <svg class="w-8 h-8 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                </svg>
                <div>
                    <p class="font-medium text-blue-900">Gérer les utilisateurs</p>
                    <p class="text-sm text-blue-600">Voir tous les comptes</p>
                </div>
            </a>
            
            <a href="{{ path('admin_modern_kyc') }}" class="flex items-center p-4 bg-yellow-50 rounded-lg hover:bg-yellow-100 transition-colors">
                <svg class="w-8 h-8 text-yellow-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <div>
                    <p class="font-medium text-yellow-900">Valider des KYC</p>
                    <p class="text-sm text-yellow-600">{{ kycPending }} en attente</p>
                </div>
            </a>
            
            <a href="{{ path('app_home') }}" class="flex items-center p-4 bg-purple-50 rounded-lg hover:bg-purple-100 transition-colors">
                <svg class="w-8 h-8 text-purple-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                <div>
                    <p class="font-medium text-purple-900">Retour au site</p>
                    <p class="text-sm text-purple-600">Interface utilisateur</p>
