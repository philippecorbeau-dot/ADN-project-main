{% block javascripts %}
<script>
/* ─── Synchronisation O2S automatique ─── */
let isSyncing = false;

function triggerO2sSync() {
    if (isSyncing) return;
    isSyncing = true;

    const btn = document.getElementById('sync-btn');
    const btnText = document.getElementById('sync-btn-text');
    const btnIcon = document.getElementById('sync-btn-icon');
    const syncStatus = document.getElementById('sync-status');

    // UI: état "en cours"
    btn.disabled = true;
    btn.classList.add('opacity-75', 'cursor-not-allowed');
    btnText.textContent = 'Synchronisation…';
    btnIcon.classList.add('animate-spin');
    syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span> Synchronisation en cours…';
    syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700';

    fetch('{{ path("admin_api_sync_o2s") }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/json' }
    })
    .then(r => r.json())
    .then(data => {
        isSyncing = false;
        btn.disabled = false;
        btn.classList.remove('opacity-75', 'cursor-not-allowed');
        btnIcon.classList.remove('animate-spin');

        if (data.success && data.stats) {
            // Mettre à jour les compteurs
            const s = data.stats;
            const updates = {
                'stat-contacts': s.totalContacts,
                'stat-pp': s.personnesPhysiquesCount,
                'stat-pm': s.personnesMoralesCount,
            };

            Object.keys(updates).forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    const oldVal = parseInt(el.textContent);
                    const newVal = updates[id];
                    el.textContent = newVal;
                    if (oldVal !== newVal) {
                        el.classList.add('text-blue-600');
                        setTimeout(() => el.classList.remove('text-blue-600'), 3000);
                    }
                }
            });

            // Mettre à jour la date de sync
            const syncDate = document.getElementById('sync-date');
            if (syncDate && s.lastO2sSync) {
                syncDate.textContent = s.lastO2sSync;
            } else if (s.lastO2sSync) {
                document.getElementById('sync-text').innerHTML = 
                    'Dernière synchronisation O2S / Harvest : <strong class="text-gray-900" id="sync-date">' + s.lastO2sSync + '</strong>';
            }

            // Résumé
            const r = data.results;
            const parts = [];
            if (r.newContacts > 0) parts.push(r.newContacts + ' nouveau(x) contact(s)');
            if (r.newComptes > 0) parts.push(r.newComptes + ' nouveau(x) contrat(s)');
            if (r.updatedComptes > 0) parts.push(r.updatedComptes + ' contrat(s) mis à jour');
            
            btnText.textContent = 'Synchroniser';
            syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> ' + 
                (parts.length > 0 ? '✓ ' + parts.join(', ') : '✓ Tout est à jour');
            syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700';

            // Reset du statut après 10s
            setTimeout(() => {
                syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Connecté';
            }, 10000);
        } else {
            btnText.textContent = 'Synchroniser';
            syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Erreur de synchronisation';
            syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-700';
        }
    })
    .catch(err => {
        console.error('O2S sync error:', err);
        isSyncing = false;
        btn.disabled = false;
        btn.classList.remove('opacity-75', 'cursor-not-allowed');
        btnIcon.classList.remove('animate-spin');
        btnText.textContent = 'Synchroniser';
        syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Erreur réseau';
        syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-700';
    });
}

// Fix placeholder emails via HTTP (contourne le blocage SSH -> Harvest)
function triggerFixEmails() {
    const btn = document.getElementById('fix-emails-btn');
    const btnText = document.getElementById('fix-emails-text');
    const btnIcon = document.getElementById('fix-emails-icon');
    const syncStatus = document.getElementById('sync-status');

    if (!btn || btn.disabled) return;

    btn.disabled = true;
    btn.classList.add('opacity-75', 'cursor-not-allowed');
    btnText.textContent = 'Correction en cours…';
    btnIcon.classList.add('animate-spin');
    syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span> Correction des emails en cours…';
    syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700';

    fetch('{{ path("admin_api_fix_emails") }}', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/json' }
    })
    .then(r => r.json())
    .then(data => {
        btn.disabled = false;
        btn.classList.remove('opacity-75', 'cursor-not-allowed');
        btnIcon.classList.remove('animate-spin');

        if (data.success) {
            const msg = data.fixed > 0
                ? '✓ ' + data.fixed + ' email(s) corrigé(s) !'
                : 'Aucun email à corriger';
            
            syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> ' + msg;
            syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700';

            // Mettre à jour le compteur
            const countEl = document.getElementById('placeholder-count');
            if (countEl) countEl.textContent = data.remaining;
            
            // Masquer le bouton si plus de placeholders
            if (data.remaining === 0) {
                btn.style.display = 'none';
            } else {
                btnText.innerHTML = 'Corriger emails (<span id="placeholder-count">' + data.remaining + '</span>)';
            }

            // Reset du statut après 10s
            setTimeout(() => {
                syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Connecté';
                syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700';
            }, 10000);
        } else {
            btnText.textContent = 'Corriger emails';
            syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Erreur: ' + (data.message || 'Erreur inconnue');
            syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-700';
        }
    })
    .catch(err => {
        console.error('Fix emails error:', err);
        btn.disabled = false;
        btn.classList.remove('opacity-75', 'cursor-not-allowed');
        btnIcon.classList.remove('animate-spin');
        btnText.textContent = 'Corriger emails';
        syncStatus.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Erreur réseau';
        syncStatus.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-50 text-red-700';
    });
}

// Auto-sync si la dernière synchronisation date de plus de 24h
document.addEventListener('DOMContentLoaded', function() {
    const lastSyncStr = '{{ lastO2sSync|default("")|date("Y-m-d H:i:s") }}';
    if (lastSyncStr) {
        const lastSync = new Date(lastSyncStr.replace(' ', 'T'));
        const now = new Date();
        const hoursSinceSync = (now - lastSync) / (1000 * 60 * 60);
        
        if (hoursSinceSync > 24) {
            console.info('Auto-sync O2S: dernière sync il y a ' + Math.round(hoursSinceSync) + 'h, déclenchement automatique…');
            setTimeout(() => triggerO2sSync(), 2000); // Petit délai pour laisser la page se charger
        }
    } else {
        // Pas de sync du tout — déclencher immédiatement
        setTimeout(() => triggerO2sSync(), 2000);
    }
});

// Users Registration Chart
const usersCtx = document.getElementById('usersChart').getContext('2d');
new Chart(usersCtx, {
    type: 'line',
    data: {
        labels: {{ usersChartLabels|json_encode|raw }},
        datasets: [{
            label: 'Inscriptions',
            data: {{ usersChartData|json_encode|raw }},
            borderColor: '#3b82f6',
            backgroundColor: 'rgba(59, 130, 246, 0.1)',
            fill: true,
            tension: 0.4,
            pointBackgroundColor: '#3b82f6',
            pointBorderColor: '#ffffff',
            pointBorderWidth: 2,
            pointRadius: 4,
            pointHoverRadius: 6
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                display: false
            },
            tooltip: {
                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                titleColor: '#ffffff',
                bodyColor: '#ffffff',
                borderColor: '#3b82f6',
                borderWidth: 1,
                cornerRadius: 8,
                displayColors: false
            }
        },
        scales: {
            x: {
                grid: {
                    display: false
                },
                border: {
                    display: false
                }
            },
            y: {
                beginAtZero: true,
                grid: {
                    color: '#f1f5f9'
                },
                border: {
                    display: false
                },
                ticks: {
                    stepSize: 1
                }
            }
        },
        interaction: {
            intersect: false,
            mode: 'index'
        }
    }
});

// KYC Status Donut Chart
const kycCtx = document.getElementById('kycChart').getContext('2d');
const kycData = {{ kycByStatus|json_encode|raw }};

new Chart(kycCtx, {
    type: 'doughnut',
    data: {
        labels: ['Validés', 'En attente', 'Refusés'],
        datasets: [{
            data: [kycData.VALIDATED, kycData.PENDING, kycData.REFUSED],
            backgroundColor: [
                '#10b981',
                '#f59e0b', 
                '#ef4444'
            ],
            borderWidth: 0,
            cutout: '70%'
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                display: false
            },
            tooltip: {
                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                titleColor: '#ffffff',
                bodyColor: '#ffffff',
                borderColor: '#6b7280',
                borderWidth: 1,
                cornerRadius: 8,
                callbacks: {
                    label: function(context) {
                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                        const percentage = ((context.parsed / total) * 100).toFixed(1);
                        return context.label + ': ' + context.parsed + ' (' + percentage + '%)';
                    }
                }
            }
        }
    }
});
</script>
{% endblock %}
