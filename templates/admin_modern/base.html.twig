<!DOCTYPE html>
<html lang="fr" data-theme="light" class="{% if app.user and app.user.isAdminDarkMode() %}dark{% endif %}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Back-office ADN Family Office{% endblock %}</title>
    
    <!-- Favicon commun (évite les 404 d'assets) -->
    <link rel="icon" href="{{ asset('assets/favicon.svg') }}" type="image/svg+xml">
    <link rel="icon" href="{{ asset('assets/favicon.ico') }}" sizes="any">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('assets/favicon-32.png') }}">
    <link rel="icon" type="image/png" sizes="192x192" href="{{ asset('assets/favicon-192.png') }}">
    <link rel="apple-touch-icon" href="{{ asset('assets/apple-touch-icon.png') }}">
    
    <!-- Tailwind CSS & Admin Modern Styles -->
    {{ encore_entry_link_tags('app') }}
    {{ encore_entry_link_tags('admin_modern') }}
    
    <!-- Alpine.js -->
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    
    <!-- Icons (Heroicons) - retiré le module ES CDN qui provoquait une erreur CORS/mime -->
    
    <style>
        /* ===== DARK MODE COMPLETE SYSTEM ===== */
        
        /* Variables CSS */
        :root {
            --bg-body: #f9fafb;
            --bg-sidebar: #ffffff;
            --bg-card: #ffffff;
            --bg-header: rgba(255, 255, 255, 0.95);
            --bg-input: #ffffff;
            --bg-hover: #f3f4f6;
            --text-primary: #111827;
            --text-secondary: #6b7280;
            --text-muted: #9ca3af;
            --border-color: #e5e7eb;
            --border-light: #f3f4f6;
            --shadow-color: rgba(0, 0, 0, 0.1);
        }
        
        html.dark {
            --bg-body: #0f172a;
            --bg-sidebar: #1e293b;
            --bg-card: #1e293b;
            --bg-header: rgba(30, 41, 59, 0.95);
            --bg-input: #334155;
            --bg-hover: #334155;
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --border-color: #334155;
            --border-light: #475569;
            --shadow-color: rgba(0, 0, 0, 0.5);
        }
        
        /* Body */
        html.dark body {
            background-color: var(--bg-body) !important;
            color: var(--text-primary) !important;
        }
        
        /* Sidebar */
        html.dark .fixed.inset-y-0.left-0 {
            background-color: var(--bg-sidebar) !important;
            border-color: var(--border-color) !important;
        }
        
        /* Header */
        html.dark header,
        html.dark #admin-header {
            background-color: var(--bg-header) !important;
            border-color: var(--border-color) !important;
        }
        
        /* Cards and panels */
        html.dark .bg-white {
            background-color: var(--bg-card) !important;
        }
        
        html.dark .bg-gray-50 {
            background-color: var(--bg-body) !important;
        }
        
        html.dark .bg-gray-100 {
            background-color: var(--bg-hover) !important;
        }
        
        /* Text colors */
        html.dark .text-gray-900 {
            color: var(--text-primary) !important;
        }
        
        html.dark .text-gray-800 {
            color: #e2e8f0 !important;
        }
        
        html.dark .text-gray-700 {
            color: #cbd5e1 !important;
        }
        
        html.dark .text-gray-600 {
            color: var(--text-secondary) !important;
        }
        
        html.dark .text-gray-500 {
            color: var(--text-muted) !important;
        }
        
        html.dark .text-gray-400 {
            color: #64748b !important;
        }
        
        /* Borders */
        html.dark .border-gray-200,
        html.dark .border-gray-300 {
            border-color: var(--border-color) !important;
        }
        
        html.dark .border-gray-100 {
            border-color: var(--border-light) !important;
        }
        
        /* Shadows */
        html.dark .shadow,
        html.dark .shadow-sm,
        html.dark .shadow-md,
        html.dark .shadow-lg,
        html.dark .shadow-xl {
            box-shadow: 0 4px 6px -1px var(--shadow-color), 0 2px 4px -1px var(--shadow-color) !important;
        }
        
        /* Hover states */
        html.dark .hover\:bg-gray-100:hover,
        html.dark .hover\:bg-gray-50:hover {
            background-color: var(--bg-hover) !important;
        }
        
        /* Specific elements */
        html.dark .gradient-bg {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%) !important;
        }
        
        /* Nav items in sidebar */
        html.dark nav a.text-gray-600 {
            color: var(--text-secondary) !important;
        }
        
        html.dark nav a.text-gray-600:hover {
            color: #818cf8 !important;
            background-color: rgba(99, 102, 241, 0.1) !important;
        }
        
        html.dark nav a.bg-indigo-50 {
            background-color: rgba(99, 102, 241, 0.15) !important;
        }
        
        /* Bottom section in sidebar */
        html.dark .absolute.bottom-0 .bg-gray-100 {
            background-color: var(--bg-hover) !important;
        }
        
        /* Green status indicator */
        html.dark .bg-green-50 {
            background-color: rgba(16, 185, 129, 0.1) !important;
        }
        
        /* Tables */
        html.dark table {
            background-color: var(--bg-card) !important;
        }
        
        html.dark thead {
            background-color: var(--bg-hover) !important;
        }
        
        html.dark tbody tr {
            border-color: var(--border-color) !important;
        }
        
        html.dark tbody tr:hover {
            background-color: var(--bg-hover) !important;
        }
        
        /* Inputs */
        html.dark input,
        html.dark select,
        html.dark textarea {
            background-color: var(--bg-input) !important;
            border-color: var(--border-color) !important;
            color: var(--text-primary) !important;
        }
        
        html.dark input::placeholder,
        html.dark textarea::placeholder {
            color: var(--text-muted) !important;
        }
        
        /* Modals & Overlays */
        html.dark .bg-gray-600.opacity-75 {
            background-color: rgba(0, 0, 0, 0.75) !important;
        }
        
        /* Ring colors */
        html.dark .ring-indigo-100 {
            --tw-ring-color: rgba(99, 102, 241, 0.3) !important;
        }
        
        /* ===== AMÉLIORATION LISIBILITÉ DARK MODE ===== */
        
        /* Tous les textes blancs/noirs */
        html.dark h1, html.dark h2, html.dark h3, html.dark h4, html.dark h5, html.dark h6 {
            color: #f1f5f9 !important;
        }
        
        html.dark p, html.dark span, html.dark div, html.dark label {
            color: inherit;
        }
        
        html.dark a:not(.btn):not([class*="bg-"]) {
            color: #93c5fd !important;
        }
        
        html.dark a:not(.btn):not([class*="bg-"]):hover {
            color: #bfdbfe !important;
        }
        
        /* Actions rapides - Cards cliquables */
        html.dark .hover\:bg-blue-50:hover,
        html.dark .hover\:bg-indigo-50:hover,
        html.dark .hover\:bg-purple-50:hover {
            background-color: rgba(99, 102, 241, 0.15) !important;
        }
        
        html.dark .bg-blue-50,
        html.dark .bg-indigo-50,
        html.dark .bg-purple-50 {
            background-color: rgba(99, 102, 241, 0.1) !important;
        }
        
        html.dark .text-blue-600,
        html.dark .text-blue-700,
        html.dark .text-indigo-600,
        html.dark .text-indigo-700 {
            color: #93c5fd !important;
        }
        
        html.dark .text-blue-500,
        html.dark .text-indigo-500 {
            color: #60a5fa !important;
        }
        
        /* Actions rapides - améliorer la visibilité */
        html.dark [class*="hover:bg-"][class*="-50"]:hover {
            background-color: var(--bg-hover) !important;
        }
        
        /* Badges et labels colorés */
        html.dark .bg-green-50,
        html.dark .bg-emerald-50 {
            background-color: rgba(16, 185, 129, 0.15) !important;
        }
        
        html.dark .text-green-600,
        html.dark .text-green-700,
        html.dark .text-emerald-600,
        html.dark .text-emerald-700 {
            color: #34d399 !important;
        }
        
        html.dark .bg-red-50,
        html.dark .bg-rose-50 {
            background-color: rgba(239, 68, 68, 0.15) !important;
        }
        
        html.dark .text-red-600,
        html.dark .text-red-700,
        html.dark .text-rose-600 {
            color: #f87171 !important;
        }
        
        html.dark .bg-yellow-50,
        html.dark .bg-amber-50,
        html.dark .bg-orange-50 {
            background-color: rgba(245, 158, 11, 0.15) !important;
        }
        
        html.dark .text-yellow-600,
        html.dark .text-yellow-700,
        html.dark .text-amber-600,
        html.dark .text-orange-600 {
            color: #fbbf24 !important;
        }
        
        html.dark .bg-purple-50,
        html.dark .bg-violet-50 {
            background-color: rgba(139, 92, 246, 0.15) !important;
        }
        
        html.dark .text-purple-600,
        html.dark .text-purple-700,
        html.dark .text-violet-600 {
            color: #a78bfa !important;
        }
        
        html.dark .bg-cyan-50,
        html.dark .bg-teal-50 {
            background-color: rgba(6, 182, 212, 0.15) !important;
        }
        
        html.dark .text-cyan-600,
        html.dark .text-cyan-700,
        html.dark .text-teal-600 {
            color: #22d3ee !important;
        }
        
        /* Badges avec fond coloré - garder la lisibilité */
        html.dark .bg-green-100 {
            background-color: rgba(16, 185, 129, 0.2) !important;
        }
        
        html.dark .bg-red-100 {
            background-color: rgba(239, 68, 68, 0.2) !important;
        }
        
        html.dark .bg-yellow-100,
        html.dark .bg-amber-100 {
            background-color: rgba(245, 158, 11, 0.2) !important;
        }
        
        html.dark .bg-blue-100,
        html.dark .bg-indigo-100 {
            background-color: rgba(99, 102, 241, 0.2) !important;
        }
        
        html.dark .bg-purple-100 {
            background-color: rgba(139, 92, 246, 0.2) !important;
        }
        
        /* Textes dans les badges colorés */
        html.dark .text-green-800 {
            color: #6ee7b7 !important;
        }
        
        html.dark .text-red-800 {
            color: #fca5a5 !important;
        }
        
        html.dark .text-yellow-800,
        html.dark .text-amber-800 {
            color: #fcd34d !important;
        }
        
        html.dark .text-blue-800,
        html.dark .text-indigo-800 {
            color: #a5b4fc !important;
        }
        
        html.dark .text-purple-800 {
            color: #c4b5fd !important;
        }
        
        /* Bordures colorées */
        html.dark .border-green-200 {
            border-color: rgba(16, 185, 129, 0.3) !important;
        }
        
        html.dark .border-red-200 {
            border-color: rgba(239, 68, 68, 0.3) !important;
        }
        
        html.dark .border-yellow-200,
        html.dark .border-amber-200 {
            border-color: rgba(245, 158, 11, 0.3) !important;
        }
        
        html.dark .border-blue-200,
        html.dark .border-indigo-200 {
            border-color: rgba(99, 102, 241, 0.3) !important;
        }
        
        html.dark .border-purple-200 {
            border-color: rgba(139, 92, 246, 0.3) !important;
        }
        
        /* Cards avec bordures */
        html.dark [class*="rounded"][class*="border"] {
            border-color: var(--border-color) !important;
        }
        
        /* Placeholder dans les inputs */
        html.dark ::placeholder {
            color: #64748b !important;
            opacity: 1 !important;
        }
        
        /* Select dropdowns */
        html.dark select option {
            background-color: #1e293b !important;
            color: #f1f5f9 !important;
        }
        
        /* Focus rings */
        html.dark *:focus {
            outline-color: #6366f1 !important;
        }
        
        html.dark .focus\:ring-indigo-500:focus {
            --tw-ring-color: rgba(99, 102, 241, 0.5) !important;
        }
        
        /* Stat cards */
        html.dark .bg-gradient-to-br.from-blue-50,
        html.dark .bg-gradient-to-br.from-indigo-50,
        html.dark .bg-gradient-to-br.from-green-50,
        html.dark .bg-gradient-to-br.from-emerald-50,
        html.dark .bg-gradient-to-br.from-amber-50,
        html.dark .bg-gradient-to-br.from-yellow-50 {
            background: var(--bg-card) !important;
            border: 1px solid var(--border-color) !important;
        }
        
        /* Info boxes / Alerts */
        html.dark .bg-blue-50.border-blue-200,
        html.dark .bg-indigo-50.border-indigo-200 {
            background-color: rgba(99, 102, 241, 0.1) !important;
            border-color: rgba(99, 102, 241, 0.3) !important;
        }
        
        html.dark .bg-green-50.border-green-200,
        html.dark .bg-emerald-50.border-emerald-200 {
            background-color: rgba(16, 185, 129, 0.1) !important;
            border-color: rgba(16, 185, 129, 0.3) !important;
        }
        
        html.dark .bg-red-50.border-red-200,
        html.dark .bg-rose-50.border-rose-200 {
            background-color: rgba(239, 68, 68, 0.1) !important;
            border-color: rgba(239, 68, 68, 0.3) !important;
        }
        
        html.dark .bg-yellow-50.border-yellow-200,
        html.dark .bg-amber-50.border-amber-200 {
            background-color: rgba(245, 158, 11, 0.1) !important;
            border-color: rgba(245, 158, 11, 0.3) !important;
        }
        
        /* Divide colors for lists */
        html.dark .divide-gray-200 > * + * {
            border-color: var(--border-color) !important;
        }
        
        html.dark .divide-gray-100 > * + * {
            border-color: var(--border-light) !important;
        }
        
        /* Scrollbar dark mode */
        html.dark ::-webkit-scrollbar-track {
            background: #1e293b !important;
        }
        
        html.dark ::-webkit-scrollbar-thumb {
            background: #475569 !important;
        }
        
        html.dark ::-webkit-scrollbar-thumb:hover {
            background: #64748b !important;
        }
        
        /* Liens dans la navigation active */
        html.dark nav a.bg-indigo-50.text-indigo-600 {
            background-color: rgba(99, 102, 241, 0.2) !important;
            color: #a5b4fc !important;
        }
        
        /* Chart.js dark mode support */
        html.dark canvas {
            filter: brightness(0.95);
        }
        
        /* Code/monospace text */
        html.dark code, html.dark pre, html.dark .font-mono {
            background-color: #0f172a !important;
            color: #e2e8f0 !important;
        }
        
        /* Loading spinner */
        html.dark .animate-spin {
            border-color: rgba(99, 102, 241, 0.2) !important;
            border-top-color: #6366f1 !important;
        }

        /* Transitions fluides */
        * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.2s ease;
        }
        
        /* Animation de fade-in */
        .fade-in {
            animation: fadeIn 0.3s ease-in-out;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Hover effects */
        .hover-lift:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        /* Glass effect */
        .glass {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        /* Gradient backgrounds */
        .gradient-bg {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .gradient-success {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        }

        .gradient-warning {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        }

        .gradient-danger {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        }

        /* Header sticky amélioré */
        #admin-header {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            will-change: transform, background, box-shadow;
        }

        #admin-header.scrolled {
            background: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(20px);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08) !important;
        }

        #admin-header.hidden {
            transform: translateY(-100%) !important;
        }

        /* Animation pour l'icône du header */
        .header-icon {
            transition: all 0.3s ease;
        }

        .header-icon:hover {
            transform: scale(1.1) rotate(5deg);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 3px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="bg-gray-50 font-inter" x-data="{ sidebarOpen: false }">
    <!-- Loading indicator -->
    <div id="loading" class="fixed inset-0 bg-white z-50 flex items-center justify-center" style="display: none;">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
    </div>

    <!-- Sidebar -->
    <div class="fixed inset-y-0 left-0 z-50 w-64 bg-white shadow-xl transform transition-transform duration-300 ease-in-out lg:translate-x-0 lg:static lg:inset-0"
         :class="{ '-translate-x-full': !sidebarOpen, 'translate-x-0': sidebarOpen }">
        
        <!-- Brand minimal (logo supprimé) -->
        <div class="flex items-center justify-center h-16 px-4 gradient-bg">
            <span class="text-xl font-bold text-white">Admin</span>
        </div>

        <!-- Navigation -->
        <nav class="mt-8 px-4 space-y-2">
            <!-- Dashboard (accessible à tous les rôles admin) -->
            {% if app.user.canAccessModule('dashboard') %}
            <a href="{{ path('admin_modern_dashboard') }}" 
               class="group flex items-center px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 hover:text-indigo-600 transition-colors
                      {% if app.request.get('_route') == 'admin_modern_dashboard' %}bg-indigo-50 text-indigo-600 border-r-2 border-indigo-600{% else %}text-gray-600{% endif %}">
                <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5a2 2 0 012-2h4a2 2 0 012 2v6a2 2 0 01-2 2H10a2 2 0 01-2-2V5z"></path>
                </svg>
                Dashboard
            </a>
            {% endif %}

            <!-- Separator -->
            <div class="border-t border-gray-200 my-4"></div>

            <!-- Tracking Section -->
            {% if app.user.canAccessModule('dashboard') %}
            <a href="{{ path('admin_modern_tracking') }}" 
               class="group flex items-center px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 hover:text-indigo-600 transition-colors
                      {% if app.request.get('_route') == 'admin_modern_tracking' %}bg-indigo-50 text-indigo-600 border-r-2 border-indigo-600{% else %}text-gray-600{% endif %}">
                <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                Tracking Inscriptions
            </a>
            {% endif %}

            <!-- Separator -->
            <div class="border-t border-gray-200 my-4"></div>

            <!-- Users Section -->
            {% if app.user.canAccessModule('users') %}
            <div class="space-y-1">
                <h3 class="px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Utilisateurs</h3>
                <a href="{{ path('admin_modern_users') }}" 
                   class="group flex items-center px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 hover:text-indigo-600 transition-colors
                          {% if app.request.get('_route') == 'admin_modern_users' %}bg-indigo-50 text-indigo-600 border-r-2 border-indigo-600{% else %}text-gray-600{% endif %}">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                    </svg>
                    Utilisateurs
                </a>
                <a href="{{ path('admin_modern_investor_profiles') }}" 
                   class="group flex items-center px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 hover:text-indigo-600 transition-colors
                          {% if app.request.get('_route') == 'admin_modern_investor_profiles' %}bg-indigo-50 text-indigo-600 border-r-2 border-indigo-600{% else %}text-gray-600{% endif %}">
                    <svg class="mr-3 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                    Profils Investisseurs
                </a>
                {% if app.user.canAccessModule('pros') %}
                <a href="{{ path('admin_modern_pros') }}" class="group flex items-center px-3 py-2 text-sm font-medium rounded-lg hover:bg-gray-100 hover:text-indigo-600 transition-colors
