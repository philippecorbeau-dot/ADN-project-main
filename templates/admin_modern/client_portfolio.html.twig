{% extends 'admin_modern/base.html.twig' %}

{% block title %}Ensemble patrimoine clients{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <div class="md:flex md:items-center md:justify-between">
            <div class="flex-1 min-w-0">
                <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                    💰 Ensemble patrimoine clients
                </h2>
                <p class="mt-1 text-sm text-gray-500">Vue d'ensemble du patrimoine de tous les clients ayant complété leur profil</p>
            </div>
            <div class="mt-4 flex-shrink-0 flex md:mt-0 md:ml-4">
                <a href="{{ path('admin_modern_client_portfolio_export') }}" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    📊 Exporter
                </a>
            </div>
        </div>
    </div>

    <!-- Statistiques globales -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white overflow-hidden shadow rounded-xl border border-gray-100">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                            </svg>
                        </div>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Clients avec patrimoine</dt>
                            <dd class="text-lg font-medium text-gray-900">{{ stats.userCount|number_format(0, ',', ' ') }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow rounded-xl border border-gray-100">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Patrimoine total</dt>
                            <dd class="text-lg font-medium text-gray-900">{{ stats.totalPatrimoine|number_format(0, ',', ' ') }} €</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow rounded-xl border border-gray-100">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                            </svg>
                        </div>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Patrimoine moyen</dt>
                            <dd class="text-lg font-medium text-gray-900">{{ stats.averagePatrimoine|number_format(0, ',', ' ') }} €</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow rounded-xl border border-gray-100">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <div class="w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                            </svg>
                        </div>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Revenus totaux</dt>
                            <dd class="text-lg font-medium text-gray-900">{{ stats.totalIncome|number_format(0, ',', ' ') }} €</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Répartition du patrimoine -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <!-- Graphique de répartition -->
        <div class="bg-white shadow rounded-xl border border-gray-100">
            <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-medium text-gray-900">📊 Répartition du patrimoine global</h3>
            </div>
            <div class="p-6">
                <div class="space-y-4">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="w-4 h-4 bg-blue-500 rounded mr-3"></div>
                            <span class="text-sm text-gray-600">Immobilier</span>
                        </div>
                        <div class="text-right">
                            <div class="text-sm font-medium text-gray-900">{{ stats.totalRealestate|number_format(0, ',', ' ') }} €</div>
                            <div class="text-xs text-gray-500">{{ stats.totalPatrimoine > 0 ? ((stats.totalRealestate / stats.totalPatrimoine) * 100)|round(1) : 0 }}%</div>
                        </div>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="w-4 h-4 bg-green-500 rounded mr-3"></div>
                            <span class="text-sm text-gray-600">Compte titres / épargne</span>
                        </div>
                        <div class="text-right">
                            <div class="text-sm font-medium text-gray-900">{{ stats.totalAccountSecurities|number_format(0, ',', ' ') }} €</div>
                            <div class="text-xs text-gray-500">{{ stats.totalPatrimoine > 0 ? ((stats.totalAccountSecurities / stats.totalPatrimoine) * 100)|round(1) : 0 }}%</div>
                        </div>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="w-4 h-4 bg-purple-500 rounded mr-3"></div>
                            <span class="text-sm text-gray-600">Capitalisation (AV)</span>
                        </div>
                        <div class="text-right">
                            <div class="text-sm font-medium text-gray-900">{{ stats.totalCapitalisation|number_format(0, ',', ' ') }} €</div>
                            <div class="text-xs text-gray-500">{{ stats.totalPatrimoine > 0 ? ((stats.totalCapitalisation / stats.totalPatrimoine) * 100)|round(1) : 0 }}%</div>
                        </div>
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="w-4 h-4 bg-yellow-500 rounded mr-3"></div>
                            <span class="text-sm text-gray-600">SCPI</span>
                        </div>
                        <div class="text-right">
                            <div class="text-sm font-medium text-gray-900">{{ stats.totalScpi|number_format(0, ',', ' ') }} €</div>
                            <div class="text-xs text-gray-500">{{ stats.totalPatrimoine > 0 ? ((stats.totalScpi / stats.totalPatrimoine) * 100)|round(1) : 0 }}%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Liquidités disponibles -->
        <div class="bg-white shadow rounded-xl border border-gray-100">
            <div class="px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-medium text-gray-900">💧 Liquidités disponibles</h3>
            </div>
            <div class="p-6">
                <div class="text-center">
                    <div class="text-3xl font-bold text-blue-600 mb-2">
                        {{ stats.totalLiquidity|number_format(0, ',', ' ') }} €
                    </div>
                    <p class="text-sm text-gray-500">Total des liquidités disponibles pour investissement</p>
                </div>
                <div class="mt-6 pt-6 border-t border-gray-200">
                    <div class="text-sm text-gray-600">
                        <div class="flex justify-between mb-2">
                            <span>Liquidité moyenne par client</span>
                            <span class="font-medium">{{ stats.userCount > 0 ? (stats.totalLiquidity / stats.userCount)|number_format(0, ',', ' ') : 0 }} €</span>
                        </div>
                        <div class="flex justify-between">
                            <span>% du patrimoine total</span>
                            <span class="font-medium">{{ stats.totalPatrimoine > 0 ? ((stats.totalLiquidity / stats.totalPatrimoine) * 100)|round(1) : 0 }}%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Liste des clients -->
    <div class="bg-white shadow rounded-xl border border-gray-100">
        <div class="px-4 sm:px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">👥 Détail par client</h3>
        </div>

        <!-- Vue Desktop : Tableau -->
        <div class="hidden lg:block overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Client</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Patrimoine total</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Immobilier / Capital</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Titres/Épargne / Réserves</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">AV / CA N‑1</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">SCPI / Résultat N‑1</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Liquidités / CA prévision</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Revenus</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Profil</th>
                        <th scope="col" class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for data in portfolioData %}
                        {% set user = data.user %}
                        {% set info = data.info %}
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10">
                                        <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center">
                                            <span class="text-sm font-medium text-indigo-600">
                                                {{ (user.firstName ?? 'U')|slice(0, 1)|upper }}{{ (user.lastName ?? 'U')|slice(0, 1)|upper }}
                                            </span>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-medium text-gray-900">
                                            {{ user.firstName ?? 'Prénom' }} {{ user.lastName ?? 'Nom' }}
                                        </div>
                                        <div class="text-sm text-gray-500">{{ user.email }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-medium text-gray-900">{{ data.totalPatrimoine|number_format(0, ',', ' ') }} €</div>
                            </td>
                            {% if data.isPro %}
                                {# Colonnes adaptées PRO #}
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ data.proSummary.capital ? (data.proSummary.capital|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ data.proSummary.stocks ? (data.proSummary.stocks|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ data.proSummary.turnover ? (data.proSummary.turnover|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ data.proSummary.oldResult ? (data.proSummary.oldResult|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ data.proSummary.forecastTurnover ? (data.proSummary.forecastTurnover|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">—</td>
                            {% else %}
                                {# Colonnes particulier #}
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ info.realestate ? (info.realestate|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ info.accountSecurities ? (info.accountSecurities|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ info.capitalisation ? (info.capitalisation|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ info.scpi ? (info.scpi|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ info.liquidity ? (info.liquidity|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ info.income ? (info.income|number_format(0, ',', ' ') ~ ' €') : '—' }}</td>
                            {% endif %}
                            <td class="px-6 py-4 whitespace-nowrap">
                                {% if user.investorProfile %}
                                    {% set profileColors = {
                                        'PRUDENT': 'bg-gray-100 text-gray-800',
                                        'EQUILIBRE': 'bg-yellow-100 text-yellow-800',
                                        'DYNAMIQUE': 'bg-orange-100 text-orange-800',
                                        'SPE': 'bg-red-100 text-red-800'
                                    } %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ profileColors[user.investorProfile] ?? 'bg-gray-100 text-gray-800' }}">
                                        {{ user.investorProfile }}
                                    </span>
                                {% else %}
                                    <span class="text-sm text-gray-500">Non défini</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href="{{ path('admin_modern_user_view', {id: user.id}) }}" class="text-indigo-600 hover:text-indigo-900">
                                    Voir le profil
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="10" class="px-6 py-12 text-center">
                                <div class="text-gray-500">
                                    <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                                    </svg>
                                    <h3 class="text-sm font-medium text-gray-900 mb-1">Aucun client avec patrimoine</h3>
                                    <p class="text-sm text-gray-500">Les clients doivent compléter l'étape 3 du KYC pour apparaître ici</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Vue Mobile/Tablet : Cartes -->
        <div class="lg:hidden p-4 sm:p-6 space-y-4">
            {% if portfolioData is not empty %}
                {% for data in portfolioData %}
                    {% set user = data.user %}
                    {% set info = data.info %}
                    <div class="bg-gradient-to-br from-white to-gray-50 rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden">
                        <!-- Header de la carte -->
                        <div class="p-4 sm:p-5 bg-gradient-to-r from-indigo-50 to-purple-50 border-b border-gray-200">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3 flex-1 min-w-0">
                                    <div class="flex-shrink-0 h-12 w-12 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
                                        <span class="text-base font-bold text-white">
                                            {{ (user.firstName ?? 'U')|slice(0, 1)|upper }}{{ (user.lastName ?? 'U')|slice(0, 1)|upper }}
                                        </span>
                                    </div>
                                    <div class="min-w-0 flex-1">
                                        <div class="text-base font-bold text-gray-900 truncate">
                                            {{ user.firstName ?? 'Prénom' }} {{ user.lastName ?? 'Nom' }}
                                        </div>
                                        <div class="text-sm text-gray-600 truncate">{{ user.email }}</div>
                                    </div>
                                </div>
                                {% if user.investorProfile %}
                                    {% set profileColors = {
                                        'PRUDENT': 'bg-gray-100 text-gray-800 border-gray-200',
                                        'EQUILIBRE': 'bg-yellow-100 text-yellow-800 border-yellow-200',
                                        'DYNAMIQUE': 'bg-orange-100 text-orange-800 border-orange-200',
                                        'SPE': 'bg-red-100 text-red-800 border-red-200'
                                    } %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold border {{ profileColors[user.investorProfile] ?? 'bg-gray-100 text-gray-800' }}">
                                        {{ user.investorProfile }}
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        <!-- Contenu de la carte -->
                        <div class="p-4 sm:p-5 space-y-4">
                            <!-- Patrimoine total -->
                            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-4 border border-blue-100">
                                <div class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-1">Patrimoine total</div>
                                <div class="text-2xl font-bold text-blue-700">{{ data.totalPatrimoine|number_format(0, ',', ' ') }} €</div>
                            </div>

                            <!-- Grille d'informations -->
                            <div class="grid grid-cols-2 gap-3">
                                {% if data.isPro %}
                                    {# Informations PRO #}
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">Capital</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ data.proSummary.capital ? (data.proSummary.capital|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">Titres/Réserves</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ data.proSummary.stocks ? (data.proSummary.stocks|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">CA N-1</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ data.proSummary.turnover ? (data.proSummary.turnover|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">Résultat N-1</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ data.proSummary.oldResult ? (data.proSummary.oldResult|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100 col-span-2">
                                        <div class="text-xs text-gray-500 mb-1">CA Prévision</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ data.proSummary.forecastTurnover ? (data.proSummary.forecastTurnover|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                {% else %}
                                    {# Informations Particulier #}
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">Immobilier</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ info.realestate ? (info.realestate|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">Titres/Épargne</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ info.accountSecurities ? (info.accountSecurities|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">AV</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ info.capitalisation ? (info.capitalisation|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">SCPI</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ info.scpi ? (info.scpi|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">Liquidités</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ info.liquidity ? (info.liquidity|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                    <div class="bg-white rounded-lg p-3 border border-gray-100">
                                        <div class="text-xs text-gray-500 mb-1">Revenus</div>
                                        <div class="text-sm font-semibold text-gray-900">{{ info.income ? (info.income|number_format(0, ',', ' ') ~ ' €') : '—' }}</div>
                                    </div>
                                {% endif %}
                            </div>

                            <!-- Bouton d'action -->
                            <div class="pt-3 border-t border-gray-200">
                                <a href="{{ path('admin_modern_user_view', {id: user.id}) }}" 
                                   class="w-full inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-gradient-to-r from-indigo-600 to-purple-600 text-white font-semibold hover:from-indigo-700 hover:to-purple-700 transition-all shadow-sm hover:shadow-md">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                    Voir le profil
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% else %}
                <div class="bg-white rounded-2xl border border-gray-200 p-8 sm:p-12 text-center">
                    <div class="text-gray-500">
                        <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path>
                        </svg>
                        <h3 class="text-base font-semibold text-gray-900 mb-1">Aucun client avec patrimoine</h3>
                        <p class="text-sm text-gray-500">Les clients doivent compléter l'étape 3 du KYC pour apparaître ici</p>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
/* Responsive table scroll */
@media (max-width: 1024px) {
    .overflow-x-auto {
        -webkit-overflow-scrolling: touch;
    }
    
    .overflow-x-auto table th,
    .overflow-x-auto table td {
        padding: 0.75rem 0.5rem !important;
        font-size: 0.875rem;
    }
}

/* Animation pour les cartes de stats */
.bg-white {
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
}

.bg-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
}

/* Améliorations pour les cartes client */
@media (max-width: 640px) {
    .space-y-4 > * + * {
        margin-top: 0.75rem;
    }
    
    /* Réduire les espacements sur très petits écrans */
    .lg\:hidden .p-4 {
        padding: 0.75rem;
    }
    
    .lg\:hidden .p-5 {
        padding: 1rem;
    }
}

/* Animation pour les cartes client */
.lg\:hidden .bg-gradient-to-br {
    transition: all 0.3s ease;
}

.lg\:hidden .bg-gradient-to-br:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.1);
}
</style>
{% endblock %}
