{% extends 'admin_modern/base.html.twig' %}

{% block page_title %}Message: {{ message.subject }}{% endblock %}

{% block content %}
<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <nav class="flex items-center space-x-2 text-sm text-gray-500 mb-4">
                <a href="{{ path('admin_modern_messages') }}" class="hover:text-gray-700">Messages</a>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-900">{{ message.subject }}</span>
            </nav>
            <h1 class="text-2xl font-bold text-gray-900">{{ message.subject }}</h1>
        </div>
        <div class="flex space-x-3">
            <form action="{{ path('admin_modern_message_toggle_read', {'id': message.id}) }}" method="POST" class="inline">
                <button type="submit" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    {% if message.isRead %}
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L12 12l-4.242-4.242M9.878 9.878L7.636 7.636"/>
                        </svg>
                        Marquer non lu
                    {% else %}
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                        Marquer lu
                    {% endif %}
                </button>
            </form>
            <a href="{{ path('admin_modern_messages') }}" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Retour à la liste
            </a>
        </div>
    </div>

    <!-- Métadonnées -->
    <div class="bg-white shadow rounded-lg p-6">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
            <div>
                <dt class="text-sm font-medium text-gray-500">Expéditeur</dt>
                <dd class="mt-1 text-sm text-gray-900">{{ message.senderName }}</dd>
                <dd class="text-sm text-gray-500">{{ message.senderEmail }}</dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-gray-500">Catégorie</dt>
                <dd class="mt-1">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                        {% if message.category == 'technical' %}bg-red-100 text-red-800
                        {% elseif message.category == 'investment' %}bg-green-100 text-green-800
                        {% elseif message.category == 'account' %}bg-blue-100 text-blue-800
                        {% elseif message.category == 'kyc' %}bg-purple-100 text-purple-800
                        {% else %}bg-gray-100 text-gray-800{% endif %}">
                        {{ message.categoryLabel }}
                    </span>
                </dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-gray-500">Priorité</dt>
                <dd class="mt-1">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                        {% if message.priority == 'urgent' %}bg-red-100 text-red-800
                        {% elseif message.priority == 'high' %}bg-orange-100 text-orange-800
                        {% elseif message.priority == 'low' %}bg-gray-100 text-gray-800
                        {% else %}bg-yellow-100 text-yellow-800{% endif %}">
                        {{ message.priorityLabel }}
                    </span>
                </dd>
            </div>
            <div>
                <dt class="text-sm font-medium text-gray-500">Date</dt>
                <dd class="mt-1 text-sm text-gray-900">{{ message.formattedCreatedAt }}</dd>
                <dd class="text-sm text-gray-500">
                    {% if message.isRead %}
                        <span class="text-green-600">• Lu</span>
                    {% else %}
                        <span class="text-orange-600">• Non lu</span>
                    {% endif %}
                </dd>
            </div>
        </div>
    </div>

    <!-- Message original -->
    <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Message de l'utilisateur</h3>
            <div class="prose prose-sm max-w-none text-gray-700">
                {{ message.message|nl2br }}
            </div>
        </div>
    </div>

    {% if message.hasResponse %}
        <!-- Réponse existante -->
        <div class="bg-white shadow rounded-lg">
            <div class="px-6 py-6">
                <h3 class="text-lg font-medium text-gray-900 mb-4">
                    Votre réponse
                    <span class="text-sm font-normal text-gray-500 ml-2">
                        • Envoyée le {{ message.adminResponseAt.format('d/m/Y à H:i') }}
                    </span>
                </h3>
                <div class="bg-green-50 border border-green-200 rounded-md p-4">
                    <div class="prose prose-sm max-w-none text-gray-700">
                        {{ message.adminResponse|nl2br }}
                    </div>
                </div>
                
                <!-- Option pour modifier la réponse -->
                <div class="mt-4 pt-4 border-t border-gray-200">
                    <button type="button" onclick="toggleResponseForm()" 
                            class="text-sm text-indigo-600 hover:text-indigo-500 font-medium">
                        Modifier la réponse
                    </button>
                </div>
            </div>
        </div>

        <!-- Formulaire de modification (caché par défaut) -->
        <div id="response-form" class="hidden bg-white shadow rounded-lg">
            <div class="px-6 py-6">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Modifier la réponse</h3>
                <form action="{{ path('admin_modern_message_respond', {'id': message.id}) }}" method="POST">
                    <div class="mb-4">
                        <label for="admin_response" class="block text-sm font-medium text-gray-700 mb-2">
                            Nouvelle réponse
                        </label>
                        <textarea name="admin_response" id="admin_response" rows="6" required
                                  class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                  placeholder="Tapez votre réponse ici...">{{ message.adminResponse }}</textarea>
                    </div>
                    <div class="flex justify-end space-x-3">
                        <button type="button" onclick="toggleResponseForm()" 
                                class="px-4 py-2 border border-gray-300 rounded-md shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            Annuler
                        </button>
                        <button type="submit" 
                                class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            Mettre à jour la réponse
                        </button>
                    </div>
                </form>
            </div>
        </div>
    {% else %}
        <!-- Formulaire de réponse -->
        <div class="bg-white shadow rounded-lg">
            <div class="px-6 py-6">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Répondre au message</h3>
                <form action="{{ path('admin_modern_message_respond', {'id': message.id}) }}" method="POST">
                    <div class="mb-4">
                        <label for="admin_response" class="block text-sm font-medium text-gray-700 mb-2">
                            Votre réponse
                        </label>
                        <textarea name="admin_response" id="admin_response" rows="6" required
                                  class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                  placeholder="Tapez votre réponse ici..."></textarea>
                        <p class="mt-2 text-sm text-gray-500">
                            Cette réponse sera visible par l'utilisateur dans son espace personnel.
                        </p>
                    </div>
                    <div class="flex justify-end">
                        <button type="submit" 
                                class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                            </svg>
                            Envoyer la réponse
                        </button>
                    </div>
                </form>
            </div>
        </div>
    {% endif %}

    <!-- Informations utilisateur -->
    <div class="bg-white shadow rounded-lg">
        <div class="px-6 py-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Informations utilisateur</h3>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                    <dt class="text-sm font-medium text-gray-500">ID Utilisateur</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ message.sender.id }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Statut du compte</dt>
                    <dd class="mt-1 text-sm">
                        {% if message.sender.isVerified %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                Vérifié
                            </span>
                        {% else %}
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                Non vérifié
                            </span>
                        {% endif %}
                    </dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Date d'inscription</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ message.sender.createdAt.format('d/m/Y') }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Actions</dt>
                    <dd class="mt-1">
                        <a href="{{ path('admin_modern_users') }}?search={{ message.sender.email }}" 
                           class="text-sm text-indigo-600 hover:text-indigo-500 font-medium">
                            Voir dans la liste des utilisateurs →
                        </a>
                    </dd>
                </div>
            </div>
        </div>
    </div>
</div>

{% if message.hasResponse %}
<script>
function toggleResponseForm() {
    const form = document.getElementById('response-form');
    form.classList.toggle('hidden');
}
</script>
{% endif %}
{% endblock %}
