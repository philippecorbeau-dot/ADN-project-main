{# Fragment réutilisé pour le rendu serveur initial ET les requêtes AJAX
   de recherche/filtrage de la liste utilisateurs. #}

{# Compteur de résultats #}
<div class="mb-4 flex items-center justify-between" data-users-count>
    <p class="text-sm text-gray-700">
        <span class="font-medium">{{ totalFiltered }}</span> utilisateur(s) trouvé(s)
        {% if currentFilters.search or currentFilters.status or currentFilters.kyc_step or currentFilters.profile_type %}
            <span class="text-blue-600">avec filtres</span>
        {% endif %}
        — page {{ currentPage }}/{{ totalPages }}
    </p>
</div>

{# Grille des cartes utilisateurs #}
<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3" data-users-grid>
    {% for user in users %}
    <div class="{% if user.isSuspended() %}bg-red-50 border-red-200{% else %}bg-white border-gray-100{% endif %} overflow-hidden shadow-sm rounded-xl border user-card {% if user.isSuspended() %}ring-2 ring-red-200{% endif %}">
        <div class="p-6 h-full flex flex-col">
            <div class="flex items-center mb-4">
                <div class="flex-shrink-0">
                    {% set initials = (user.firstName ? user.firstName|slice(0,1) : '') ~ (user.lastName ? user.lastName|slice(0,1) : '') %}
                    {% if initials == '' %}
                        {% set initials = user.email|slice(0,2)|upper %}
                    {% endif %}
                    <div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
                        <span class="text-white font-medium text-sm">{{ initials|upper }}</span>
                    </div>
                </div>
                <div class="ml-4 flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-gray-900 truncate">
                        {{ user.firstName }} {{ user.lastName }}
                    </h3>
                    <p class="text-sm text-gray-500 truncate">{{ user.email }}</p>
                </div>
            </div>

            {% if user.isSuspended() %}
            <div class="mb-3">
                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-red-100 text-red-800 border border-red-200">
                    🚫 Compte suspendu
                </span>
            </div>
            {% endif %}

            {% set adminRoles = user.adminRoles %}
            {% if adminRoles|length > 0 %}
            <div class="flex flex-wrap gap-1 mb-3">
                {% for role in adminRoles %}
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                        {% if role == 'ROLE_SUPER_ADMIN' %}bg-purple-100 text-purple-800
                        {% elseif role == 'ROLE_ADMIN' %}bg-indigo-100 text-indigo-800
                        {% elseif role == 'ROLE_ADMIN_OPERATOR' %}bg-blue-100 text-blue-800
                        {% elseif role == 'ROLE_ADMIN_KYC' %}bg-green-100 text-green-800
                        {% elseif role == 'ROLE_ADMIN_SUPPORT' %}bg-cyan-100 text-cyan-800
                        {% elseif role == 'ROLE_ADMIN_MARKETING' %}bg-orange-100 text-orange-800
                        {% else %}bg-gray-100 text-gray-800{% endif %}">
                        {% if role == 'ROLE_SUPER_ADMIN' %}👑
                        {% elseif role == 'ROLE_ADMIN' %}🔑
                        {% elseif role == 'ROLE_ADMIN_OPERATOR' %}🔧
                        {% elseif role == 'ROLE_ADMIN_KYC' %}📋
                        {% elseif role == 'ROLE_ADMIN_SUPPORT' %}💬
                        {% elseif role == 'ROLE_ADMIN_MARKETING' %}📢
                        {% endif %}
                        {{ constant('App\\Entity\\User\\User::ROLES_ADMIN_LABELS')[role]|default(role|replace({'ROLE_ADMIN_': '', 'ROLE_': ''})) }}
                    </span>
                {% endfor %}
            </div>
            {% endif %}

            <div class="space-y-3 mb-4">
                <div class="flex items-center justify-between">
                    <span class="text-xs text-gray-500">Email</span>
                    {% if user.isVerified %}
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            ✓ Vérifié
                        </span>
                    {% else %}
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800">
                            ✗ Non vérifié
                        </span>
                    {% endif %}
                </div>

                <div class="space-y-2">
                    <div class="flex items-center justify-between">
                        <span class="text-xs text-gray-500">Parcours KYC</span>
                        <div class="flex items-center space-x-2">
                            {% set currentStep = user.stepKyc ?? 0 %}
                            <span class="text-xs font-medium text-gray-700">
                                {{ currentStep }}/5
                            </span>
                            {% if currentStep == 5 %}
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                                    ✓ Complété
                                </span>
                            {% elseif currentStep > 0 %}
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                                    En cours
                                </span>
                            {% else %}
                                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                                    Non démarré
                                </span>
                            {% endif %}
                        </div>
                    </div>

                     <div class="w-full bg-gray-200 rounded-full h-2">
                         {% set progressPercent = ((user.stepKyc ?? 0) / 5 * 100)|round %}
                         {% set hue = (progressPercent * 1.2)|round %}
                         {% set hueEnd = (hue + 10) > 120 ? 120 : (hue + 10) %}
                         <div
                             class="kyc-progress-bar h-2 rounded-full transition-all duration-700 js-kyc-bar"
                             data-progress="{{ progressPercent }}"
                             style="
                                 width: {{ progressPercent }}%;
                                 background: linear-gradient(90deg, hsl({{ hue }}, 85%, 55%) 0%, hsl({{ hueEnd }}, 85%, 45%) 100%);
                             "></div>
                     </div>
                     <div class="text-right mt-1">
                         <span class="text-[10px] text-gray-500 js-kyc-percent" data-target="{{ progressPercent }}">0%</span>
                     </div>

                    <div class="flex justify-between text-xs">
                        {% for step in 1..5 %}
                            {% set isCompleted = (user.stepKyc ?? 0) >= step %}
                            {% set isCurrent = (user.stepKyc ?? 0) == step %}
                            <div class="flex flex-col items-center">
                                <div class="kyc-progress-step w-4 h-4 rounded-full flex items-center justify-center mb-1
                                    {% if isCompleted %}
                                        bg-blue-500 text-white
                                    {% elseif isCurrent %}
                                        bg-blue-200 text-blue-800 border-2 border-blue-500
                                    {% else %}
                                        bg-gray-200 text-gray-400
                                    {% endif %}">
                                    {% if isCompleted %}
                                        <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
                                        </svg>
                                    {% else %}
                                        {{ step }}
                                    {% endif %}
                                </div>
                                <span class="text-xs text-center leading-tight text-gray-500 w-12">
                                    {% if step == 1 %}Profil{% endif %}
                                    {% if step == 2 %}Objectifs{% endif %}
                                    {% if step == 3 %}Patrimoine{% endif %}
                                    {% if step == 4 %}Expérience{% endif %}
                                    {% if step == 5 %}Documents{% endif %}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {% if user.investorProfile %}
                    <div class="flex items-center justify-between">
                        <span class="text-xs text-gray-500">Profil</span>
                        {% set profileColors = {
                            'PRUDENT': 'bg-gray-100 text-gray-800',
                            'EQUILIBRE': 'bg-yellow-100 text-yellow-800',
                            'DYNAMIQUE': 'bg-orange-100 text-orange-800',
                            'SPE': 'bg-red-100 text-red-800'
                        } %}
                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium {{ profileColors[user.investorProfile] ?? 'bg-gray-100 text-gray-800' }}">
                            {{ profileTypes[user.investorProfile] ?? user.investorProfile }}
                        </span>
                    </div>
                {% endif %}
            </div>

            <div class="text-xs text-gray-500 mb-4 flex-grow">
                <p>Inscrit le {{ user.createdAt|date('d/m/Y') }}</p>
                {% if user.updatedAt %}
                    <p>Dernière mise à jour : {{ user.updatedAt|date('d/m/Y H:i') }}</p>
                {% endif %}
            </div>

            <div class="flex space-x-2 mt-auto">
                <a href="{{ path('admin_modern_user_view', {id: user.id}) }}"
                   class="flex-1 bg-blue-600 text-white text-center py-2 px-3 rounded-md text-xs font-medium hover:bg-blue-700 transition-colors">
                    👁️ Voir
                </a>
                <a href="{{ path('admin_modern_user_edit', {id: user.id}) }}"
                   class="flex-1 bg-gray-100 text-gray-700 text-center py-2 px-3 rounded-md text-xs font-medium hover:bg-gray-200 transition-colors">
                    ✏️ Éditer
                </a>
            </div>
        </div>
    </div>
    {% else %}
    <div class="col-span-full">
        <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2M4 13h2m13-5l-4 4L9 8"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Aucun utilisateur trouvé</h3>
            <p class="mt-1 text-sm text-gray-500">Essayez de modifier vos critères de recherche</p>
        </div>
    </div>
    {% endfor %}
</div>

{# Pagination — les liens portent data-page pour permettre la navigation AJAX #}
{% if totalPages > 1 %}
<nav class="mt-8 flex items-center justify-between" aria-label="Pagination" data-users-pagination>
    <div class="hidden sm:block">
        <p class="text-sm text-gray-700">
            Page <span class="font-medium">{{ currentPage }}</span> sur <span class="font-medium">{{ totalPages }}</span>
        </p>
    </div>
    <div class="flex-1 flex justify-between sm:justify-end space-x-2">
        {% if currentPage > 1 %}
            <a href="{{ path('admin_modern_users', currentFilters|merge({page: currentPage - 1})) }}"
               data-page="{{ currentPage - 1 }}"
               class="js-page-link inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                ← Précédent
            </a>
        {% endif %}

        <div class="hidden md:flex space-x-1">
            {% set startPage = max(1, currentPage - 2) %}
            {% set endPage = min(totalPages, currentPage + 2) %}

            {% if startPage > 1 %}
                <a href="{{ path('admin_modern_users', currentFilters|merge({page: 1})) }}"
                   data-page="1"
                   class="js-page-link inline-flex items-center px-3 py-2 border text-sm font-medium rounded-md border-gray-300 text-gray-700 bg-white hover:bg-gray-50">1</a>
                {% if startPage > 2 %}
                    <span class="inline-flex items-center px-2 py-2 text-sm text-gray-500">…</span>
                {% endif %}
            {% endif %}

            {% for p in startPage..endPage %}
                {% if p == currentPage %}
                    <span class="inline-flex items-center px-3 py-2 border text-sm font-medium rounded-md border-blue-500 text-white bg-blue-600">{{ p }}</span>
                {% else %}
                    <a href="{{ path('admin_modern_users', currentFilters|merge({page: p})) }}"
                       data-page="{{ p }}"
                       class="js-page-link inline-flex items-center px-3 py-2 border text-sm font-medium rounded-md border-gray-300 text-gray-700 bg-white hover:bg-gray-50">{{ p }}</a>
                {% endif %}
            {% endfor %}

            {% if endPage < totalPages %}
                {% if endPage < totalPages - 1 %}
                    <span class="inline-flex items-center px-2 py-2 text-sm text-gray-500">…</span>
                {% endif %}
                <a href="{{ path('admin_modern_users', currentFilters|merge({page: totalPages})) }}"
                   data-page="{{ totalPages }}"
                   class="js-page-link inline-flex items-center px-3 py-2 border text-sm font-medium rounded-md border-gray-300 text-gray-700 bg-white hover:bg-gray-50">{{ totalPages }}</a>
            {% endif %}
        </div>

        {% if currentPage < totalPages %}
            <a href="{{ path('admin_modern_users', currentFilters|merge({page: currentPage + 1})) }}"
               data-page="{{ currentPage + 1 }}"
               class="js-page-link inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors">
                Suivant →
            </a>
        {% endif %}
    </div>
</nav>
{% endif %}
