{% extends 'admin_modern/base.html.twig' %}

{% block title %}Gestion des contacts{% endblock %}

{% block content %}
<div x-data="contactsManager()" x-init="init()">
    <!-- En-tête -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-3">
                <span class="w-10 h-10 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </span>
                Gestion des contacts
            </h1>
            <p class="mt-1 text-sm text-gray-500">Consultez et gérez tous les messages reçus</p>
        </div>
        
        <!-- Statistique -->
        <div class="flex items-center gap-4">
            <div class="bg-gradient-to-br from-blue-500 to-indigo-600 text-white px-6 py-4 rounded-2xl shadow-lg">
                <div class="text-3xl font-bold" x-text="filteredCount">{{ totalContacts }}</div>
                <div class="text-sm opacity-90">Messages</div>
            </div>
        </div>
    </div>

    <!-- Recherche et filtres -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 mb-6">
        <div class="flex flex-col md:flex-row gap-4">
            <!-- Recherche -->
            <div class="flex-1 relative">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" 
                       x-model="searchQuery"
                       @input.debounce.300ms="filterContacts()"
                       placeholder="Rechercher par nom, email, message..."
                       class="w-full pl-12 pr-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 transition-colors text-sm">
                <button x-show="searchQuery" 
                        @click="searchQuery = ''; filterContacts()"
                        class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            
            <!-- Filtre sujet -->
            <div class="md:w-72">
                <select x-model="selectedSubject" 
                        @change="filterContacts()"
                        class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-0 transition-colors text-sm bg-white">
                    <option value="">Tous les sujets</option>
                    {% for key, label in subjects %}
                        <option value="{{ key }}">{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
        
        <!-- Résumé des filtres actifs -->
        <div x-show="searchQuery || selectedSubject" 
             x-transition
             class="mt-3 flex items-center gap-2 text-sm text-gray-600">
            <span>Filtres actifs :</span>
            <template x-if="searchQuery">
                <span class="inline-flex items-center gap-1 px-2 py-1 bg-blue-50 text-blue-700 rounded-lg">
                    <span x-text="'Recherche: ' + searchQuery"></span>
                    <button @click="searchQuery = ''; filterContacts()" class="hover:text-blue-900">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </span>
            </template>
            <template x-if="selectedSubject">
                <span class="inline-flex items-center gap-1 px-2 py-1 bg-purple-50 text-purple-700 rounded-lg">
                    <span x-text="getSubjectLabel(selectedSubject)"></span>
                    <button @click="selectedSubject = ''; filterContacts()" class="hover:text-purple-900">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </span>
            </template>
        </div>
    </div>

    <!-- Liste des contacts - Vue Desktop -->
    <div class="hidden lg:block bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full">
            <thead>
                <tr class="bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Date</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Contact</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Sujet</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Message</th>
                    <th class="px-6 py-4 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for contact in contacts %}
                <tr class="contact-row hover:bg-blue-50/50 transition-colors group"
                    data-search="{{ contact.firstname|lower }} {{ contact.lastname|lower }} {{ contact.email|lower }} {{ contact.message|lower }}"
                    data-subject="{{ contact.subject }}">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-semibold text-gray-900">{{ contact.createdAt|date('d/m/Y') }}</div>
                        <div class="text-xs text-gray-500">{{ contact.createdAt|date('H:i') }}</div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="relative">
                                <div class="w-10 h-10 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-full flex items-center justify-center text-white font-semibold text-sm">
                                    {{ contact.firstname|slice(0,1)|upper }}{{ contact.lastname|slice(0,1)|upper }}
                                </div>
                                {% if not contact.isRead %}
                                    <span class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full border-2 border-white"></span>
                                {% endif %}
                            </div>
                            <div>
                                <div class="flex items-center gap-2">
                                    <div class="text-sm font-semibold {% if not contact.isRead %}text-gray-900{% else %}text-gray-600{% endif %}">{{ contact.firstname }} {{ contact.lastname }}</div>
                                    {% if contact.isRead %}
                                        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    {% endif %}
                                </div>
                                <a href="mailto:{{ contact.email }}" class="text-xs text-blue-600 hover:underline">{{ contact.email }}</a>
                                {% if contact.phone %}
                                    <div class="text-xs text-gray-500">{{ contact.phone }}</div>
                                {% endif %}
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        {% set subjectColors = {
                            '0': 'bg-blue-100 text-blue-800 border-blue-200',
                            '1': 'bg-emerald-100 text-emerald-800 border-emerald-200',
                            '2': 'bg-amber-100 text-amber-800 border-amber-200',
                            '3': 'bg-purple-100 text-purple-800 border-purple-200',
                            '4': 'bg-rose-100 text-rose-800 border-rose-200',
                            '5': 'bg-indigo-100 text-indigo-800 border-indigo-200'
                        } %}
                        <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium border {{ subjectColors[contact.subject ~ ''] ?? 'bg-gray-100 text-gray-800 border-gray-200' }}">
                            {{ contact.subjectName }}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <p class="text-sm text-gray-600 line-clamp-2 max-w-xs">
                            {{ contact.message|length > 80 ? contact.message|slice(0, 80) ~ '...' : contact.message }}
                        </p>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-center gap-2">
                            <a href="{{ path('admin_modern_contacts_show', {'id': contact.id}) }}" 
                               class="inline-flex items-center gap-1.5 px-3 py-2 bg-blue-50 text-blue-700 rounded-lg text-xs font-medium hover:bg-blue-100 transition-colors group-hover:shadow-sm">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                Voir
                            </a>
                            <button type="button" 
                                    @click="confirmDelete({{ contact.id }}, '{{ csrf_token('delete' ~ contact.id) }}')"
                                    class="inline-flex items-center gap-1.5 px-3 py-2 bg-red-50 text-red-700 rounded-lg text-xs font-medium hover:bg-red-100 transition-colors group-hover:shadow-sm">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                                Supprimer
                            </button>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-16 text-center">
                        <div class="flex flex-col items-center">
                            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mb-4">
                                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                                </svg>
                            </div>
                            <h3 class="text-lg font-semibold text-gray-900">Aucun message</h3>
                            <p class="text-gray-500 mt-1">Aucun message de contact reçu pour le moment.</p>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Liste des contacts - Vue Mobile (Cartes) -->
    <div class="lg:hidden space-y-4">
        {% for contact in contacts %}
        <div class="contact-card bg-white rounded-2xl shadow-sm border border-gray-100 p-4"
             data-search="{{ contact.firstname|lower }} {{ contact.lastname|lower }} {{ contact.email|lower }} {{ contact.message|lower }}"
             data-subject="{{ contact.subject }}">
            <!-- Header de la carte -->
            <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <div class="w-12 h-12 bg-gradient-to-br from-blue-400 to-indigo-500 rounded-full flex items-center justify-center text-white font-semibold">
                            {{ contact.firstname|slice(0,1)|upper }}{{ contact.lastname|slice(0,1)|upper }}
                        </div>
                        {% if not contact.isRead %}
                            <span class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full border-2 border-white"></span>
                        {% endif %}
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <div class="font-semibold {% if not contact.isRead %}text-gray-900{% else %}text-gray-600{% endif %}">{{ contact.firstname }} {{ contact.lastname }}</div>
                            {% if contact.isRead %}
                                <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                </svg>
                            {% endif %}
                        </div>
                        <a href="mailto:{{ contact.email }}" class="text-sm text-blue-600">{{ contact.email }}</a>
                    </div>
                </div>
                <div class="text-right">
                    <div class="text-sm font-medium text-gray-900">{{ contact.createdAt|date('d/m/Y') }}</div>
                    <div class="text-xs text-gray-500">{{ contact.createdAt|date('H:i') }}</div>
                </div>
            </div>
            
            <!-- Sujet -->
            {% set subjectColors = {
                '0': 'bg-blue-100 text-blue-800 border-blue-200',
                '1': 'bg-emerald-100 text-emerald-800 border-emerald-200',
                '2': 'bg-amber-100 text-amber-800 border-amber-200',
                '3': 'bg-purple-100 text-purple-800 border-purple-200',
                '4': 'bg-rose-100 text-rose-800 border-rose-200',
                '5': 'bg-indigo-100 text-indigo-800 border-indigo-200'
            } %}
            <div class="mb-3">
                <span class="inline-flex items-center px-3 py-1.5 rounded-lg text-xs font-medium border {{ subjectColors[contact.subject ~ ''] ?? 'bg-gray-100 text-gray-800 border-gray-200' }}">
                    {{ contact.subjectName }}
                </span>
            </div>
            
            <!-- Message preview -->
            <p class="text-sm text-gray-600 mb-4 line-clamp-2">
                {{ contact.message|length > 100 ? contact.message|slice(0, 100) ~ '...' : contact.message }}
            </p>
            
            <!-- Actions -->
            <div class="flex gap-2 pt-3 border-t border-gray-100">
                <a href="{{ path('admin_modern_contacts_show', {'id': contact.id}) }}" 
                   class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-blue-600 text-white rounded-xl text-sm font-medium hover:bg-blue-700 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    Voir détail
                </a>
                <button type="button"
                        @click="confirmDelete({{ contact.id }}, '{{ csrf_token('delete' ~ contact.id) }}')"
                        class="inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-red-50 text-red-700 rounded-xl text-sm font-medium hover:bg-red-100 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                </button>
            </div>
        </div>
        {% else %}
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900">Aucun message</h3>
            <p class="text-gray-500 mt-1">Aucun message de contact reçu.</p>
        </div>
        {% endfor %}
    </div>

    <!-- Compteur de résultats filtrés -->
    <div x-show="(searchQuery || selectedSubject) && filteredCount !== {{ contacts|length }}" 
         x-transition
         class="mt-4 text-center text-sm text-gray-500">
        <span x-text="filteredCount + ' résultat(s) sur {{ contacts|length }} messages'"></span>
    </div>

    <!-- Pagination -->
    {% if totalPages > 1 %}
    <div class="mt-6 flex justify-center">
        <nav class="flex items-center gap-2">
            {% if currentPage > 1 %}
                <a href="{{ path('admin_modern_contacts_index', {'page': currentPage - 1, 'subject': currentSubject, 'search': currentSearch}) }}" 
                   class="inline-flex items-center gap-1 px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                    Précédent
                </a>
            {% endif %}

            <div class="flex items-center gap-1">
                {% for page in 1..totalPages %}
                    {% if page == currentPage %}
                        <span class="px-4 py-2 bg-blue-600 text-white rounded-xl text-sm font-medium">{{ page }}</span>
                    {% elseif page == 1 or page == totalPages or (page >= currentPage - 1 and page <= currentPage + 1) %}
                        <a href="{{ path('admin_modern_contacts_index', {'page': page, 'subject': currentSubject, 'search': currentSearch}) }}" 
                           class="px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">{{ page }}</a>
                    {% elseif page == 2 and currentPage > 3 %}
                        <span class="px-2 text-gray-400">...</span>
                    {% elseif page == totalPages - 1 and currentPage < totalPages - 2 %}
                        <span class="px-2 text-gray-400">...</span>
                    {% endif %}
                {% endfor %}
            </div>

            {% if currentPage < totalPages %}
                <a href="{{ path('admin_modern_contacts_index', {'page': currentPage + 1, 'subject': currentSubject, 'search': currentSearch}) }}" 
                   class="inline-flex items-center gap-1 px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                    Suivant
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            {% endif %}
        </nav>
    </div>
    {% endif %}

    <!-- Modal de confirmation de suppression -->
    <div x-show="showDeleteModal" 
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-50 overflow-y-auto"
         style="display: none;">
        <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:p-0">
            <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm" @click="showDeleteModal = false"></div>
            
            <div x-show="showDeleteModal"
                 x-transition:enter="transition ease-out duration-200"
                 x-transition:enter-start="opacity-0 scale-95"
                 x-transition:enter-end="opacity-100 scale-100"
                 x-transition:leave="transition ease-in duration-150"
                 x-transition:leave-start="opacity-100 scale-100"
                 x-transition:leave-end="opacity-0 scale-95"
                 class="relative bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl z-10">
                
                <div class="w-14 h-14 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-7 h-7 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                </div>
                
                <h3 class="text-xl font-bold text-gray-900 mb-2">Confirmer la suppression</h3>
                <p class="text-gray-500 mb-6">Êtes-vous sûr de vouloir supprimer ce message ? Cette action est irréversible.</p>
                
                <div class="flex gap-3">
                    <button type="button" 
                            @click="showDeleteModal = false"
                            class="flex-1 px-4 py-3 bg-gray-100 text-gray-700 rounded-xl font-medium hover:bg-gray-200 transition-colors">
                        Annuler
                    </button>
                    <form :action="deleteUrl" method="POST" class="flex-1">
                        <input type="hidden" name="_token" :value="deleteToken">
                        <button type="submit" 
                                class="w-full px-4 py-3 bg-red-600 text-white rounded-xl font-medium hover:bg-red-700 transition-colors">
                            Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function contactsManager() {
    return {
        searchQuery: '{{ currentSearch|default('')|e('js') }}',
        selectedSubject: '{{ currentSubject|default('')|e('js') }}',
        showDeleteModal: false,
        deleteUrl: '',
        deleteToken: '',
        filteredCount: {{ contacts|length }},
        
        subjects: {
            {% for key, label in subjects %}
            '{{ key }}': '{{ label|e('js') }}'{% if not loop.last %},{% endif %}
            {% endfor %}
        },
        
        init() {
            // Initialisation
            this.filterContacts();
        },
        
        getSubjectLabel(key) {
            return this.subjects[key] || key;
        },
        
        filterContacts() {
            const rows = document.querySelectorAll('.contact-row, .contact-card');
            const search = this.searchQuery.toLowerCase().trim();
            const subject = this.selectedSubject;
            let count = 0;
            
            rows.forEach(row => {
                const rowSearch = row.dataset.search || '';
                const rowSubject = row.dataset.subject || '';
                
                let matchesSearch = !search || rowSearch.includes(search);
                let matchesSubject = !subject || rowSubject === subject;
                
                if (matchesSearch && matchesSubject) {
                    row.style.display = '';
                    count++;
                } else {
                    row.style.display = 'none';
                }
            });
            
            this.filteredCount = count;
        },
        
        confirmDelete(id, token) {
            this.deleteUrl = '{{ path('admin_modern_contacts_delete', {'id': 0}) }}'.replace('/0', '/' + id);
            this.deleteToken = token;
            this.showDeleteModal = true;
        }
    }
}
</script>

<style>
/* Line clamp pour les textes tronqués */
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Animation de survol des lignes */
.contact-row {
    transition: all 0.15s ease;
}

