<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redirection vers MoneyPitch - ADN Family Office</title>
    <link rel="icon" href="{{ asset('assets/favicon.svg') }}" type="image/svg+xml">
    <link rel="icon" href="{{ asset('assets/favicon.ico') }}" sizes="any">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --adn-primary: #1C29A1;
            --adn-primary-light: #3B82F6;
            --adn-purple: #7C3AED;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #0F1751 0%, #1C29A1 30%, #2D3FDB 70%, #3B82F6 100%);
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* Header */
        .header {
            padding: 1.5rem 2rem;
            display: flex;
            justify-content: center;
        }

        .logo {
            height: 45px;
            filter: brightness(0) invert(1);
            opacity: 0.95;
        }

        /* Container principal */
        .main-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        /* Card */
        .redirect-card {
            background: white;
            border-radius: 1.5rem;
            padding: 2.5rem;
            max-width: 440px;
            width: 100%;
            text-align: center;
            box-shadow: 
                0 25px 50px -12px rgba(0, 0, 0, 0.25),
                0 0 0 1px rgba(255, 255, 255, 0.1);
            animation: slideUp 0.5s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Icône */
        .redirect-icon {
            width: 80px;
            height: 80px;
            margin: 0 auto 1.5rem;
            background: linear-gradient(135deg, var(--adn-primary) 0%, var(--adn-purple) 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 25px -5px rgba(28, 41, 161, 0.4);
            animation: pulse 1.5s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .redirect-icon svg {
            width: 40px;
            height: 40px;
            color: white;
        }

        /* Titre */
        .redirect-title {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--adn-primary), var(--adn-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.75rem;
            line-height: 1.3;
        }

        /* Message */
        .redirect-message {
            color: #64748B;
            font-size: 1rem;
            line-height: 1.6;
            margin-bottom: 1.25rem;
        }

        /* Email badge */
        .email-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
            color: var(--adn-primary);
            padding: 0.625rem 1.25rem;
            border-radius: 2rem;
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            border: 1px solid #C7D2FE;
        }

        /* Loader */
        .loader {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            margin-bottom: 1.25rem;
        }

        .loader-dot {
            width: 12px;
            height: 12px;
            background: linear-gradient(135deg, var(--adn-primary), var(--adn-purple));
            border-radius: 50%;
            animation: bounce 1.4s ease-in-out infinite;
        }

        .loader-dot:nth-child(1) { animation-delay: 0s; }
        .loader-dot:nth-child(2) { animation-delay: 0.2s; }
        .loader-dot:nth-child(3) { animation-delay: 0.4s; }

        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
            40% { transform: scale(1); opacity: 1; }
        }

        /* Note */
        .redirect-note {
            font-size: 0.875rem;
            color: #94A3B8;
            line-height: 1.5;
        }

        .redirect-note a {
            color: var(--adn-primary);
            text-decoration: none;
            font-weight: 500;
        }

        .redirect-note a:hover {
            text-decoration: underline;
        }

        /* Footer */
        .footer {
            padding: 1.5rem;
            text-align: center;
        }

        .footer p {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.85rem;
        }

        .footer a {
            color: rgba(255, 255, 255, 0.9);
            text-decoration: none;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        /* Responsive */
        @media (max-width: 480px) {
            .header {
                padding: 1rem;
            }

            .logo {
                height: 35px;
            }

            .redirect-card {
                padding: 1.5rem;
                border-radius: 1rem;
                margin: 0 0.5rem;
            }

            .redirect-icon {
                width: 64px;
                height: 64px;
            }

            .redirect-icon svg {
                width: 32px;
                height: 32px;
            }

            .redirect-title {
                font-size: 1.25rem;
            }

            .redirect-message {
                font-size: 0.95rem;
            }

            .email-badge {
                font-size: 0.85rem;
                padding: 0.5rem 1rem;
            }
        }

        /* Particules */
        .particle {
            position: fixed;
            width: 6px;
            height: 6px;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            pointer-events: none;
            animation: float 15s infinite ease-in-out;
        }

        .particle:nth-child(1) { left: 10%; top: 20%; animation-delay: 0s; }
        .particle:nth-child(2) { left: 20%; top: 60%; animation-delay: 2s; }
        .particle:nth-child(3) { left: 70%; top: 30%; animation-delay: 4s; }
        .particle:nth-child(4) { left: 80%; top: 70%; animation-delay: 6s; }
        .particle:nth-child(5) { left: 50%; top: 80%; animation-delay: 8s; }

        @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
            50% { transform: translateY(-20px) translateX(10px); opacity: 0.6; }
        }
    </style>
</head>
<body>
    <!-- Particules -->
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>

    <!-- Header -->
    <header class="header">
        <a href="{{ path('app_home') }}">
            <img src="{{ asset('build/theme/images/ADN_Logo_enlarged_x5.png') }}" alt="ADN Family Office" class="logo">
        </a>
    </header>

    <!-- Contenu principal -->
    <main class="main-container">
        <div class="redirect-card">
            <div class="redirect-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
            </div>

            <h1 class="redirect-title">Redirection vers MoneyPitch</h1>
            
            <p class="redirect-message">
                Vous allez être redirigé vers votre espace MoneyPitch pour accéder à vos investissements.
            </p>

            <div class="email-badge">
                📧 {{ user_email }}
            </div>

            <div class="loader">
                <div class="loader-dot"></div>
                <div class="loader-dot"></div>
                <div class="loader-dot"></div>
            </div>

            <p class="redirect-note">
                Saisissez votre mot de passe MoneyPitch sur la page suivante.<br>
                <a href="{{ path('app_logout') }}">Se déconnecter</a>
            </p>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <p>© {{ 'now'|date('Y') }} <a href="{{ path('app_home') }}">ADN Family Office</a></p>
    </footer>

    <!-- Formulaire caché pour auto-submit vers MoneyPitch -->
    <form id="moneypitchForm" method="post" action="{{ moneypitch_url }}" style="display: none;">
        <input type="hidden" name="redirect" value="{{ redirect_url }}">
        <input type="hidden" name="returnurl" value="{{ return_url }}">
        <input type="hidden" name="crypted" value="0">
        <input type="hidden" name="login" value="{{ user_email }}">
        <input type="hidden" name="password" value="">
    </form>

    <script>
        // Auto-submit après 1.5 secondes
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                document.getElementById('moneypitchForm').submit();
            }, 1500);
        });
    </script>
</body>
</html>
